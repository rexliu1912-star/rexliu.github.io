      let followersDeltaChart = null;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const escapeHtml = (value = '') => value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const t = (path) => path.split('.').reduce((acc, key) => acc?.[key], copy[currentLang]);
      const formatNumber = (value) => new Intl.NumberFormat(currentLang === 'zh' ? 'zh-CN' : 'en-US').format(Math.round(value || 0));
      const formatCompact = (value) => new Intl.NumberFormat(currentLang === 'zh' ? 'zh-CN' : 'en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(value || 0);
      const formatShortNumber = (value) => {
        const numericValue = Number(value) || 0;
        const absoluteValue = Math.abs(numericValue);
        if (absoluteValue >= 1_000_000) return `${(numericValue / 1_000_000).toFixed(1)}M`;
        if (absoluteValue >= 1_000) return `${(numericValue / 1_000).toFixed(1)}K`;
        return formatNumber(numericValue);
      };
      const formatMonthYear = (value) => new Date(`${value}T00:00:00Z`).toLocaleDateString(copy[currentLang].dates.locale, { month: 'short', year: 'numeric', timeZone: 'UTC' });
      const formatDateRange = (start, end) => {
        const startDate = new Date(`${start}T00:00:00Z`);
        const endDate = new Date(`${end}T00:00:00Z`);
        const locale = copy[currentLang].dates.locale;
        const monthDayFormatter = new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric', timeZone: 'UTC' });
        const endFormatter = new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
        return `${monthDayFormatter.format(startDate)} – ${endFormatter.format(endDate)}`;
      };
      const truncate = (text, max = 220) => (text && text.length > max ? `${text.slice(0, max).trim()}…` : (text || ''));

      const formatPercentChange = (current, previous) => {
        const currentValue = Number(current) || 0;
        const previousValue = Number(previous) || 0;
        if (!previousValue) return { value: '0.0%', numeric: 0 };
        const numeric = ((currentValue - previousValue) / previousValue) * 100;
        const prefix = numeric > 0 ? '+' : '';
        return { value: `${prefix}${numeric.toFixed(1)}%`, numeric };
      };
      const extractWeekNumber = (week = '') => week.split('-W')[1] || week;
      const getPillarConfig = () => ([
        { key: 'crypto', label: copy[currentLang].contentIntelligence.pillars.labels.crypto, keywords: ['snek', 'cardano', 'ada', 'btc', 'bitcoin', 'crypto', 'defi', 'chain', 'token', 'whale'] },
        { key: 'ai', label: copy[currentLang].contentIntelligence.pillars.labels.ai, keywords: ['ai', 'agent', 'claude', 'gpt', 'code', 'build', 'ship', 'tool', 'automation'] },
