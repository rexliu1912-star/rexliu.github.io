              y: { grid: { color: theme.grid }, ticks: { color: theme.tick, callback: (value) => formatNumber(value) } }
            }
          }
        });
      }
      function renderMiniCharts(data) {
        const weeklyStats = data.weeklyStats || [];
        const locale = copy[currentLang].dates.locale;
        const labels = weeklyStats.map((item, index) => {
          const date = new Date(`${item.startDate}T00:00:00Z`);
