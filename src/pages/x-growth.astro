              x: { grid: { display: false }, ticks: { maxTicksLimit: 8, color: theme.tick } },
              y: { grid: { color: theme.grid }, ticks: { color: theme.tick, callback: (value) => tooltipFormatter(value) } }
            }
          }
        });
      }
      function createFollowersBarChart(canvas, labels, values) {
        if (!canvas || typeof Chart === 'undefined') return null;
        followersDeltaChart?.destroy();
        const theme = chartTheme();
        return new Chart(canvas, {
          type: 'bar',
