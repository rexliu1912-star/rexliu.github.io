          if (!previous) return label;
          const previousLabel = new Date(`${previous.startDate}T00:00:00Z`).toLocaleDateString(locale, { month: 'short', year: 'numeric', timeZone: 'UTC' });
          return previousLabel === label ? '' : label;
        });
        engagementChart = createAreaChart(engagementChart, document.getElementById('engagementChart'), labels, weeklyStats.map((item) => item.totalEngagement || 0), t('miniCharts.engagement.eyebrow'));
        profileVisitsChart = createAreaChart(profileVisitsChart, document.getElementById('profileVisitsChart'), labels, weeklyStats.map((item) => Number(item.profileVisits) || 0), t('miniCharts.profileVisits.eyebrow'));
        followersDeltaChart = createFollowersBarChart(document.getElementById('followersDeltaChart'), labels, weeklyStats.map((item) => Number(item.newFollowers) || 0));

        const peakWeek = weeklyStats.reduce((best, item) => ((item.totalViews || 0) > (best?.totalViews || 0) ? item : best), null);
        if (!peakWeek) return;
        var peakDate = new Date(`${peakWeek.startDate}T00:00:00Z`);
        document.getElementById('peakWeekLabel').textContent = peakDate.toLocaleDateString(locale, { month: 'short', year: 'numeric', timeZone: 'UTC' });
