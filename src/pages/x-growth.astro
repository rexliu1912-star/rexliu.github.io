      function revealOnScroll() {
        const items = [...root.querySelectorAll('.fade-in-up')];
        items.forEach((item, index) => {
          if (prefersReducedMotion) {
            item.classList.add('visible');
            return;
          }
          setTimeout(() => item.classList.add('visible'), index * 70);
        });
      }

      function animateCount(element, target) {
        if (!element) return;
        if (prefersReducedMotion) {
          element.textContent = element.dataset.countup === 'impressions' ? formatShortNumber(target) : formatNumber(target);
          return;
        }
        const duration = 1400;
        const start = performance.now();
        const step = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = target * eased;
          element.textContent = element.dataset.countup === 'impressions' ? formatShortNumber(value) : formatNumber(value);
          if (progress < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }

