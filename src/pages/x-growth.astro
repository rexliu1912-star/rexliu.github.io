      ]);
      const analyzePillars = (tweets = []) => {
        const config = getPillarConfig();
        return config.map((pillar) => ({
          ...pillar,
          count: tweets.reduce((total, tweet) => {
            const textValue = `${tweet.text || ''}`.toLowerCase();
            return total + (pillar.keywords.some((keyword) => textValue.includes(keyword)) ? 1 : 0);
          }, 0)
        }));
      };
      const strongestPillar = (pillars = []) => pillars.reduce((best, pillar) => {
        if (!best) return pillar;
        if (pillar.count > best.count) return pillar;
        return best;
      }, null);
      const chartTheme = () => ({
        tick: document.documentElement.dataset.theme === 'dark' ? '#8f8b96' : '#8a7d8f',
        label: document.documentElement.dataset.theme === 'dark' ? '#e7ddf6' : '#5b5563',
        grid: 'rgba(137, 83, 209, 0.1)'
      });
      function createAreaChart(instance, canvas, labels, values, tooltipLabel, tooltipFormatter = formatNumber) {
        if (!canvas || typeof Chart === 'undefined') return instance;
        instance?.destroy();
        const theme = chartTheme();
        return new Chart(canvas, {
          type: 'line',
          data: {
            labels,
            datasets: [{
              label: tooltipLabel,
              data: values,
              borderColor: '#8953d1',
              backgroundColor: (context) => {
                const { chart } = context;
                const { ctx, chartArea } = chart;
                if (!chartArea) return 'rgba(137, 83, 209, 0.18)';
                const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
                gradient.addColorStop(0, 'rgba(137, 83, 209, 0.28)');
                gradient.addColorStop(1, 'rgba(137, 83, 209, 0.01)');
                return gradient;
              },
              fill: true,
              tension: 0.28,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 14
