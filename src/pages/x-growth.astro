      function renderGrowthChart(data) {
        const canvas = document.getElementById('growthChart');
        if (!canvas || typeof Chart === 'undefined') return;
        const history = data.followerHistory || [];
        const labels = history.map((item) => item.date);
        const values = history.map((item) => item.count);
        const milestones = new Map((data.milestones || []).map((item) => [item.date, item]));
        const hoveredMilestone = { value: null };

        const milestonePlugin = {
          id: 'milestonePlugin',
          afterDatasetsDraw(chart) {
            const { ctx, chartArea, scales: { x, y } } = chart;
            ctx.save();
            history.forEach((item, index) => {
              const milestone = milestones.get(item.date);
              if (!milestone) return;
              const point = chart.getDatasetMeta(0).data[index];
              if (!point) return;
              const active = hoveredMilestone.value === item.date;
              ctx.beginPath();
              ctx.fillStyle = '#8953d1';
              ctx.shadowColor = 'rgba(137,83,209,0.35)';
              ctx.shadowBlur = active ? 18 : 12;
              ctx.arc(point.x, point.y, active ? 6 : 4, 0, Math.PI * 2);
              ctx.fill();
              ctx.shadowBlur = 0;

              if (active) {
                ctx.font = '12px Georgia, serif';
                const text = typeof milestone.count === 'number' && milestone.count >= 100 ? `${formatShortNumber(milestone.count)} · ${formatMonthYear(milestone.date)}` : `${milestone.label} · ${formatMonthYear(milestone.date)}`;
                const textWidth = ctx.measureText(text).width;
                const boxWidth = textWidth + 16;
                const boxHeight = 28;
                const boxX = Math.min(Math.max(point.x - boxWidth / 2, chartArea.left + 4), chartArea.right - boxWidth - 4);
                const boxY = Math.max(point.y - 42, y.top + 6);
                ctx.fillStyle = document.documentElement.dataset.theme === 'dark' ? 'rgba(21,21,21,0.95)' : 'rgba(255,248,235,0.96)';
                ctx.strokeStyle = document.documentElement.dataset.theme === 'dark' ? 'rgba(231,221,246,0.26)' : 'rgba(137,83,209,0.18)';
                ctx.lineWidth = 1;
                const radius = 12;
                ctx.beginPath();
                ctx.moveTo(boxX + radius, boxY);
                ctx.lineTo(boxX + boxWidth - radius, boxY);
                ctx.quadraticCurveTo(boxX + boxWidth, boxY, boxX + boxWidth, boxY + radius);
                ctx.lineTo(boxX + boxWidth, boxY + boxHeight - radius);
                ctx.quadraticCurveTo(boxX + boxWidth, boxY + boxHeight, boxX + boxWidth - radius, boxY + boxHeight);
                ctx.lineTo(boxX + radius, boxY + boxHeight);
                ctx.quadraticCurveTo(boxX, boxY + boxHeight, boxX, boxY + boxHeight - radius);
                ctx.lineTo(boxX, boxY + radius);
                ctx.quadraticCurveTo(boxX, boxY, boxX + radius, boxY);
                ctx.closePath();
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = document.documentElement.dataset.theme === 'dark' ? '#e7ddf6' : '#6b6574';
                ctx.fillText(text, boxX + 8, boxY + 18);
              }
            });
            ctx.restore();
          }
        };

        growthChart?.destroy();
        growthChart = new Chart(canvas, {
          type: 'line',
          data: {
            labels,
            datasets: [{
              label: t('growth.tooltipFollowers'),
              data: values,
              borderColor: '#8953d1',
              backgroundColor: (context) => {
                const { chart } = context;
                const { ctx, chartArea } = chart;
                if (!chartArea) return 'rgba(137, 83, 209, 0.18)';
                const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
                gradient.addColorStop(0, 'rgba(137, 83, 209, 0.28)');
                gradient.addColorStop(1, 'rgba(137, 83, 209, 0.01)');
                return gradient;
              },
              fill: true,
              tension: 0.28,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 16
            }]
          },
          options: {
            animation: prefersReducedMotion ? false : { duration: 1600 },
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            onHover(event, elements, chart) {
              if (!elements.length) {
                hoveredMilestone.value = null;
                chart.draw();
                chart.canvas.style.cursor = 'default';
                return;
              }
              const index = elements[0].index;
              hoveredMilestone.value = milestones.has(history[index]?.date) ? history[index].date : null;
              chart.canvas.style.cursor = hoveredMilestone.value ? 'pointer' : 'default';
              chart.draw();
            },
            onClick(event, elements, chart) {
              if (!elements.length) return;
              const index = elements[0].index;
              hoveredMilestone.value = milestones.has(history[index]?.date) ? history[index].date : null;
              chart.draw();
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: (context) => `${t('growth.tooltipFollowers')}: ${formatNumber(context.parsed.y)}`,
                  afterBody: (items) => {
                    const date = items[0]?.label;
                    if (!milestones.has(date)) return [];
                    const milestone = milestones.get(date);
                    return [typeof milestone.count === 'number' && milestone.count >= 100 ? `${formatShortNumber(milestone.count)} · ${formatMonthYear(milestone.date)}` : `${milestone.label} · ${formatMonthYear(milestone.date)}`];
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { display: false },
                ticks: { maxTicksLimit: 6, color: document.documentElement.dataset.theme === 'dark' ? '#8f8b96' : '#8a7d8f' }
              },
              y: {
                grid: { color: 'rgba(137, 83, 209, 0.1)' },
                ticks: {
                  color: document.documentElement.dataset.theme === 'dark' ? '#8f8b96' : '#8a7d8f',
                  callback: (value) => formatCompact(value)
                }
              }
            }
          },
          plugins: [milestonePlugin]
        });
      }


      function renderImpressionsChart(data) {
        const canvas = document.getElementById('impressionsChart');
        if (!canvas || typeof Chart === 'undefined') return;

        const weeklyStats = (data.weeklyStats || []).slice(-53);
        const labels = weeklyStats.map((item, index) => {
          const date = new Date(`${item.startDate}T00:00:00Z`);
          const label = date.toLocaleDateString(copy[currentLang].dates.locale, { month: 'short', year: 'numeric', timeZone: 'UTC' });
          const previous = weeklyStats[index - 1];
          if (!previous) return label;
          const previousLabel = new Date(`${previous.startDate}T00:00:00Z`).toLocaleDateString(copy[currentLang].dates.locale, { month: 'short', year: 'numeric', timeZone: 'UTC' });
          return previousLabel === label ? '' : label;
        });
        const values = weeklyStats.map((item) => item.totalViews || 0);

        impressionsChart?.destroy();
        impressionsChart = new Chart(canvas, {
          type: 'line',
          data: {
            labels,
            datasets: [{
              label: t('impressionsChart.title'),
              data: values,
              borderColor: '#8953d1',
              backgroundColor: (context) => {
                const { chart } = context;
                const { ctx, chartArea } = chart;
                if (!chartArea) return 'rgba(137, 83, 209, 0.18)';
                const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
                gradient.addColorStop(0, 'rgba(137, 83, 209, 0.28)');
                gradient.addColorStop(1, 'rgba(137, 83, 209, 0.01)');
                return gradient;
              },
              fill: true,
              tension: 0.28,
              borderWidth: 3,
              pointRadius: 0,
              pointHitRadius: 16
            }]
          },
          options: {
            animation: prefersReducedMotion ? false : { duration: 1600 },
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  title: (items) => {
                    const item = weeklyStats[items[0]?.dataIndex || 0];
                    return formatDateRange(item.startDate, item.endDate);
                  },
                  label: (context) => `${t('impressionsChart.tooltipViews')}: ${formatShortNumber(context.parsed.y)}`
                }
              }
            },
            scales: {
              x: {
                grid: { display: false },
                ticks: { maxTicksLimit: 13, color: document.documentElement.dataset.theme === 'dark' ? '#8f8b96' : '#8a7d8f' }
              },
              y: {
                grid: { color: 'rgba(137, 83, 209, 0.1)' },
                ticks: {
                  color: document.documentElement.dataset.theme === 'dark' ? '#8f8b96' : '#8a7d8f',
                  callback: (value) => formatShortNumber(value)
                }
              }
            }
          }
        });
      }

      function renderDashboard(data) {
        dashboardData = data;
        animateCount(document.querySelector('[data-countup="followers"]'), data.heroStats.currentFollowers);
        animateCount(document.querySelector('[data-countup="daysWriting"]'), data.profile?.daysWriting || 1456);
        animateCount(document.querySelector('[data-countup="totalTweets"]'), data.profile?.totalTweets || 27066);
        animateCount(document.querySelector('[data-countup="impressions"]'), data.heroStats.totalImpressions);
        animateCount(document.querySelector('[data-countup="engagement"]'), data.heroStats.avgWeeklyEngagement);

        document.getElementById('weekTweets').textContent = formatNumber(data.thisWeek.tweets);
        document.getElementById('weekViews').textContent = formatCompact(data.thisWeek.views);
        document.getElementById('weekEngagement').textContent = formatNumber(data.thisWeek.engagement);
        document.getElementById('weekGrowth').textContent = data.thisWeek.growthRate || '—';
        document.getElementById('weekBestText').textContent = data.thisWeek.bestTweet?.text || t('week.empty');
        document.getElementById('weekBestLink').href = data.thisWeek.bestTweet?.url || t('tweets.openFallback');
        document.getElementById('weekBestViews').textContent = `${t('week.metrics.views')} ${formatCompact(data.thisWeek.bestTweet?.views || 0)}`;
        document.getElementById('weekBestLikes').textContent = `${t('week.metrics.likes')} ${formatNumber(data.thisWeek.bestTweet?.likes || 0)}`;
        document.getElementById('weekBestEngagement').textContent = `${t('week.metrics.engagement')} ${formatNumber(data.thisWeek.bestTweet?.engagements || 0)}`;

        const updated = new Date(data.lastUpdated).toLocaleString(copy[currentLang].dates.locale, { dateStyle: 'medium', timeStyle: 'short' });
        document.getElementById('dashboardUpdated').textContent = t('footer.updated').replace('{value}', updated);

        buildTweetsRail('recentTweetsRail', getRecentSevenDaysTweets(data.recentTweets || []));
        buildTweetsRail('allTimeTweetsRail', data.allTimeTweets || []);
        renderRadar(data);
        renderGrowthChart(data);
        renderImpressionsChart(data);
        renderMiniCharts(data);
        renderContentIntelligence(data);
      }

      // Listen for global language toggle (LanguageToggle.astro sets data-lang on <html>)
      new MutationObserver(() => {
        const lang = document.documentElement.getAttribute('data-lang') || 'en';
        if (lang !== currentLang) {
          currentLang = lang;
          updateStaticCopy();
          if (dashboardData) renderDashboard(dashboardData);
        }
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

      updateStaticCopy();
      attachRailControls('recentTweetsRail', 'recentTweetsPrev', 'recentTweetsNext');
      attachRailControls('allTimeTweetsRail', 'allTimeTweetsPrev', 'allTimeTweetsNext');

      fetch('/data/dashboard.json')
        .then((response) => response.json())
        .then((data) => {
          renderDashboard(data);
          revealOnScroll();
        })
        .catch((error) => {
          console.error('Failed to load dashboard data', error);
          document.getElementById('dashboardUpdated').textContent = t('footer.failed');
        });
    })();
  </script>
</PageLayout>
