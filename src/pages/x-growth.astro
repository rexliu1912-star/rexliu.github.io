      function getRecentSevenDaysTweets(tweets = []) {
        if (!tweets.length) return [];
        const stamped = tweets
          .map((tweet) => ({ ...tweet, parsedDate: new Date(`${tweet.date}T00:00:00Z`) }))
          .filter((tweet) => !Number.isNaN(tweet.parsedDate.getTime()));
        const maxTime = Math.max(...stamped.map((tweet) => tweet.parsedDate.getTime()));
        const windowStart = maxTime - (6 * 24 * 60 * 60 * 1000);
        return stamped
          .filter((tweet) => tweet.parsedDate.getTime() >= windowStart)
          .sort((a, b) => (b.engagements || 0) - (a.engagements || 0));
      }

