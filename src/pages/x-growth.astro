---
import PageLayout from "@/layouts/Base.astro";

const meta = {
  title: "X Growth Dashboard",
  description: "A public dashboard tracking Rex Liu's X growth, reach, and weekly momentum.",
};
---

<PageLayout meta={meta}>
  <section class="mb-8 border-b border-black/8 pb-6 dark:border-white/10">
    <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p id="heroEyebrow" class="mb-3 font-serif text-xs font-bold tracking-[0.25em] text-[#8953d1]/70 uppercase dark:text-[#e7ddf6]/80">
          Build in public
        </p>
        <h1 id="heroTitle" class="font-serif text-4xl font-bold tracking-tight text-black dark:text-white sm:text-5xl">
          X Growth Dashboard
        </h1>
      </div>

    </div>
    <p id="heroDescription" class="max-w-3xl font-serif text-base leading-7 text-gray-600 dark:text-gray-300 sm:text-lg">
      A live public record of audience growth, reach, and content momentum on X. Warm brand surface,
      clean signal, zero vanity theater.
    </p>
  </section>

  <div id="x-growth-dashboard" class="space-y-8 pb-12">
    <section class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
      <article class="glow-card fade-in-up rounded-3xl border border-black/8 bg-white/70 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
        <p data-i18n="stats.followers.label" class="mb-3 text-[11px] font-bold tracking-[0.22em] text-gray-400 uppercase dark:text-gray-500">Current Followers</p>
        <p data-countup="followers" class="font-serif text-4xl font-bold text-black dark:text-white">0</p>
      </article>
      <article class="glow-card fade-in-up rounded-3xl border border-black/8 bg-white/70 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 60ms">
        <p data-i18n="stats.daysWriting.label" class="mb-3 text-[11px] font-bold tracking-[0.22em] text-gray-400 uppercase dark:text-gray-500">Days Writing</p>
        <p data-countup="daysWriting" class="font-serif text-4xl font-bold text-black dark:text-white">0</p>
      </article>
      <article class="glow-card fade-in-up rounded-3xl border border-black/8 bg-white/70 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 120ms">
        <p data-i18n="stats.totalTweets.label" class="mb-3 text-[11px] font-bold tracking-[0.22em] text-gray-400 uppercase dark:text-gray-500">Total Tweets</p>
        <p data-countup="totalTweets" class="font-serif text-4xl font-bold text-black dark:text-white">0</p>
      </article>
      <article class="glow-card fade-in-up rounded-3xl border border-black/8 bg-white/70 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 180ms">
        <p data-i18n="stats.impressions.label" class="mb-3 text-[11px] font-bold tracking-[0.22em] text-gray-400 uppercase dark:text-gray-500">Total Impressions</p>
        <p data-countup="impressions" class="font-serif text-4xl font-bold text-black dark:text-white">0</p>
      </article>
      <article class="glow-card fade-in-up rounded-3xl border border-black/8 bg-white/70 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5 col-span-2 sm:col-span-1" style="--delay: 240ms">
        <p data-i18n="stats.engagement.label" class="mb-3 text-[11px] font-bold tracking-[0.22em] text-gray-400 uppercase dark:text-gray-500">Avg Weekly Engagement</p>
        <p data-countup="engagement" class="font-serif text-4xl font-bold text-black dark:text-white">0</p>
      </article>
    </section>

    <section class="space-y-4">
      <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p data-i18n="growth.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Growth Curve</p>
            <h2 data-i18n="growth.title" class="font-serif text-2xl font-semibold text-black dark:text-white">Followers over time</h2>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-[1.5rem] border border-[#8953d1]/10 bg-[linear-gradient(180deg,rgba(137,83,209,0.08),rgba(255,248,235,0.4))] p-4 dark:border-[#e7ddf6]/10 dark:bg-[linear-gradient(180deg,rgba(231,221,246,0.08),rgba(21,21,21,0.4))]">
          <canvas id="growthChart" class="h-[320px] w-full"></canvas>
        </div>
      </article>

      <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 60ms">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p data-i18n="impressionsChart.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Reach Curve</p>
            <h2 data-i18n="impressionsChart.title" class="font-serif text-2xl font-semibold text-black dark:text-white">Weekly Impressions</h2>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-[1.5rem] border border-[#8953d1]/10 bg-[linear-gradient(180deg,rgba(137,83,209,0.08),rgba(255,248,235,0.4))] p-4 dark:border-[#e7ddf6]/10 dark:bg-[linear-gradient(180deg,rgba(231,221,246,0.08),rgba(21,21,21,0.4))]">
          <canvas id="impressionsChart" class="h-[320px] w-full"></canvas>
        </div>
      </article>

      <section class="grid gap-4 md:grid-cols-2">
        <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 90ms">
          <div class="mb-4 flex items-start justify-between gap-3">
            <div>
              <p data-i18n="miniCharts.engagement.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Engagement</p>
              <h3 data-i18n="miniCharts.engagement.title" class="font-serif text-xl font-semibold text-black dark:text-white">互动量</h3>
            </div>
          </div>
          <div class="relative overflow-hidden rounded-[1.5rem] border border-[#8953d1]/10 bg-[linear-gradient(180deg,rgba(137,83,209,0.08),rgba(255,248,235,0.4))] p-4 dark:border-[#e7ddf6]/10 dark:bg-[linear-gradient(180deg,rgba(231,221,246,0.08),rgba(21,21,21,0.4))]">
            <canvas id="engagementChart" class="h-[200px] w-full"></canvas>
          </div>
        </article>

        <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 120ms">
          <div class="mb-4">
            <p data-i18n="miniCharts.peakWeek.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Peak Week</p>
            <h3 data-i18n="miniCharts.peakWeek.title" class="font-serif text-xl font-semibold text-black dark:text-white">最佳单周</h3>
          </div>
          <div class="h-[200px] rounded-[1.5rem] border border-[#8953d1]/12 bg-[#8953d1]/[0.05] p-5 dark:border-[#e7ddf6]/12 dark:bg-[#e7ddf6]/[0.04]">
            <div class="flex h-full flex-col justify-between">
              <div>
                <div class="mb-3 flex items-center justify-between gap-3">
                  <p id="peakWeekLabel" class="font-serif text-3xl font-semibold text-black dark:text-white">—</p>
                  <span data-i18n="miniCharts.peakWeek.badge" class="rounded-full border border-[#8953d1]/20 bg-white/80 px-3 py-1 text-[11px] font-bold tracking-[0.18em] text-[#8953d1] uppercase dark:border-[#e7ddf6]/20 dark:bg-white/10 dark:text-[#e7ddf6]">Best reach</span>
                </div>
                <p id="peakWeekRange" class="text-sm leading-6 text-gray-500 dark:text-gray-400">—</p>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl border border-black/6 bg-white/70 p-4 dark:border-white/8 dark:bg-white/[0.03]">
                  <p data-i18n="miniCharts.peakWeek.viewsLabel" class="text-[11px] uppercase tracking-[0.18em] text-gray-400">Views</p>
                  <p id="peakWeekViews" class="mt-2 font-serif text-2xl text-black dark:text-white">—</p>
                </div>
                <div class="rounded-2xl border border-black/6 bg-white/70 p-4 dark:border-white/8 dark:bg-white/[0.03]">
                  <p data-i18n="miniCharts.peakWeek.engagementLabel" class="text-[11px] uppercase tracking-[0.18em] text-gray-400">Engagement</p>
                  <p id="peakWeekEngagement" class="mt-2 font-serif text-2xl text-black dark:text-white">—</p>
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 150ms">
          <div class="mb-4">
            <p data-i18n="miniCharts.profileVisits.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Profile Visits</p>
            <h3 data-i18n="miniCharts.profileVisits.title" class="font-serif text-xl font-semibold text-black dark:text-white">主页访问</h3>
          </div>
          <div class="relative overflow-hidden rounded-[1.5rem] border border-[#8953d1]/10 bg-[linear-gradient(180deg,rgba(137,83,209,0.08),rgba(255,248,235,0.4))] p-4 dark:border-[#e7ddf6]/10 dark:bg-[linear-gradient(180deg,rgba(231,221,246,0.08),rgba(21,21,21,0.4))]">
            <canvas id="profileVisitsChart" class="h-[200px] w-full"></canvas>
          </div>
        </article>

        <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 180ms">
          <div class="mb-4">
            <p data-i18n="miniCharts.followers.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Weekly Followers</p>
            <h3 data-i18n="miniCharts.followers.title" class="font-serif text-xl font-semibold text-black dark:text-white">每周新增关注</h3>
          </div>
          <div class="relative overflow-hidden rounded-[1.5rem] border border-[#8953d1]/10 bg-[linear-gradient(180deg,rgba(137,83,209,0.08),rgba(255,248,235,0.4))] p-4 dark:border-[#e7ddf6]/10 dark:bg-[linear-gradient(180deg,rgba(231,221,246,0.08),rgba(21,21,21,0.4))]">
            <canvas id="followersDeltaChart" class="h-[200px] w-full"></canvas>
          </div>
        </article>
      </section>
    </section>

    <section class="grid gap-4 lg:grid-cols-[minmax(300px,0.95fr)_minmax(0,1.05fr)]">
      <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 120ms">
        <div class="mb-5">
          <p data-i18n="week.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">This Week Snapshot</p>
          <h2 data-i18n="week.title" class="font-serif text-2xl font-semibold text-black dark:text-white">Momentum in one glance</h2>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
          <div class="rounded-2xl border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]"><p data-i18n="week.cards.tweets" class="text-xs uppercase tracking-[0.2em] text-gray-400">Tweets</p><p id="weekTweets" class="mt-2 font-serif text-3xl text-black dark:text-white">—</p></div>
          <div class="rounded-2xl border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]"><p data-i18n="week.cards.views" class="text-xs uppercase tracking-[0.2em] text-gray-400">Views</p><p id="weekViews" class="mt-2 font-serif text-3xl text-black dark:text-white">—</p></div>
          <div class="rounded-2xl border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]"><p data-i18n="week.cards.engagement" class="text-xs uppercase tracking-[0.2em] text-gray-400">Engagement</p><p id="weekEngagement" class="mt-2 font-serif text-3xl text-black dark:text-white">—</p></div>
          <div class="rounded-2xl border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]"><p data-i18n="week.cards.wow" class="text-xs uppercase tracking-[0.2em] text-gray-400">WoW</p><p id="weekGrowth" class="mt-2 font-serif text-3xl text-black dark:text-white">—</p></div>
        </div>
        <div class="mt-4 rounded-[1.5rem] border border-[#8953d1]/12 bg-[#8953d1]/[0.05] p-4 dark:border-[#e7ddf6]/12 dark:bg-[#e7ddf6]/[0.04]">
          <div class="mb-2 flex items-center justify-between gap-4">
            <p data-i18n="week.best.label" class="text-xs uppercase tracking-[0.2em] text-[#8953d1]/80 dark:text-[#e7ddf6]/80">Best tweet this week</p>
            <a id="weekBestLink" data-i18n="week.best.link" class="text-xs text-gray-500 hover:text-[#8953d1] dark:text-gray-400 dark:hover:text-[#e7ddf6]" href="#" target="_blank" rel="noreferrer">View on X</a>
          </div>
          <p id="weekBestText" class="line-clamp-4 font-serif leading-7 text-gray-700 dark:text-gray-200">Loading…</p>
          <div class="mt-3 flex flex-wrap gap-3 text-xs text-gray-500 dark:text-gray-400">
            <span id="weekBestViews">—</span>
            <span id="weekBestLikes">—</span>
            <span id="weekBestEngagement">—</span>
          </div>
        </div>
      </article>

      <article class="glow-card fade-in-up rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
        <div class="mb-5">
          <p data-i18n="radar.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Content Radar</p>
          <h2 data-i18n="radar.title" class="font-serif text-2xl font-semibold text-black dark:text-white">Average impressions by content pillar</h2>
          <p data-i18n="radar.description" class="mt-2 text-sm leading-6 text-gray-500 dark:text-gray-400">Grounded in baseline pillar analysis, so the chart reflects what actually earns attention instead of proxy metrics.</p>
        </div>
        <div class="rounded-[1.5rem] border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]">
          <canvas id="radarChart" class="h-[280px] w-full"></canvas>
        </div>
        <div id="radarLegend" class="mt-4 grid gap-2 text-sm text-gray-500 dark:text-gray-400"></div>
      </article>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
      <article class="glow-card fade-in-up overflow-hidden rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
        <div class="mb-5">
          <p data-i18n="contentIntelligence.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Weekly Content Analysis</p>
          <h2 data-i18n="contentIntelligence.title" class="font-serif text-2xl font-semibold text-black dark:text-white">Content Intelligence</h2>
          <p data-i18n="contentIntelligence.description" class="mt-2 max-w-2xl text-sm leading-6 text-gray-500 dark:text-gray-400">Read the strongest 7-day posts, the dominant content pillar, and the week-over-week shift without expanding the dashboard length.</p>
        </div>

        <div class="grid gap-4">
          <div id="contentTopTweets" class="grid gap-3"></div>

          <div class="grid gap-4 lg:grid-cols-[minmax(0,1.05fr)_minmax(280px,0.95fr)]">
            <div class="rounded-[1.5rem] border border-black/6 bg-black/[0.02] p-4 dark:border-white/8 dark:bg-white/[0.03]">
              <div class="mb-4 flex items-center justify-between gap-3">
                <div>
                  <p data-i18n="contentIntelligence.pillars.eyebrow" class="text-[11px] font-bold tracking-[0.2em] text-[#8953d1]/75 uppercase dark:text-[#e7ddf6]/75">Topic Signals</p>
                  <h3 data-i18n="contentIntelligence.pillars.title" class="mt-2 font-serif text-xl font-semibold text-black dark:text-white">Weekly pillar mix</h3>
                </div>
                <span id="contentStrongestPillar" class="rounded-full border border-[#8953d1]/20 bg-[#8953d1]/[0.06] px-3 py-1 text-[11px] font-bold tracking-[0.18em] text-[#8953d1] uppercase dark:border-[#e7ddf6]/20 dark:bg-[#e7ddf6]/[0.08] dark:text-[#e7ddf6]">—</span>
              </div>
              <div id="pillarBars" class="grid gap-3"></div>
            </div>

            <div class="rounded-[1.5rem] border border-[#8953d1]/12 bg-[#8953d1]/[0.05] p-4 dark:border-[#e7ddf6]/12 dark:bg-[#e7ddf6]/[0.04]">
              <p data-i18n="contentIntelligence.compare.eyebrow" class="text-[11px] font-bold tracking-[0.2em] text-[#8953d1]/75 uppercase dark:text-[#e7ddf6]/75">Week over week</p>
              <h3 data-i18n="contentIntelligence.compare.title" class="mt-2 font-serif text-xl font-semibold text-black dark:text-white">This week vs last week</h3>
              <div id="weekCompareBars" class="mt-4 grid gap-4"></div>
            </div>
          </div>
        </div>
      </article>

      <article class="glow-card fade-in-up overflow-hidden rounded-[2rem] border border-black/8 bg-white/75 p-5 backdrop-blur-sm dark:border-white/10 dark:bg-white/5" style="--delay: 120ms">
        <div class="mb-5 flex items-center justify-between gap-4">
          <div>
            <p data-i18n="tweets.allTime.eyebrow" class="mb-2 text-[11px] font-bold tracking-[0.22em] text-[#8953d1]/80 uppercase dark:text-[#e7ddf6]/80">Top Tweets</p>
            <h2 data-i18n="tweets.allTime.title" class="font-serif text-2xl font-semibold text-black dark:text-white">All-Time Best</h2>
          </div>
          <div class="hidden gap-2 sm:flex">
            <button id="allTimeTweetsPrev" class="rounded-full border border-black/8 px-3 py-1 text-xs text-gray-500 hover:border-[#8953d1]/40 hover:text-[#8953d1] dark:border-white/10 dark:text-gray-400 dark:hover:border-[#e7ddf6]/40 dark:hover:text-[#e7ddf6]">←</button>
            <button id="allTimeTweetsNext" class="rounded-full border border-black/8 px-3 py-1 text-xs text-gray-500 hover:border-[#8953d1]/40 hover:text-[#8953d1] dark:border-white/10 dark:text-gray-400 dark:hover:border-[#e7ddf6]/40 dark:hover:text-[#e7ddf6]">→</button>
          </div>
        </div>
        <div id="allTimeTweetsRail" class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 [scrollbar-width:none]"></div>
      </article>
    </section>

    <p id="dashboardUpdated" class="text-right text-xs tracking-[0.14em] text-gray-400 uppercase dark:text-gray-500">Loading dashboard data…</p>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script is:inline>
    (() => {
      const root = document.getElementById('x-growth-dashboard');
      if (!root) return;

      const copy = {
        en: {
          heroEyebrow: 'Build in public',
          heroTitle: 'X Growth Dashboard',
          heroDescription: 'A live public record of audience growth, reach, and content momentum on X. Warm brand surface, clean signal, zero vanity theater.',
          stats: {
            followers: { label: 'Current Followers' },
            daysWriting: { label: 'Days Writing' },
            totalTweets: { label: 'Total Tweets' },
            impressions: { label: 'Total Impressions' },
            engagement: { label: 'Avg Weekly Engagement' }
          },
          growth: { eyebrow: 'Growth Curve', title: 'Followers over time', tooltipFollowers: 'Followers' },
          impressionsChart: { eyebrow: 'Reach Curve', title: 'Weekly Impressions', tooltipViews: 'Views', tooltipRange: 'Week' },
          miniCharts: {
            engagement: { eyebrow: 'Engagement', title: '互动量' },
            peakWeek: { eyebrow: 'Peak Week', title: 'Best week', badge: 'Best reach', viewsLabel: 'Views', engagementLabel: 'Engagement' },
            profileVisits: { eyebrow: 'Profile Visits', title: '主页访问' },
            followers: { eyebrow: 'Weekly Followers', title: 'Followers / week' }
          },
          week: {
            eyebrow: 'This Week Snapshot',
            title: 'Momentum in one glance',
            cards: { tweets: 'Tweets', views: 'Views', engagement: 'Engagement', wow: 'WoW' },
            best: { label: 'Best tweet this week', link: 'View on X' },
            empty: 'No standout tweet captured this week yet.',
            metrics: { views: 'Views', likes: 'Likes', engagement: 'Engagement' }
          },
          radar: {
            eyebrow: 'Content Radar',
            title: 'Average impressions by content pillar',
            description: 'Grounded in baseline pillar analysis, so the chart reflects what actually earns attention instead of proxy metrics.'
          },
          contentIntelligence: {
            eyebrow: 'Weekly Content Analysis',
            title: 'Content Intelligence',
            description: 'Read the strongest 7-day posts, the dominant content pillar, and the week-over-week shift without expanding the dashboard length.',
            topTweets: { rank: 'Top {value}' },
            pillars: {
              eyebrow: 'Topic Signals',
              title: 'Weekly pillar mix',
              strongest: 'Hot: {value}',
              tweetsCount: '{value} tweets',
              labels: {
                crypto: 'Crypto / SNEK',
                ai: 'AI / Tech',
                investment: 'Investment',
                lifestyle: 'Lifestyle',
                growth: 'Growth / X'
              }
            },
            compare: {
              eyebrow: 'Week over week',
              title: 'This week vs last week',
              views: 'Views',
              engagement: 'Engagement',
              vs: 'vs'
            }
          },
          tweets: {
            recent: { eyebrow: 'Top Tweets', title: 'Last 7 Days' },
            allTime: { eyebrow: 'Top Tweets', title: 'All-Time Best' },
            views: 'views',
            metrics: { engagement: 'Engagement', replies: 'Replies' },
            openFallback: 'https://x.com/rexliu'
          },
          footer: {
            updated: 'Last updated {value}',
            loading: 'Loading dashboard data…',
            failed: 'Failed to load dashboard data.'
          },
          dates: { locale: 'en-SG' }
        },
        zh: {
          heroEyebrow: '公开构建中',
          heroTitle: 'X 增长看板',
