---
import milestonesData from "@/data/lucky-milestones.json";
import PageLayout from "@/layouts/Base.astro";

const milestones = [...milestonesData.milestones].sort(
	(a, b) => new Date(a.date).valueOf() - new Date(b.date).valueOf(),
);

const categoryMeta = {
	life: { label: "Life", labelZh: "生命", color: "#F59E0B", icon: "🎂" },
	english: { label: "English", labelZh: "英语", color: "#8953D1", icon: "🇬🇧" },
	social: { label: "Social", labelZh: "社交", color: "#10B981", icon: "👫" },
	math: { label: "Math", labelZh: "数学", color: "#3B82F6", icon: "📐" },
	growth: { label: "Growth", labelZh: "成长", color: "#EC4899", icon: "🌱" },
} as const;

const fallbackMilestone = {
	id: "lucky-placeholder",
	day: 0,
	date: "2021-01-01",
	category: "growth",
	title: "成长开始",
	title_en: "Growth begins",
	narrative: "每一段旅程都得先有第一颗星。",
	narrative_en: "Every journey starts with the first star.",
	weight: 1,
	ripple: false,
} as const;

const totalMilestones = milestones.length;
const totalConstellations = new Set(milestones.map((item) => item.category)).size;
const maxDay = Math.max(...milestones.map((item) => item.day));
const initialMilestone = milestones[milestones.length - 1] ?? milestones[0] ?? fallbackMilestone;
const milestonesJson = JSON.stringify(milestones);
const categoryMetaJson = JSON.stringify(categoryMeta);

// Build-time dynamic stats
const birthDate = new Date("2021-10-02T00:00:00Z");
const now = new Date();
const msPerDay = 1000 * 60 * 60 * 24;
const totalDaysAlive = Math.floor((now.getTime() - birthDate.getTime()) / msPerDay);
const yearsAlive = Math.floor(totalDaysAlive / 365);
const monthsRemainder = Math.floor((totalDaysAlive % 365) / 30);
const ageLabel = `${yearsAlive}y ${monthsRemainder}m`;
const lastMilestoneDate = new Date(
	`${milestones[milestones.length - 1]?.date ?? "2021-10-02"}T00:00:00Z`,
);
const daysSinceLastMilestone = Math.floor((now.getTime() - lastMilestoneDate.getTime()) / msPerDay);

const meta = {
	title: "Lucky Growth Star Map",
	description:
		"A scroll-driven growth star map of Lucky's milestones — from birth to day 43 of English awakening.",
};

const timelineMilestones = [...milestones].reverse();
---

<PageLayout meta={meta}>
	<section class="lucky-page">
		<div class="mb-6">
			<a
				href="/lab/"
				class="font-serif text-sm text-white/60 transition-colors hover:text-[#c9b4f5]"
			>
				← Lab
			</a>
		</div>

		<section class="lucky-hero">
			<h1 class="font-serif text-4xl font-bold tracking-tight text-white sm:text-5xl">
				<span class="lang-en">Lucky's Growth Star Map</span>
				<span class="lang-zh">Lucky 成长星图</span>
			</h1>
			<p class="lucky-subtitle font-serif text-lg leading-relaxed text-white/72 sm:text-xl">
				<span class="lang-en">Every milestone is a star. Scroll to watch them light up.</span>
				<span class="lang-zh">每个里程碑都是一颗星。往下滚，看它们依次亮起。</span>
			</p>
			<div class="lucky-hero-stats" aria-label="Growth star map statistics">
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">Age</span>
						<span class="lang-zh">年龄</span>
					</span>
					<strong class="lucky-stat-value font-serif">{ageLabel}</strong>
				</article>
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">Days Alive</span>
						<span class="lang-zh">来到世界</span>
					</span>
					<strong class="lucky-stat-value font-serif" data-count-target={totalDaysAlive}>{totalDaysAlive.toLocaleString()}</strong>
				</article>
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">Milestones</span>
						<span class="lang-zh">里程碑</span>
					</span>
					<strong class="lucky-stat-value font-serif" data-count-target={totalMilestones}>{totalMilestones}</strong>
				</article>
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">English Streak</span>
						<span class="lang-zh">英语启蒙</span>
					</span>
					<strong class="lucky-stat-value font-serif" data-count-target={maxDay} data-count-prefix="Day ">Day {maxDay}</strong>
				</article>
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">Constellations</span>
						<span class="lang-zh">星座类别</span>
					</span>
					<strong class="lucky-stat-value font-serif" data-count-target={totalConstellations}>{totalConstellations}</strong>
				</article>
				<article class="lucky-stat-card">
					<span class="lucky-stat-label">
						<span class="lang-en">Last Milestone</span>
						<span class="lang-zh">上次里程碑</span>
					</span>
					<strong class="lucky-stat-value font-serif" data-count-target={daysSinceLastMilestone} data-count-suffix="d ago">{daysSinceLastMilestone}d ago</strong>
				</article>
			</div>
			<div class="lucky-scroll-cue" aria-hidden="true">↓</div>
		</section>

		<section class="star-scroll" id="star-scroll">
			<div class="star-stage">
				<canvas id="lucky-star-canvas" aria-hidden="true"></canvas>
				<div class="star-stage-top">
					<div class="star-stage-copy">
						<p class="star-kicker">
							<span class="lang-en">Interactive constellation</span>
							<span class="lang-zh">互动星空</span>
						</p>
						<h2 class="font-serif text-2xl font-semibold text-white sm:text-3xl">
							<span class="lang-en">From birth to the first spontaneous sentence</span>
							<span class="lang-zh">从出生，到第一句主动说出口的英语</span>
						</h2>
						<p class="star-stage-note text-sm leading-6 text-white/65 sm:text-base">
							<span class="lang-en">Click any star to open the story behind it.</span>
							<span class="lang-zh">点任意星星，会展开那一刻背后的故事。</span>
						</p>
					</div>
					<div class="star-legend" aria-label="Milestone categories">
						{Object.entries(categoryMeta).map(([key, value]) => (
							<span class="star-legend-item" data-category={key}>
								<span class="star-legend-dot" style={`--legend-color: ${value.color}`}></span>
								<span class="lang-en">{value.label}</span>
								<span class="lang-zh">{value.labelZh}</span>
							</span>
						))}
					</div>
				</div>

		<aside class="milestone-card" id="milestone-card" aria-live="polite">
				<div class="milestone-card-glow"></div>
				<div class="milestone-card-head">
					<div>
						<p class="milestone-pill" id="milestone-pill">🌱 English · Day 42</p>
						<time class="milestone-date" id="milestone-date" datetime={initialMilestone.date}>
							{initialMilestone.date}
						</time>
					</div>
					<button
						id="milestone-close"
						type="button"
						class="milestone-close"
						aria-label="Close milestone card"
					>
						✕
					</button>
				</div>
				<div class="milestone-card-body">
					<h3 class="milestone-title font-serif text-2xl font-semibold text-white" id="milestone-title">
						{initialMilestone.title}
					</h3>
					<blockquote class="milestone-quote" id="milestone-narrative">
						{initialMilestone.narrative}
					</blockquote>
				</div>
					<div class="milestone-card-nav">
						<button id="milestone-prev" type="button" class="milestone-nav-btn">←</button>
						<button id="milestone-next" type="button" class="milestone-nav-btn">→</button>
					</div>
				</aside>

				<div class="star-progress" aria-live="polite">
					<div class="star-progress-track">
						<div id="star-progress-fill" class="star-progress-fill"></div>
					</div>
					<p class="star-progress-meta" id="star-progress-meta">Scroll to explore → Day {maxDay}</p>
				</div>
			</div>
		</section>

		<section class="timeline-section" id="timeline-section">
			<div class="timeline-head">
				<p class="timeline-kicker">
					<span class="lang-en">Timeline</span>
					<span class="lang-zh">完整时间线</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold text-white">
					<span class="lang-en">Readable, searchable, shareable</span>
					<span class="lang-zh">可读、可搜、可分享的文字版</span>
				</h2>
				<p class="font-serif text-base leading-7 text-white/70">
					<span class="lang-en">Canvas is the wow. The timeline is the memory.</span>
					<span class="lang-zh">星空负责惊艳，时间线负责留存。</span>
				</p>
			</div>

			<div class="timeline-list" role="list">
				{timelineMilestones.map((milestone) => {
					const originalIndex = milestones.indexOf(milestone);
					const category = categoryMeta[milestone.category as keyof typeof categoryMeta];
					return (
						<button
							type="button"
							class="timeline-item"
							role="listitem"
							data-milestone-index={originalIndex}
							data-milestone-id={milestone.id}
						>
							<span class="timeline-item-dot" style={`--item-color: ${category.color}`}>✦</span>
							<span class="timeline-item-date">{milestone.date.replace(/-/g, ".")}</span>
							<span class="timeline-item-title">
								<span class="lang-en">{milestone.title_en}</span>
								<span class="lang-zh">{milestone.title}</span>
							</span>
							<span class="timeline-item-tag" style={`--item-color: ${category.color}`}>
								{category.icon} <span class="lang-en">{category.label}</span><span class="lang-zh">{category.labelZh}</span>
							</span>
						</button>
					);
				})}
			</div>
		</section>
	</section>

	<script is:inline id="lucky-milestones-data" type="application/json" set:html={milestonesJson}></script>
	<script is:inline id="lucky-category-meta" type="application/json" set:html={categoryMetaJson}></script>
	<script is:inline>
		function __initHeroAnimate() {
			const page = document.querySelector('.lucky-page');
			if (!page || page.dataset.heroReady === 'true') return;
			page.dataset.heroReady = 'true';
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (!reduceMotion) {
				const fadeIn = (el, delay, dur) => {
					if (!el) return;
					el.style.opacity = '0';
					el.style.animation = `lucky-fade-up ${dur || 420}ms ease ${delay}ms forwards`;
				};
				fadeIn(page.querySelector('.lucky-eyebrow'), 300);
				const heroTitle = page.querySelector('.lucky-hero h1');
				if (heroTitle && !heroTitle.dataset.animated) {
					heroTitle.dataset.animated = 'true';
					const zh = (document.documentElement.getAttribute('data-lang') || 'en') === 'zh';
					const span = heroTitle.querySelector(zh ? '.lang-zh' : '.lang-en');
					if (span) {
						const text = span.textContent || '';
						let charDelay = 480;
						if (zh) {
							span.innerHTML = [...text].map((c) => {
								if (!c.trim()) return c;
								const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up 0.38s ease ${charDelay}ms forwards">${c}</span>`;
								charDelay += 38;
								return s;
							}).join('');
						} else {
							span.innerHTML = text.trim().split(/\s+/).map((w) => {
								const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up 0.38s ease ${charDelay}ms forwards">${w}</span>`;
								charDelay += 38;
								return s;
							}).join(' ');
						}
					}
				}
				fadeIn(page.querySelector('.lucky-subtitle'), 780);
				const statCards = Array.from(page.querySelectorAll('.lucky-stat-card'));
				statCards.forEach((card, i) => fadeIn(card, 920 + i * 65));
				fadeIn(page.querySelector('.lucky-scroll-cue'), 920 + statCards.length * 65 + 80);
			}

			setTimeout(() => {
				if (reduceMotion) return;
				page.querySelectorAll('.lucky-stat-value[data-count-target]').forEach((el) => {
					const target = Number(el.dataset.countTarget);
					if (!target || Number.isNaN(target)) return;
					const prefix = el.dataset.countPrefix || '';
					const suffix = el.dataset.countSuffix || '';
					const dur = 1100;
					const t0 = performance.now();
					el.textContent = `${prefix}0${suffix}`;
					const tick = (now) => {
						const p = Math.min((now - t0) / dur, 1);
						const e = 1 - (1 - p) ** 3;
						el.textContent = prefix + Math.round(target * e).toLocaleString() + suffix;
						if (p < 1) requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				});
			}, 900);
		}

		function __initLuckyStarMap() {
			const page = document.querySelector('.lucky-page');
			if (!page || page.dataset.luckyReady === 'true') return;
			page.dataset.luckyReady = 'true';

			const milestones = JSON.parse(document.getElementById('lucky-milestones-data')?.textContent || '[]');
			const categoryMeta = JSON.parse(document.getElementById('lucky-category-meta')?.textContent || '{}');
			const canvas = document.getElementById('lucky-star-canvas');
			const card = document.getElementById('milestone-card');
			const closeBtn = document.getElementById('milestone-close');
			const prevBtn = document.getElementById('milestone-prev');
			const nextBtn = document.getElementById('milestone-next');
			const progressFill = document.getElementById('star-progress-fill');
			const progressMeta = document.getElementById('star-progress-meta');
			const starScroll = document.getElementById('star-scroll');
			const timelineButtons = Array.from(document.querySelectorAll('.timeline-item'));
			if (!(canvas instanceof HTMLCanvasElement) || !card || !starScroll) return;

			const ctx = canvas.getContext('2d');
			if (!ctx) return;

			const state = {
				currentIndex: Math.max(0, milestones.length - 1),
				selectedIndex: Math.max(0, milestones.length - 1),
				progress: 1,
				paused: false,
				stars: [],
				particles: [],
				animationFrame: 0,
				time: 0,
			};

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const isZh = () => (document.documentElement.getAttribute('data-lang') || 'en') === 'zh';
			const isLight = () => document.documentElement.getAttribute('data-theme') === 'light';
			const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
			const formatDate = (value) => value.replace(/-/g, '.');
			const gradientPalette = ['rgba(137,83,209,0.24)', 'rgba(59,130,246,0.18)', 'rgba(236,72,153,0.14)'];
			const hexToRgba = (hex, alpha) => {
				const normalized = (hex || '#ffffff').replace('#', '');
				const safe = normalized.length === 3
					? normalized.split('').map((char) => char + char).join('')
					: normalized.padEnd(6, 'f').slice(0, 6);
				const value = Number.parseInt(safe, 16);
				const r = (value >> 16) & 255;
				const g = (value >> 8) & 255;
				const b = value & 255;
				return `rgba(${r}, ${g}, ${b}, ${alpha})`;
			};

			function buildStars() {
				const width = canvas.clientWidth;
				const height = canvas.clientHeight;
				const paddingX = width < 768 ? 48 : 96;
				const paddingY = width < 768 ? 88 : 120;
				const usableWidth = Math.max(100, width - paddingX * 2);
				const usableHeight = Math.max(100, height - paddingY * 2);
				const categories = Object.keys(categoryMeta);
				const categoryIndex = Object.fromEntries(categories.map((key, index) => [key, index]));
				const total = milestones.length - 1 || 1;

				state.stars = milestones.map((milestone, index) => {
					const progress = total === 0 ? 1 : index / total;
					const categoryOrder = categoryIndex[milestone.category] ?? 0;
					const mobile = width < 768;
					const laneCount = categories.length;
					const laneRatio = laneCount <= 1 ? 0.5 : categoryOrder / (laneCount - 1);
					const wave = Math.sin((index + 1) * 1.3) * (mobile ? 16 : 28);
					const waveY = Math.cos((index + 1) * 0.9) * (mobile ? 14 : 24);
					const x = mobile
						? paddingX + usableWidth * (0.18 + laneRatio * 0.64) + wave
						: paddingX + usableWidth * progress + wave;
					const y = mobile
						? paddingY + usableHeight * progress + waveY
						: height - paddingY - usableHeight * (0.12 + progress * 0.78) - laneRatio * 48 + waveY;
					const radius = mobile ? 2 + milestone.weight * 1.9 : 2.6 + milestone.weight * 2.4;
					return {
						index,
						x,
						y,
						radius,
						color: categoryMeta[milestone.category]?.color || '#fff',
						category: milestone.category,
						milestone,
					};
				});

				state.particles = Array.from({ length: width < 768 ? 28 : 48 }, (_, index) => ({
					x: (width / Math.max(1, (width < 768 ? 28 : 48) - 1)) * index,
					y: ((index * 61) % height),
					radius: 0.7 + ((index % 5) * 0.35),
					speed: 0.06 + ((index % 7) * 0.02),
					alpha: 0.12 + ((index % 4) * 0.04),
				}));
			}

			function resizeCanvas() {
				const ratio = Math.min(window.devicePixelRatio || 1, 2);
				const width = canvas.clientWidth;
				const height = canvas.clientHeight;
				canvas.width = Math.floor(width * ratio);
				canvas.height = Math.floor(height * ratio);
				ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
				buildStars();
				draw();
			}

			function drawBackground(width, height) {
				const light = isLight();
				const gradient = ctx.createLinearGradient(0, 0, 0, height);
				if (light) {
					gradient.addColorStop(0, '#f5f2eb');
					gradient.addColorStop(0.5, '#faf8f3');
					gradient.addColorStop(1, '#f0ede5');
				} else {
					gradient.addColorStop(0, '#060814');
					gradient.addColorStop(0.5, '#0d1021');
					gradient.addColorStop(1, '#0b1120');
				}
				ctx.fillStyle = gradient;
				ctx.fillRect(0, 0, width, height);

				const palette = light
					? ['rgba(137,83,209,0.08)', 'rgba(59,130,246,0.06)', 'rgba(236,72,153,0.05)']
					: gradientPalette;
				palette.forEach((color, index) => {
					const glow = ctx.createRadialGradient(
						width * (0.22 + index * 0.28),
						height * (0.22 + index * 0.12),
						0,
						width * (0.22 + index * 0.28),
						height * (0.22 + index * 0.12),
						width * 0.28,
					);
					glow.addColorStop(0, color);
					glow.addColorStop(1, light ? 'rgba(255,255,255,0)' : 'rgba(0,0,0,0)');
					ctx.fillStyle = glow;
					ctx.fillRect(0, 0, width, height);
				});

				const particleColor = light ? 'rgba(137,83,209,' : 'rgba(255,255,255,';
				state.particles.forEach((particle) => {
					particle.y -= particle.speed;
					if (particle.y < -8) particle.y = height + 8;
					ctx.beginPath();
					ctx.fillStyle = `${particleColor}${light ? particle.alpha * 0.5 : particle.alpha})`;
					ctx.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
					ctx.fill();
				});
			}

			function drawConnections() {
				const activeIndex = state.currentIndex;
				const groups = new Map();
				state.stars.forEach((star) => {
					if (!groups.has(star.category)) groups.set(star.category, []);
					groups.get(star.category).push(star);
				});
				groups.forEach((stars, category) => {
					ctx.save();
					ctx.strokeStyle = hexToRgba(categoryMeta[category]?.color || '#ffffff', 0.22);
					ctx.lineWidth = 1;
					ctx.setLineDash([6, 10]);
					ctx.beginPath();
					stars.forEach((star, index) => {
						if (index === 0) ctx.moveTo(star.x, star.y);
						else ctx.lineTo(star.x, star.y);
					});
					ctx.globalAlpha = 0.2 + activeIndex / Math.max(1, milestones.length - 1) * 0.35;
					ctx.stroke();
					ctx.restore();
				});
			}

			function drawStars() {
				const activeIndex = state.currentIndex;
				// Slower, deeper pulse = "breathing". ~1.8s full cycle.
				const pulse = reduceMotion ? 0 : (Math.sin(state.time / 900) + 1) / 2;
				state.stars.forEach((star) => {
					const isActive = star.index <= activeIndex;
					const isSelected = star.index === state.selectedIndex;
					const alpha = isActive ? 1 : 0.26;
					const glowRadius = star.radius * (isSelected ? 7.2 + pulse * 3.2 : isActive ? 4.2 : 2.3);
					const glow = ctx.createRadialGradient(star.x, star.y, 0, star.x, star.y, glowRadius);
					glow.addColorStop(0, `${star.color}${isActive ? '66' : '2e'}`);
					glow.addColorStop(1, 'rgba(0,0,0,0)');
					ctx.fillStyle = glow;
					ctx.beginPath();
					ctx.arc(star.x, star.y, glowRadius, 0, Math.PI * 2);
					ctx.fill();

					ctx.beginPath();
					ctx.fillStyle = isActive ? star.color : (isLight() ? 'rgba(137,83,209,0.28)' : 'rgba(255,255,255,0.42)');
					ctx.globalAlpha = alpha;
					ctx.arc(star.x, star.y, star.radius + (isSelected ? pulse * 1.6 : 0), 0, Math.PI * 2);
					ctx.fill();
					ctx.globalAlpha = 1;

					// Expanding breathing halo ring for the currently selected star —
					// adds a second layer of motion on top of the pulsing glow.
					if (isSelected && !reduceMotion) {
						const ringRadius = star.radius * (5.0 + pulse * 5.5);
						ctx.beginPath();
						ctx.strokeStyle = hexToRgba(star.color, 0.35 * (1 - pulse) + 0.08);
						ctx.lineWidth = 1.4;
						ctx.arc(star.x, star.y, ringRadius, 0, Math.PI * 2);
						ctx.stroke();
					}

					if (star.milestone.ripple && isActive) {
						const rippleRadius = star.radius * (3.8 + pulse * 1.8);
						ctx.beginPath();
						ctx.strokeStyle = `${star.color}${isSelected ? 'aa' : '66'}`;
						ctx.lineWidth = 1.2;
						ctx.arc(star.x, star.y, rippleRadius, 0, Math.PI * 2);
						ctx.stroke();
					}
				});
			}

			function draw() {
				const width = canvas.clientWidth;
				const height = canvas.clientHeight;
				ctx.clearRect(0, 0, width, height);
				drawBackground(width, height);
				drawConnections();
				drawStars();
			}

			function animate() {
				state.time += 16;
				draw();
				state.animationFrame = requestAnimationFrame(animate);
			}

			// DOM-only renderer for the milestone card. Shared by click/keyboard/
			// timeline entry points AND by scroll-driven index changes, so the
			// card stays in sync with whichever star is currently highlighted
			// in the canvas.
			function renderCardDom(index) {
				const milestone = milestones[index];
				if (!milestone) return;
				const category = categoryMeta[milestone.category] || categoryMeta.growth;
				const zh = isZh();
				card.querySelector('#milestone-pill').textContent = `${category.icon} ${zh ? category.labelZh : category.label}${milestone.day > 0 ? ` · Day ${milestone.day}` : ''}`;
				const dateEl = card.querySelector('#milestone-date');
				dateEl.textContent = formatDate(milestone.date);
				dateEl.setAttribute('datetime', milestone.date);
				card.querySelector('#milestone-title').textContent = zh ? milestone.title : milestone.title_en;
				card.querySelector('#milestone-narrative').textContent = zh ? milestone.narrative : milestone.narrative_en;
				prevBtn.disabled = index <= 0;
				nextBtn.disabled = index >= milestones.length - 1;
				timelineButtons.forEach((button) => {
					button.classList.toggle('is-active', Number(button.dataset.milestoneIndex) === index);
				});
			}

			function updateCard(index) {
				const milestone = milestones[index];
				if (!milestone) return;
				state.selectedIndex = index;
				state.currentIndex = Math.max(state.currentIndex, index);
				card.classList.add('is-open');
				renderCardDom(index);
				updateProgress(state.currentIndex / Math.max(1, milestones.length - 1), true);
			}

			function updateProgress(progress, freezeIndex = false) {
				state.progress = clamp(progress, 0, 1);
				const activeIndex = clamp(Math.round(state.progress * (milestones.length - 1)), 0, milestones.length - 1);
				const prevCurrent = state.currentIndex;
				if (!freezeIndex) state.currentIndex = activeIndex;
				progressFill.style.width = `${state.progress * 100}%`;
				// When scroll (not an explicit click/keyboard) moves us to a new star,
				// re-render the card so it tracks what the reader is looking at, and
				// sync selectedIndex so the pulse animation in drawStars() highlights
				// the currently viewed star.
				if (!freezeIndex && state.currentIndex !== prevCurrent) {
					state.selectedIndex = state.currentIndex;
					renderCardDom(state.currentIndex);
					card.classList.add('is-open');
				}
				const milestone = milestones[state.currentIndex] || milestones[0];
				const birthDate = new Date('2021-10-02T00:00:00Z');
				const milestoneDate = new Date(`${milestone.date}T00:00:00Z`);
				const ageDays = Math.floor((milestoneDate - birthDate) / (1000 * 60 * 60 * 24));
				const ageLabel = ageDays < 365
					? `${Math.floor(ageDays / 30)}m${ageDays % 30}d`
					: `${Math.floor(ageDays / 365)}y${Math.floor((ageDays % 365) / 30)}m`;
				const dayLabel = milestone.day > 0 ? `Day ${milestone.day}` : ageLabel;
				progressMeta.textContent = isZh()
					? `${dayLabel} · ${milestone.title}`
					: `${dayLabel} · ${milestone.title_en}`;
			}

			function updateScrollProgress() {
				if (state.paused) return;
				const rect = starScroll.getBoundingClientRect();
				const total = Math.max(1, starScroll.offsetHeight - window.innerHeight);
				const progress = clamp(-rect.top / total, 0, 1);
				updateProgress(progress);
			}

			function openFromHash() {
				const hash = decodeURIComponent(window.location.hash.replace(/^#/, ''));
				if (!hash) return;
				const index = milestones.findIndex((item) => item.id === hash);
				if (index >= 0) {
					state.currentIndex = Math.max(state.currentIndex, index);
					updateCard(index);
					starScroll.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
				}
			}

			canvas.addEventListener('click', (event) => {
				const rect = canvas.getBoundingClientRect();
				const x = event.clientX - rect.left;
				const y = event.clientY - rect.top;
				const target = state.stars.find((star) => Math.hypot(star.x - x, star.y - y) <= Math.max(16, star.radius + 10));
				if (!target) return;
				updateCard(target.index);
				history.replaceState({}, '', `#${target.milestone.id}`);
			});

			timelineButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const index = Number(button.dataset.milestoneIndex);
					updateCard(index);
					history.replaceState({}, '', `#${milestones[index].id}`);
					starScroll.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
				});
			});

			closeBtn.addEventListener('click', () => card.classList.remove('is-open'));
			prevBtn.addEventListener('click', () => updateCard(clamp(state.selectedIndex - 1, 0, milestones.length - 1)));
			nextBtn.addEventListener('click', () => updateCard(clamp(state.selectedIndex + 1, 0, milestones.length - 1)));

			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') card.classList.remove('is-open');
				if (event.key === 'ArrowLeft') updateCard(clamp(state.selectedIndex - 1, 0, milestones.length - 1));
				if (event.key === 'ArrowRight') updateCard(clamp(state.selectedIndex + 1, 0, milestones.length - 1));
				if (event.code === 'Space') {
					event.preventDefault();
					state.paused = !state.paused;
				}
			});

			window.addEventListener('resize', resizeCanvas, { passive: true });
			window.addEventListener('scroll', updateScrollProgress, { passive: true });
			window.addEventListener('hashchange', openFromHash);
			document.addEventListener('languagechange', () => updateCard(state.selectedIndex));

			resizeCanvas();
			updateProgress(1);
			updateCard(state.selectedIndex);
			updateScrollProgress();
			openFromHash();
			cancelAnimationFrame(state.animationFrame);
			animate();
		}

		function __runLucky() {
			__initHeroAnimate();
			__initLuckyStarMap();
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', __runLucky, { once: true });
		} else {
			__runLucky();
		}
		document.addEventListener('astro:page-load', __runLucky);
