---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Travel",
	description: "An interactive map of Rex Liu's digital nomad journey across China.",
};
---

<PageLayout meta={meta}>
  <div class="mb-8">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
      ← Lab
    </a>
  </div>

  <section class="travel-shell">

    <!-- ====== HERO ====== -->
    <div class="travel-hero">
      <p class="eyebrow fade-in-up" style="--delay: 40ms">Digital Nomad Atlas</p>
      <h1 class="hero-reveal-text font-serif text-4xl font-bold dark:text-white sm:text-5xl" style="letter-spacing: -0.01em">
        The Journey
      </h1>
      <p class="hero-reveal-subtitle font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300" style="max-width: 44rem">
        Digital nomad since Oct 2025 — a living map of cities, detours, libraries, and the shape of a sovereign life on the road.
      </p>
      <div class="hero-stats fade-in-up" style="--delay: 260ms" aria-label="Travel statistics">
        <article class="stat-card">
          <span class="stat-label">Cities Covered</span>
          <strong class="stat-value font-serif" data-counter="cities">0</strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Days on the Road</span>
          <strong class="stat-value font-serif" data-counter="days">0</strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Total Distance</span>
          <strong class="stat-value font-serif" data-counter="distance">0 km</strong>
        </article>
      </div>
    </div>

    <!-- ====== MAP (full width, main hero) ====== -->
    <div class="map-section fade-in-up" style="--delay: 80ms">
      <div class="map-frame">
        <div class="map-overlay">
          <div>
            <p class="panel-kicker">Interactive Map</p>
            <h3 class="map-title font-serif">城市轨迹 / City by city</h3>
          </div>
        </div>
        <div id="travel-map" class="travel-map" aria-label="Travel map"></div>
      </div>
    </div>

    <!-- ====== HORIZONTAL TIMELINE ====== -->
    <div class="timeline-section fade-in-up" style="--delay: 120ms">
      <div class="timeline-nav">
        <button class="tl-arrow tl-arrow--left font-serif" id="tl-arrow-left" type="button" aria-label="Scroll left">←</button>
        <div class="tl-scroll" id="tl-scroll">
          <div class="tl-track-h" id="tl-track"></div>
        </div>
        <button class="tl-arrow tl-arrow--right font-serif" id="tl-arrow-right" type="button" aria-label="Scroll right">→</button>
      </div>
      <button class="prior-toggle font-serif" id="prior-toggle" type="button" aria-expanded="false">
        <span id="prior-toggle-label" data-en="Earlier travels" data-zh="更早的旅行">Earlier travels</span>
        <span class="prior-arrow" id="prior-arrow">↓</span>
      </button>
      <div class="prior-track-wrap" id="prior-track-wrap" aria-hidden="true">
        <div class="tl-scroll tl-scroll--prior">
          <div class="tl-track-h" id="tl-prior-track"></div>
        </div>
      </div>
    </div>

    <!-- ====== STORY CARD ====== -->
    <div class="story-card-wrap" id="story-card-wrap">
      <article class="story-card" id="story-card">
        <div class="story-head">
          <div class="story-head-left">
            <h2 class="story-city font-serif" id="story-city">—</h2>
            <span class="story-meta font-serif" id="story-meta"></span>
          </div>
          <span class="story-time font-serif" id="story-time"></span>
        </div>
        <div class="story-images" id="story-images"></div>
        <blockquote class="story-quote font-serif" id="story-quote"></blockquote>
        <div class="story-details" id="story-details"></div>
      </article>
    </div>

    <!-- ====== INSIGHT GRID ====== -->
    <div class="insight-grid">
      <article class="insight-card">
        <span class="insight-label">Longest Stay</span>
        <strong class="font-serif" id="longest-stay">—</strong>
        <p id="longest-stay-note">Slow living compounds.</p>
      </article>
      <article class="insight-card">
        <span class="insight-label">Shortest Stay</span>
        <strong class="font-serif" id="shortest-stay">—</strong>
        <p id="shortest-stay-note">Quick trips still leave a mark.</p>
      </article>
      <article class="insight-card">
        <span class="insight-label">Current Streak</span>
        <strong class="font-serif" id="current-streak">—</strong>
        <p>Days since the journey began.</p>
      </article>
      <article class="insight-card">
        <span class="insight-label">Libraries Found</span>
        <strong class="font-serif" id="libraries-found">—</strong>
        <p>Bookstores and libraries along the route.</p>
      </article>
      <article class="insight-card insight-card--wide">
        <span class="insight-label">Best Meals on Record</span>
        <strong class="font-serif" id="best-meal">—</strong>
        <p id="best-meal-note">Every city leaves a taste memory.</p>
      </article>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    /* ---- Leaflet overrides ---- */
    :global(.leaflet-control-attribution),
    :global(.leaflet-control-zoom a) {
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent) !important;
      color: var(--travel-text) !important;
      border-color: color-mix(in srgb, #8953d1 24%, transparent) !important;
    }
    :global(.leaflet-control-zoom a:hover) { color: #8953d1 !important; }

    /* ---- CSS variables ---- */
    .travel-shell {
      --travel-surface: rgba(255, 255, 255, 0.78);
      --travel-panel:   rgba(255, 251, 244, 0.82);
      --travel-text:    #171717;
      --travel-soft:    #5c5668;
      --travel-muted:   #7d748c;
      --travel-border:  rgba(137, 83, 209, 0.15);
      --purple:         #8953d1;
      --purple-light:   #a175e8;
      display: grid;
      gap: 2rem;
      padding-bottom: 3.5rem;
    }
    :global(html[data-theme="dark"]) .travel-shell {
      --travel-surface: rgba(22, 22, 26, 0.82);
      --travel-panel:   rgba(16, 16, 20, 0.85);
      --travel-text:    #f0eaff;
      --travel-soft:    #cdc5dc;
      --travel-muted:   #9b90ad;
      --travel-border:  rgba(161, 117, 232, 0.18);
    }

    /* ---- Hero ---- */
    .travel-hero { display: grid; gap: 1rem; padding-bottom: 0.5rem; }
    .eyebrow {
      margin: 0;
      color: var(--purple);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 0.72rem;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      margin-top: 0.5rem;
    }
    .stat-card {
      border-radius: 1.25rem;
      padding: 1.1rem 1.2rem;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 88%, transparent);
      transition: border-color 0.25s, box-shadow 0.25s;
    }
    .stat-card:hover {
      border-color: color-mix(in srgb, var(--purple) 40%, transparent);
      box-shadow: 0 4px 16px rgba(137,83,209,0.12);
    }
    .stat-label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--travel-muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .stat-value {
      color: var(--travel-text);
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      line-height: 1.05;
    }

    /* ---- Map ---- */
    .map-section { display: grid; }
    .map-frame {
      position: relative;
      overflow: hidden;
      border-radius: 1.6rem;
      min-height: 620px;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 90%, transparent);
    }
    .map-overlay {
      position: absolute;
      top: 1rem; left: 1rem; right: 1rem;
      z-index: 500;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      pointer-events: none;
    }
    .map-overlay > * { pointer-events: auto; }
    .panel-kicker {
      margin: 0;
      color: var(--purple);
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 0.68rem;
    }
    .map-title {
      margin: 0.15rem 0 0;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--travel-text);
    }
    .travel-map { width: 100%; min-height: 620px; }

    /* ---- Horizontal Timeline ---- */
    .timeline-section { display: grid; gap: 0.75rem; }
    .timeline-nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .tl-arrow {
      flex-shrink: 0;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent);
      color: var(--travel-muted);
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .tl-arrow:hover {
      border-color: var(--purple);
      color: var(--purple);
      background: color-mix(in srgb, var(--purple) 8%, transparent);
    }
    .tl-scroll {
      flex: 1;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .tl-scroll::-webkit-scrollbar { display: none; }
    .tl-track-h {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0.75rem 0;
      position: relative;
    }

    /* Timeline dot-item */
    .tl-stop {
      scroll-snap-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      min-width: 5.5rem;
      padding: 0.5rem 0.4rem;
      cursor: pointer;
      border-radius: 0.75rem;
      transition: background 0.2s;
      position: relative;
    }
    .tl-stop:hover { background: color-mix(in srgb, var(--purple) 6%, transparent); }
    .tl-stop.is-active { background: color-mix(in srgb, var(--purple) 10%, transparent); }
    .tl-stop-dot {
      width: 0.6rem;
      height: 0.6rem;
      border-radius: 50%;
      background: color-mix(in srgb, var(--purple) 45%, transparent);
      border: 1.5px solid color-mix(in srgb, var(--purple) 55%, transparent);
      transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
      flex-shrink: 0;
    }
    .tl-stop:hover .tl-stop-dot,
    .tl-stop.is-active .tl-stop-dot {
      background: var(--purple);
      border-color: var(--purple);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--purple) 18%, transparent);
    }
    .tl-stop-dot.is-current {
      background: var(--purple);
      border-color: var(--purple);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--purple) 25%, transparent); }
      50% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--purple) 10%, transparent); }
    }
    .tl-stop-name {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--travel-text);
      white-space: nowrap;
    }
    .tl-stop.is-active .tl-stop-name { color: var(--purple); }
    :global(html[data-theme="dark"]) .tl-stop.is-active .tl-stop-name { color: var(--purple-light); }
    .tl-stop-date {
      font-size: 0.6rem;
      color: var(--travel-muted);
      letter-spacing: 0.06em;
      white-space: nowrap;
    }
    .now-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
      background: var(--purple);
      color: #fff;
      font-size: 0.55rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.15rem 0.45rem;
      border-radius: 999px;
      font-weight: 600;
    }
    /* Line connector between dots */
    .tl-connector {
      width: 2rem;
      height: 1px;
      background: color-mix(in srgb, var(--purple) 22%, transparent);
      flex-shrink: 0;
      margin-top: -1.2rem;
      align-self: flex-start;
      margin-top: 0.65rem;
    }

    /* Prior toggle */
    .prior-toggle {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      padding: 0.55rem 0.8rem;
      border-radius: 0.75rem;
      border: 1px dashed var(--travel-border);
      background: transparent;
      color: var(--travel-muted);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .prior-toggle:hover {
      border-color: color-mix(in srgb, var(--purple) 40%, transparent);
      color: var(--purple);
      background: color-mix(in srgb, var(--purple) 5%, transparent);
    }
    .prior-arrow { transition: transform 0.25s ease; }
    .prior-toggle[aria-expanded="true"] .prior-arrow { transform: rotate(180deg); }

    .prior-track-wrap {
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.35s ease;
    }
    .prior-track-wrap.is-open { max-height: 200px; }
    .tl-scroll--prior { opacity: 0.7; }

    /* Prior dots — gray */
    .tl-stop--prior .tl-stop-dot {
      background: color-mix(in srgb, #94a3b8 40%, transparent);
      border-color: color-mix(in srgb, #94a3b8 50%, transparent);
    }
    .tl-stop--prior:hover .tl-stop-dot,
    .tl-stop--prior.is-active .tl-stop-dot {
      background: #94a3b8;
      border-color: #94a3b8;
      box-shadow: 0 0 0 4px rgba(148,163,184,0.18);
    }

    /* ---- Story Card ---- */
    .story-card-wrap {
      position: relative;
      min-height: 120px;
    }
    .story-card {
      border-radius: 1.35rem;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 95%, transparent);
      padding: 1.5rem 1.8rem;
      display: grid;
      gap: 1.1rem;
      transition: opacity 280ms ease, transform 280ms ease;
      box-shadow: 0 2px 12px rgba(137,83,209,0.06);
    }
    .story-card.is-exit {
      opacity: 0;
      transform: translateX(-20px);
    }
    .story-card.is-enter {
      opacity: 0;
      transform: translateX(20px);
    }
    .story-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .story-head-left { display: flex; flex-direction: column; gap: 0.25rem; }
    .story-city {
      margin: 0;
      font-size: clamp(1.6rem, 3.5vw, 2rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--travel-text);
    }
    .story-meta {
      font-size: 0.78rem;
      color: var(--travel-muted);
      letter-spacing: 0.06em;
    }
    .story-time {
      font-size: 0.78rem;
      color: var(--purple);
      letter-spacing: 0.06em;
      white-space: nowrap;
      padding-top: 0.35rem;
    }
    :global(html[data-theme="dark"]) .story-time { color: var(--purple-light); }

    /* Images */
    .story-images {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.75rem;
    }
    .story-images:empty { display: none; }
    .story-images img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      border-radius: 0.75rem;
      border: 1px solid var(--travel-border);
    }

    /* Quote */
    .story-quote {
      margin: 0;
      font-size: clamp(1.05rem, 2vw, 1.25rem);
      font-style: italic;
      line-height: 1.75;
      color: var(--travel-soft);
      padding: 0.5rem 0;
      border-top: 1px solid var(--travel-border);
    }
    .story-quote:empty { display: none; }

    /* Details (tastes + picks) */
    .story-details { display: grid; gap: 0.6rem; }
    .story-details:empty { display: none; }
    .story-detail-row {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      font-size: 0.85rem;
      color: var(--travel-soft);
      flex-wrap: wrap;
    }
    .story-detail-icon { flex-shrink: 0; }
    .story-pick-tag {
      display: inline-block;
      border-radius: 999px;
      background: color-mix(in srgb, var(--purple) 10%, transparent);
      color: var(--purple);
      padding: 0.2rem 0.6rem;
      font-size: 0.72rem;
    }
    :global(html[data-theme="dark"]) .story-pick-tag {
      color: var(--purple-light);
      background: color-mix(in srgb, var(--purple-light) 12%, transparent);
    }

    /* ---- Insight grid ---- */
    .insight-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .insight-card {
      border-radius: 1.35rem;
      padding: 1.2rem 1.3rem;
      min-height: 140px;
      border: 1px solid var(--travel-border);
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--travel-surface) 95%, transparent),
        color-mix(in srgb, var(--travel-panel) 100%, transparent));
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .insight-card:hover {
      border-color: color-mix(in srgb, var(--purple) 35%, transparent);
      box-shadow: 0 4px 16px rgba(137,83,209,0.1);
      transform: translateY(-2px);
    }
    .insight-label {
      display: block;
      margin-bottom: 0.55rem;
      color: var(--travel-muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .insight-card strong {
      display: block;
      color: var(--travel-text);
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      line-height: 1.15;
    }
    .insight-card p {
      margin: 0.5rem 0 0;
      line-height: 1.65;
      color: var(--travel-soft);
      font-size: 0.85rem;
    }
    .insight-card--wide { grid-column: span 2; }

    /* ---- Responsive ---- */
    @media (max-width: 720px) {
      .hero-stats, .insight-grid { grid-template-columns: 1fr; }
      .insight-card--wide { grid-column: span 1; }
      .map-frame, .travel-map { min-height: 50vh; }
      .tl-arrow { display: none; }
      .story-card { padding: 1.2rem; }
    }
  </style>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script is:inline>
    const TILE_LIGHT = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
    const TILE_DARK  = "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";
    const PURPLE = "#8953d1";

    const getLang = () => document.documentElement.getAttribute("data-lang") === "zh" ? "zh" : "en";
    const fmtShort = (v, lang) => {
      if (!v) return lang === "zh" ? "至今" : "Now";
      const d = new Date(v);
      return lang === "zh"
        ? `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,"0")}`
        : d.toLocaleDateString("en-US", { month:"short", year:"2-digit" });
    };
    const daysBetween = (a, b) => Math.max(1, Math.round((b - a) / 86400000) + 1);
    const haversine = (a, b) => {
      const R = 6371, r = d => d * Math.PI / 180;
      const dLat = r(b.lat - a.lat), dLng = r(b.lng - a.lng);
      const q = Math.sin(dLat/2)**2 + Math.cos(r(a.lat)) * Math.cos(r(b.lat)) * Math.sin(dLng/2)**2;
      return 2 * R * Math.atan2(Math.sqrt(q), Math.sqrt(1-q));
    };

    const markerSvg = (current=false, prior=false) => {
      const c = prior ? "#94a3b8" : PURPLE;
      const pulse = current ? `<circle cx="22" cy="22" r="17" fill="${c}" opacity="0.16"><animate attributeName="r" values="14;22;14" dur="2s" repeatCount="indefinite"/></circle>` : "";
      return `<svg width="44" height="44" viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg">
        ${pulse}
        <circle cx="22" cy="22" r="10" fill="${c}" opacity="0.18"/>
        <circle cx="22" cy="22" r="6.5" fill="${c}" stroke="white" stroke-width="2.5"/>
      </svg>`;
    };
    const spotSvg = `<svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><circle cx="9" cy="9" r="5" fill="#fdf7ff" stroke="#8953d1" stroke-width="2"/></svg>`;

    let _map, _data, _currentCityItem, _markerRefs, _spotLayer, _selectedId;

    /* ---- Story Card ---- */
    const renderStoryCard = (city, isPrior) => {
      const lang = getLang();
      const card = document.getElementById("story-card");
      const isZh = lang === "zh";

      // Exit animation
      card.classList.add("is-exit");

      setTimeout(() => {
        // City name
        document.getElementById("story-city").textContent = isZh ? city.nameCN : city.name;

        // Meta: province + stay
        let metaParts = [];
        if (city.provinceCN || city.province) metaParts.push(isZh ? city.provinceCN : city.province);
        if (city.stayLabelCN || city.stayLabel) metaParts.push(isZh ? city.stayLabelCN : city.stayLabel);
        document.getElementById("story-meta").textContent = metaParts.join(" · ");

        // Time
        const timeEl = document.getElementById("story-time");
        if (city.isCurrent) {
          timeEl.innerHTML = '<span class="now-pill">NOW</span>';
        } else if (isPrior) {
          timeEl.textContent = isZh ? (city.yearCN || city.year) : city.year;
        } else {
          timeEl.textContent = `${fmtShort(city.arrival, lang)} — ${fmtShort(city.departure, lang)}`;
        }

        // Images
        const imgEl = document.getElementById("story-images");
        imgEl.innerHTML = "";
        if (city.images && city.images.length > 0) {
          city.images.forEach(src => {
            const img = document.createElement("img");
            img.src = src;
            img.alt = isZh ? city.nameCN : city.name;
            img.loading = "lazy";
            imgEl.appendChild(img);
          });
        }

        // Quote
        const quoteEl = document.getElementById("story-quote");
        const quote = isZh ? (city.quoteCN || city.quote) : city.quote;
        quoteEl.textContent = quote ? `"${quote}"` : "";

        // Details (tastes + picks)
        const detEl = document.getElementById("story-details");
        detEl.innerHTML = "";

        if (city.tastes && city.tastes.length > 0) {
          const row = document.createElement("div");
          row.className = "story-detail-row";
          const tasteText = city.tastes.map(t => isZh ? t.nameCN : t.name).join(" · ");
          row.innerHTML = `<span class="story-detail-icon">🍜</span> <span>${isZh ? "味道推荐" : "Taste Picks"}：${tasteText}</span>`;
          detEl.appendChild(row);
        }

        if (city.picks && city.picks.length > 0) {
          const row = document.createElement("div");
          row.className = "story-detail-row";
          row.innerHTML = `<span class="story-detail-icon">📍</span> ${city.picks.map(p => `<span class="story-pick-tag">${p}</span>`).join(" ")}`;
          detEl.appendChild(row);
        }

        // Enter animation
        card.classList.remove("is-exit");
        card.classList.add("is-enter");
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.classList.remove("is-enter");
          });
        });
      }, 280);
    };

    /* ---- Select city (unified) ---- */
    const selectCity = (cityId, isPrior) => {
      if (_selectedId === cityId) return;
      _selectedId = cityId;

      // Update timeline highlight
      document.querySelectorAll(".tl-stop").forEach(n => n.classList.toggle("is-active", n.dataset.cityId === cityId));

      // Scroll active into view
      const active = document.querySelector(`.tl-stop[data-city-id="${cityId}"]`);
      active?.scrollIntoView({ inline: "center", behavior: "smooth" });

      // Find city data
      const allCities = [..._data.cities, ...(_data.priorCities || [])];
      const city = allCities.find(c => c.id === cityId);
      if (!city) return;

      // Map flyTo
      _map.flyTo([city.lat, city.lng], city.spots?.length ? 7.5 : 6.2, { duration: 0.9 });

      // Show spots
      _spotLayer.clearLayers();
      if (!isPrior && city.spots?.length) {
        city.spots.forEach(s => {
          const icon = L.divIcon({ html: spotSvg, className: "", iconSize: [18,18], iconAnchor: [9,9] });
          L.marker([s.lat, s.lng], { icon })
            .bindTooltip(`${s.nameCN} · ${s.name}`, { direction: "top", offset: [0,-8] })
            .addTo(_spotLayer);
        });
        if (city.spots.length > 1) {
          L.polyline(city.spots.map(s => [s.lat, s.lng]), { color: PURPLE, opacity: 0.32, weight: 1.5, dashArray: "4 7" }).addTo(_spotLayer);
        }
      }

      // Update story card
      renderStoryCard(city, isPrior);
    };

    /* ---- Build horizontal timeline ---- */
    const buildTimeline = () => {
      const lang = getLang();
      const isZh = lang === "zh";
      const track = document.getElementById("tl-track");
      const priorTrack = document.getElementById("tl-prior-track");
      track.innerHTML = "";
      priorTrack.innerHTML = "";

      // Nomad cities — chronological order
      const sorted = [..._data.cities].sort((a,b) => new Date(a.arrival) - new Date(b.arrival));
      sorted.forEach((city, idx) => {
        if (idx > 0) {
          const conn = document.createElement("div");
          conn.className = "tl-connector";
          track.appendChild(conn);
        }
        const stop = document.createElement("div");
        stop.className = "tl-stop";
        stop.dataset.cityId = city.id;
        if (city.id === _selectedId) stop.classList.add("is-active");

        const dotClass = city.isCurrent ? "tl-stop-dot is-current" : "tl-stop-dot";
        const nameText = isZh ? city.nameCN : city.name;
        const dateText = city.isCurrent ? "" : fmtShort(city.arrival, lang);
        const nowBadge = city.isCurrent ? `<span class="now-pill">NOW</span>` : "";

        stop.innerHTML = `
          ${nowBadge}
          <div class="${dotClass}"></div>
          <span class="tl-stop-name">${nameText}</span>
          <span class="tl-stop-date">${dateText}</span>
        `;
        stop.addEventListener("click", () => selectCity(city.id, false));
        track.appendChild(stop);
      });

      // Prior cities
      const priorCities = _data.priorCities || [];
      priorCities.forEach((city, idx) => {
        if (idx > 0) {
          const conn = document.createElement("div");
          conn.className = "tl-connector";
          priorTrack.appendChild(conn);
        }
        const stop = document.createElement("div");
        stop.className = "tl-stop tl-stop--prior";
        stop.dataset.cityId = city.id;
        if (city.id === _selectedId) stop.classList.add("is-active");

        const nameText = isZh ? city.nameCN : city.name;
        stop.innerHTML = `
          <div class="tl-stop-dot"></div>
          <span class="tl-stop-name">${nameText}</span>
          <span class="tl-stop-date">${city.year || ""}</span>
        `;
        stop.addEventListener("click", () => selectCity(city.id, true));
        priorTrack.appendChild(stop);
      });

      // Update prior toggle label
      const toggleLabel = document.getElementById("prior-toggle-label");
      if (toggleLabel) toggleLabel.textContent = isZh ? "更早的旅行" : "Earlier travels";
    };

    /* ---- Main init ---- */
    const initTravel = async () => {
      const mapNode = document.getElementById("travel-map");
      if (!mapNode || !window.L) return;
      if (mapNode.dataset.ready === "true") return;
      mapNode.dataset.ready = "true";

      _data = await fetch("/data/travel.json").then(r => r.json());
      const cities = _data.cities;
      const priorCities = _data.priorCities || [];
      const today = new Date();
      const startDate = new Date(_data.meta.startDate);
      const daysOnRoad = daysBetween(startDate, today);
      const totalDistance = cities.slice(1).reduce((s, c, i) => s + haversine(cities[i], c), 0);
      const citiesCovered = cities.length + priorCities.length;

      _currentCityItem = cities.find(c => c.id === _data.meta.currentCity) || cities[cities.length - 1];
      const longestStay  = cities.filter(c => c.stayDays).sort((a,b) => b.stayDays - a.stayDays)[0];
      const shortestStay = cities.filter(c => c.stayDays).sort((a,b) => a.stayDays - b.stayDays)[0];
      const libraries = cities.flatMap(c => c.spots||[]).filter(s => s.isLibrary).length;
      const allMeals = cities.filter(c => c.mealCN).map(c => `${c.nameCN} · ${c.mealCN}`);

      // Counter animation
      const fillCounter = (sel, val, suffix="") => {
        const node = document.querySelector(`[data-counter="${sel}"]`);
        if (!node) return;
        const dur = 1400, t0 = performance.now(), end = Number(val);
        const frame = (t) => {
          const p = Math.min(1, (t-t0)/dur);
          const e = 1 - Math.pow(1-p, 3);
          node.textContent = `${Math.round(end*e).toLocaleString()}${suffix}`;
          if (p < 1) requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      };
      fillCounter("cities", citiesCovered);
      fillCounter("days", daysOnRoad);
      fillCounter("distance", Math.round(totalDistance), " km");

      // Insight badges
      const el = id => document.getElementById(id);
      el("longest-stay").textContent   = longestStay ? `${longestStay.name} · ${longestStay.stayDays}d` : "—";
      el("longest-stay-note").textContent  = longestStay?.quoteCN || "";
      el("shortest-stay").textContent  = shortestStay ? `${shortestStay.name} · ${shortestStay.stayDays}d` : "—";
      el("shortest-stay-note").textContent = shortestStay?.quoteCN || "";
      el("current-streak").textContent = `${daysOnRoad} days`;
      el("libraries-found").textContent = `${libraries}`;
      el("best-meal").textContent = allMeals.slice(0,3).join(" / ");
      el("best-meal-note").textContent = _currentCityItem?.mealCN ? `${_currentCityItem.nameCN} right now: ${_currentCityItem.mealCN}` : "";

      // Map init
      _map = L.map(mapNode, { zoomControl: true, attributionControl: true, preferCanvas: true })
               .setView([27.5, 106.1], 5.4);
      let tileLayer;
      const setTiles = () => {
        const dark = document.documentElement.getAttribute("data-theme") === "dark";
        if (tileLayer) tileLayer.remove();
        tileLayer = L.tileLayer(dark ? TILE_DARK : TILE_LIGHT, {
          subdomains: "abcd", maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
        }).addTo(_map);
      };
      setTiles();

      const routeLayer  = L.layerGroup().addTo(_map);
      const markerLayer = L.layerGroup().addTo(_map);
      _spotLayer   = L.layerGroup().addTo(_map);
      const priorLayer  = L.layerGroup().addTo(_map);
      const bounds = L.latLngBounds([]);
      _markerRefs = new Map();

      // Prior city markers (no popup)
      priorCities.forEach(city => {
        bounds.extend([city.lat, city.lng]);
        const icon = L.divIcon({ html: markerSvg(false, true), className: "", iconSize: [44,44], iconAnchor: [22,22] });
        const m = L.marker([city.lat, city.lng], { icon, keyboard: false }).addTo(priorLayer);
        m.on("click", () => selectCity(city.id, true));
      });

      // Nomad city markers — staggered + route dash animation
      const sortedCities = [...cities].sort((a,b) => new Date(a.arrival) - new Date(b.arrival));
      const lineLatLngs = [];

      sortedCities.forEach((city, idx) => {
        bounds.extend([city.lat, city.lng]);
        setTimeout(() => {
          const icon = L.divIcon({ html: markerSvg(city.isCurrent), className: "", iconSize: [44,44], iconAnchor: [22,22] });
          const m = L.marker([city.lat, city.lng], { icon }).addTo(markerLayer);
          m.on("click", () => selectCity(city.id, false));
          _markerRefs.set(city.id, m);

          lineLatLngs.push([city.lat, city.lng]);

          // SVG dash animation for route segments
          if (lineLatLngs.length > 1) {
            const segment = L.polyline(lineLatLngs.slice(-2), {
              color: PURPLE, weight: 2.5, opacity: 0,
              dashArray: "7 11", lineCap: "round",
              className: "route-segment"
            }).addTo(routeLayer);

            // Animate in: fade opacity
            requestAnimationFrame(() => {
              const el = segment.getElement();
              if (el) {
                const len = el.getTotalLength ? el.getTotalLength() : 500;
                el.style.strokeDasharray = `${len}`;
                el.style.strokeDashoffset = `${len}`;
                el.style.opacity = "0.78";
                el.style.transition = "stroke-dashoffset 600ms ease-out";
                requestAnimationFrame(() => { el.style.strokeDashoffset = "0"; });
              }
            });
          }

          // After last city → select current
          if (idx === sortedCities.length - 1) {
            setTimeout(() => {
              _selectedId = null;
              selectCity(_currentCityItem.id, false);
            }, 400);
          }
        }, 300 * idx + 160);
      });

      _map.fitBounds(bounds.pad(0.15));

      // Build timeline
      buildTimeline();

      // Arrow navigation
      const scrollContainer = document.getElementById("tl-scroll");
      document.getElementById("tl-arrow-left")?.addEventListener("click", () => {
        scrollContainer.scrollBy({ left: -200, behavior: "smooth" });
      });
      document.getElementById("tl-arrow-right")?.addEventListener("click", () => {
        scrollContainer.scrollBy({ left: 200, behavior: "smooth" });
      });

      // Prior toggle
      const priorToggle = document.getElementById("prior-toggle");
      const priorWrap = document.getElementById("prior-track-wrap");
      priorToggle?.addEventListener("click", () => {
        const open = priorWrap.classList.toggle("is-open");
        priorToggle.setAttribute("aria-expanded", String(open));
      });

      // Theme observer — swap tiles
      new MutationObserver(setTiles).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

      // Lang observer — rebuild timeline + refresh story card
      new MutationObserver(() => {
        buildTimeline();
        // Refresh current story card
        if (_selectedId) {
          const allCities = [..._data.cities, ...(_data.priorCities || [])];
          const city = allCities.find(c => c.id === _selectedId);
          const isPrior = (_data.priorCities || []).some(c => c.id === _selectedId);
          if (city) {
            // Skip exit animation for lang switch — just re-render instantly
            const card = document.getElementById("story-card");
            card.classList.remove("is-exit", "is-enter");
            const savedId = _selectedId;
            _selectedId = null;
            // Temporarily bypass animation
            renderStoryCard(city, isPrior);
            _selectedId = savedId;
          }
        }
      }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-lang"] });
    };

    initTravel();
    document.addEventListener("astro:page-load", () => {
      const mapNode = document.getElementById("travel-map");
      if (mapNode) mapNode.dataset.ready = "";
      _selectedId = null;
      initTravel();
    });
  </script>
</PageLayout>
