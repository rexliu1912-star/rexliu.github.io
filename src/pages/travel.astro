---
import PageLayout from "@/layouts/Base.astro";

const meta = {
  title: "Travel",
  description: "An interactive map of Rex Liu's digital nomad journey across China.",
};
---

<PageLayout meta={meta}>
  <section class="travel-shell">
    <div class="travel-hero glow-card">
      <div class="hero-copy">
        <p class="eyebrow fade-in-up" style="--delay: 80ms">Digital Nomad Atlas</p>
        <h1 class="hero-reveal-text hero-title">The Journey</h1>
        <p class="hero-reveal-subtitle hero-subtitle">Digital nomad since Oct 2025</p>
        <p class="hero-note fade-in-up" style="--delay: 280ms">
          From Dali to Chengdu — a living map of cities, detours, libraries, meals, and the shape
          of a sovereign life on the road.
        </p>
      </div>
      <div class="hero-stats" aria-label="Travel statistics">
        <article class="stat-card fade-in-up" style="--delay: 200ms">
          <span class="stat-label">Cities Covered</span>
          <strong class="stat-value" data-counter="cities">0</strong>
        </article>
        <article class="stat-card fade-in-up" style="--delay: 300ms">
          <span class="stat-label">Days on the Road</span>
          <strong class="stat-value" data-counter="days">0</strong>
        </article>
        <article class="stat-card fade-in-up" style="--delay: 400ms">
          <span class="stat-label">Total Distance</span>
          <strong class="stat-value" data-counter="distance">0 km</strong>
        </article>
      </div>
    </div>

    <div class="travel-layout">
      <aside class="timeline-panel glow-card fade-in-up" style="--delay: 180ms">
        <div class="panel-head">
          <div>
            <p class="panel-kicker">Timeline</p>
            <h2>Nomad Route</h2>
          </div>
          <span class="panel-badge">12 stops</span>
        </div>
        <div class="timeline-list" id="timeline-list"></div>
      </aside>

      <section class="map-panel fade-in-up" style="--delay: 120ms">
        <div class="map-frame glow-card">
          <div class="map-overlay">
            <div>
              <p class="panel-kicker">Interactive map</p>
              <h2>城市轨迹 / City by city</h2>
            </div>
            <button class="drawer-toggle" id="timeline-toggle" type="button" aria-expanded="false">
              Timeline
            </button>
          </div>
          <div id="travel-map" class="travel-map" aria-label="Travel map"></div>
        </div>

        <div class="insight-grid">
          <article class="insight-card glow-card">
            <span class="insight-label">Longest Stay</span>
            <strong id="longest-stay">—</strong>
            <p id="longest-stay-note">Slow living compounds.</p>
          </article>
          <article class="insight-card glow-card">
            <span class="insight-label">Shortest Stay</span>
            <strong id="shortest-stay">—</strong>
            <p id="shortest-stay-note">Quick trips still leave a mark.</p>
          </article>
          <article class="insight-card glow-card">
            <span class="insight-label">Current Streak</span>
            <strong id="current-streak">—</strong>
            <p>Days since the journey began.</p>
          </article>
          <article class="insight-card glow-card">
            <span class="insight-label">Libraries Found</span>
            <strong id="libraries-found">—</strong>
            <p>Bookstores and libraries logged along the route.</p>
          </article>
          <article class="insight-card glow-card insight-card--wide">
            <span class="insight-label">Best Meals on Record</span>
            <strong id="best-meal">—</strong>
            <p id="best-meal-note">Every city leaves a taste memory.</p>
          </article>
        </div>
      </section>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    :global(.leaflet-popup-content-wrapper),
    :global(.leaflet-popup-tip) {
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent);
      color: var(--travel-text);
      border: 1px solid color-mix(in srgb, #8953d1 24%, transparent);
      box-shadow: 0 20px 50px rgba(16, 18, 27, 0.18);
      backdrop-filter: blur(18px);
    }
    :global(.leaflet-popup-content) {
      margin: 0;
      min-width: 260px;
    }
    :global(.leaflet-control-attribution),
    :global(.leaflet-control-zoom a) {
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent) !important;
      color: var(--travel-text) !important;
      border-color: color-mix(in srgb, #8953d1 24%, transparent) !important;
    }
    :global(.leaflet-control-zoom a:hover) {
      color: #8953d1 !important;
    }
    :global(.travel-popup) {
      padding: 1rem;
      font-family: Georgia, serif;
    }
    :global(.travel-popup h3) {
      margin: 0 0 0.2rem;
      font-size: 1.15rem;
      color: var(--travel-text);
    }
    :global(.travel-popup .meta) {
      display: block;
      margin-bottom: 0.6rem;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--travel-muted);
    }
    :global(.travel-popup p) {
      margin: 0 0 0.85rem;
      line-height: 1.6;
      color: var(--travel-soft);
      font-size: 0.95rem;
    }
    :global(.travel-popup .tags) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    :global(.travel-popup .tags span) {
      border-radius: 999px;
      background: color-mix(in srgb, #8953d1 10%, transparent);
      color: #8953d1;
      padding: 0.22rem 0.58rem;
      font-size: 0.72rem;
    }

    .travel-shell {
      --travel-bg: #fff8eb;
      --travel-surface: rgba(255, 255, 255, 0.76);
      --travel-panel: rgba(255, 251, 244, 0.78);
      --travel-text: #171717;
      --travel-soft: #5f5a67;
      --travel-muted: #7d748c;
      --travel-border: rgba(137, 83, 209, 0.16);
      display: grid;
      gap: 1.5rem;
      padding-bottom: 3rem;
    }
    :global(html[data-theme="dark"]) .travel-shell {
      --travel-bg: #151515;
      --travel-surface: rgba(24, 24, 28, 0.8);
      --travel-panel: rgba(18, 18, 22, 0.82);
      --travel-text: #f6f0ff;
      --travel-soft: #d2cae1;
      --travel-muted: #9b90ad;
      --travel-border: rgba(167, 117, 232, 0.18);
    }
    .travel-hero,
    .timeline-panel,
    .map-frame,
    .insight-card {
      border: 1px solid var(--travel-border);
      background: linear-gradient(180deg, color-mix(in srgb, var(--travel-surface) 95%, transparent), color-mix(in srgb, var(--travel-panel) 100%, transparent));
      backdrop-filter: blur(18px);
    }
    .travel-hero {
      display: grid;
      gap: 1.5rem;
      padding: 1.5rem;
      border-radius: 1.75rem;
    }
    .eyebrow,
    .panel-kicker,
    .panel-badge {
      margin: 0;
      color: #8953d1;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 0.72rem;
    }
    .hero-title {
      margin: 0.25rem 0 0.35rem;
      font-size: clamp(2.8rem, 7vw, 4.8rem);
      line-height: 0.98;
      color: var(--travel-text);
    }
    .hero-subtitle,
    .hero-note {
      max-width: 42rem;
      color: var(--travel-soft);
      font-family: Georgia, serif;
    }
    .hero-note { font-size: 1rem; line-height: 1.8; }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
    }
    .stat-card,
    .insight-card {
      border-radius: 1.35rem;
      padding: 1rem 1.1rem;
      background: color-mix(in srgb, var(--travel-surface) 88%, transparent);
      border: 1px solid var(--travel-border);
    }
    .stat-label,
    .insight-label {
      display: block;
      margin-bottom: 0.55rem;
      color: var(--travel-muted);
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .stat-value,
    .insight-card strong {
      font-family: Georgia, serif;
      color: var(--travel-text);
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      line-height: 1.05;
    }
    .travel-layout {
      display: grid;
      grid-template-columns: 320px minmax(0, 1fr);
      gap: 1.25rem;
      align-items: start;
    }
    .timeline-panel {
      position: sticky;
      top: 5.6rem;
      border-radius: 1.6rem;
      padding: 1.1rem;
      max-height: calc(100vh - 7rem);
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: start;
      margin-bottom: 0.9rem;
    }
    .panel-head h2,
    .map-overlay h2 {
      margin: 0.15rem 0 0;
      font-family: Georgia, serif;
      font-size: 1.35rem;
      color: var(--travel-text);
    }
    .panel-badge {
      border-radius: 999px;
      border: 1px solid var(--travel-border);
      padding: 0.35rem 0.6rem;
      white-space: nowrap;
    }
    .timeline-list {
      display: grid;
      gap: 0.75rem;
      max-height: calc(100vh - 13rem);
      overflow: auto;
      padding-right: 0.2rem;
    }
    .timeline-item {
      position: relative;
      width: 100%;
      text-align: left;
      border-radius: 1.2rem;
      border: 1px solid transparent;
      background: color-mix(in srgb, var(--travel-surface) 70%, transparent);
      padding: 0.95rem 1rem 0.95rem 1.3rem;
      transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
      color: inherit;
    }
    .timeline-item::before {
      content: "";
      position: absolute;
      left: 0.7rem;
      top: 1.1rem;
      width: 0.38rem;
      height: calc(100% - 2.2rem);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(137,83,209,0.9), rgba(137,83,209,0.18));
    }
    .timeline-item:hover,
    .timeline-item.is-active {
      border-color: color-mix(in srgb, #8953d1 40%, transparent);
      transform: translateY(-1px);
      background: color-mix(in srgb, #8953d1 8%, var(--travel-surface));
    }
    .timeline-item--prior::before {
      background: linear-gradient(180deg, rgba(148, 163, 184, 0.85), rgba(148,163,184,0.18));
    }
    .timeline-item .time {
      display: block;
      color: var(--travel-muted);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 0.35rem;
    }
    .timeline-item strong {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 1rem;
      font-family: Georgia, serif;
      color: var(--travel-text);
    }
    .timeline-item p {
      margin: 0.35rem 0 0;
      color: var(--travel-soft);
      line-height: 1.55;
      font-size: 0.86rem;
    }
    .timeline-now {
      display: inline-flex;
      align-items: center;
      gap: 0.28rem;
      color: #8953d1;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .map-panel { display: grid; gap: 1rem; }
    .map-frame {
      position: relative;
      overflow: hidden;
      border-radius: 1.75rem;
      min-height: 720px;
    }
    .map-overlay {
      position: absolute;
      top: 1rem;
      left: 1rem;
      right: 1rem;
      z-index: 500;
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      pointer-events: none;
    }
    .map-overlay > * { pointer-events: auto; }
    .drawer-toggle {
      display: none;
      border-radius: 999px;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 90%, transparent);
      color: var(--travel-text);
      padding: 0.7rem 1rem;
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .travel-map { width: 100%; min-height: 720px; }
    .insight-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .insight-card {
      border-radius: 1.45rem;
      min-height: 160px;
    }
    .insight-card p {
      margin: 0.55rem 0 0;
      line-height: 1.65;
      color: var(--travel-soft);
      font-family: Georgia, serif;
    }
    .insight-card--wide { grid-column: span 2; }

    @media (max-width: 980px) {
      .travel-layout { grid-template-columns: 1fr; }
      .timeline-panel {
        position: fixed;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        top: auto;
        z-index: 700;
        max-height: min(72vh, 34rem);
        transform: translateY(calc(100% + 1.5rem));
        transition: transform 280ms ease;
      }
      .timeline-panel.is-open { transform: translateY(0); }
      .drawer-toggle { display: inline-flex; }
      .map-frame,
      .travel-map { min-height: 70vh; }
    }
    @media (max-width: 720px) {
      .travel-hero { padding: 1.15rem; }
      .hero-stats,
      .insight-grid { grid-template-columns: 1fr; }
      .insight-card--wide { grid-column: span 1; }
      .map-frame,
      .travel-map { min-height: 64vh; }
      .map-overlay {
        flex-direction: column;
        align-items: start;
      }
    }
  </style>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script is:inline>
    const TILE_LIGHT = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
    const TILE_DARK = "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";
    const PURPLE = "#8953d1";

    const fmtDate = (value) => {
      if (!value) return "Now";
      return new Date(value).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
    };

    const daysBetween = (start, end) => Math.max(1, Math.round((end - start) / 86400000) + 1);
    const haversine = (a, b) => {
      const R = 6371;
      const toRad = (deg) => (deg * Math.PI) / 180;
      const dLat = toRad(b.lat - a.lat);
      const dLng = toRad(b.lng - a.lng);
      const q = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) * Math.sin(dLng / 2) ** 2;
      return 2 * R * Math.atan2(Math.sqrt(q), Math.sqrt(1 - q));
    };

    const popupHtml = (city) => `
      <article class="travel-popup">
        <span class="meta">${city.nameCN} · ${city.provinceCN || city.yearCN || ""}</span>
        <h3>${city.name}</h3>
        <p>${city.quoteCN || city.quote}</p>
        <div class="tags">
          ${(city.spots || []).slice(0, 5).map((spot) => `<span>${spot.nameCN}</span>`).join("")}
        </div>
      </article>
    `;

    const markerSvg = (current = false, prior = false) => {
      const color = prior ? "#94a3b8" : PURPLE;
      const pulse = current
        ? `<circle cx="22" cy="22" r="17" fill="${color}" opacity="0.18"><animate attributeName="r" values="15;23;15" dur="1.8s" repeatCount="indefinite" /></circle>`
        : "";
      return `
        <svg width="44" height="44" viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg">
          ${pulse}
          <circle cx="22" cy="22" r="10" fill="${color}" opacity="0.18"/>
          <circle cx="22" cy="22" r="6.5" fill="${color}" stroke="white" stroke-width="2.5"/>
        </svg>`;
    };

    const spotSvg = `<svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><circle cx="9" cy="9" r="5" fill="#fdf7ff" stroke="#8953d1" stroke-width="2"/></svg>`;

    const initTravel = async () => {
      const mapNode = document.getElementById("travel-map");
      if (!mapNode || !window.L) return;
      if (mapNode.dataset.ready === "true") return;
      mapNode.dataset.ready = "true";

      const response = await fetch("/data/travel.json");
      const data = await response.json();
      const cities = data.cities;
      const priorCities = data.priorCities || [];
      const today = new Date();
      const startDate = new Date(data.meta.startDate);
      const citiesCovered = cities.length + priorCities.length;
      const daysOnRoad = daysBetween(startDate, today);
      const totalDistance = cities.slice(1).reduce((sum, city, index) => sum + haversine(cities[index], city), 0);
      const longestStay = cities.filter((city) => city.stayDays).sort((a, b) => b.stayDays - a.stayDays)[0];
      const shortestStay = cities.filter((city) => city.stayDays).sort((a, b) => a.stayDays - b.stayDays)[0];
      const currentCity = cities.find((city) => city.id === data.meta.currentCity) || cities[cities.length - 1];
      const libraries = cities.flatMap((city) => city.spots || []).filter((spot) => spot.isLibrary).length;
      const allMeals = cities.filter((city) => city.mealCN).map((city) => `${city.nameCN} · ${city.mealCN}`);

      const fillCounter = (selector, value, suffix = "") => {
        const node = document.querySelector(`[data-counter="${selector}"]`);
        if (!node) return;
        const duration = 1400;
        const start = performance.now();
        const endValue = Number(value);
        const frame = (time) => {
          const p = Math.min(1, (time - start) / duration);
          const eased = 1 - Math.pow(1 - p, 3);
          const current = Math.round(endValue * eased);
          node.textContent = `${current.toLocaleString()}${suffix}`;
          if (p < 1) requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      };
      fillCounter("cities", citiesCovered);
      fillCounter("days", daysOnRoad);
      fillCounter("distance", Math.round(totalDistance), " km");

      document.getElementById("longest-stay").textContent = `${longestStay.name} · ${longestStay.stayDays} days`;
      document.getElementById("longest-stay-note").textContent = longestStay.quoteCN;
      document.getElementById("shortest-stay").textContent = `${shortestStay.name} · ${shortestStay.stayDays} day${shortestStay.stayDays > 1 ? "s" : ""}`;
      document.getElementById("shortest-stay-note").textContent = shortestStay.quoteCN;
      document.getElementById("current-streak").textContent = `${daysOnRoad} days`;
      document.getElementById("libraries-found").textContent = `${libraries}`;
      document.getElementById("best-meal").textContent = allMeals.slice(0, 3).join(" / ");
      document.getElementById("best-meal-note").textContent = `${currentCity.nameCN} right now: ${currentCity.mealCN}`;

      const map = L.map(mapNode, {
        zoomControl: true,
        attributionControl: true,
        preferCanvas: true,
      }).setView([27.5, 106.1], 5.4);

      let tileLayer;
      const setTiles = () => {
        const theme = document.documentElement.getAttribute("data-theme");
        const url = theme === "dark" ? TILE_DARK : TILE_LIGHT;
        if (tileLayer) tileLayer.remove();
        tileLayer = L.tileLayer(url, {
          subdomains: "abcd",
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors &copy; CARTO',
        }).addTo(map);
      };
      setTiles();

      const routeLayer = L.layerGroup().addTo(map);
      const markerLayer = L.layerGroup().addTo(map);
      const spotLayer = L.layerGroup().addTo(map);
      const priorLayer = L.layerGroup().addTo(map);
      const bounds = L.latLngBounds([]);

      const showCitySpots = (city) => {
        spotLayer.clearLayers();
        if (!city.spots?.length) return;
        const latlngs = city.spots.map((spot) => [spot.lat, spot.lng]);
        latlngs.forEach((latlng, index) => {
          const spot = city.spots[index];
          const icon = L.divIcon({ html: spotSvg, className: "", iconSize: [18, 18], iconAnchor: [9, 9] });
          L.marker(latlng, { icon }).bindTooltip(`${spot.nameCN} · ${spot.name}`, { direction: "top", offset: [0, -8] }).addTo(spotLayer);
        });
        if (latlngs.length > 1) {
          L.polyline(latlngs, { color: PURPLE, opacity: 0.36, weight: 2, dashArray: "5 8" }).addTo(spotLayer);
        }
        map.flyToBounds(L.latLngBounds(latlngs).pad(0.35), { duration: 0.9, maxZoom: 10 });
      };

      const selectTimeline = (id) => {
        document.querySelectorAll(".timeline-item").forEach((node) => node.classList.toggle("is-active", node.dataset.cityId === id));
      };

      const timelineList = document.getElementById("timeline-list");
      const addTimelineItem = (city, prior = false) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = `timeline-item${prior ? " timeline-item--prior" : ""}`;
        button.dataset.cityId = city.id;
        button.innerHTML = `
          <span class="time">${prior ? city.year : `${fmtDate(city.arrival)} — ${fmtDate(city.departure)}`}</span>
          <strong>${city.nameCN}${city.isCurrent ? '<span class="timeline-now">📍 Now</span>' : ""}</strong>
          <p>${city.quoteCN || city.quote}</p>`;
        button.addEventListener("click", () => {
          selectTimeline(city.id);
          if (prior) {
            map.flyTo([city.lat, city.lng], 6.1, { duration: 0.9 });
          } else {
            map.flyTo([city.lat, city.lng], city.spots?.length ? 7.4 : 6.4, { duration: 0.9 });
            showCitySpots(city);
            const marker = markerRefs.get(city.id);
            marker?.openPopup();
          }
          if (window.innerWidth <= 980) timelinePanel.classList.remove("is-open");
        });
        timelineList.appendChild(button);
      };

      priorCities.forEach((city) => {
        addTimelineItem(city, true);
        bounds.extend([city.lat, city.lng]);
        const icon = L.divIcon({ html: markerSvg(false, true), className: "", iconSize: [44, 44], iconAnchor: [22, 22] });
        const marker = L.marker([city.lat, city.lng], { icon, keyboard: false }).bindPopup(popupHtml(city), { offset: [0, -10] });
        marker.on("click", () => selectTimeline(city.id));
        marker.addTo(priorLayer);
      });

      const markerRefs = new Map();
      cities.forEach((city) => addTimelineItem(city, false));

      const lineLatLngs = [];
      cities.forEach((city, index) => {
        bounds.extend([city.lat, city.lng]);
        setTimeout(() => {
          const icon = L.divIcon({ html: markerSvg(city.isCurrent), className: "", iconSize: [44, 44], iconAnchor: [22, 22] });
          const marker = L.marker([city.lat, city.lng], { icon }).bindPopup(popupHtml(city), { offset: [0, -12] });
          marker.on("click", () => {
            selectTimeline(city.id);
            showCitySpots(city);
          });
          marker.addTo(markerLayer);
          markerRefs.set(city.id, marker);
          lineLatLngs.push([city.lat, city.lng]);
          if (lineLatLngs.length > 1) {
            L.polyline(lineLatLngs.slice(-2), {
              color: PURPLE,
              weight: 3,
              opacity: 0.82,
              dashArray: "8 12",
              lineCap: "round",
            }).addTo(routeLayer);
          }
          if (index === cities.length - 1) {
            setTimeout(() => {
              selectTimeline(city.id);
              marker.openPopup();
              showCitySpots(city);
            }, 420);
          }
        }, 220 * index + 180);
      });

      map.fitBounds(bounds.pad(0.16));

      const timelinePanel = document.querySelector(".timeline-panel");
      const toggle = document.getElementById("timeline-toggle");
      toggle?.addEventListener("click", () => {
        const open = timelinePanel.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", String(open));
      });

      const observer = new MutationObserver(() => setTiles());
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    };

    initTravel();
    document.addEventListener("astro:page-load", initTravel);
  </script>
</PageLayout>
