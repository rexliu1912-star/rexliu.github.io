---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Travel",
	description: "An interactive map of Rex Liu's digital nomad journey across China.",
};
---

<PageLayout meta={meta}>
  <div class="mb-8">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
      ← Lab
    </a>
  </div>

  <section class="travel-shell">

    <!-- ====== HERO ====== -->
    <div class="travel-hero">
      <p class="eyebrow fade-in-up" style="--delay: 40ms">Digital Nomad Atlas</p>
      <h1 class="hero-reveal-text font-serif text-4xl font-bold dark:text-white sm:text-5xl" style="letter-spacing: -0.01em">
        The Journey
      </h1>
      <p class="hero-reveal-subtitle font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300" style="max-width: 44rem">
        Digital nomad since Nov 2025 — a living map of cities, detours, libraries, and the shape of a sovereign life on the road.
      </p>
      <div class="hero-stats fade-in-up" style="--delay: 260ms" aria-label="Travel statistics">
        <article class="stat-card">
          <span class="stat-label">Cities</span>
          <strong class="stat-value font-serif" data-counter="cities">0</strong>
          <span class="stat-sub" id="province-count" style="display:block;font-size:0.72rem;color:var(--travel-muted);margin-top:0.25rem"></span>
        </article>
        <article class="stat-card">
          <span class="stat-label">Days on the Road</span>
          <strong class="stat-value font-serif" data-counter="days">0</strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Total Distance</span>
          <strong class="stat-value font-serif" data-counter="distance">0 km</strong>
        </article>
      </div>
    </div>

    <!-- ====== MAP ====== -->
    <div class="map-section fade-in-up" style="--delay: 80ms">
      <div class="map-frame">
        <div class="map-overlay">
          <div>
            <p class="panel-kicker">Interactive Map</p>
            <h3 class="map-title font-serif">城市轨迹 / City by city</h3>
          </div>
          <div class="map-controls">
            <button id="replay-btn" class="map-ctrl-btn" title="Journey Replay" aria-label="Play journey replay">▶</button>
          </div>
        </div>
        <div id="travel-map" class="travel-map" aria-label="Travel map"></div>

        <!-- ====== LIVE COUNTER BADGE ====== -->
        <div class="live-counter" id="live-counter" aria-live="polite"></div>

        <!-- ====== NEXT STOP BADGE ====== -->
        <div class="next-stop-badge" id="next-stop-badge" aria-label="Next destination"></div>

        <!-- ====== REPLAY PROGRESS ====== -->
        <div class="replay-progress" id="replay-progress" aria-hidden="true">
          <div class="replay-track"><div class="replay-fill" id="replay-fill"></div></div>
          <span class="replay-label" id="replay-label"></span>
        </div>

        <!-- ====== MAP STORY PANEL ====== -->
        <aside class="map-panel" id="map-panel" aria-hidden="true">
          <button class="map-panel-close" id="map-panel-close" type="button" aria-label="Close">✕</button>
          <div class="map-panel-inner" id="story-card">
            <div class="story-head">
              <div class="story-head-left">
                <h2 class="story-city font-serif" id="story-city">—</h2>
                <span class="story-meta" id="story-meta"></span>
              </div>
              <span class="story-time" id="story-time"></span>
            </div>
            <div class="story-images" id="story-images"></div>
            <blockquote class="story-quote" id="story-quote"></blockquote>
            <div class="story-details" id="story-details"></div>
          </div>
        </aside>
      </div>
    </div>

    <!-- ====== YEAR TAB TIMELINE ====== -->
    <div class="year-tab-section fade-in-up" style="--delay: 120ms">
      <div class="year-tabs" id="year-tabs" role="tablist" aria-label="Travel years"></div>
      <div class="year-cities" id="year-cities" role="tabpanel"></div>
    </div>

    <!-- ====== INSIGHT GRID ====== -->
    <div class="insight-grid">
      <article class="insight-card">
        <span class="insight-label">Longest Stay</span>
        <strong class="font-serif" id="longest-stay">—</strong>
        <p id="longest-stay-note">Slow living compounds.</p>
      </article>
      <article class="insight-card">
        <span class="insight-label">Shortest Stay</span>
        <strong class="font-serif" id="shortest-stay">—</strong>
        <p id="shortest-stay-note">Quick trips still leave a mark.</p>
      </article>
      
      <article class="insight-card">
        <span class="insight-label">Libraries Found</span>
        <strong class="font-serif" id="libraries-found">—</strong>
        <p>Bookstores and libraries along the route.</p>
      </article>
      <article class="insight-card">
        <span class="insight-label">Longest Leg</span>
        <strong class="font-serif" id="longest-leg">—</strong>
        <p id="longest-leg-note">The farthest single hop.</p>
      </article>
      <article class="insight-card insight-card--wide">
        <span class="insight-label">Best Meals on Record</span>
        <strong class="font-serif" id="best-meal">—</strong>
        <p id="best-meal-note">Every city leaves a taste memory.</p>
      </article>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    /* ---- Leaflet overrides ---- */
    :global(.leaflet-control-attribution),
    :global(.leaflet-control-zoom a) {
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent) !important;
      color: var(--travel-text) !important;
      border-color: color-mix(in srgb, #8953d1 24%, transparent) !important;
    }
    :global(.leaflet-control-zoom a:hover) { color: #8953d1 !important; }
    :global(.next-stop-tooltip) {
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      font-family: Georgia, Cambria, "Times New Roman", Times, serif;
    }
    :global(.next-stop-tooltip::before) { display: none !important; }

    /* ---- Base font: match site-wide Georgia serif (Lab/Home pages) ---- */
    .travel-shell {
      font-family: Georgia, Cambria, "Times New Roman", Times, serif;
    }
    .travel-shell {
      --travel-surface: rgba(255, 255, 255, 0.78);
      --travel-panel:   rgba(255, 251, 244, 0.82);
      --travel-text:    #171717;
      --travel-soft:    #5c5668;
      --travel-muted:   #7d748c;
      --travel-border:  rgba(137, 83, 209, 0.15);
      --purple:         #8953d1;
      --purple-light:   #a175e8;
      display: grid;
      gap: 2rem;
      padding-bottom: 3.5rem;
    }
    :global(html[data-theme="dark"]) .travel-shell {
      --travel-surface: rgba(22, 22, 26, 0.82);
      --travel-panel:   rgba(16, 16, 20, 0.85);
      --travel-text:    #f0eaff;
      --travel-soft:    #cdc5dc;
      --travel-muted:   #9b90ad;
      --travel-border:  rgba(161, 117, 232, 0.18);
    }

    /* ---- Hero ---- */
    .travel-hero { display: grid; gap: 1rem; padding-bottom: 0.5rem; }
    .eyebrow {
      margin: 0;
      color: var(--purple);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 0.72rem;
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      margin-top: 0.5rem;
    }
    .stat-card {
      border-radius: 1.25rem;
      padding: 1.1rem 1.2rem;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 88%, transparent);
      transition: border-color 0.25s, box-shadow 0.25s;
    }
    .stat-card:hover {
      border-color: color-mix(in srgb, var(--purple) 40%, transparent);
      box-shadow: 0 4px 16px rgba(137,83,209,0.12);
    }
    .stat-label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--travel-muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .stat-value {
      color: var(--travel-text);
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      line-height: 1.05;
    }

    /* ---- Map ---- */
    .map-section { display: grid; }
    .map-frame {
      position: relative;
      overflow: hidden;
      border-radius: 1.6rem;
      min-height: 620px;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 90%, transparent);
    }
    .map-overlay {
      position: absolute;
      top: 1rem; left: 1rem; right: 1rem;
      z-index: 500;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      pointer-events: none;
    }
    .map-overlay > * { pointer-events: auto; }
    .panel-kicker {
      margin: 0;
      color: var(--purple);
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 0.68rem;
    }
    .map-title {
      margin: 0.15rem 0 0;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--travel-text);
    }
    .travel-map { width: 100%; min-height: 620px; }

    /* ---- Story panel content entrance animation ---- */
    @keyframes story-slide-in {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .map-panel.is-open .map-panel-inner {
      animation: story-slide-in 0.35s ease both;
    }

    /* ---- Map Story Panel ---- */
    .map-panel {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      bottom: 0.75rem;
      width: min(340px, calc(100% - 1.5rem));
      z-index: 600;
      border-radius: 1.25rem;
      background: color-mix(in srgb, var(--travel-panel) 97%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--travel-border);
      box-shadow: 0 8px 40px rgba(0,0,0,0.14), 0 0 0 1px rgba(137,83,209,0.08);
      transform: translateX(calc(100% + 1.5rem));
      transition: transform 0.38s cubic-bezier(0.34, 1.28, 0.64, 1), opacity 0.3s;
      opacity: 0;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-width: thin;
      scrollbar-color: color-mix(in srgb, var(--purple) 22%, transparent) transparent;
    }
    .map-panel::-webkit-scrollbar { width: 4px; }
    .map-panel::-webkit-scrollbar-thumb {
      background: color-mix(in srgb, var(--purple) 22%, transparent);
      border-radius: 2px;
    }
    .map-panel.is-open {
      transform: translateX(0);
      opacity: 1;
    }

    .map-panel-close {
      position: sticky;
      top: 0.6rem;
      float: right;
      margin: 0.65rem 0.7rem 0 0;
      width: 1.7rem;
      height: 1.7rem;
      border-radius: 50%;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 95%, transparent);
      color: var(--travel-muted);
      font-size: 0.75rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .map-panel-close:hover {
      background: color-mix(in srgb, var(--purple) 12%, transparent);
      border-color: var(--purple);
      color: var(--purple);
    }

    .map-panel-inner {
      padding: 0.4rem 1.2rem 1.5rem;
      display: grid;
      gap: 1rem;
    }

    /* story elements inside panel */
    .map-panel-inner .story-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .map-panel-inner .story-head-left { display: flex; flex-direction: column; gap: 0.2rem; }
    .map-panel-inner .story-city {
      margin: 0;
      font-size: clamp(1.3rem, 2.5vw, 1.6rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--travel-text);
    }
    .map-panel-inner .story-meta {
      font-size: 0.73rem;
      color: var(--travel-muted);
      letter-spacing: 0.05em;
    }
    .map-panel-inner .story-time {
      font-size: 0.73rem;
      color: var(--purple);
      letter-spacing: 0.05em;
      white-space: nowrap;
      padding-top: 0.2rem;
    }
    :global(html[data-theme="dark"]) .map-panel-inner .story-time { color: var(--purple-light); }

    .map-panel-inner .story-images {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
    .map-panel-inner .story-images:empty { display: none; }
    .map-panel-inner .story-images img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      border-radius: 0.65rem;
      border: 1px solid var(--travel-border);
    }

    .map-panel-inner .story-quote {
      margin: 0;
      font-size: 0.93rem;
      font-style: italic;
      line-height: 1.72;
      color: var(--travel-soft);
      padding: 0.5rem 0;
      border-top: 1px solid var(--travel-border);
    }
    .map-panel-inner .story-quote:empty { display: none; }

    .map-panel-inner .story-details { display: grid; gap: 0.5rem; }
    .map-panel-inner .story-details:empty { display: none; }
    .map-panel-inner .story-detail-row {
      display: flex;
      align-items: flex-start;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: var(--travel-soft);
      flex-wrap: wrap;
    }
    .map-panel-inner .story-pick-tag {
      display: inline-block;
      border-radius: 999px;
      background: color-mix(in srgb, var(--purple) 10%, transparent);
      color: var(--purple);
      padding: 0.18rem 0.55rem;
      font-size: 0.7rem;
    }
    :global(html[data-theme="dark"]) .map-panel-inner .story-pick-tag {
      color: var(--purple-light);
      background: color-mix(in srgb, var(--purple-light) 12%, transparent);
    }

    .now-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
      background: var(--purple);
      color: #fff;
      font-size: 0.55rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.15rem 0.45rem;
      border-radius: 999px;
      font-weight: 600;
    }

    /* ---- Year Tab Timeline ---- */
    .year-tab-section { display: grid; gap: 1.2rem; }

    .year-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.15rem 0.5rem;
      align-items: baseline;
    }

    .year-tab {
      padding: 0.25rem 0.15rem;
      border-radius: 0;
      border: none;
      border-bottom: 2px solid transparent;
      background: transparent;
      color: var(--travel-muted);
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
      font-family: Georgia, Cambria, "Times New Roman", Times, serif;
      white-space: nowrap;
    }
    .year-tab:hover {
      color: var(--purple);
      border-bottom-color: color-mix(in srgb, var(--purple) 40%, transparent);
    }
    .year-tab.is-active {
      color: var(--purple);
      border-bottom-color: var(--purple);
      font-weight: 700;
    }

    /* "Now" tab special style */
    .year-tab--now {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-weight: 600;
    }
    .year-tab--now::before {
      content: "";
      width: 0.42rem;
      height: 0.42rem;
      border-radius: 50%;
      background: currentColor;
      opacity: 0.7;
      flex-shrink: 0;
    }
    .year-tab--now.is-active::before {
      opacity: 1;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 25%, transparent); }
      50% { box-shadow: 0 0 0 7px color-mix(in srgb, currentColor 10%, transparent); }
    }

    /* City grid */
    .year-cities {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.65rem;
    }

    .year-city-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0.2rem;
      border-radius: 0;
      border: none;
      border-bottom: 1px solid color-mix(in srgb, var(--travel-border) 50%, transparent);
      background: transparent;
      cursor: pointer;
      transition: color 0.2s, padding-left 0.2s;
      position: relative;
    }
    .year-city-item:hover {
      color: var(--purple);
      padding-left: 0.5rem;
    }
    .year-city-item:hover::before {
      content: "→";
      position: absolute;
      left: -0.8rem;
      color: var(--purple);
      font-size: 0.75rem;
      opacity: 1;
    }
    .year-city-item::before {
      content: "";
      position: absolute;
      left: -0.8rem;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .year-city-item.is-active {
      color: var(--purple);
      padding-left: 0.5rem;
    }
    .year-city-item.is-active::before {
      content: "→";
      position: absolute;
      left: -0.8rem;
      color: var(--purple);
      font-size: 0.75rem;
      opacity: 1;
    }

    .year-city-dot {
      display: none;
    }
    .year-city-dot--current {
      background: var(--purple) !important;
      border-color: var(--purple) !important;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    .year-city-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .year-city-name {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--travel-text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .year-city-item:hover .year-city-name,
    .year-city-item.is-active .year-city-name { color: var(--purple); }
    :global(html[data-theme="dark"]) .year-city-item:hover .year-city-name,
    :global(html[data-theme="dark"]) .year-city-item.is-active .year-city-name { color: var(--purple-light); }
    .year-city-date {
      font-size: 0.7rem;
      color: var(--travel-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      letter-spacing: 0.02em;
    }

    /* ---- Insight grid ---- */
    .insight-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .insight-card {
      border-radius: 1.35rem;
      padding: 1.2rem 1.3rem;
      min-height: 140px;
      border: 1px solid var(--travel-border);
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--travel-surface) 95%, transparent),
        color-mix(in srgb, var(--travel-panel) 100%, transparent));
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .insight-card:hover {
      border-color: color-mix(in srgb, var(--purple) 35%, transparent);
      box-shadow: 0 4px 16px rgba(137,83,209,0.1);
      transform: translateY(-2px);
    }
    .insight-label {
      display: block;
      margin-bottom: 0.55rem;
      color: var(--travel-muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }
    .insight-card strong {
      display: block;
      color: var(--travel-text);
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      line-height: 1.15;
    }
    .insight-card p {
      margin: 0.5rem 0 0;
      line-height: 1.65;
      color: var(--travel-soft);
      font-size: 0.85rem;
    }
    .insight-card--wide { grid-column: span 2; }

    /* ---- Map Controls ---- */
    .map-controls {
      display: flex;
      gap: 0.45rem;
      align-items: center;
    }
    .map-ctrl-btn {
      width: 2.1rem;
      height: 2.1rem;
      border-radius: 50%;
      border: 1px solid var(--travel-border);
      background: color-mix(in srgb, var(--travel-surface) 92%, transparent);
      color: var(--travel-muted);
      font-size: 0.8rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      backdrop-filter: blur(8px);
    }
    .map-ctrl-btn:hover {
      border-color: var(--purple);
      color: var(--purple);
      background: color-mix(in srgb, var(--purple) 10%, transparent);
    }
    .map-ctrl-btn.is-active {
      background: var(--purple);
      border-color: var(--purple);
      color: #fff;
    }

    /* ---- Live Counter ---- */
    .live-counter {
      position: absolute;
      bottom: 1rem;
      left: 1rem;
      z-index: 600;
      background: color-mix(in srgb, var(--travel-panel) 96%, transparent);
      backdrop-filter: blur(12px);
      border: 1px solid var(--travel-border);
      border-radius: 999px;
      padding: 0.28rem 0.75rem;
      font-size: 0.73rem;
      color: var(--purple);
      font-weight: 600;
      letter-spacing: 0.03em;
      display: none;
      gap: 0.3rem;
      align-items: center;
    }
    .live-counter.is-visible { display: flex; }
    .live-counter::before {
      content: "";
      width: 0.38rem;
      height: 0.38rem;
      border-radius: 50%;
      background: var(--purple);
      animation: pulse-dot 2s ease-in-out infinite;
      flex-shrink: 0;
    }
    :global(html[data-theme="dark"]) .live-counter { color: var(--purple-light); }
    :global(html[data-theme="dark"]) .live-counter::before { background: var(--purple-light); }

    /* ---- Next Stop Badge ---- */
    .next-stop-badge {
      position: absolute;
      bottom: 1rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 600;
      background: color-mix(in srgb, var(--travel-panel) 96%, transparent);
      backdrop-filter: blur(12px);
      border: 1px solid color-mix(in srgb, var(--purple) 30%, transparent);
      border-radius: 999px;
      padding: 0.28rem 0.85rem;
      font-size: 0.73rem;
      color: var(--travel-soft);
      white-space: nowrap;
      display: none;
    }
    .next-stop-badge.is-visible { display: block; }
    .next-stop-badge strong { color: var(--purple); font-size: 0.78rem; }
    :global(html[data-theme="dark"]) .next-stop-badge strong { color: var(--purple-light); }

    /* ---- Replay Progress ---- */
    .replay-progress {
      position: absolute;
      bottom: 3.4rem;
      left: 1rem;
      right: 1rem;
      z-index: 600;
      display: none;
      align-items: center;
      gap: 0.65rem;
    }
    .replay-progress.is-active { display: flex; }
    .replay-track {
      flex: 1;
      height: 3px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--purple) 20%, transparent);
      overflow: hidden;
    }
    .replay-fill {
      height: 100%;
      width: 0%;
      background: var(--purple);
      border-radius: 999px;
      transition: width 0.4s ease;
    }
    .replay-label {
      font-size: 0.68rem;
      color: var(--purple);
      white-space: nowrap;
      min-width: 4rem;
      text-align: right;
    }
    :global(html[data-theme="dark"]) .replay-label { color: var(--purple-light); }
    :global(html[data-theme="dark"]) .replay-fill { background: var(--purple-light); }

    /* ---- Responsive ---- */
    @media (max-width: 720px) {
      .hero-stats, .insight-grid { grid-template-columns: 1fr; }
      .insight-card--wide { grid-column: span 1; }
      .map-frame, .travel-map { min-height: 50vh; }
      .year-cities { grid-template-columns: 1fr 1fr; }
      /* panel slides up from bottom on mobile */
      .map-panel {
        top: auto;
        right: 0.5rem;
        left: 0.5rem;
        bottom: 0.5rem;
        width: auto;
        max-height: 55%;
        transform: translateY(calc(100% + 1rem));
        transition: transform 0.38s cubic-bezier(0.34, 1.28, 0.64, 1), opacity 0.3s;
      }
      .map-panel.is-open { transform: translateY(0); opacity: 1; }
      .next-stop-badge { display: none !important; }
      .live-counter { font-size: 0.65rem; padding: 0.22rem 0.6rem; }
    }
  </style>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script is:inline>
    const TILE_LIGHT  = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
    const TILE_DARK   = "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";
    const PURPLE      = "#8953d1";
    const NEXT_CITY   = { name: "Xi'an", nameCN: "西安", lat: 34.3416, lng: 108.9398, date: "2026-03-31" };

    // Region color palette — brand-adjacent but lively
    const REGION_COLORS = {
      "Yunnan":    { main: "#10b981", glow: "rgba(16,185,129,0.22)" },   // 翠绿
      "Guangxi":   { main: "#f59e0b", glow: "rgba(245,158,11,0.22)" },   // 橙金
      "Fujian":    { main: "#0ea5e9", glow: "rgba(14,165,233,0.22)" },   // 海蓝
      "Sichuan":   { main: "#ef4444", glow: "rgba(239,68,68,0.22)" },    // 辣红
      "Chongqing": { main: "#f97316", glow: "rgba(249,115,22,0.22)" },   // 橙红
      "default":   { main: PURPLE,    glow: "rgba(137,83,209,0.22)" },
    };
    const getRegionColor = (province) => REGION_COLORS[province] || REGION_COLORS["default"];

    const getLang = () => document.documentElement.getAttribute("data-lang") === "zh" ? "zh" : "en";
    const fmtShort = (v, lang) => {
      if (!v) return lang === "zh" ? "至今" : "Now";
      const d = new Date(v);
      return lang === "zh"
        ? `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,"0")}`
        : d.toLocaleDateString("en-US", { month:"short", year:"2-digit" });
    };
    const daysBetween = (a, b) => Math.max(1, Math.round((b - a) / 86400000) + 1);
    const haversine = (a, b) => {
      const R = 6371, r = d => d * Math.PI / 180;
      const dLat = r(b.lat - a.lat), dLng = r(b.lng - a.lng);
      const q = Math.sin(dLat/2)**2 + Math.cos(r(a.lat)) * Math.cos(r(b.lat)) * Math.sin(dLng/2)**2;
      return 2 * R * Math.atan2(Math.sqrt(q), Math.sqrt(1-q));
    };
    // Extract starting year from prior city year string e.g. "2018-02-09 ~ 02-12" → "2018"
    const extractYear = (yearStr) => {
      if (!yearStr) return "Unknown";
      const m = yearStr.match(/(\d{4})/);
      return m ? m[1] : "Unknown";
    };

    const MARKER_SIZE = 56;
    const MARKER_CENTER = 28;
    const markerSvg = (current=false, prior=false, color=null) => {
      const c = prior ? "#94a3b8" : (color || PURPLE);
      const pulse = current
        ? `<circle cx="${MARKER_CENTER}" cy="${MARKER_CENTER}" r="20" fill="${c}" opacity="0.16"><animate attributeName="r" values="16;24;16" dur="2s" repeatCount="indefinite"/></circle>`
        : "";
      const glow = !prior && !current
        ? `<circle cx="${MARKER_CENTER}" cy="${MARKER_CENTER}" r="15" fill="${c}" opacity="0.10"/>` : "";
      return `<svg width="${MARKER_SIZE}" height="${MARKER_SIZE}" viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg">
        <circle cx="${MARKER_CENTER}" cy="${MARKER_CENTER}" r="24" fill="transparent"/>
        ${pulse}${glow}
        <circle cx="${MARKER_CENTER}" cy="${MARKER_CENTER}" r="10" fill="${c}" opacity="0.18"/>
        <circle cx="${MARKER_CENTER}" cy="${MARKER_CENTER}" r="6.5" fill="${c}" stroke="white" stroke-width="2.5"/>
      </svg>`;
    };
    const spotSvg = `<svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><circle cx="9" cy="9" r="5" fill="#fdf7ff" stroke="#8953d1" stroke-width="2"/></svg>`;

    let _map, _data, _currentCityItem, _markerRefs, _spotLayer, _selectedId, _activeYear;
    let _replayTimer = null, _replayIndex = 0, _isReplaying = false;
    

    /* ---- Map Panel ---- */
    const openMapPanel = () => {
      const panel = document.getElementById("map-panel");
      if (panel) { panel.classList.add("is-open"); panel.setAttribute("aria-hidden", "false"); }
    };
    const closeMapPanel = () => {
      const panel = document.getElementById("map-panel");
      if (panel) { panel.classList.remove("is-open"); panel.setAttribute("aria-hidden", "true"); }
    };

    /* ---- Story Card Render ---- */
    const renderStoryCard = (city, isPrior) => {
      const lang = getLang();
      const isZh = lang === "zh";

      document.getElementById("story-city").textContent = isZh ? city.nameCN : city.name;

      let metaParts = [];
      if (city.provinceCN || city.province) metaParts.push(isZh ? (city.provinceCN || city.province) : city.province);
      if (city.stayLabelCN || city.stayLabel) metaParts.push(isZh ? (city.stayLabelCN || city.stayLabel) : city.stayLabel);
      document.getElementById("story-meta").textContent = metaParts.join(" · ");

      const timeEl = document.getElementById("story-time");
      if (city.isCurrent) {
        timeEl.innerHTML = '<span class="now-pill">NOW</span>';
      } else if (isPrior) {
        timeEl.textContent = isZh ? (city.yearCN || city.year || "") : (city.year || "");
      } else {
        timeEl.textContent = `${fmtShort(city.arrival, lang)} — ${fmtShort(city.departure, lang)}`;
      }

      const imgEl = document.getElementById("story-images");
      imgEl.innerHTML = "";
      if (city.images && city.images.length > 0) {
        city.images.forEach(src => {
          const img = document.createElement("img");
          img.src = src; img.alt = isZh ? city.nameCN : city.name; img.loading = "lazy";
          imgEl.appendChild(img);
        });
      }

      const quoteEl = document.getElementById("story-quote");
      const quote = isZh ? (city.quoteCN || city.quote) : city.quote;
      quoteEl.textContent = quote ? `"${quote}"` : "";

      const detEl = document.getElementById("story-details");
      detEl.innerHTML = "";
      if (city.tastes && city.tastes.length > 0) {
        const row = document.createElement("div");
        row.className = "story-detail-row";
        const tasteText = city.tastes.map(t => isZh ? t.nameCN : t.name).join(" · ");
        row.innerHTML = `<span>🍜</span> <span>${isZh ? "味道推荐" : "Taste Picks"}：${tasteText}</span>`;
        detEl.appendChild(row);
      }
      if (city.picks && city.picks.length > 0) {
        const row = document.createElement("div");
        row.className = "story-detail-row";
        row.innerHTML = `<span>📍</span> ${city.picks.map(p => `<span class="story-pick-tag">${p}</span>`).join(" ")}`;
        detEl.appendChild(row);
      }

      // Extra visits from merged cities
      const extraVisits = _data && _data._visitMergeMap ? (_data._visitMergeMap[city.id] || []) : [];
      if (extraVisits.length > 0) {
        const divider = document.createElement("div");
        divider.style.cssText = "border-top:1px solid var(--travel-border);padding-top:0.75rem;margin-top:0.25rem;";
        const label = document.createElement("div");
        label.style.cssText = "font-size:0.68rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--travel-muted);margin-bottom:0.5rem;";
        label.textContent = isZh ? "历次到访" : "Previous Visits";
        divider.appendChild(label);
        extraVisits.forEach(v => {
          const vrow = document.createElement("div");
          vrow.style.cssText = "display:flex;flex-direction:column;gap:0.2rem;padding:0.5rem 0.75rem;border-radius:0.65rem;border:1px solid var(--travel-border);background:color-mix(in srgb,var(--travel-surface) 80%,transparent);margin-bottom:0.4rem;";
          const vtitle = document.createElement("div");
          vtitle.style.cssText = "font-size:0.82rem;font-weight:600;color:var(--travel-text);";
          vtitle.textContent = (isZh ? (v.yearCN || v.year) : v.year) || "";
          const vquote = document.createElement("div");
          vquote.style.cssText = "font-size:0.78rem;font-style:italic;color:var(--travel-soft);line-height:1.6;";
          vquote.textContent = (isZh ? (v.quoteCN || v.quote) : v.quote) || "";
          vrow.appendChild(vtitle);
          if (vquote.textContent) vrow.appendChild(vquote);
          divider.appendChild(vrow);
        });
        detEl.appendChild(divider);
      }
    };

    /* ---- Select city ---- */
    const selectCity = (cityId, isPrior) => {
      _selectedId = cityId;

      document.querySelectorAll(".year-city-item").forEach(n =>
        n.classList.toggle("is-active", n.dataset.cityId === cityId)
      );

      const allCities = [..._data.cities, ...(_data.priorCities || [])];
      const city = allCities.find(c => c.id === cityId);
      if (!city) return;

      // Dramatic fly: zoom out briefly then push into city
      const targetZoom = city.spots?.length ? 8 : 6.8;
      const currentZoom = _map.getZoom();
      if (Math.abs(_map.getCenter().lat - city.lat) > 3 || Math.abs(_map.getCenter().lng - city.lng) > 3) {
        _map.flyTo([city.lat, city.lng], targetZoom, { duration: 1.2, easeLinearity: 0.3 });
      } else {
        _map.flyTo([city.lat, city.lng], targetZoom, { duration: 0.8, easeLinearity: 0.5 });
      }

      _spotLayer.clearLayers();
      if (!isPrior && city.spots?.length) {
        city.spots.forEach(s => {
          const icon = L.divIcon({ html: spotSvg, className: "", iconSize: [18,18], iconAnchor: [9,9] });
          L.marker([s.lat, s.lng], { icon })
            .bindTooltip(`${s.nameCN} · ${s.name}`, { direction: "top", offset: [0,-8] })
            .addTo(_spotLayer);
        });
        if (city.spots.length > 1) {
          L.polyline(city.spots.map(s => [s.lat, s.lng]), {
            color: PURPLE, opacity: 0.32, weight: 1.5, dashArray: "4 7"
          }).addTo(_spotLayer);
        }
      }

      renderStoryCard(city, isPrior);
      openMapPanel();
    };

    /* ---- Year tab rendering ---- */
    const renderYearCities = (isZh) => {
      const citiesEl = document.getElementById("year-cities");
      if (!citiesEl) return;
      citiesEl.innerHTML = "";

      let citiesToShow = [];
      let isPriorGroup = false;

      if (_activeYear === "now") {
        citiesToShow = [..._data.cities].sort((a, b) => new Date(a.arrival) - new Date(b.arrival));
        isPriorGroup = false;
      } else {
        citiesToShow = (_data.priorCities || []).filter(c => extractYear(c.year) === _activeYear);
        isPriorGroup = true;
      }

      citiesToShow.forEach(city => {
        const item = document.createElement("div");
        item.className = `year-city-item${_selectedId === city.id ? " is-active" : ""}`;
        item.dataset.cityId = city.id;

        const dotClass = city.isCurrent ? "year-city-dot year-city-dot--current" : "year-city-dot";
        const nameText = isZh ? city.nameCN : city.name;
        let dateText = "";
        if (city.isCurrent) {
          dateText = isZh ? "当前城市" : "Current";
        } else if (isPriorGroup) {
          dateText = city.year || "";
        } else {
          dateText = fmtShort(city.arrival, isZh ? "zh" : "en");
        }

        item.innerHTML = `
          <div class="${dotClass}"></div>
          <div class="year-city-body">
            <span class="year-city-name">${nameText}</span>
            <span class="year-city-date">${dateText}</span>
          </div>
        `;
        item.addEventListener("click", () => selectCity(city.id, isPriorGroup));
        citiesEl.appendChild(item);
      });
    };

    const switchYear = (year) => {
      _activeYear = year;
      _selectedId = null;
      closeMapPanel();

      document.querySelectorAll(".year-tab").forEach(btn => {
        const active = btn.dataset.year === year;
        btn.classList.toggle("is-active", active);
        btn.setAttribute("aria-selected", active ? "true" : "false");
      });

      const isZh = getLang() === "zh";
      renderYearCities(isZh);

      // Fly to year's cities bounds
      if (_map) {
        const bounds = L.latLngBounds([]);
        const citiesToShow = year === "now"
          ? _data.cities
          : (_data.priorCities || []).filter(c => extractYear(c.year) === year);
        citiesToShow.forEach(c => bounds.extend([c.lat, c.lng]));
        if (bounds.isValid()) _map.flyToBounds(bounds.pad(0.3), { duration: 0.9 });
        _spotLayer.clearLayers();
      }
    };

    const buildYearTabs = () => {
      const lang = getLang();
      const isZh = lang === "zh";
      const tabsEl = document.getElementById("year-tabs");
      if (!tabsEl) return;

      // Gather unique start years from prior cities
      const priorCities = _data.priorCities || [];
      const yearSet = new Set(priorCities.map(c => extractYear(c.year)));
      const sortedYears = [...yearSet].sort((a, b) => a - b);

      tabsEl.innerHTML = "";

      sortedYears.forEach(yr => {
        const btn = document.createElement("button");
        btn.className = `year-tab${_activeYear === yr ? " is-active" : ""}`;
        btn.setAttribute("role", "tab");
        btn.setAttribute("aria-selected", _activeYear === yr ? "true" : "false");
        btn.dataset.year = yr;
        btn.textContent = yr;
        btn.addEventListener("click", () => switchYear(yr));
        tabsEl.appendChild(btn);
      });

      // "Now" tab (last, right side)
      const nowBtn = document.createElement("button");
      nowBtn.className = `year-tab year-tab--now${_activeYear === "now" ? " is-active" : ""}`;
      nowBtn.setAttribute("role", "tab");
      nowBtn.setAttribute("aria-selected", _activeYear === "now" ? "true" : "false");
      nowBtn.dataset.year = "now";
      nowBtn.textContent = isZh ? "游牧中" : "Now";
      nowBtn.addEventListener("click", () => switchYear("now"));
      tabsEl.appendChild(nowBtn);

      renderYearCities(isZh);
    };

    /* ---- Main init ---- */
    const initTravel = async () => {
      const mapNode = document.getElementById("travel-map");
      if (!mapNode || !window.L) return;
      if (mapNode.dataset.ready === "true") return;
      mapNode.dataset.ready = "true";

      _data = await fetch("/data/travel.json").then(r => r.json());
      const cities = _data.cities;
      const priorCities = _data.priorCities || [];

      // Pre-build visit merge map on _data for renderStoryCard
      _data._visitMergeMap = {};
      priorCities.forEach(c => {
        if (c.mergeInto) {
          if (!_data._visitMergeMap[c.mergeInto]) _data._visitMergeMap[c.mergeInto] = [];
          _data._visitMergeMap[c.mergeInto].push(c);
        }
      });
      const today = new Date();
      const startDate = new Date(_data.meta.startDate);
      const daysOnRoad = daysBetween(startDate, today);
      const totalDistance = cities.slice(1).reduce((s, c, i) => s + haversine(cities[i], c), 0);
      const citiesCovered = cities.length + priorCities.length;

      _currentCityItem = cities.find(c => c.id === _data.meta.currentCity) || cities[cities.length - 1];
      const longestStay  = cities.filter(c => c.stayDays).sort((a,b) => b.stayDays - a.stayDays)[0];
      const shortestStay = cities.filter(c => c.stayDays).sort((a,b) => a.stayDays - b.stayDays)[0];
      const libraries = cities.flatMap(c => c.spots||[]).filter(s => s.isLibrary).length;
      const allMeals = cities.filter(c => c.mealCN).map(c => `${c.nameCN} · ${c.mealCN}`);

      // Counter animation
      const fillCounter = (sel, val, suffix="") => {
        const node = document.querySelector(`[data-counter="${sel}"]`);
        if (!node) return;
        const dur = 1400, t0 = performance.now(), end = Number(val);
        const frame = (t) => {
          const p = Math.min(1, (t-t0)/dur);
          const e = 1 - Math.pow(1-p, 3);
          node.textContent = `${Math.round(end*e).toLocaleString()}${suffix}`;
          if (p < 1) requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      };
      fillCounter("cities", citiesCovered);
      fillCounter("days", daysOnRoad);
      fillCounter("distance", Math.round(totalDistance), " km");

      const el = id => document.getElementById(id);
      el("longest-stay").textContent       = longestStay ? `${longestStay.name} · ${longestStay.stayDays}d` : "—";
      el("longest-stay-note").textContent  = longestStay?.quoteCN || "";
      el("shortest-stay").textContent      = shortestStay ? `${shortestStay.name} · ${shortestStay.stayDays}d` : "—";
      el("shortest-stay-note").textContent = shortestStay?.quoteCN || "";
      el("libraries-found").textContent    = `${libraries}`;
      el("best-meal").textContent          = allMeals.slice(0,3).join(" / ");
      el("best-meal-note").textContent     = _currentCityItem?.mealCN
        ? `${_currentCityItem.nameCN} right now: ${_currentCityItem.mealCN}` : "";

      // Map init
      _map = L.map(mapNode, { zoomControl: true, attributionControl: true, preferCanvas: true })
               .setView([27.5, 106.1], 5.4);
      let tileLayer;
      const setTiles = () => {
        const dark = document.documentElement.getAttribute("data-theme") === "dark";
        if (tileLayer) tileLayer.remove();
        tileLayer = L.tileLayer(dark ? TILE_DARK : TILE_LIGHT, {
          subdomains: "abcd", maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
        }).addTo(_map);
      };
      setTiles();

      const routeLayer  = L.layerGroup().addTo(_map);
      const markerLayer = L.layerGroup().addTo(_map);
      _spotLayer        = L.layerGroup().addTo(_map);
      const priorLayer  = L.layerGroup().addTo(_map);
      const bounds = L.latLngBounds([]);
      _markerRefs = new Map();

      // Province lookup for prior cities (no province field in data)
      const PRIOR_PROVINCE = {
        "nanchang": "Jiangxi", "shangrao": "Jiangxi", "wuyuan": "Jiangxi", "ganzhou": "Jiangxi", "jian": "Jiangxi",
        "dongguan": "Guangdong", "humen": "Guangdong", "shenzhen": "Guangdong",
        "shanghai-life": "Shanghai", "shanghai-lucky": "Shanghai",
        "suzhou-2014": "Jiangsu", "suzhou-2023": "Jiangsu",
        "nanjing": "Jiangsu", "wuxi": "Jiangsu",
        "hongkong-macau": "Guangdong", "xiamen": "Fujian",
        "kunming": "Yunnan", "dali-first": "Yunnan",
        "yunhe": "Zhejiang", "sanya": "Hainan",
      };

      // Province count
      const provinceSet = new Set();
      cities.forEach(c => { if (c.province) provinceSet.add(c.province); });
      Object.values(PRIOR_PROVINCE).forEach(p => provinceSet.add(p));
      const provEl = document.getElementById("province-count");
      if (provEl) provEl.textContent = `across ${provinceSet.size} provinces`;

      // Longest leg between consecutive nomad cities
      const sortedForLeg = [...cities].sort((a,b) => new Date(a.arrival) - new Date(b.arrival));
      let maxDist = 0, legFrom = null, legTo = null;
      for (let i = 1; i < sortedForLeg.length; i++) {
        const d = haversine(sortedForLeg[i-1], sortedForLeg[i]);
        if (d > maxDist) { maxDist = d; legFrom = sortedForLeg[i-1]; legTo = sortedForLeg[i]; }
      }
      if (legFrom) {
        const legEl = document.getElementById("longest-leg");
        const legNoteEl = document.getElementById("longest-leg-note");
        if (legEl) legEl.textContent = `${Math.round(maxDist)} km`;
        if (legNoteEl) legNoteEl.textContent = `${legFrom.name} → ${legTo.name}`;
      }

      // Prior city markers — skip merged cities (rendered via primary)
      priorCities.forEach(city => {
        if (city.mergeInto) return; // skip, shown via primary marker
        bounds.extend([city.lat, city.lng]);
        const province = PRIOR_PROVINCE[city.id] || "default";
        const rc = getRegionColor(province);
        const icon = L.divIcon({
          html: markerSvg(false, false, rc.main),
          className: "", iconSize: [MARKER_SIZE, MARKER_SIZE], iconAnchor: [MARKER_CENTER, MARKER_CENTER]
        });
        const m = L.marker([city.lat, city.lng], { icon, keyboard: false }).addTo(priorLayer);
        m.on("mouseover", () => {
          const el = m.getElement();
          if (el) {
            const svg = el.querySelector("svg");
            if (svg) { svg.style.transform = "scale(1.18)"; svg.style.transition = "transform 0.2s ease"; }
            el.style.zIndex = "999";
          }
        });
        m.on("mouseout", () => {
          const el = m.getElement();
          if (el) {
            const svg = el.querySelector("svg");
            if (svg) { svg.style.transform = "scale(1)"; }
            el.style.zIndex = "";
          }
        });
        m.on("click", () => {
          const yr = extractYear(city.year);
          if (_activeYear !== yr) {
            switchYear(yr);
            setTimeout(() => selectCity(city.id, true), 200);
          } else {
            selectCity(city.id, true);
          }
        });
      });

      // Nomad city markers + animated route (region-colored)
      const sortedCities = [...cities].sort((a,b) => new Date(a.arrival) - new Date(b.arrival));
      const lineLatLngs = [];

      sortedCities.forEach((city, idx) => {
        bounds.extend([city.lat, city.lng]);
        setTimeout(() => {
          const rc = getRegionColor(city.province);
          const icon = L.divIcon({
            html: markerSvg(city.isCurrent, false, rc.main),
            className: "",
            iconSize: [MARKER_SIZE, MARKER_SIZE],
            iconAnchor: [MARKER_CENTER, MARKER_CENTER]
          });
          const m = L.marker([city.lat, city.lng], { icon }).addTo(markerLayer);

          // Hover glow ring
          const glowDiv = document.createElement("div");
          glowDiv.style.cssText = `position:absolute;width:44px;height:44px;border-radius:50%;background:${rc.glow};transform:scale(0);transition:transform 0.25s ease;pointer-events:none;top:0;left:0`;
          m.on("mouseover", () => {
            const el = m.getElement();
            if (el) {
              const svg = el.querySelector("svg");
              if (svg) { svg.style.transform = "scale(1.22)"; svg.style.transition = "transform 0.2s ease"; }
              el.style.zIndex = "999";
            }
          });
          m.on("mouseout", () => {
            const el = m.getElement();
            if (el) {
              const svg = el.querySelector("svg");
              if (svg) { svg.style.transform = "scale(1)"; }
              el.style.zIndex = "";
            }
          });

          m.on("click", () => {
            if (_activeYear !== "now") {
              switchYear("now");
              setTimeout(() => selectCity(city.id, false), 200);
            } else {
              selectCity(city.id, false);
            }
          });
          _markerRefs.set(city.id, m);

          // Colored route segment connecting to previous city
          const prevCity = sortedCities[idx - 1];
          lineLatLngs.push([city.lat, city.lng]);
          if (lineLatLngs.length > 1) {
            const segColor = prevCity ? getRegionColor(prevCity.province).main : PURPLE;
            const segment = L.polyline(lineLatLngs.slice(-2), {
              color: segColor, weight: 2.5, opacity: 0,
              dashArray: "7 11", lineCap: "round"
            }).addTo(routeLayer);
            // Animate route draw-in then flow
            segment.setStyle({ opacity: 0.72 });
            let dashOff = 0;
            const flowInterval = setInterval(() => { dashOff -= 0.5; segment.setStyle({ dashOffset: dashOff }); }, 50);
          }

          if (idx === sortedCities.length - 1) {
            // Auto-open current city story without flying (stay on full map view)
            setTimeout(() => {
              _selectedId = _currentCityItem.id;
              document.querySelectorAll(".year-city-item").forEach(n =>
                n.classList.toggle("is-active", n.dataset.cityId === _currentCityItem.id)
              );
              renderStoryCard(_currentCityItem, false);
              openMapPanel();
            }, 600);
          }
        }, 300 * idx + 160);
      });

      // Fit to nomad route only (not prior cities) for a tighter initial view
      const nomadBounds = L.latLngBounds([]);
      sortedCities.forEach(c => nomadBounds.extend([c.lat, c.lng]));
      if (nomadBounds.isValid()) {
        _map.fitBounds(nomadBounds.pad(0.25), { maxZoom: 6 });
      }

      // Panel close button
      document.getElementById("map-panel-close")?.addEventListener("click", closeMapPanel);

      // Build year tabs (default: "now")
      _activeYear = "now";
      buildYearTabs();

      // ---- Live Counter ----
      const counterEl = document.getElementById("live-counter");
      if (counterEl && _currentCityItem) {
        const updateCounter = () => {
          const now = new Date();
          const arr = new Date(_currentCityItem.arrival);
          const d = Math.floor((now - arr) / 86400000);
          const h = Math.floor(((now - arr) % 86400000) / 3600000);
          const m = Math.floor(((now - arr) % 3600000) / 60000);
          const s = Math.floor(((now - arr) % 60000) / 1000);
          const isZh = getLang() === "zh";
          counterEl.textContent = isZh
            ? `成都第 ${d}天 ${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`
            : `Day ${d} in Chengdu · ${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
        };
        counterEl.classList.add("is-visible");
        updateCounter();
        setInterval(updateCounter, 1000);
      }

      // ---- Next Stop Badge ----
      const nextBadge = document.getElementById("next-stop-badge");
      if (nextBadge) {
        const isZh = getLang() === "zh";
        const daysUntil = Math.ceil((new Date(NEXT_CITY.date) - new Date()) / 86400000);
        const inStr = daysUntil > 0
          ? (isZh ? `${daysUntil} 天后出发` : `in ${daysUntil} day${daysUntil===1?"":"s"}`)
          : (isZh ? "今天出发！" : "Today!");
        nextBadge.innerHTML = isZh
          ? `下一站 → <strong>${NEXT_CITY.nameCN}</strong> · ${inStr}`
          : `Next → <strong>${NEXT_CITY.name}</strong> · ${inStr}`;
        nextBadge.classList.add("is-visible");
        // Draw dashed preview line to Xi'an
        if (_currentCityItem) {
          L.polyline(
            [[_currentCityItem.lat, _currentCityItem.lng], [NEXT_CITY.lat, NEXT_CITY.lng]],
            { color: PURPLE, weight: 2, opacity: 0.38, dashArray: "4 9" }
          ).addTo(_map);
          const nextIcon = L.divIcon({
            html: `<svg width="44" height="44" viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg">
              <circle cx="22" cy="22" r="10" fill="${PURPLE}" opacity="0.08"/>
              <circle cx="22" cy="22" r="6" fill="none" stroke="${PURPLE}" stroke-width="2" stroke-dasharray="3 3" opacity="0.7"/>
            </svg>`,
            className: "", iconSize: [MARKER_SIZE, MARKER_SIZE], iconAnchor: [MARKER_CENTER, MARKER_CENTER]
          });
          const nextMarker = L.marker([NEXT_CITY.lat, NEXT_CITY.lng], { icon: nextIcon, interactive: false }).addTo(_map);
          const tooltip = isZh
            ? `<span style="color:${PURPLE};font-size:0.75rem">下一站 · ${NEXT_CITY.nameCN}</span>`
            : `<span style="color:${PURPLE};font-size:0.75rem">Next · ${NEXT_CITY.name}</span>`;
          nextMarker.bindTooltip(tooltip, { permanent: true, direction: "right", offset: [8, 0], className: "next-stop-tooltip" });
        }
      }

      // ---- Journey Replay ----
      const replayBtn = document.getElementById("replay-btn");
      const replayProgress = document.getElementById("replay-progress");
      const replayFill = document.getElementById("replay-fill");
      const replayLabel = document.getElementById("replay-label");
      const REPLAY_DELAY = 2200;

      const stopReplay = () => {
        _isReplaying = false;
        clearTimeout(_replayTimer);
        if (replayBtn) { replayBtn.textContent = "▶"; replayBtn.classList.remove("is-active"); }
        if (replayProgress) replayProgress.classList.remove("is-active");
      };

      // Build full chronological list: prior cities + nomad cities
      // Prior cities: extract start year from year string for sorting
      const parsePriorDate = (yearStr) => {
        if (!yearStr) return new Date(0);
        const m = yearStr.match(/(\d{4})-?(\d{2})?-?(\d{2})?/);
        if (!m) return new Date(0);
        return new Date(`${m[1]}-${m[2]||"01"}-${m[3]||"01"}`);
      };
      const allCitiesChron = [
        ...priorCities.filter(c => !c.mergeInto).map(c => ({ ...c, _isPrior: true, _sortDate: parsePriorDate(c.year) })),
        ...cities.map(c => ({ ...c, _isPrior: false, _sortDate: new Date(c.arrival) }))
      ].sort((a, b) => a._sortDate - b._sortDate);

      const replayStep = (idx, sorted) => {
        if (idx >= sorted.length) { stopReplay(); return; }
        const city = sorted[idx];
        const pct = Math.round(((idx + 1) / sorted.length) * 100);
        if (replayFill) replayFill.style.width = `${pct}%`;
        if (replayLabel) replayLabel.textContent = getLang() === "zh" ? city.nameCN : city.name;

        // Switch year tab to match
        if (city._isPrior) {
          const yr = extractYear(city.year);
          if (_activeYear !== yr) switchYear(yr);
          setTimeout(() => selectCity(city.id, true), _activeYear !== extractYear(city.year) ? 150 : 0);
        } else {
          if (_activeYear !== "now") switchYear("now");
          setTimeout(() => selectCity(city.id, false), 0);
        }
        _replayTimer = setTimeout(() => replayStep(idx + 1, sorted), REPLAY_DELAY);
      };

      if (replayBtn) {
        replayBtn.addEventListener("click", () => {
          if (_isReplaying) { stopReplay(); return; }
          _isReplaying = true;
          replayBtn.textContent = "⏸";
          replayBtn.classList.add("is-active");
          replayProgress.classList.add("is-active");
          replayFill.style.width = "0%";
          replayStep(0, allCitiesChron);
        });
      }

      // ---- City Boundary Highlights (GeoJSON) ----
      const PROVINCE_CODES = {
        530000: "Yunnan", 450000: "Guangxi", 350000: "Fujian", 510000: "Sichuan",
        500000: "Chongqing", 360000: "Jiangxi", 440000: "Guangdong", 310000: "Shanghai",
        320000: "Jiangsu", 460000: "Hainan", 330000: "Zhejiang"
      };
      const visitedCityNames = new Set([
        ...cities.map(c => c.nameCN),
        ...priorCities.filter(c => !c.mergeInto).map(c => c.nameCN)
      ]);
      const CITY_ALIASES = {
        "巍山": "大理", "阳朔": "桂林", "武夷山": "南平",
        "虎门": "东莞", "婺源": "上饶", "云和": "丽水",
        "腾冲": "保山",
      };
      const aliasParents = new Set();
      Object.entries(CITY_ALIASES).forEach(function(e) {
        if (visitedCityNames.has(e[0])) aliasParents.add(e[1]);
      });
      // Direct municipalities: if any city in this province was visited, light up ALL districts
      const MUNICIPALITY_PROVINCES = { "310000": "上海", "500000": "重庆" };
      const lightUpAllDistricts = new Set();
      Object.entries(MUNICIPALITY_PROVINCES).forEach(function(e) {
        if (visitedCityNames.has(e[1])) lightUpAllDistricts.add(e[0]);
      });

      // Also add region colors for provinces not yet defined
      if (!REGION_COLORS["Jiangxi"]) REGION_COLORS["Jiangxi"] = { main: "#f472b6", glow: "rgba(244,114,182,0.22)" };
      if (!REGION_COLORS["Guangdong"]) REGION_COLORS["Guangdong"] = { main: "#06b6d4", glow: "rgba(6,182,212,0.22)" };
      if (!REGION_COLORS["Shanghai"]) REGION_COLORS["Shanghai"] = { main: "#8b5cf6", glow: "rgba(139,92,246,0.22)" };
      if (!REGION_COLORS["Jiangsu"]) REGION_COLORS["Jiangsu"] = { main: "#14b8a6", glow: "rgba(20,184,166,0.22)" };
      if (!REGION_COLORS["Hainan"]) REGION_COLORS["Hainan"] = { main: "#f97316", glow: "rgba(249,115,22,0.22)" };
      if (!REGION_COLORS["Zhejiang"]) REGION_COLORS["Zhejiang"] = { main: "#22c55e", glow: "rgba(34,197,94,0.22)" };

      (async function() {
        for (var code in PROVINCE_CODES) {
          var provinceName = PROVINCE_CODES[code];
          try {
            var resp = await fetch("/data/geo/" + code + ".json");
            var geo = await resp.json();
            geo.features.forEach(function(feature) {
              var name = feature.properties.name;
              var visited = false;
              // For municipalities (Shanghai, Chongqing), light up all districts
              if (lightUpAllDistricts.has(String(code))) { visited = true; }
              // Normal city name matching
              if (!visited) visitedCityNames.forEach(function(cn) { if (name.indexOf(cn) !== -1) visited = true; });
              if (!visited) aliasParents.forEach(function(p) { if (name.indexOf(p) !== -1) visited = true; });
              if (visited) {
                var rc = getRegionColor(provinceName);
                L.geoJSON(feature, {
                  style: { fillColor: rc.main, fillOpacity: 0.13, weight: 1, color: rc.main, opacity: 0.3 },
                  onEachFeature: function(f, layer) {
                    layer.on("mouseover", function() { layer.setStyle({ fillOpacity: 0.25 }); });
                    layer.on("mouseout", function() { layer.setStyle({ fillOpacity: 0.13 }); });
                  }
                }).addTo(_map);
              }
            });
          } catch(e) { console.warn("GeoJSON failed:", code, e); }
        }
      })();

      // ---- Hero Parallax ----
      window.addEventListener("scroll", () => {
        const hero = document.querySelector(".travel-hero");
        if (hero) {
          const y = window.scrollY;
          hero.style.transform = `translateY(${y * 0.15}px)`;
          hero.style.opacity = Math.max(0, 1 - y / 600);
        }
      }, { passive: true });

      // ---- City Grid Stagger ----
      const triggerStagger = () => {
        const grid = document.getElementById("year-cities");
        if (!grid) return;
        const items = grid.querySelectorAll(".year-city-item");
        items.forEach((item, i) => {
          item.style.opacity = "0";
          item.style.transform = "translateY(12px)";
          item.style.transition = `opacity 0.4s ease ${i * 50}ms, transform 0.4s ease ${i * 50}ms`;
          setTimeout(() => { item.style.opacity = "1"; item.style.transform = "translateY(0)"; }, 50);
        });
      };
      // Trigger on initial load
      triggerStagger();
      // Re-trigger on tab switch (patch switchYear)
      const _origSwitchYear = switchYear;
      // switchYear already calls renderYearCities, add stagger after
      const yearCitiesEl = document.getElementById("year-cities");
      if (yearCitiesEl) {
        new MutationObserver(() => { setTimeout(triggerStagger, 30); }).observe(yearCitiesEl, { childList: true });
      }

      // Theme observer
      new MutationObserver(setTiles).observe(
        document.documentElement, { attributes: true, attributeFilter: ["data-theme"] }
      );

      // Lang observer
      new MutationObserver(() => {
        buildYearTabs();
        if (_selectedId) {
          const allCities = [..._data.cities, ...(_data.priorCities || [])];
          const city = allCities.find(c => c.id === _selectedId);
          const isPrior = (_data.priorCities || []).some(c => c.id === _selectedId);
          if (city) renderStoryCard(city, isPrior);
        }
      }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-lang"] });
    };

    initTravel();
    document.addEventListener("astro:page-load", () => {
      const mapNode = document.getElementById("travel-map");
      if (mapNode) mapNode.dataset.ready = "";
      _selectedId = null;
      _activeYear = null;
      initTravel();
    });
  </script>
</PageLayout>
