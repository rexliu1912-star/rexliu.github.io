---
import PageLayout from "@/layouts/Base.astro";

const investmentPhilosophies = [
  {
    titleEn: "Buy the Expectation, Sell the Fact",
    titleZh: "买预期，卖事实",
    bodyEn: [
      "Markets don't react to facts. They react to expectations about facts. By the time the news is out, the price has already moved.",
      "The real edge is acting before the market's expectation shifts — especially at inflection points.",
    ],
    bodyZh: [
      "行情是所有人预期的总和。价格变化的背后是预期的变化，不是事实本身。",
      "等消息出了再行动，那已经是事实了——价格变化只在那一瞬间。",
    ],
  },
  {
    titleEn: "Know Your Counterparty",
    titleZh: "研究对手盘",
    bodyEn: [
      "Before every trade, ask: whose money am I taking, and why can I take it? If you can't answer that, you are the counterparty.",
    ],
    bodyZh: [
      "每次交易前问自己：赚的是谁的钱？为什么能赚到？答不上来，你就是那个对手盘。",
    ],
  },
  {
    titleEn: "Wins and Losses Share the Same Root",
    titleZh: "盈亏同源",
    bodyEn: [
      "Every trading framework has a cost. The same system that produces your best wins will also produce your worst losses. Accept the framework's losses. Pursue big wins and small losses — not perfection.",
    ],
    bodyZh: [
      "让你赚钱的框架，也会让你亏钱。接受框架自带的亏损，追求大赚小赔，不追求完美。",
    ],
  },
  {
    titleEn: "Express Late, Act Decisive",
    titleZh: "学会晚表态",
    bodyEn: [
      "Don't rush to have an opinion. Wait until the fog clears and you can play your cards face-up. The best trades come from patience, not speed.",
    ],
    bodyZh: [
      "不急着表态。等局势明朗、可以打明牌的时候再出手。最好的交易来自耐心，不是速度。",
    ],
  },
  {
    titleEn: "Always Keep a Card in Reserve",
    titleZh: "含苞待放",
    bodyEn: [
      "A bud opening is an upward process. You always hold something back. Your last card stays hidden — that's what keeps you safe. The moment you go all-in, you're exposed.",
    ],
    bodyZh: [
      "含苞待放是一个向上的过程。你始终留有后手，始终留有底牌。底牌不出你才是安全的，底牌出尽，你就置身险境了。",
    ],
  },
  {
    titleEn: "Conviction is Gold",
    titleZh: "信心就是黄金",
    bodyEn: [
      "The ideal state: palms slightly sweaty during the day, sleeping soundly at night. If you can't sleep, the position is too big. If you feel nothing, the position is too small.",
    ],
    bodyZh: [
      "理想交易状态：手心微出汗，晚上睡得香。睡不着说明仓位太重，毫无感觉说明仓位太轻。",
    ],
  },
];

const contentPillars = [
  {
    en: "AI & Vibe Coding — Building in public with AI tools",
    zh: "AI & Vibe Coding — 用 AI 工具公开造东西",
  },
  {
    en: "Crypto Analysis — On-chain data, macro cycles, pattern recognition",
    zh: "加密分析 — 链上数据、宏观周期、模式识别",
  },
  {
    en: "Investment Philosophy — Frameworks over predictions",
    zh: "投资哲学 — 框架大于预测",
  },
  {
    en: "Lifestyle — Digital nomad life, family, travel",
    zh: "生活方式 — 数字游牧、家庭、旅行",
  },
  {
    en: "X Growth — What works, what doesn't, transparent metrics",
    zh: "X 增长 — 有用无用皆有、透明数据",
  },
];

const writingRules = [
  {
    en: "Data from real experience only. Never fabricate.",
    zh: "数据只用真实经历，不编造。",
  },
  {
    en: "Build in public — name the tools, show the process.",
    zh: "Build in Public——点名工具和项目，不藏着。",
  },
  {
    en: "Direct over literary. Cut anything that sounds clever but says nothing.",
    zh: "直接大于词藻。砍掉一切听起来聪明但没内容的话。",
  },
];

const lifeQuestions = [
  {
    en: "What do I have?",
    zh: "我有什么？",
  },
  {
    en: "What do I want?",
    zh: "我要什么？",
  },
  {
    en: "What am I willing to give up?",
    zh: "我愿意付出什么？",
  },
];

const relationshipPoints = [
  {
    en: "Conflict comes from expectations. Disappointment drives change.",
    zh: "矛盾源于期待，失望才会改变。",
  },
  {
    en: "Parents see their child frozen at age 10. Children see their parents frozen at age 20.",
    zh: "父母看孩子停留在 10 岁前，孩子看父母停留在 20 岁后。",
  },
  {
    en: "Love → hustle → family bond → trust. Relationships evolve. Let them.",
    zh: "爱情→打拼→亲情→信任，关系会随时间演变。",
  },
  {
    en: "Do your own work well — that's duty. Everything else is a bonus.",
    zh: "做好自己的事是本分，其他都是福分。",
  },
];

const stackGroups = [
  {
    labelEn: "Writing",
    labelZh: "写作",
    valueEn: "AI Agent team (Loki) + Rex Ink voice system",
    valueZh: "AI Agent 团队（Loki）+ Rex Ink 系统",
  },
  {
    labelEn: "Research",
    labelZh: "研究",
    valueEn: "Alpha Radar + KOL tracking + 6551 API",
    valueZh: "Alpha Radar + KOL 追踪 + 6551 API",
  },
  {
    labelEn: "Building",
    labelZh: "架构",
    valueEn: "Astro + Tailwind + Cloudflare (Pages, R2, Workers)",
    valueZh: "Astro + Tailwind + Cloudflare（Pages, R2, Workers）",
  },
  {
    labelEn: "Operations",
    labelZh: "运营",
    valueEn: "OpenClaw + 30+ automated cron jobs",
    valueZh: "OpenClaw + 30+ 自动化定时任务",
  },
  {
    labelEn: "Finance",
    labelZh: "理财",
    valueEn: "Multi-exchange portfolio sync",
    valueZh: "多交易所组合同步",
  },
];

const meta = {
  title: "Operating System — Rex Liu",
  description: "How Rex thinks about investing, content, and life.",
};
---

<PageLayout meta={meta}>
  <section class="fade-in-up os-hero relative overflow-hidden rounded-[2rem] border border-white/10 bg-[#0d0d14] px-6 py-14 sm:px-10 sm:py-20">
    <div class="os-glow os-glow-top"></div>
    <div class="os-glow os-glow-side"></div>

    <p class="mb-4 font-serif text-xs font-semibold tracking-[0.35em] text-[#b99af0] uppercase">
      Rex's Operating System
    </p>

    <h1 class="max-w-4xl font-serif text-4xl leading-tight font-semibold text-white sm:text-5xl md:text-6xl">
      <span class="lang-en">This is not an about page. It's how I think.</span>
      <span class="lang-zh">这不是一个关于我的页面。这是我的思考方式。</span>
    </h1>

    <p class="mt-6 max-w-2xl font-serif text-base leading-8 text-white/66 sm:text-lg">
      <span class="lang-en">Investing, content, life, and the stack behind all of it — reduced into a system I can repeat.</span>
      <span class="lang-zh">投资、内容、人生，以及支撑它们运转的工具栈——被我压缩成一套可以重复运行的系统。</span>
    </p>
  </section>

  <section class="fade-in-up mt-14" style="--delay: 80ms">
    <div class="mb-8 flex items-end justify-between gap-4 border-b border-white/10 pb-5">
      <div>
        <p class="os-kicker"><span class="lang-en">Investment OS</span><span class="lang-zh">投资操作系统</span></p>
        <h2 class="mt-3 font-serif text-3xl text-white sm:text-4xl">
          <span class="lang-en">Frameworks that protect edge.</span>
          <span class="lang-zh">保护优势的交易框架。</span>
        </h2>
      </div>
    </div>

    <div class="grid gap-4">
      {investmentPhilosophies.map((item, index) => (
        <details class="os-detail fade-in-up group" style={`--delay: ${120 + index * 60}ms`}>
          <summary class="os-detail-summary">
            <div>
              <p class="font-serif text-[11px] tracking-[0.28em] text-[#b99af0] uppercase">0{index + 1}</p>
              <h3 class="mt-2 font-serif text-xl text-white sm:text-2xl">
                <span class="lang-en">{item.titleEn}</span>
                <span class="lang-zh">{item.titleZh}</span>
              </h3>
            </div>
            <span class="os-detail-icon" aria-hidden="true"></span>
          </summary>

          <div class="os-detail-body">
            <div class="space-y-4 font-serif text-base leading-8 text-white/72">
              <div class="lang-en space-y-4">
                {item.bodyEn.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="lang-zh space-y-4">
                {item.bodyZh.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="mt-20">
    <div class="fade-in-up mb-10 border-b border-white/10 pb-5" style="--delay: 120ms">
      <p class="os-kicker"><span class="lang-en">Content OS</span><span class="lang-zh">内容操作系统</span></p>
      <h2 class="mt-3 font-serif text-3xl text-white sm:text-4xl">
        <span class="lang-en">What I publish, and the rules behind it.</span>
        <span class="lang-zh">我输出什么，以及我遵守的规则。</span>
      </h2>
    </div>

    <div class="fade-in-up" style="--delay: 160ms">
      <h3 class="mb-5 font-serif text-lg tracking-wide text-white/72">
        <span class="lang-en">5 Pillars</span><span class="lang-zh">五大支柱</span>
      </h3>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {contentPillars.map((pillar, index) => (
          <article class="os-card fade-in-up" style={`--delay: ${200 + index * 60}ms`}>
            <span class="os-card-index">0{index + 1}</span>
            <p class="mt-5 font-serif text-lg leading-8 text-white/86">
              <span class="lang-en">{pillar.en}</span>
              <span class="lang-zh">{pillar.zh}</span>
            </p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="os-card fade-in-up" style="--delay: 260ms">
        <h3 class="font-serif text-xl text-white">
          <span class="lang-en">Writing Rules</span><span class="lang-zh">写作规则</span>
        </h3>
        <ul class="mt-5 space-y-4 font-serif text-base leading-8 text-white/72">
          {writingRules.map((rule) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#8953d1]"></span>
              <span>
                <span class="lang-en">{rule.en}</span>
                <span class="lang-zh">{rule.zh}</span>
              </span>
            </li>
          ))}
        </ul>
      </article>

      <article class="os-card fade-in-up" style="--delay: 320ms">
        <h3 class="font-serif text-xl text-white">
          <span class="lang-en">The Team</span><span class="lang-zh">团队</span>
        </h3>
        <div class="mt-5 space-y-5 font-serif text-base leading-8 text-white/72">
          <div>
            <p class="lang-en">I run a 6-agent AI team. They write drafts, track KOLs, analyze data, design images, and manage operations — 24/7.</p>
            <p class="lang-zh">我有一个 6 人 AI Agent 团队。他们写草稿、追踪 KOL、分析数据、设计配图、管理运营——全天候运行。</p>
          </div>
          <p class="os-team-line">
            <span class="lang-en">Samantha (brain) · Loki (writer) · Vision (researcher) · Jarvis (coder) · Shuri (designer) · Friday (analyst)</span>
            <span class="lang-zh">Samantha（主脑）· Loki（写手）· Vision（研究员）· Jarvis（程序员）· Shuri（设计师）· Friday（分析师）</span>
          </p>
          <p>
            <span class="lang-en">I make the decisions. They do the work.</span>
            <span class="lang-zh">我做决策，他们干活。</span>
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="mt-20">
    <div class="fade-in-up mb-10 border-b border-white/10 pb-5" style="--delay: 140ms">
      <p class="os-kicker"><span class="lang-en">Life OS</span><span class="lang-zh">人生操作系统</span></p>
      <h2 class="mt-3 font-serif text-3xl text-white sm:text-4xl">
        <span class="lang-en">Reduce noise. Keep the questions.</span>
        <span class="lang-zh">降低噪音，留下最重要的问题。</span>
      </h2>
    </div>

    <article class="fade-in-up os-panel-center" style="--delay: 200ms">
      <p class="mb-8 font-serif text-sm tracking-[0.3em] text-[#b99af0] uppercase">
        <span class="lang-en">Three Questions</span><span class="lang-zh">三个问题</span>
      </p>
      <div class="space-y-5">
        {lifeQuestions.map((question, index) => (
          <p class="font-serif text-3xl leading-tight text-white sm:text-4xl md:text-5xl" style={`opacity:${1 - index * 0.08}`}>
            <span class="lang-en">{question.en}</span>
            <span class="lang-zh">{question.zh}</span>
          </p>
        ))}
      </div>
      <p class="mt-10 font-serif text-base leading-8 text-white/66">
        <span class="lang-en">Every major decision passes through these three filters.</span>
        <span class="lang-zh">每一个重大决策都过这三个滤网。</span>
      </p>
    </article>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <article class="os-card fade-in-up" style="--delay: 260ms">
        <h3 class="font-serif text-xl text-white">
          <span class="lang-en">Simplify, Then Repeat</span><span class="lang-zh">复杂问题简单化</span>
        </h3>
        <div class="mt-5 space-y-4 font-serif text-base leading-8 text-white/72">
          <p class="lang-en">Simplify the complex. Repeat the simple. Build your framework, then run it over and over. The people who win long-term aren't the smartest — they're the most consistent.</p>
          <p class="lang-zh">复杂问题简单化，简单事情重复做。建立自己的框架，然后不断重复。长期赢的人不是最聪明的，是最稳定的。</p>
        </div>
      </article>

      <article class="os-card fade-in-up" style="--delay: 320ms">
        <h3 class="font-serif text-xl text-white">
          <span class="lang-en">Relationships</span><span class="lang-zh">关系</span>
        </h3>
        <ul class="mt-5 space-y-4 font-serif text-base leading-8 text-white/72">
          {relationshipPoints.map((point) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#8953d1]"></span>
              <span>
                <span class="lang-en">{point.en}</span>
                <span class="lang-zh">{point.zh}</span>
              </span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="mt-20">
    <div class="fade-in-up mb-10 border-b border-white/10 pb-5" style="--delay: 160ms">
      <p class="os-kicker"><span class="lang-en">Stack</span><span class="lang-zh">工具栈</span></p>
      <h2 class="mt-3 font-serif text-3xl text-white sm:text-4xl">
        <span class="lang-en">The infrastructure behind the thinking.</span>
        <span class="lang-zh">思考方式背后的基础设施。</span>
      </h2>
    </div>

    <div class="grid gap-4">
      {stackGroups.map((item, index) => (
        <article class="os-stack-row fade-in-up" style={`--delay: ${220 + index * 50}ms`}>
          <div class="os-stack-label">
            <span class="lang-en">{item.labelEn}</span>
            <span class="lang-zh">{item.labelZh}</span>
          </div>
          <div class="os-stack-value">
            <span class="lang-en">{item.valueEn}</span>
            <span class="lang-zh">{item.valueZh}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="fade-in-up mt-20 mb-8 text-center" style="--delay: 420ms">
    <p class="os-signature">Stay Invested in the Game. 🐍</p>
  </section>

  <style>
    :global(body) {
      background:
        radial-gradient(circle at top, rgba(137, 83, 209, 0.12), transparent 32%),
        linear-gradient(180deg, #08080d 0%, #0b0b13 40%, #09090f 100%);
    }

    :global(main[data-pagefind-body]) {
      position: relative;
    }

    .os-hero,
    .os-card,
    .os-detail,
    .os-panel-center,
    .os-stack-row {
      background: linear-gradient(180deg, rgba(20, 20, 31, 0.94) 0%, rgba(11, 11, 18, 0.96) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.34),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .os-glow {
      position: absolute;
      border-radius: 9999px;
      filter: blur(80px);
      pointer-events: none;
    }

    .os-glow-top {
      top: -3rem;
      right: -2rem;
      height: 12rem;
      width: 12rem;
      background: rgba(137, 83, 209, 0.22);
    }

    .os-glow-side {
      bottom: -4rem;
      left: 15%;
      height: 10rem;
      width: 10rem;
      background: rgba(137, 83, 209, 0.12);
    }

    .os-kicker {
      font-family: Georgia, serif;
      font-size: 0.78rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: #b99af0;
    }

    .os-card {
      position: relative;
      overflow: hidden;
      border-radius: 1.5rem;
      padding: 1.6rem;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .os-card:hover,
    .os-stack-row:hover,
    .os-detail:hover {
      transform: translateY(-4px) scale(1.005);
      border-color: rgba(137, 83, 209, 0.45);
      box-shadow:
        0 24px 80px rgba(0, 0, 0, 0.5),
        0 0 0 1px rgba(137, 83, 209, 0.2),
        0 0 40px rgba(137, 83, 209, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }

    .os-card-index {
      display: inline-flex;
      min-width: 2.5rem;
      align-items: center;
      justify-content: center;
      border-radius: 9999px;
      border: 1px solid rgba(137, 83, 209, 0.35);
      background: rgba(137, 83, 209, 0.1);
      padding: 0.4rem 0.75rem;
      font-family: Georgia, serif;
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      color: #cfbbf6;
    }

    .os-detail {
      border-radius: 1.5rem;
      overflow: hidden;
      transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    }

    .os-detail-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      cursor: pointer;
      list-style: none;
      padding: 1.35rem 1.5rem;
    }

    .os-detail-summary::-webkit-details-marker {
      display: none;
    }

    .os-detail-icon {
      position: relative;
      display: inline-flex;
      height: 2.5rem;
      width: 2.5rem;
      flex-shrink: 0;
      border-radius: 9999px;
      border: 1px solid rgba(137, 83, 209, 0.28);
      background: rgba(137, 83, 209, 0.08);
    }

    .os-detail-icon::before,
    .os-detail-icon::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      background: #c8aff5;
      transform: translate(-50%, -50%);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .os-detail-icon::before {
      height: 2px;
      width: 14px;
    }

    .os-detail-icon::after {
      height: 14px;
      width: 2px;
    }

    .os-detail[open] .os-detail-icon::after {
      transform: translate(-50%, -50%) rotate(90deg);
      opacity: 0;
    }

    .os-detail-body {
      padding: 0 1.5rem 1.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      animation: os-slide-down 0.3s ease-out;
    }

    @keyframes os-slide-down {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .os-detail[open] {
      border-color: rgba(137, 83, 209, 0.3);
      box-shadow: 0 0 30px rgba(137, 83, 209, 0.06);
    }

    .os-team-line {
      color: #fff;
      font-size: 1.02rem;
      line-height: 1.9;
    }

    .os-panel-center {
      border-radius: 2rem;
      padding: 3rem 1.5rem;
      text-align: center;
    }

    .os-stack-row {
      display: grid;
      gap: 1rem;
      border-radius: 1.25rem;
      padding: 1.2rem 1.25rem;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .os-stack-label {
      font-family: Georgia, serif;
      font-size: 0.82rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #b99af0;
    }

    .os-stack-value {
      font-family: Georgia, serif;
      font-size: 1rem;
      line-height: 1.9;
      color: rgba(255, 255, 255, 0.8);
    }

    .os-signature {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 4vw, 3.75rem);
      font-style: italic;
      letter-spacing: 0.02em;
      color: rgba(255, 255, 255, 0.95);
      text-shadow: 0 0 28px rgba(137, 83, 209, 0.22);
      animation: os-pulse-glow 4s ease-in-out infinite alternate;
    }

    @keyframes os-pulse-glow {
      0% { text-shadow: 0 0 28px rgba(137, 83, 209, 0.15); }
      100% { text-shadow: 0 0 48px rgba(137, 83, 209, 0.35), 0 0 12px rgba(137, 83, 209, 0.1); }
    }

    /* Smooth section divider glow */
    section + section::before {
      content: "";
      display: block;
      width: 60px;
      height: 1px;
      margin: 0 auto 2rem;
