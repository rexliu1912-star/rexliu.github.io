---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";
import booksData from "@/data/books.json";

// Fetch essays for cross-links
const allPosts = await getCollection("post");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf(),
);

// Investment essays: must have a "hard" investment tag, exclude pure-life posts
const investmentHardTags = new Set(["investment", "wealth", "framework", "alpha", "evergreen"]);
const investmentSoftTags = new Set(["crypto", "macro"]);
const lifePureTags = new Set(["life", "reflection", "family", "people", "mental health", "entertainment", "travel"]);

const investmentEssays = sortedPosts
  .filter(p => {
    const tags = (p.data.tags || []).map((t: string) => t.toLowerCase());
    const hasHard = tags.some(t => investmentHardTags.has(t));
    const hasSoft = tags.some(t => investmentSoftTags.has(t));
    const isOnlyLife = tags.every(t => lifePureTags.has(t));
    return (hasHard || (hasSoft && !isOnlyLife)) && !isOnlyLife;
  })
  .slice(0, 3);

// Life essays: primarily about life, exclude investment-heavy posts
const lifeHardTags = new Set(["life", "reflection", "family", "people", "mental health"]);
const investmentExclude = new Set(["investment", "wealth", "framework", "alpha", "evergreen"]);

const lifeEssays = sortedPosts
  .filter(p => {
    const tags = (p.data.tags || []).map((t: string) => t.toLowerCase());
    const hasLife = tags.some(t => lifeHardTags.has(t));
    const hasInvestment = tags.some(t => investmentExclude.has(t));
    return hasLife && !hasInvestment;
  })
  .slice(0, 3);

function formatShortDate(date: Date) {
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

const investmentPhilosophies = [
  {
    titleEn: "Buy the Expectation, Sell the Fact",
    titleZh: "买预期，卖事实",
    bodyEn: "Markets don't react to facts. They react to expectations about facts. By the time the news is out, the price has already moved. The real edge is acting before the market's expectation shifts.",
    bodyZh: "行情是所有人预期的总和，价格变化的背后是预期的变化，不是事实本身。等消息出了再行动，那已经是事实了——价格变化只在那一瞬间。",
  },
  {
    titleEn: "Know Your Counterparty",
    titleZh: "研究对手盘",
    bodyEn: "Before every trade, ask: whose money am I taking, and why can I take it? If you can't answer that, you are the counterparty.",
    bodyZh: "每次交易前问自己：赚的是谁的钱？为什么能赚到？答不上来，你就是那个对手盘。",
  },
  {
    titleEn: "Wins and Losses Share the Same Root",
    titleZh: "盈亏同源",
    bodyEn: "Every trading framework has a cost. The same system that produces your best wins will also produce your worst losses. Accept the framework's losses. Pursue big wins and small losses — not perfection.",
    bodyZh: "让你赚钱的框架，也会让你亏钱，接受框架自带的亏损，追求大赚小赔，不追求完美。",
  },
  {
    titleEn: "Express Late, Act Decisive",
    titleZh: "学会晚表态",
    bodyEn: "Don't rush to have an opinion. Wait until the fog clears and you can play your cards face-up. The best trades come from patience, not speed.",
    bodyZh: "不急着表态。等局势明朗、可以打明牌的时候再出手。最好的交易来自耐心，不是速度。",
  },
  {
    titleEn: "Always Keep a Card in Reserve",
    titleZh: "永远有底牌",
    bodyEn: "A bud opening is an upward process. You always hold something back. Your last card stays hidden — that's what keeps you safe. The moment you go all-in, you're exposed.",
    bodyZh: "含苞待放是一个向上的过程。你始终留有后手，始终留有底牌。底牌不出你才是安全的，底牌出尽，你就置身险境了。",
  },
  {
    titleEn: "Conviction is Gold",
    titleZh: "信心就是黄金",
    bodyEn: "The ideal state: palms slightly sweaty during the day, sleeping soundly at night. If you can't sleep, the position is too big. If you feel nothing, the position is too small.",
    bodyZh: "理想交易状态：手心微出汗，晚上睡得香。睡不着说明仓位太重，毫无感觉说明仓位太轻。",
  },
];

const contentPillars = [
  { en: "AI & Vibe Coding", zh: "AI & Vibe Coding", desc_en: "Building in public with AI tools", desc_zh: "用 AI 工具公开创造", posts: ["2026-04-07-losing-claude-on-openclaw", "2026-03-19-stay-human-01-ai-coding-is-gambling", "obsidian-openclaw-knowledge-system"] },
  { en: "Crypto Analysis", zh: "加密分析", desc_en: "On-chain data, macro cycles, pattern recognition", desc_zh: "链上数据、宏观周期、模式识别", posts: ["2026-02-25-alpha-radar-framework", "hype-investment-thesis", "kol-stance-tracker"] },
  { en: "Investment Philosophy", zh: "投资哲学", desc_en: "Frameworks over predictions", desc_zh: "框架大于预测", posts: ["gold-etf-trade-review", "2026-wealth-strategy", "xifeng-reading-reflection"] },
  { en: "Lifestyle", zh: "生活方式", desc_en: "Digital nomad life, family, travel", desc_zh: "数字游民、家庭、旅行", posts: ["travel-in-dali", "2026-02-15-watching-mother-fade", "12-years-annual-review-ai"] },
  { en: "X Growth", zh: "X 增长", desc_en: "What works, what doesn't, transparent metrics", desc_zh: "有用无用皆有、透明数据", posts: ["how-I-hit-5-million-impressions-in-24-hours", "my-x-growth"] },
];

const writingRules = [
  { en: "Data from real experience only. Never fabricate.", zh: "数据只用真实经历，不编造。" },
  { en: "Build in public — name the tools, show the process.", zh: "Build in Public——点名工具和项目，不藏着。" },
  { en: "Direct over literary. Cut anything that sounds clever but says nothing.", zh: "直接大于词藻。砍掉一切听起来聪明但没内容的话。" },
];

const lifeQuestions = [
  { en: "What do I have?", zh: "我有什么？" },
  { en: "What do I want?", zh: "我要什么？" },
  { en: "What am I willing to give up?", zh: "我愿意付出什么？" },
];

const relationshipPoints = [
  { en: "Conflict comes from expectations. Disappointment drives change.", zh: "矛盾源于期待，失望才会改变。" },
  { en: "Parents see their child frozen at age 10. Children see their parents frozen at age 20.", zh: "父母看孩子停留在 10 岁前，孩子看父母停留在 20 岁后。" },
  { en: "Love → hustle → family bond → trust. Relationships evolve. Let them.", zh: "爱情→打拼→亲情→信任，关系会随时间演变。" },
  { en: "Do your own work well — that's duty. Everything else is a bonus.", zh: "做好自己的事是本分，其他都是福分。" },
];

const stackGroups = [
  { label_en: "AI Team", label_zh: "AI 团队", value_en: "6 specialized agents — writing, research, code, design, data, coordination", value_zh: "6 个专职 Agent — 写作、研究、开发、设计、数据、协调", link: "/lab/agents/", linkEn: "Watch them work →", linkZh: "看他们工作 →" },
  { label_en: "Writing", label_zh: "写作", value_en: "AI Agent team (Loki) + Rex Ink voice system", value_zh: "AI Agent 团队（Loki）+ Rex Ink 系统" },
  { label_en: "Research", label_zh: "研究", value_en: "Alpha Radar + KOL tracking + 6551 API", value_zh: "Alpha Radar + KOL 追踪 + 6551 API" },
  { label_en: "Building", label_zh: "架构", value_en: "Astro + Tailwind + Cloudflare (Pages, R2, Workers)", value_zh: "Astro + Tailwind + Cloudflare（Pages, R2, Workers）" },
  { label_en: "Operations", label_zh: "运营", value_en: "Hermes + 30+ automated cron jobs", value_zh: "Hermes + 30+ 自动化定时任务", link: "/lab/builder-log/", linkEn: "See the build log →", linkZh: "查看构建日志 →" },
  { label_en: "Finance", label_zh: "理财", value_en: "Multi-exchange portfolio sync", value_zh: "多交易所组合同步" },
];

const meta = {
  title: "Operating System — Rex Liu",
  description: "How Rex thinks about investing, content, and life.",
};

// Build post lookup for content pillar links
const postMap = new Map(sortedPosts.map(p => [p.id, p]));

// Recent finished books
const recentBooks = (booksData as any[])
  .filter(b => b.endDate && (b.status === "done" || b.status === "已读" || b.status === "read"))
  .sort((a, b) => new Date(b.endDate).getTime() - new Date(a.endDate).getTime())
  .slice(0, 3);
---

<PageLayout meta={meta}>
  <section class="mb-12">
    <h1 class="hero-reveal-text mb-4 font-serif text-4xl font-bold dark:text-white">
      <span class="lang-en">Operating System</span>
      <span class="lang-zh">操作系统</span>
    </h1>
    <p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      <span class="lang-en">This is not an about page. It's how I think.</span>
      <span class="lang-zh">不为「关于」，只为「思考」。</span>
    </p>
    <p class="hero-reveal-subtitle max-w-2xl font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400">
      <span class="lang-en">Investing, content, life, and the stack behind all of it — reduced into a system I can repeat.</span>
      <span class="lang-zh">投资、内容、人生，以及支撑它们运转的工具栈——被我压缩成一套可以重复运行的系统。</span>
    </p>
  </section>

  <!-- Investment OS -->
  <section class="mb-16">
    <h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
      <span class="lang-en">Investment OS</span>
      <span class="lang-zh">投资操作系统</span>
    </h2>
    <p class="fade-in-up mb-8 font-serif text-2xl font-semibold dark:text-white" style="--delay: 140ms">
      <span class="lang-en">Frameworks that protect edge.</span>
      <span class="lang-zh">保护优势的交易框架。</span>
    </p>

    <div class="space-y-6">
      {investmentPhilosophies.map((item, index) => (
        <details class="fade-in-up group" style={`--delay: ${180 + index * 50}ms`}>
          <summary class="flex cursor-pointer items-center justify-between py-3 font-serif transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]">
            <div class="flex items-baseline gap-3">
              <span class="text-xs text-gray-400 dark:text-gray-500">0{index + 1}</span>
              <h3 class="text-lg font-medium">
                <span class="lang-en">{item.titleEn}</span>
                <span class="lang-zh">{item.titleZh}</span>
              </h3>
            </div>
            <span class="os-toggle text-gray-400 transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="os-expand-body pb-4 pl-8 pr-4 font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400">
            <p class="lang-en">{item.bodyEn}</p>
            <p class="lang-zh">{item.bodyZh}</p>
          </div>
        </details>
      ))}
    </div>

    {investmentEssays.length > 0 && (
      <div class="fade-in-up mt-10 border-t border-gray-200/60 pt-6 dark:border-gray-700/40" style="--delay: 500ms">
        <p class="mb-4 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
          <span class="lang-en">These ideas in practice</span>
          <span class="lang-zh">这些理念的实践</span>
        </p>
        <div class="space-y-3">
          {investmentEssays.map((p) => (
            <a href={`/posts/${p.id}/`} class="group flex items-baseline justify-between gap-4 font-serif text-sm transition-colors">
              <span class="text-gray-600 group-hover:text-[#8953d1] dark:text-gray-400 dark:group-hover:text-[#a175e8]">{p.data.title}</span>
              <time datetime={p.data.publishDate.toISOString()} class="shrink-0 text-xs text-gray-400 dark:text-gray-500">{formatShortDate(p.data.publishDate)}</time>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="fade-in-up mt-8 rounded-xl border border-gray-200/60 bg-gray-50/50 p-6 dark:border-gray-700/40 dark:bg-[#151515]" style="--delay: 550ms">
      <a href="/portfolio/" class="group flex items-center justify-between font-serif">
        <div>
          <p class="mb-1 text-xs font-bold tracking-widest text-[#8953d1] uppercase dark:text-[#a175e8]">
            <span class="lang-en">Live Portfolio</span>
            <span class="lang-zh">实盘持仓</span>
          </p>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <span class="lang-en">See how these frameworks play out in real positions →</span>
            <span class="lang-zh">看看这些框架在真实持仓中如何运作 →</span>
          </p>
        </div>
        <span class="text-2xl text-gray-300 transition-transform group-hover:translate-x-1 dark:text-gray-600">→</span>
      </a>
    </div>
  </section>

  <!-- Content OS -->
  <section class="mb-16">
    <h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
      <span class="lang-en">Content OS</span>
      <span class="lang-zh">内容操作系统</span>
    </h2>
    <p class="fade-in-up mb-8 font-serif text-2xl font-semibold dark:text-white" style="--delay: 140ms">
      <span class="lang-en">What I publish, and the rules behind it.</span>
      <span class="lang-zh">我输出什么，以及我遵守的规则。</span>
    </p>

    <div class="fade-in-up mb-10" style="--delay: 180ms">
      <h3 class="mb-4 font-serif text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">
        <span class="lang-en">5 Pillars</span>
        <span class="lang-zh">五大支柱</span>
      </h3>
      <div class="space-y-6">
        {contentPillars.map((pillar, index) => (
          <div class="fade-in-up" style={`--delay: ${220 + index * 40}ms`}>
            <div class="flex items-baseline gap-3 font-serif">
              <span class="text-xs text-gray-400 dark:text-gray-500">0{index + 1}</span>
              <div>
                <span class="font-medium dark:text-white">
                  <span class="lang-en">{pillar.en}</span>
                  <span class="lang-zh">{pillar.zh}</span>
                </span>
                <span class="text-gray-500 dark:text-gray-400">
                  {" — "}
                  <span class="lang-en">{pillar.desc_en}</span>
                  <span class="lang-zh">{pillar.desc_zh}</span>
                </span>
              </div>
            </div>
            {pillar.posts && (
              <div class="ml-6 mt-2 flex flex-wrap gap-x-4 gap-y-1">
                {pillar.posts.map((slug: string) => {
                  const p = postMap.get(slug);
                  return p ? (
                    <a href={`/posts/${p.id}/`} class="font-serif text-xs text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
                      {p.data.title}
                    </a>
                  ) : null;
                })}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <div class="fade-in-up mb-10" style="--delay: 300ms">
      <h3 class="mb-4 font-serif text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">
        <span class="lang-en">Writing Rules</span>
        <span class="lang-zh">写作规则</span>
      </h3>
      <ul class="space-y-3 font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400">
        {writingRules.map((rule) => (
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#8953d1]"></span>
            <span>
              <span class="lang-en">{rule.en}</span>
              <span class="lang-zh">{rule.zh}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>

    <div class="fade-in-up" style="--delay: 340ms">
      <h3 class="mb-4 font-serif text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">
        <span class="lang-en">The Team</span>
        <span class="lang-zh">团队</span>
      </h3>
      <div class="font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400">
        <p class="mb-3">
          <span class="lang-en">I run a 6-agent AI team. They write drafts, track KOLs, analyze data, design images, and manage operations — 24/7.</span>
          <span class="lang-zh">我有一个 6 人 AI Agent 团队。他们写草稿、追踪 KOL、分析数据、设计配图、管理运营——全天候运行。</span>
        </p>
        <p class="mb-3 font-medium text-gray-700 dark:text-gray-300">
          <span class="lang-en">Samantha (brain) · Loki (writer) · Vision (researcher) · Jarvis (coder) · Shuri (designer) · Friday (analyst)</span>
          <span class="lang-zh">Samantha（主脑）· Loki（写手）· Vision（研究员）· Jarvis（程序员）· Shuri（设计师）· Friday（分析师）</span>
        </p>
        <p>
          <span class="lang-en">I make the decisions. They do the work.</span>
          <span class="lang-zh">我做决策，他们干活。</span>
        </p>
        <p class="mt-4">
          <a href="/lab/agents/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
            <span class="lang-en">Watch them work →</span>
            <span class="lang-zh">看他们工作 →</span>
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Life OS -->
  <section class="mb-16">
    <h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
      <span class="lang-en">Life OS</span>
      <span class="lang-zh">人生操作系统</span>
    </h2>
    <p class="fade-in-up mb-8 font-serif text-2xl font-semibold dark:text-white" style="--delay: 140ms">
      <span class="lang-en">Reduce noise. Keep the questions.</span>
      <span class="lang-zh">降低噪音，留下最重要的问题。</span>
    </p>

    <div class="fade-in-up mb-10 border-l-2 border-[#8953d1]/30 py-6 pl-6" style="--delay: 180ms">
      <p class="mb-5 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase">
        <span class="lang-en">Three Questions</span>
        <span class="lang-zh">三个问题</span>
      </p>
      <div class="space-y-3">
        {lifeQuestions.map((q, index) => (
          <p class="font-serif text-2xl font-semibold dark:text-white sm:text-3xl" style={`opacity: ${1 - index * 0.12}`}>
            <span class="lang-en">{q.en}</span>
            <span class="lang-zh">{q.zh}</span>
          </p>
        ))}
      </div>
      <p class="mt-6 font-serif text-sm text-gray-500 dark:text-gray-400">
        <span class="lang-en">Every major decision passes through these three filters.</span>
        <span class="lang-zh">每一个重大决策都过这三个滤网。</span>
      </p>
    </div>

    <div class="fade-in-up mb-10" style="--delay: 240ms">
      <h3 class="mb-4 font-serif text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">
        <span class="lang-en">Simplify, Then Repeat</span>
        <span class="lang-zh">复杂问题简单化</span>
      </h3>
      <p class="font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400">
        <span class="lang-en">Simplify the complex. Repeat the simple. Build your framework, then run it over and over. The people who win long-term aren't the smartest — they're the most consistent.</span>
        <span class="lang-zh">复杂问题简单化，简单事情重复做，建立自己的框架，然后不断重复，长期赢的人不是最聪明的，是最稳定的。</span>
      </p>
    </div>

    <div class="fade-in-up" style="--delay: 280ms">
      <h3 class="mb-4 font-serif text-sm font-bold tracking-wide text-gray-500 uppercase dark:text-gray-400">
        <span class="lang-en">Relationships</span>
        <span class="lang-zh">关系</span>
      </h3>
      <ul class="space-y-3 font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400">
        {relationshipPoints.map((point) => (
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#8953d1]"></span>
            <span>
              <span class="lang-en">{point.en}</span>
              <span class="lang-zh">{point.zh}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>

    {lifeEssays.length > 0 && (
      <div class="fade-in-up mt-10 border-t border-gray-200/60 pt-6 dark:border-gray-700/40" style="--delay: 320ms">
        <p class="mb-4 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
          <span class="lang-en">From the essays</span>
          <span class="lang-zh">相关文章</span>
        </p>
        <div class="space-y-3">
          {lifeEssays.map((p) => (
            <a href={`/posts/${p.id}/`} class="group flex items-baseline justify-between gap-4 font-serif text-sm transition-colors">
              <span class="text-gray-600 group-hover:text-[#8953d1] dark:text-gray-400 dark:group-hover:text-[#a175e8]">{p.data.title}</span>
              <time datetime={p.data.publishDate.toISOString()} class="shrink-0 text-xs text-gray-400 dark:text-gray-500">{formatShortDate(p.data.publishDate)}</time>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="fade-in-up mt-8 rounded-xl border border-gray-200/60 bg-gray-50/50 p-6 dark:border-gray-700/40 dark:bg-[#151515]" style="--delay: 360ms">
      <a href="/travel/" class="group flex items-center justify-between font-serif">
        <div>
          <p class="mb-1 text-xs font-bold tracking-widest text-[#8953d1] uppercase dark:text-[#a175e8]">
            <span class="lang-en">Travel Log</span>
            <span class="lang-zh">旅行足迹</span>
          </p>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <span class="lang-en">Dali, Hong Kong, Hulunbuir — where life happens →</span>
            <span class="lang-zh">大理、香港、呼伦贝尔——生活在别处 →</span>
          </p>
        </div>
        <span class="text-2xl text-gray-300 transition-transform group-hover:translate-x-1 dark:text-gray-600">→</span>
      </a>
    </div>
  </section>

  <!-- Stack -->
  <section class="mb-16">
    <h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
      <span class="lang-en">Stack</span>
      <span class="lang-zh">工具栈</span>
    </h2>
    <p class="fade-in-up mb-8 font-serif text-2xl font-semibold dark:text-white" style="--delay: 140ms">
      <span class="lang-en">The infrastructure behind the thinking.</span>
      <span class="lang-zh">思考方式背后的基础设施。</span>
    </p>

    <div class="space-y-4">
      {stackGroups.map((item, index) => (
        <div class="fade-in-up flex flex-col gap-1 border-b border-gray-200/60 pb-4 font-serif dark:border-gray-700/40 sm:flex-row sm:items-baseline sm:gap-6" style={`--delay: ${180 + index * 40}ms`}>
          <span class="text-xs font-bold tracking-widest text-[#8953d1] uppercase dark:text-[#a175e8] sm:w-28 sm:shrink-0">
            <span class="lang-en">{item.label_en}</span>
            <span class="lang-zh">{item.label_zh}</span>
          </span>
          <span class="text-base text-gray-600 dark:text-gray-400">
            <span class="lang-en">{item.value_en}</span>
            <span class="lang-zh">{item.value_zh}</span>
            {item.link && (
              <a href={item.link} class="ml-3 text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
                <span class="lang-en">{item.linkEn}</span>
                <span class="lang-zh">{item.linkZh}</span>
              </a>
            )}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- Library -->
  <section class="mb-16">
    <h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
      <span class="lang-en">Library</span>
      <span class="lang-zh">书影音</span>
    </h2>
    <p class="fade-in-up mb-8 font-serif text-2xl font-semibold dark:text-white" style="--delay: 140ms">
      <span class="lang-en">What shaped how I think.</span>
      <span class="lang-zh">塑造了我思考方式的输入。</span>
    </p>

    {recentBooks.length > 0 && (
      <div class="fade-in-up mb-6 grid grid-cols-3 gap-4 sm:gap-6" style="--delay: 180ms">
        {recentBooks.map((book: any) => (
          <div class="group overflow-hidden rounded-lg border border-gray-200/60 bg-gray-50/50 dark:border-gray-700/40 dark:bg-[#151515]">
            {book.cover && (
              <div class="aspect-[3/4] overflow-hidden">
                <img src={book.cover} alt={book.titleEn || book.title} class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
              </div>
            )}
            <div class="p-3">
              <p class="font-serif text-xs font-medium leading-tight dark:text-white">
                {book.titleEn || book.title}
              </p>
              {book.author && (
                <p class="mt-1 font-serif text-[10px] text-gray-400 dark:text-gray-500">{book.author}</p>
              )}
              {book.rating && (
                <p class="mt-1 text-xs">{book.rating}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    <a href="/os/library/" class="fade-in-up inline-block font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" style="--delay: 220ms">
      <span class="lang-en">Browse all books, films & shows →</span>
      <span class="lang-zh">浏览全部书籍、电影和剧集 →</span>
    </a>
  </section>

  <!-- Cross-page Navigation -->
  <nav class="fade-in-up mt-8 border-t border-gray-200/60 pt-10 dark:border-gray-700/40" style="--delay: 100ms">
    <p class="mb-6 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
      <span class="lang-en">Continue Exploring</span>
      <span class="lang-zh">继续探索</span>
    </p>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <a href="/portfolio/" class="group rounded-xl border border-gray-200/60 p-5 transition-colors hover:border-[#8953d1]/40 dark:border-gray-700/40 dark:hover:border-[#a175e8]/40">
        <p class="mb-1 font-serif text-sm font-medium dark:text-white">Portfolio</p>
        <p class="font-serif text-xs text-gray-500 dark:text-gray-400">
          <span class="lang-en">Live positions & regime tracker</span>
          <span class="lang-zh">实盘持仓与宏观温度计</span>
        </p>
      </a>
      <a href="/lab/agents/" class="group rounded-xl border border-gray-200/60 p-5 transition-colors hover:border-[#8953d1]/40 dark:border-gray-700/40 dark:hover:border-[#a175e8]/40">
        <p class="mb-1 font-serif text-sm font-medium dark:text-white">
          <span class="lang-en">AI Lab</span>
          <span class="lang-zh">AI 实验室</span>
        </p>
        <p class="font-serif text-xs text-gray-500 dark:text-gray-400">
          <span class="lang-en">Agent team & builder log</span>
          <span class="lang-zh">Agent 团队与构建日志</span>
        </p>
      </a>
      <a href="/posts/" class="group rounded-xl border border-gray-200/60 p-5 transition-colors hover:border-[#8953d1]/40 dark:border-gray-700/40 dark:hover:border-[#a175e8]/40">
        <p class="mb-1 font-serif text-sm font-medium dark:text-white">
          <span class="lang-en">Blog</span>
          <span class="lang-zh">博客</span>
        </p>
        <p class="font-serif text-xs text-gray-500 dark:text-gray-400">
          <span class="lang-en">Essays on investing, crypto & life</span>
          <span class="lang-zh">投资、加密与生活随笔</span>
        </p>
      </a>
      <a href="/travel/" class="group rounded-xl border border-gray-200/60 p-5 transition-colors hover:border-[#8953d1]/40 dark:border-gray-700/40 dark:hover:border-[#a175e8]/40">
        <p class="mb-1 font-serif text-sm font-medium dark:text-white">
          <span class="lang-en">Travel</span>
          <span class="lang-zh">旅行</span>
        </p>
        <p class="font-serif text-xs text-gray-500 dark:text-gray-400">
          <span class="lang-en">Footnotes from the road</span>
          <span class="lang-zh">路上的故事</span>
        </p>
      </a>
    </div>
  </nav>

  <style>
    details summary {
      list-style: none;
    }
    details summary::-webkit-details-marker {
      display: none;
    }
    .os-toggle {
      font-size: 1.25rem;
      line-height: 1;
      font-weight: 300;
      transition: transform 0.2s ease;
    }
    .os-expand-body {
      animation: os-slide 0.25s ease-out;
    }
    @keyframes os-slide {
      from { opacity: 0; transform: translateY(-6px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</PageLayout>
