                      <li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>
                    ))}
                  </ul>
                )}
                {item.notes?.impact && item.notes.impact.trim() && (
                  <p class="mt-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.impact}</p>
                )}
                {item.weread?.thoughts && item.weread.thoughts.length > 0 && (
                  <div class="mt-4 space-y-3">
                    <p class="font-serif text-xs uppercase tracking-[0.18em] text-[#8953d1] dark:text-[#a175e8]"><span class="lang-en">WeRead thoughts</span><span class="lang-zh">微信读书想法</span></p>
                    {item.weread.thoughts.slice(0, 3).map((thought) => (
                      <blockquote class="rounded-2xl border border-[#8953d1]/10 bg-[#8953d1]/5 p-4 font-serif text-sm leading-relaxed text-gray-700 dark:border-[#a175e8]/15 dark:bg-[#a175e8]/10 dark:text-gray-300">
                        {thought.chapter && <p class="mb-2 text-xs text-gray-400 dark:text-gray-500">{thought.chapter}</p>}
                        <p>{thought.content}</p>
                      </blockquote>
                    ))}
                  </div>
                )}
                {!hasNotes(item) && (
                  <p class="mt-4 font-serif text-sm text-gray-500 dark:text-gray-400">
                    <span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span>
                  </p>
                )}
                {item.reviewSlug && (
                  <a href={`/posts/${item.reviewSlug}/`} class="mt-4 inline-flex items-center gap-1.5 font-serif text-sm text-[#8953d1] dark:text-[#a175e8] hover:opacity-70 transition-opacity no-underline">
                    <span>📝</span>
                    <span class="lang-zh">阅读书评</span>
                    <span class="lang-en">Read Review</span>
                    <span>→</span>
                  </a>
