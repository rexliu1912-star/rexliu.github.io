  <script is:inline>
  function initLibrary() {
    let activeTab = 'books';
    let activeTag = '全部';

    // ── Count-up ──────────────────────────────────────────────
    document.querySelectorAll('[data-countup]').forEach(el => {
      const target = parseInt(el.dataset.countup, 10);
      const start = performance.now();
      const step = (now) => {
        const p = Math.min((now - start) / 1000, 1);
        el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });

    // ── Scroll stagger entry ──────────────────────────────────
    function initStagger() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.lib-card').forEach((card, i) => {
        card.style.transitionDelay = `${(i % 16) * 45}ms`;
        observer.observe(card);
      });
    }
    initStagger();
    setTimeout(() => {
      document.querySelectorAll('.lib-card:not(.revealed)').forEach(c => c.classList.add('revealed'));
    }, 800);

    // ── 3D hover tilt (via CSS vars — no conflict with .revealed transform) ──
    function attachTilt(card) {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top)  / r.height - 0.5;
        card.style.setProperty('--rx', `${-y * 9}deg`);
        card.style.setProperty('--ry', `${x * 9}deg`);
        card.style.setProperty('--rs', '1.045');
        card.style.transition = 'transform 0.1s ease, box-shadow 0.1s ease, opacity 0.5s ease';
        card.style.boxShadow = `${-x*14}px ${y*14}px 32px rgba(137,83,209,0.18)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--rx', '0deg');
        card.style.setProperty('--ry', '0deg');
        card.style.setProperty('--rs', '1');
        card.style.transition = 'transform 0.4s ease, box-shadow 0.4s ease, opacity 0.5s ease';
        card.style.boxShadow = '';
      });
    }
    document.querySelectorAll('.lib-card').forEach(attachTilt);

    // ── Tab switching ─────────────────────────────────────────
    const tabs   = document.querySelectorAll('.lib-tab');
    const panels = document.querySelectorAll('.lib-panel');

    const TAB_ORDER = ['books', 'films', 'series', 'variety', 'documentary'];

    function switchTab(tab) {
      const prevIdx = TAB_ORDER.indexOf(activeTab);
      const nextIdx = TAB_ORDER.indexOf(tab);
      const goRight = nextIdx > prevIdx; // forward = slide in from right

      activeTab = tab;
      activeTag = '全部';
      tabs.forEach(t => {
        const on = t.dataset.tab === tab;
        t.setAttribute('aria-pressed', on);
        t.classList.toggle('border-[#8953d1]', on);
        t.classList.toggle('text-[#8953d1]', on);
        t.classList.toggle('dark:text-[#a175e8]', on);
        t.classList.toggle('border-transparent', !on);
        t.classList.toggle('text-gray-400', !on);
      });
      panels.forEach(p => {
        const show = p.dataset.panel === tab;
        p.classList.toggle('hidden', !show);
        if (show) {
          // Directional page-turn
          const anim = goRight ? 'pageFromRight' : 'pageFromLeft';
          p.style.animation = 'none';
          requestAnimationFrame(() => {
            p.style.animation = `${anim} 0.3s cubic-bezier(0.34,1.15,0.64,1) both`;
          });
          // Stagger newly visible cards
          p.querySelectorAll('.lib-card:not(.revealed)').forEach((c, i) => {
            c.style.transitionDelay = `${(i % 16) * 45}ms`;
          });
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); } });
          }, { threshold: 0.08 });
          p.querySelectorAll('.lib-card:not(.revealed)').forEach(c => obs.observe(c));
        }
      });
      renderTags();
      applyTagFilter();
    }
    tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

    // ── Tag filters ───────────────────────────────────────────
    const tagRoot = document.getElementById('tag-filters');

    function getTagsForTab() {
      const tags = new Set();
      document.querySelectorAll(`.lib-card[data-group="${activeTab}"]`).forEach(card => {
        try { JSON.parse(card.dataset.tags || '[]').forEach(t => tags.add(t)); } catch {}
      });
      return ['全部', ...Array.from(tags).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN'))];
    }

    function isEnglish() {
      return document.documentElement.classList.contains('lang-en') ||
        document.documentElement.lang === 'en' ||
        document.documentElement.getAttribute('data-lang') === 'en' ||
        document.body.classList.contains('lang-en');
    }

    function t(zh, en) {
      return isEnglish() ? en : zh;
    }

    window.__isEn = isEnglish();

    // Tag translations (zh → en)
    const TAG_EN = {
      '成长':'Growth','古琴':'Guqin','历史':'History','投资':'Investing',
      '文化':'Culture','文学':'Literature','写作':'Writing','哲学':'Philosophy',
      '心理':'Psychology','商业':'Business','传记':'Biography','科技':'Tech',
      '社会':'Society','经济':'Economics','艺术':'Art','音乐':'Music',
      '爱情':'Romance','家庭':'Family','剧情':'Drama','喜剧':'Comedy',
      '悬疑':'Thriller','动画':'Animation','科幻':'Sci-Fi','战争':'War',
      '日剧':'J-Drama','韩剧':'K-Drama','美剧':'US Drama','港剧':'HK Drama',
      '励志':'Inspire','认知':'Cognition','财富':'Wealth','时间':'Time',
      '人生':'Life','情感':'Emotion','亲情':'Kinship','纪实':'Documentary',
    };
    function tagLabel(tag) {
      if (tag === '全部') return '<span class="lang-zh">全部</span><span class="lang-en">All</span>';
      const en = TAG_EN[tag];
      return en
        ? `<span class="lang-zh">${tag}</span><span class="lang-en">${en}</span>`
        : tag;
    }

    function renderTags() {
      tagRoot.innerHTML = '';
      getTagsForTab().forEach(tag => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tag-btn rounded-full border border-purple-500/20 px-4 py-2 font-serif text-sm text-gray-500 dark:border-purple-500/15 dark:text-gray-400';
        btn.innerHTML = tagLabel(tag);
        if (tag === activeTag) btn.classList.add('active');
        btn.addEventListener('click', () => {
          activeTag = tag === activeTag ? '全部' : tag;
          renderTags();
          applyTagFilter();
        });
        tagRoot.appendChild(btn);
      });
    }

    function applyTagFilter() {
      document.querySelectorAll(`.lib-card[data-group="${activeTab}"]`).forEach(card => {
        const show = activeTag === '全部' || (() => { try { return JSON.parse(card.dataset.tags||'[]').includes(activeTag); } catch { return false; } })();
        card.style.display = show ? '' : 'none';
      });
      // Re-layout shelf if active
      if (activeTab === 'books' && activeView === 'shelf') organizeShelf();
      // Notify masonry view (React island) — scoped by active tab
      window.dispatchEvent(new CustomEvent(`library:${activeTab}:tag-filter`, {
        detail: { tag: activeTag === '全部' ? null : activeTag }
      }));
    }

    // ── Frosted-glass Modal ───────────────────────────────────
    // Modal elements exist above in DOM, safe to query now
    function getModal()        { return document.getElementById('lib-modal'); }
    function getModalContent() { return document.getElementById('lib-modal-content'); }

    function openModal(cardEl) {
      const id = cardEl.dataset.id;
      const detail = document.querySelector(`.lib-detail[data-detail="${id}"]`);
      const modal = getModal();
      const modalContent = getModalContent();
      if (!detail || !modal || !modalContent) return;

      // If closing animation running, cut it short
      modal.classList.remove('closing');
      modalContent.innerHTML = detail.innerHTML;

      document.querySelectorAll('.lib-card.is-active').forEach(c => c.classList.remove('is-active'));
      cardEl.classList.add('is-active');
    }

    function closeModal() {
      const modal = getModal();
      if (!modal || !modal.classList.contains('open')) return;
      // Play closing animation, then hide
      modal.classList.add('closing');
      setTimeout(() => {
        modal.classList.remove('open', 'closing');
        document.body.style.overflow = '';
        document.querySelectorAll('.lib-card.is-active').forEach(c => c.classList.remove('is-active'));
      }, 220);
    }

    document.addEventListener('click', (e) => {
      // Close button
      if (e.target.closest('#lib-modal-close')) { closeModal(); return; }
      // Backdrop
      if (e.target.id === 'lib-modal-backdrop') { closeModal(); return; }
      // Card
      const card = e.target.closest('.lib-card, .library-masonry-card');
      if (card) { e.preventDefault(); openModal(card); }
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // ── View switching (masonry / grid / shelf) ──────────────
    let activeView = 'masonry';
    const masonryView = document.getElementById('books-masonry-view');
    const gridView  = document.getElementById('books-grid-view');
    const shelfView = document.getElementById('books-shelf-view');
    const shelfStage = document.getElementById('lib-shelf-stage');
    const btnMasonry = document.getElementById('view-btn-masonry');
    const btnGrid  = document.getElementById('view-btn-grid');
    const btnShelf = document.getElementById('view-btn-shelf');

    function organizeShelf() {
      if (!shelfStage) return;
      // Collect ALL shelf books from anywhere in the DOM (they may be in rows or loose)
      const allBooks = Array.from(document.querySelectorAll('[data-shelf-entry]'));
      if (!allBooks.length) return;

      const visibleBooks = allBooks.filter(b => {
        if (activeTag === '全部') return true;
        try { return JSON.parse(b.dataset.tags || '[]').includes(activeTag); } catch { return false; }
      });
      const hiddenBooks = allBooks.filter(b => !visibleBooks.includes(b));

      const w = window.innerWidth;
      const cols = w >= 1280 ? 14 : w >= 1024 ? 12 : w >= 768 ? 10 : w >= 640 ? 8 : 7;

      // Detach all books first, then clear stage
      allBooks.forEach(b => b.parentNode && b.parentNode.removeChild(b));
      shelfStage.innerHTML = '';

      // Build rows in order and append
      for (let i = 0; i < visibleBooks.length; i += cols) {
        const row = document.createElement('div');
        row.className = 'shelf-row';
        visibleBooks.slice(i, i + cols).forEach(b => { b.style.display = ''; row.appendChild(b); });
        shelfStage.appendChild(row);
      }

      // Hidden books: keep in DOM (needed for modal data) in a hidden container
      if (hiddenBooks.length) {
        const hiddenWrap = document.createElement('div');
        hiddenWrap.style.display = 'none';
        hiddenBooks.forEach(b => { b.style.display = 'none'; hiddenWrap.appendChild(b); });
        shelfStage.appendChild(hiddenWrap);
      }
    }

    let _switchLock = false;
    const sleep = ms => new Promise(r => setTimeout(r, ms));

    function updateViewBtns(view) {
      const btns = { masonry: btnMasonry, grid: btnGrid, shelf: btnShelf };
      Object.entries(btns).forEach(([key, btn]) => {
        if (!btn) return;
        const active = key === view;
        btn.classList.toggle('bg-[#8953d1]', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('dark:bg-[#a175e8]', active);
        btn.classList.toggle('dark:text-black', active);
        btn.classList.toggle('text-gray-500', !active);
        btn.setAttribute('aria-pressed', String(active));
      });
    }

    async function switchView(view) {
      if (view === activeView || _switchLock) return;
      _switchLock = true;
      const prevView = activeView;
      activeView = view;
      updateViewBtns(view);

      const STAGGER = 14;
      const CAP     = 180;

      // Masonry transitions use simple class toggle (no dramatic animation)
      if (prevView === 'masonry' || view === 'masonry') {
        [masonryView, gridView, shelfView].forEach(el => el && el.classList.remove('active'));
        const target = view === 'masonry' ? masonryView : view === 'grid' ? gridView : shelfView;
        if (target) target.classList.add('active');
        if (view === 'shelf') organizeShelf();
        _switchLock = false;
        return;
      }

      // Grid ↔ Shelf: original fly-out/fly-in animation
      if (view === 'shelf') {
        const cards = [...gridView.querySelectorAll('.lib-card')]
          .filter(c => c.style.display !== 'none' && c.offsetParent !== null);
        cards.forEach((c, i) => {
          const d = Math.min(i * STAGGER, CAP);
          c.style.transition = 'none';
          c.style.animation = `libFlyOut 0.22s ${d}ms cubic-bezier(0.55,0,1,1) both`;
        });
        await sleep(Math.min(cards.length * STAGGER, CAP) + 230);

        gridView.classList.remove('active');
        cards.forEach(c => { c.style.animation = ''; });
        shelfView.classList.add('active');
        organizeShelf();

        const spines = [...document.querySelectorAll('.shelf-entry')];
        spines.forEach((s, i) => {
          const d = Math.min(i * 10, CAP);
          s.style.animation = `libSpineIn 0.38s ${d}ms cubic-bezier(0.34,1.56,0.64,1) both`;
        });
        await sleep(Math.min(spines.length * 10, CAP) + 380);
        spines.forEach(s => { s.style.animation = ''; });
      } else {
        const spines = [...document.querySelectorAll('.shelf-entry')];
        spines.forEach((s, i) => {
          const d = Math.min(i * 8, 120);
          s.style.animation = `libSpineOut 0.18s ${d}ms ease both`;
        });
        await sleep(Math.min(spines.length * 8, 120) + 180);

        shelfView.classList.remove('active');
        spines.forEach(s => { s.style.animation = ''; });
        gridView.classList.add('active');

        const cards = [...gridView.querySelectorAll('.lib-card')]
          .filter(c => c.style.display !== 'none');
        cards.forEach((c, i) => {
          const d = Math.min(i * STAGGER, CAP);
          c.classList.remove('revealed');
          c.style.transition = 'none';
          c.style.animation = `libCardIn 0.38s ${d}ms cubic-bezier(0.34,1.56,0.64,1) both`;
        });
        await sleep(Math.min(cards.length * STAGGER, CAP) + 380);
        cards.forEach(c => {
          c.style.animation = '';
          c.style.transition = '';
          c.classList.add('revealed');
        });
      }
      _switchLock = false;
    }

    if (btnMasonry) btnMasonry.addEventListener('click', () => switchView('masonry'));
    if (btnGrid)    btnGrid.addEventListener('click',    () => switchView('grid'));
    if (btnShelf)   btnShelf.addEventListener('click',   () => switchView('shelf'));

    // ── Films / Series two-view toggle (masonry + grid) ──────
    function wireMediaToggle(tabKey) {
      const masonry = document.getElementById(`${tabKey}-masonry-view`);
      const grid    = document.getElementById(`${tabKey}-grid-view`);
      const btnM    = document.getElementById(`view-btn-${tabKey}-masonry`);
      const btnG    = document.getElementById(`view-btn-${tabKey}-grid`);
      if (!masonry || !grid || !btnM || !btnG) return;
      const activate = (view) => {
        const isM = view === 'masonry';
        masonry.classList.toggle('active',  isM);
        grid.classList.toggle('active',    !isM);
        [btnM, btnG].forEach((btn, i) => {
          const active = (i === 0) === isM;
          btn.classList.toggle('bg-[#8953d1]', active);
          btn.classList.toggle('text-white', active);
          btn.classList.toggle('dark:bg-[#a175e8]', active);
          btn.classList.toggle('dark:text-black', active);
          btn.classList.toggle('text-gray-500', !active);
          btn.setAttribute('aria-pressed', String(active));
        });
      };
      btnM.addEventListener('click', () => activate('masonry'));
      btnG.addEventListener('click', () => activate('grid'));
    }
    wireMediaToggle('films');
    wireMediaToggle('series');

    // Shelf book click → open modal
    document.addEventListener('click', (e) => {
      const sb = e.target.closest('[data-shelf-book]');
      if (sb) {
        e.preventDefault();
        const id = sb.dataset.id;
        const card = document.querySelector(`.lib-card[data-id="${id}"]`);
        if (card) openModal(card);
      }
    });

    // ── Cursor spotlight on card grids ────────────────────────
    document.querySelectorAll('.lib-panel').forEach(panel => {
      panel.addEventListener('mousemove', (e) => {
        const r = panel.getBoundingClientRect();
        panel.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        panel.style.setProperty('--my', (e.clientY - r.top)  + 'px');
        panel.style.setProperty('--spotlight', '1');
      });
      panel.addEventListener('mouseleave', () => {
        panel.style.setProperty('--spotlight', '0');
      });
    });

    // Sort/filter books
    const booksSortEl = document.getElementById('books-sort');
    const booksGridEl = document.getElementById('books-grid');
    const allBookCards = Array.from(document.querySelectorAll('.lib-card[data-group="books"]'));
    const originalOrder = allBookCards.map(c => c.dataset.id);

    function applySortFilter() {
      const sort = booksSortEl ? booksSortEl.value : 'date';
      // Notify books masonry (React island) — sort only applies to books
      window.dispatchEvent(new CustomEvent('library:books:sort-change', {
        detail: { sortBy: sort }
      }));
      if (!booksGridEl) return;
      if (sort === 'notes') {
        allBookCards.forEach(c => {
          const hasNote = c.querySelector('.lib-bookmark') !== null;
          c.style.display = hasNote ? '' : 'none';
        });
        return;
      }
      allBookCards.forEach(c => { c.style.display = ''; });
      if (sort === 'date') {
        originalOrder.forEach(id => {
          const c = booksGridEl.querySelector('.lib-card[data-id="' + id + '"]');
          if (c) booksGridEl.appendChild(c);
        });
      } else if (sort === 'rating') {
        const cards = Array.from(booksGridEl.querySelectorAll('.lib-card[data-group="books"]'));
        const sorted = cards.sort((a, b) => {
          const ra = (a.querySelectorAll('.bg-\\[\\#8953d1\\]') || []).length;
          const rb = (b.querySelectorAll('.bg-\\[\\#8953d1\\]') || []).length;
          return rb - ra;
        });
        sorted.forEach(c => booksGridEl.appendChild(c));
      }
      applyTagFilter();
    }

    if (booksSortEl) booksSortEl.addEventListener('change', applySortFilter);


    // ── Sort select language sync ─────────────────────────────
    function syncSortLang() {
      if (!booksSortEl) return;
      booksSortEl.querySelectorAll('option').forEach(opt => {
        opt.textContent = isEnglish() ? (opt.dataset.en || opt.textContent) : (opt.dataset.zh || opt.textContent);
      });
    }

    syncSortLang();

    const syncLanguageUI = () => {
      syncSortLang();
    };

    new MutationObserver(syncLanguageUI).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-lang', 'lang', 'class'],
    });

    const langToggle = document.querySelector('[data-lang-toggle], .lang-toggle-btn, button[aria-label*="lang"], button[aria-label*="English"], button[aria-label*="中文"]');
    if (langToggle) {
      langToggle.addEventListener('click', () => {
        setTimeout(syncLanguageUI, 50);
      });
    }

    // ── Init ──────────────────────────────────────────────────
    // Force reset select to default (prevent browser form history restoring a filter)
    if (booksSortEl) booksSortEl.value = 'date';
    renderTags();

  } // end initLibrary

  // Run on both initial load and View Transitions navigation
  document.addEventListener('astro:page-load', initLibrary);
  </script>
</PageLayout>
