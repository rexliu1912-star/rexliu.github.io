---
import LibraryMasonry from "@/components/library/LibraryMasonry";
import booksData from "@/data/books.json";
import mediaData from "@/data/media.json";
import readingStatsData from "@/data/weread/reading-stats.json";
import PageLayout from "@/layouts/Base.astro";

type Notes = {
	quotes?: string[];
	core_ideas?: string[];
	impact?: string;
};

type WeReadThought = {
	id?: string;
	content: string;
	chapter?: string;
	createdAt?: string;
	rating?: number;
};

type WeReadProgress = {
	percent?: number;
	chapterName?: string;
	updatedAt?: string;
	isFinished?: boolean;
};

type BookEntry = {
	slug?: string;
	title: string;
	titleEn?: string;
	author?: string;
	status: string;
	type?: string;
	rating?: string | null;
	tags?: string[];
	endDate?: string;
	notes?: Notes;
	cover?: string;
	reviewSlug?: string;
	weread?: {
		bookId?: string;
		category?: string;
		finishReading?: boolean;
		lastReadDate?: string;
		rankedReadTime?: string;
		badges?: string[];
		currentlyReading?: boolean;
		progress?: WeReadProgress;
		thoughts?: WeReadThought[];
	};
};

type MediaEntry = {
	slug?: string;
	title: string;
	titleEn?: string;
	year?: number;
	status: string;
	type: "movie" | "series" | "variety" | "documentary";
	tags?: string[];
	notes?: Notes;
	cover?: string;
};

type LibraryItem = {
	id: string;
	title: string;
	titleEn: string | undefined;
	subtitle: string;
	format: "book" | "movie" | "series" | "variety" | "documentary";
	rating: string | null | undefined;
	tags: string[];
	notes: Notes | undefined;
	meta: string | undefined;
	sortDate: string | undefined;
	year: number | undefined;
	cover: string | undefined;
	coverClass: string;
	reviewSlug: string | undefined;
	weread: BookEntry["weread"];
};

type WeReadStatItem = {
	stat?: string;
	counts?: string;
};

type WeReadLongestItem = {
	cover?: string;
	title?: string;
	author?: string;
	readTimeText?: string;
};

type WeReadCategoryItem = {
	categoryTitle?: string;
	readingTimeText?: string;
};

type WeReadStatsBlock = {
	readStat?: WeReadStatItem[];
	readLongest?: WeReadLongestItem[];
	preferCategory?: WeReadCategoryItem[];
	totalReadTimeText?: string;
	readDays?: number;
	preferCategoryWord?: string;
	preferTimeWord?: string;
};

type WeReadReadingStats = {
	updatedAt?: string;
	shelf?: {
		publicBooks?: number;
		[key: string]: unknown;
	};
	annual?: WeReadStatsBlock;
	overall?: WeReadStatsBlock;
};

const bookTagColors: Record<string, string> = {
	投资: "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
	成长: "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
	文化: "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
	文学: "bg-gradient-to-br from-[#ec4899] to-[#be185d]",
	古琴: "bg-gradient-to-br from-[#10b981] to-[#047857]",
	写作: "bg-gradient-to-br from-[#6366f1] to-[#4338ca]",
};
const defaultBookColor = "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]";
const mediaTypeColors: Record<string, string> = {
	movie: "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
	series: "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
	variety: "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
	documentary: "bg-gradient-to-br from-[#6b7280] to-[#374151]",
};

function ratingDots(rating: string | null | undefined): number {
	if (!rating) return 0;
	const m = rating.match(/^(\d+(?:\.\d+)?)\/(\d+)/);
	if (m?.[1] && m[2]) {
		return Math.round((Number.parseFloat(m[1]) / Number.parseFloat(m[2])) * 5);
	}
	const full = (rating.match(/🌕/g) || []).length;
	const half = (rating.match(/🌗/g) || []).length;
	return Math.min(5, Math.round(full + half * 0.5));
}

function hasNotes(item: LibraryItem) {
	return !!(
		(item.notes &&
			((item.notes.quotes && item.notes.quotes.length > 0) ||
				(item.notes.core_ideas && item.notes.core_ideas.length > 0) ||
				(item.notes.impact && item.notes.impact.trim().length > 0))) ||
		(item.weread?.thoughts && item.weread.thoughts.length > 0)
	);
}

function getNoteQuote(item: LibraryItem) {
	return (
		item.notes?.quotes?.[0]?.slice(0, 80) ?? item.weread?.thoughts?.[0]?.content.slice(0, 80) ?? ""
	);
}

function readingProgressPercent(item: LibraryItem) {
	return Math.max(0, Math.min(100, Math.round(Number(item.weread?.progress?.percent || 0))));
}

const zhCategoryMap: Record<string, string> = {
	小说: "Fiction",
	社会小说: "Social Fiction",
	悬疑推理: "Mystery & Detective",
	文学: "Literature",
	散文杂著: "Essays",
	历史: "History",
	人物传记: "Biography",
	传记: "Biography",
	哲学宗教: "Philosophy",
	哲学: "Philosophy",
	宗教: "Religion",
	社会文化: "Society & Culture",
	社会: "Society",
	文化: "Culture",
	政治军事: "Politics & Military",
	政治: "Politics",
	军事: "Military",
	经济理财: "Economics & Finance",
	经济: "Economics",
	理财: "Finance",
	投资: "Investing",
	商业: "Business",
	管理: "Management",
	个人成长: "Personal Growth",
	成长: "Growth",
	心理: "Psychology",
	心理学: "Psychology",
	科技互联网: "Tech & Internet",
	科技: "Technology",
	互联网: "Internet",
	计算机: "Computer Science",
	艺术: "Art",
	漫画: "Comics",
	教育: "Education",
	英语: "English",
	生活百科: "Lifestyle",
	生活: "Lifestyle",
	医学健康: "Health",
	健康: "Health",
	原版书: "Original Edition",
};

function translateZhCategory(value = ""): string {
	if (!value) return "";
	return value
		.split(/[-/·]/)
		.map((part) => zhCategoryMap[part.trim()] || part.trim())
		.filter(Boolean)
		.join(" / ");
}

function translateDuration(value = ""): string {
	if (!value) return "";
	return value
		.replace(/(\d+)\s*时/g, "$1h")
		.replace(/(\d+)\s*分/g, "$1m")
		.replace(/(\d+)\s*小时/g, "$1h")
		.replace(/(\d+)\s*分钟/g, "$1m")
		.replace(/(\d+)\s*天/g, "$1d")
		.replace(/(\d+)\s*秒/g, "$1s");
}

function translateCount(value: string, singular: string, plural = `${singular}s`): string {
	const number = value.match(/\d+/)?.[0] || "0";
	return `${number} ${number === "1" ? singular : plural}`;
}

function translatePreferenceWord(value = ""): string {
	if (!value) return "—";
	const category = value.match(/^偏好阅读(.+)$/)?.[1];
	if (category) return `Prefers ${translateZhCategory(category)}`;
	const time = value.match(/^偏好(.+)阅读$/)?.[1];
	if (time) {
		const timeMap: Record<string, string> = {
			早晨: "morning",
			上午: "morning",
			中午: "midday",
			下午: "afternoon",
			晚上: "evening",
			夜晚: "night",
			凌晨: "late-night",
		};
		return `Prefers ${timeMap[time] || translateZhCategory(time)} reading`;
	}
	return translateZhCategory(value)
		.replace(/最多/g, "most")
		.replace(/最常读/g, "most read")
		.replace(/偏爱/g, "prefers")
		.replace(/阅读/g, "reading");
}

function translateBadge(value = ""): string {
	return value
		.replace(/读完/g, "Finished")
		.replace(/在读/g, "Reading")
		.replace(/最长/g, "Longest")
		.replace(/最久/g, "Longest")
		.replace(/本年度/g, "This year")
		.replace(/年度/g, "Yearly");
}

const books: LibraryItem[] = (booksData as BookEntry[])
	.map((book, index) => ({
		id: book.slug || `book-${index}`,
		title: book.title,
		titleEn: book.titleEn,
		subtitle: book.author || "Unknown author",
		format: "book" as const,
		rating: book.rating,
		tags: book.tags || [],
		notes: book.notes,
		meta: book.type,
		sortDate: book.endDate && book.endDate !== "-" ? book.endDate : book.weread?.lastReadDate,
		year: undefined,
		cover: book.cover,
		coverClass: (book.tags?.[0] ? bookTagColors[book.tags[0]] : undefined) || defaultBookColor,
		reviewSlug: book.reviewSlug,
		weread: book.weread,
	}))
	.sort((a, b) => {
		if (!a.sortDate && !b.sortDate) return 0;
		if (!a.sortDate) return 1;
		if (!b.sortDate) return -1;
		return new Date(b.sortDate).valueOf() - new Date(a.sortDate).valueOf();
	});

const media: LibraryItem[] = (mediaData as MediaEntry[])
	.map((item, index) => ({
		id: item.slug || `media-${index}`,
		title: item.title,
		titleEn: item.titleEn,
		subtitle:
			item.type === "movie"
				? "Film"
				: item.type === "series"
					? "Series"
					: item.type === "documentary"
						? "Documentary"
						: "Variety",
		format: item.type,
		rating: undefined,
		tags: item.tags || [],
		notes: item.notes,
		meta: undefined,
		sortDate: undefined,
		year: item.year,
		cover: item.cover,
		coverClass: mediaTypeColors[item.type] || defaultBookColor,
		reviewSlug: undefined,
		weread: undefined,
	}))
	.sort((a, b) => (b.year || 0) - (a.year || 0));

const films = media.filter((item) => item.format === "movie");
const series = media.filter((item) => item.format === "series");
const variety = media.filter((item) => item.format === "variety");
const documentary = media.filter((item) => item.format === "documentary");

const meta = {
	title: "Library — OS",
	description: "Books, films, and shows that shaped how Rex thinks.",
};

const statsWithNotes =
	books.filter((b) => hasNotes(b)).length + media.filter((m) => hasNotes(m)).length;
const wereadStats = readingStatsData as WeReadReadingStats;
const annualStats = wereadStats.annual || {};
const overallStats = wereadStats.overall || {};
const shelfStats = wereadStats.shelf || {};
const annualReadBooks = annualStats.readStat?.find((item) => item.stat === "读过")?.counts || "0本";
const annualFinishedBooks =
	annualStats.readStat?.find((item) => item.stat === "读完")?.counts || "0本";
const overallNotes = overallStats.readStat?.find((item) => item.stat === "笔记")?.counts || "0条";
const annualReadBooksEn = translateCount(annualReadBooks, "book");
const annualFinishedBooksEn = translateCount(annualFinishedBooks, "book");
const overallNotesEn = translateCount(overallNotes, "note");
const topAnnualBook = annualStats.readLongest?.[0];
const topOverallCategories = (overallStats.preferCategory || []).slice(0, 4);
const wereadUpdatedDate = wereadStats.updatedAt
	? new Date(wereadStats.updatedAt).toLocaleDateString("en-CA", { timeZone: "Asia/Shanghai" })
	: "";
const wereadBooksCount = books.filter((book) => book.weread?.bookId).length;
const currentlyReadingBooks = books
	.filter((book) => book.weread?.currentlyReading)
	.sort((a, b) => readingProgressPercent(b) - readingProgressPercent(a))
	.slice(0, 3);

// Prepare items for Masonry views — plain serializable objects passed to React islands
const masonryBooks = books.map((b) => ({
	id: b.id,
	title: b.title,
	titleEn: b.titleEn,
	subtitle: b.subtitle,
	cover: b.cover,
	coverClass: b.coverClass,
	rating: b.rating,
	tags: b.tags,
	sortDate: b.sortDate,
	sortYear: undefined,
	notes: b.notes,
	reviewSlug: b.reviewSlug,
	hasNotes: hasNotes(b),
	weread: b.weread,
}));

function mediaSubtitle(m: LibraryItem): string {
	const label =
		m.format === "movie"
			? "Film"
			: m.format === "series"
				? "Series"
				: m.format === "variety"
					? "Variety"
					: "Documentary";
	return m.year ? `${label} · ${m.year}` : label;
}
function toMasonryMedia(m: LibraryItem) {
	return {
		id: m.id,
		title: m.title,
		titleEn: m.titleEn,
		subtitle: mediaSubtitle(m),
		cover: m.cover,
		coverClass: m.coverClass,
		rating: m.rating,
		tags: m.tags,
		sortDate: undefined,
		sortYear: m.year,
		notes: m.notes,
		reviewSlug: undefined,
		hasNotes: hasNotes(m),
	};
}
const masonryFilms = films.map(toMasonryMedia);
const masonrySeries = series.map(toMasonryMedia);
---

<PageLayout meta={meta}>
  <!-- Header -->
  <section class="mb-12">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">← Lab</a>
    <h1 class="mt-4 mb-4 font-serif text-4xl font-bold dark:text-white"><span class="lang-en">Library</span><span class="lang-zh">书影音</span></h1>
    <p class="lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">Books, films, and shows that shaped how I think.</p>
    <p class="lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">读过的书、看过的片，塑造了现在的我。</p>
    <p class="mt-4 font-serif text-sm text-gray-400 dark:text-gray-500">
      <span data-countup={books.length}>0</span>
      <span class="lang-en"> books</span><span class="lang-zh"> 本书</span> ·
      <span data-countup={statsWithNotes}>0</span>
      <span class="lang-en"> with notes</span><span class="lang-zh"> 有笔记</span> ·
      <span data-countup={media.length}>0</span>
      <span class="lang-en"> films & shows</span><span class="lang-zh"> 部影视</span>
    </p>
  </section>

  <!-- WeRead public reading stats -->
  <section class="mb-10 overflow-hidden rounded-[1.5rem] border border-[#8953d1]/15 bg-[#fff7ed]/70 p-5 shadow-sm backdrop-blur dark:border-[#a175e8]/20 dark:bg-gray-900/50 sm:p-6">
    <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-serif text-xs uppercase tracking-[0.28em] text-[#8953d1] dark:text-[#a175e8]">WeRead Sync</p>
        <h2 class="mt-2 font-serif text-2xl font-semibold text-gray-950 dark:text-white">
          <span class="lang-en">Reading telemetry</span>
          <span class="lang-zh">微信读书轨迹</span>
        </h2>
      </div>
      {wereadUpdatedDate && (
        <p class="font-serif text-xs text-gray-400 dark:text-gray-500">
          <span class="lang-en">Updated {wereadUpdatedDate}</span>
          <span class="lang-zh">更新于 {wereadUpdatedDate}</span>
        </p>
      )}
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl border border-black/5 bg-white/65 p-4 dark:border-white/10 dark:bg-black/20">
        <p class="font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Overall reading</span><span class="lang-zh">累计阅读</span></p>
        <p class="mt-2 font-serif text-2xl font-semibold text-gray-950 dark:text-white"><span class="lang-en">{translateDuration(overallStats.totalReadTimeText)}</span><span class="lang-zh">{overallStats.totalReadTimeText}</span></p>
        <p class="mt-1 font-serif text-xs text-gray-500 dark:text-gray-400"><span class="lang-en">{overallStats.readDays} days · {overallNotesEn}</span><span class="lang-zh">{overallStats.readDays} 天 · {overallNotes}</span></p>
      </div>
      <div class="rounded-2xl border border-black/5 bg-white/65 p-4 dark:border-white/10 dark:bg-black/20">
        <p class="font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">This year</span><span class="lang-zh">今年</span></p>
        <p class="mt-2 font-serif text-2xl font-semibold text-gray-950 dark:text-white"><span class="lang-en">{translateDuration(annualStats.totalReadTimeText)}</span><span class="lang-zh">{annualStats.totalReadTimeText}</span></p>
        <p class="mt-1 font-serif text-xs text-gray-500 dark:text-gray-400"><span class="lang-en">{annualReadBooksEn} read · {annualFinishedBooksEn} finished</span><span class="lang-zh">读过 {annualReadBooks} · 读完 {annualFinishedBooks}</span></p>
      </div>
      <div class="rounded-2xl border border-black/5 bg-white/65 p-4 dark:border-white/10 dark:bg-black/20">
        <p class="font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Public shelf</span><span class="lang-zh">公开书架</span></p>
        <p class="mt-2 font-serif text-2xl font-semibold text-gray-950 dark:text-white">{wereadBooksCount}</p>
        <p class="mt-1 font-serif text-xs text-gray-500 dark:text-gray-400"><span class="lang-en">{shelfStats.publicBooks || wereadBooksCount} WeRead books synced</span><span class="lang-zh">已同步 {shelfStats.publicBooks || wereadBooksCount} 本微信读书</span></p>
      </div>
      <div class="rounded-2xl border border-black/5 bg-white/65 p-4 dark:border-white/10 dark:bg-black/20">
        <p class="font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Preference</span><span class="lang-zh">阅读偏好</span></p>
        <p class="mt-2 font-serif text-lg font-semibold text-gray-950 dark:text-white"><span class="lang-en">{translatePreferenceWord(overallStats.preferCategoryWord)}</span><span class="lang-zh">{overallStats.preferCategoryWord || "—"}</span></p>
        <p class="mt-1 font-serif text-xs text-gray-500 dark:text-gray-400"><span class="lang-en">{translatePreferenceWord(overallStats.preferTimeWord || "WeRead")}</span><span class="lang-zh">{overallStats.preferTimeWord || "WeRead"}</span></p>
      </div>
    </div>

    <div class="mt-5 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      {topAnnualBook && (
        <div class="rounded-2xl border border-[#8953d1]/10 bg-white/55 p-4 dark:border-[#a175e8]/15 dark:bg-black/15">
          <p class="font-serif text-xs uppercase tracking-[0.18em] text-gray-400 dark:text-gray-500"><span class="lang-en">Longest this year</span><span class="lang-zh">今年读得最久</span></p>
          <div class="mt-3 flex gap-3">
            {topAnnualBook.cover && <img src={topAnnualBook.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="h-24 w-16 rounded-md object-cover shadow" />}
            <div class="min-w-0">
              <p class="font-serif text-base font-semibold text-gray-950 dark:text-white line-clamp-2">{topAnnualBook.title}</p>
              <p class="mt-1 font-serif text-xs text-gray-500 dark:text-gray-400">{topAnnualBook.author}</p>
              <p class="mt-2 font-serif text-sm text-[#8953d1] dark:text-[#a175e8]"><span class="lang-en">{translateDuration(topAnnualBook.readTimeText)}</span><span class="lang-zh">{topAnnualBook.readTimeText}</span></p>
            </div>
          </div>
        </div>
      )}
      <div class="rounded-2xl border border-[#8953d1]/10 bg-white/55 p-4 dark:border-[#a175e8]/15 dark:bg-black/15">
        <p class="font-serif text-xs uppercase tracking-[0.18em] text-gray-400 dark:text-gray-500"><span class="lang-en">Top categories</span><span class="lang-zh">阅读类别</span></p>
        <div class="mt-3 space-y-2">
			{topOverallCategories.map((category) => (
            <div class="flex items-center justify-between gap-3 font-serif text-sm">
              <span class="text-gray-700 dark:text-gray-300"><span class="lang-en">{translateZhCategory(category.categoryTitle)}</span><span class="lang-zh">{category.categoryTitle}</span></span>
              <span class="shrink-0 text-gray-400 dark:text-gray-500"><span class="lang-en">{translateDuration(category.readingTimeText)}</span><span class="lang-zh">{category.readingTimeText}</span></span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <p class="mt-4 font-serif text-xs leading-relaxed text-gray-400 dark:text-gray-500">
      <span class="lang-en">Shelf metadata, aggregate stats, reading progress, and Rex's own WeRead thoughts are public here; raw highlights are not published.</span>
      <span class="lang-zh">这里公开书架元数据、聚合统计、阅读进度和我自己写的微信读书想法；原始划线不发布。</span>
    </p>
  </section>

  {currentlyReadingBooks.length > 0 && (
    <section class="mb-8 rounded-[28px] border border-[#8953d1]/10 bg-[#fffaf0]/70 p-5 shadow-sm backdrop-blur dark:border-[#a175e8]/15 dark:bg-white/[0.03]">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <p class="font-serif text-xs uppercase tracking-[0.22em] text-[#8953d1] dark:text-[#a175e8]"><span class="lang-en">Currently reading</span><span class="lang-zh">正在读</span></p>
          <h2 class="mt-1 font-serif text-2xl text-gray-950 dark:text-white"><span class="lang-en">Live reading desk</span><span class="lang-zh">实时阅读桌面</span></h2>
        </div>
        <p class="hidden max-w-sm font-serif text-xs leading-relaxed text-gray-500 dark:text-gray-400 sm:block">
          <span class="lang-en">Pulled from WeRead progress. Thoughts are Rex's own notes, not highlights.</span>
          <span class="lang-zh">来自微信读书进度；展示的是我自己写的想法，不是划线。</span>
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {currentlyReadingBooks.map((item) => {
          const percent = readingProgressPercent(item);
          const firstThought = item.weread?.thoughts?.[0];
          return (
            <article class="rounded-2xl border border-[#8953d1]/10 bg-white/65 p-4 dark:border-[#a175e8]/15 dark:bg-black/15">
              <div class="flex gap-4">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="h-28 w-[74px] shrink-0 rounded-md object-cover shadow" />
                ) : (
                  <div class={`flex h-28 w-[74px] shrink-0 items-center justify-center rounded-md px-2 text-center ${item.coverClass}`}><span class="font-serif text-xs text-white">{item.title}</span></div>
                )}
                <div class="min-w-0 flex-1">
                  <h3 class="font-serif text-base font-semibold leading-snug text-gray-950 dark:text-white line-clamp-2">{item.title}</h3>
