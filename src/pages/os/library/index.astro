                    {item.weread.lastReadDate && <span class="rounded-full bg-gray-100 px-2.5 py-1 dark:bg-white/10"><span class="lang-en">Last read {item.weread.lastReadDate}</span><span class="lang-zh">最近阅读 {item.weread.lastReadDate}</span></span>}
                    {item.weread.rankedReadTime && <span class="rounded-full bg-gray-100 px-2.5 py-1 dark:bg-white/10"><span class="lang-en">Read time {translateDuration(item.weread.rankedReadTime)}</span><span class="lang-zh">阅读时长 {item.weread.rankedReadTime}</span></span>}
                    {item.weread.badges?.map((badge) => <span class="rounded-full bg-amber-100 px-2.5 py-1 text-amber-700 dark:bg-amber-400/15 dark:text-amber-200"><span class="lang-en">{translateBadge(badge)}</span><span class="lang-zh">{badge}</span></span>)}
                    {item.weread.progress?.percent !== undefined && <span class="rounded-full bg-[#8953d1]/10 px-2.5 py-1 text-[#8953d1] dark:bg-[#a175e8]/15 dark:text-[#a175e8]"><span class="lang-en">Progress {readingProgressPercent(item)}%</span><span class="lang-zh">进度 {readingProgressPercent(item)}%</span></span>}
                  </div>
