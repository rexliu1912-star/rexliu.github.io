---
import rawPortfolioData from "@/data/portfolio-public.json";
import PageLayout from "@/layouts/Base.astro";

// ─── Public portfolio shape ──────────────────────────────
// The generated JSON has many optional/null fields (stop=null when no stop
// rule, watchlist_heatmap=null until scan data accrues, etc.). TypeScript's
// inference from the JSON literal would lock these into `null` types and
// break narrowing at every call site; so we hand-type the surface we use.
interface PortfolioSignal {
	label: string;
	value: string;
	light: string;
}
interface PortfolioStop {
	level_pct_from_current: string;
	severity: string;
	description?: string;
}
interface PortfolioTarget {
	price_pct_from_current: string | null;
	description?: string;
	optimistic_price?: string | null;
}
interface PortfolioNextEvent {
	date: string;
	label: string;
	urgency: string;
}
interface PortfolioPosition {
	symbol: string;
	market: string;
	flag: string;
	sector_tags_en: string[];
	sector_tags_zh: string[];
	thesis_en: string;
	thesis_zh: string;
	stage: number;
	status_en: string;
	status_zh: string;
	conviction: string;
	entry_year?: number;
	horizon?: string;
	layer?: string | null;
	layer_label_en?: string | null;
	layer_label_zh?: string | null;
	stop?: PortfolioStop | null;
	target?: PortfolioTarget | null;
	price?: number;
	daily_change_pct?: number;
	next_event?: PortfolioNextEvent | null;
	news?: {
		summary: string;
		sentiment: "positive" | "neutral" | "negative";
		items: { title: string; snippet: string }[];
	} | null;
}
interface PortfolioHeatmap {
	tickers: string[];
	dates: string[];
	scores: (number | null)[][];
	ticker_names: Record<string, string>;
}
interface PortfolioRegimeCurrent {
	label: string;
	label_en: string;
	aggression: string;
	green_count: number;
	total_signals?: number;
	signals: Record<string, PortfolioSignal>;
}
interface PortfolioRegimeHistoryPoint {
	date: string;
	regime: string;
	green_count: number;
	vix: number | null;
}
interface PortfolioData {
	regime: { current: PortfolioRegimeCurrent; history_60d: PortfolioRegimeHistoryPoint[] };
	allocation: { current: { categories: any[] } };
	positions: PortfolioPosition[];
	crypto: {
		updated_at: string;
		positions: {
			symbol: string;
			role: "core" | "community";
			tags_en: string[];
			tags_zh: string[];
			thesis_en: string;
			thesis_zh: string;
			strategy_en: string;
			strategy_zh: string;
		}[];
	} | null;
	crypto_monitor: any | null;
	gold_tracker: any | null;
	watchlist_heatmap: PortfolioHeatmap | null;
	clearances: any[];
	roundtables: any[];
	sector_research?: any[];
	deep_research?: any[];
	stats: {
		active_positions: number;
		markets: number;
		tracked_rules: number;
		upcoming_events: number;
		weekly_scan_hits: number;
		days_since_last_clearance: number | null;
	};
	generated_at: string;
}

const portfolioData = rawPortfolioData as unknown as PortfolioData;

const {
	regime,
	allocation,
	positions,
	crypto,
	crypto_monitor: cryptoMonitor,
	gold_tracker: goldTracker,
	watchlist_heatmap: heatmap,
	clearances,
	roundtables,
	sector_research = [],
	deep_research = [],
	stats,
	generated_at,
} = portfolioData;

// Derived: Fear & Greed Index
const fgi = cryptoMonitor?.macro?.fear_greed;

// Derived: BTC ETF daily flow


// Derived: Crypto timeseries for master chart
const cryptoTS = (portfolioData as any)?.crypto_timeseries;


const cryptoPositions = crypto?.positions ?? [];
const activePositionCount = positions.length + cryptoPositions.length;

// Derived: Gold Tracker
const goldSignal = goldTracker?.signal?.status ?? goldTracker?.signal?.signal ?? "yellow";
const goldSignalLabel = goldTracker?.signal?.label_en ?? goldTracker?.signal?.signal_label_en ?? "Watch";
const goldSignalLabelZh = goldTracker?.signal?.label_zh ?? goldTracker?.signal?.signal_label_zh ?? "观察";
const goldXau = goldTracker?.price?.xau_usd;
const goldDay = goldTracker?.price?.day_change_pct;
const goldPeak = goldTracker?.price?.peak_price ?? goldTracker?.price?.week_52_high;
const goldDrawdown = goldTracker?.price?.drawdown_from_peak_pct;
const goldM2Pct = Math.min(100, Math.max(0, goldTracker?.monetary?.m2_to_trigger_pct ?? 0));
const goldM2Label = goldTracker?.monetary?.inversion_label_en ?? goldSignalLabel;
const goldM2LabelZh = goldTracker?.monetary?.inversion_label_zh ?? goldSignalLabelZh;
const goldPremium = goldTracker?.premium?.premium_pct ?? goldTracker?.metrics?.premium_shanghai_pct;
const goldPremiumDate = goldTracker?.premium?.updated_at ?? goldTracker?.metrics?.premium_date ?? "manual";
const goldCycle = goldTracker?.metrics?.cycle_label_en ?? "Cycle watch";
const goldCycleZh = goldTracker?.metrics?.cycle_label_zh ?? "周期观察";
const goldStop = goldTracker?.signal?.stop_loss ?? goldTracker?.signal?.aisc_range?.[0] ?? goldTracker?.cost_floor?.aisc_usd ?? 1750;
const goldRangeHigh = goldTracker?.signal?.aisc_range?.[1] ?? goldStop;

// Group deep research by sector for organized display
const deepBySector = deep_research.reduce((acc: Record<string, { sector_en: string; sector_zh: string; items: any[] }>, d: any) => {
	const key = d.sector_en || "Unclassified";
	if (!acc[key]) acc[key] = { sector_en: d.sector_en || "Unclassified", sector_zh: d.sector_zh || "未分类", items: [] };
	acc[key].items.push(d);
	return acc;
}, {} as Record<string, { sector_en: string; sector_zh: string; items: any[] }>);
const deepSectors = Object.values(deepBySector);

const regimeColors: Record<string, string> = {
	进攻期: "#10b981",
	中性期: "#f59e0b",
	防御期: "#ef4444",
	Offensive: "#10b981",
	Neutral: "#f59e0b",
	Defensive: "#ef4444",
};

const lightColors: Record<string, string> = {
	green: "#10b981",
	yellow: "#f59e0b",
	red: "#ef4444",
	gray: "#9ca3af",
};
const conviction: Record<string, string> = { high: "🔥", medium: "🌱", low: "❄️" };

// Signal ordering + labels for the regime 5×N history grid (used when
// less than ~7 days of thermometer history are available — before the
// full 60-day line chart kicks in).
const SIGNAL_ORDER = ["tnx", "dxy", "vix", "naaim", "policy"] as const;
const SIGNAL_LABELS: Record<string, { en: string; zh: string }> = {
	tnx: { en: "10Y", zh: "10年美债" },
	dxy: { en: "DXY", zh: "美元指数" },
	vix: { en: "VIX", zh: "恐慌指数" },
	naaim: { en: "NAAIM", zh: "主动管理" },
	policy: { en: "Policy", zh: "政策" },
};

// Conviction bar colors (used for position confidence fill).
const convictionStroke: Record<string, string> = {
	high: "#8953d1",
	medium: "#10b981",
	low: "#9ca3af",
};

// ─── Topology layer data (dynamic from JSON, not hardcoded) ──
// const TOPO_LAYERS = [
// 	{ id: "L5", widthPct: 32, label_en: "AI Compute", label_zh: "AI 算力", sub_en: null, sub_zh: null },
// 	{ id: "L4", widthPct: 44, label_en: "Data Centers", label_zh: "数据中心", sub_en: "Demand Driver", sub_zh: "需求引擎" },
// 	{ id: "L3", widthPct: 58, label_en: "Power Equipment", label_zh: "电力设备", sub_en: null, sub_zh: null },
// 	{ id: "L2", widthPct: 74, label_en: "Transmission & Distribution", label_zh: "输配电", sub_en: null, sub_zh: null },
// 	{ id: "L1", widthPct: 100, label_en: "Baseload Generation", label_zh: "基荷发电", sub_en: null, sub_zh: null },
// ] as const;

// Build topology nodes from positions that have a layer assignment
const topoNodesByLayer: Record<string, { symbol: string; status: string }[]> = {};
for (const p of positions) {
	if (!p.layer) continue;
	const layerKey = p.layer;
	if (!topoNodesByLayer[layerKey]) topoNodesByLayer[layerKey] = [];
	// Determine tag style: held = active position, watch = watchlist candidate
	const status = "held";
	topoNodesByLayer[layerKey].push({ symbol: p.symbol, status });
}

// Add watchlist tickers that aren't in positions (e.g. ETN, HUBB at L3)
// These come from deep_research entries marked as in_portfolio=false
for (const d of deep_research) {
	if (!d.in_portfolio && d.ticker) {
		// Extract layer from sector_en like "Electrical (L3 Conversion)"
		const layerMatch = (d.sector_en || "").match(/\(L(\d)/);
		const layer = layerMatch ? `L${layerMatch[1]}` : null;
		if (layer) {
			if (!topoNodesByLayer[layer]) topoNodesByLayer[layer] = [];
			// Avoid duplicates
			if (!topoNodesByLayer[layer].some((n) => n.symbol === d.ticker)) {
				topoNodesByLayer[layer].push({ symbol: d.ticker, status: "watch" });
			}
		}
	}
}

const dataJson = JSON.stringify({
	regime,
	allocation,
	heatmap,
	positions,
	clearances,
	crypto_timeseries: cryptoTS,
	crypto_portfolio_history: (portfolioData as any)?.crypto_portfolio_history,
	allocation_history: (portfolioData as any)?.allocation_history,
});

const updatedLabel = new Date(generated_at).toISOString().split("T")[0];

const meta = {
	title: "Portfolio · Rex Liu",
	description:
		"Public portfolio dashboard — sectors, theses, stage-gated decisions, and trade replays. No amounts, just conviction.",
};

// Stage metadata (from investment decision framework v2.0)
const stages = [
	{
		num: 0,
		title_en: "Macro Thermometer",
		title_zh: "宏观温度计",
		purpose_en: "Read market regime: offensive / neutral / defensive",
		purpose_zh: "判断市场温度：进攻 / 中性 / 防御",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 1,
		title_en: "Sector Research",
		title_zh: "赛道研究",
		purpose_en: "1-2 day deep report before picking stocks",
		purpose_zh: "选股之前先做重度赛道报告",
		automated: false,
		badge_en: "Manual",
		badge_zh: "手动",
	},
	{
		num: 2,
		title_en: "Watchlist Scan",
		title_zh: "个股池初筛",
		purpose_en: "15 tickers, 5-dimension filter → 10-20 names",
		purpose_zh: "15 只标的五维扫描 → 10-20 家观察名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 3,
		title_en: "Short List",
		title_zh: "短名单",
		purpose_en: "Valuation + catalyst + technicals → 3-5 names",
		purpose_zh: "估值 + 催化 + 技术面 → 3-5 家可操作短名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 4,
		title_en: "Deep Research",
		title_zh: "深度研究",
		purpose_en: "Skill: 4+1 card per company, 3 hard theses",
		purpose_zh: "Skill：每家公司 4+1 段名片 + 三条硬结论",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 5,
		title_en: "Roundtable",
		title_zh: "圆桌讨论",
		purpose_en: "6-seat masters challenge the theses; dissent required",
		purpose_zh: "6 席位大师挑战结论；反方必选",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 6,
		title_en: "Execution Plan",
		title_zh: "执行计划",
		purpose_en: "10-point scorecard ≥7, R:R ≥ 2.0, 3 stop-lines",
		purpose_zh: "10 分评分卡 ≥7，R:R ≥ 2.0，3 条撤退线",
		automated: true,
		badge_en: "Scorecard",
		badge_zh: "评分卡",
	},
	{
		num: 7,
		title_en: "Position Management",
		title_zh: "持仓管理 + 复盘",
		purpose_en: "L0-L3 monitoring + monthly/quarterly/annual reviews",
		purpose_zh: "L0-L3 四层监控 + 月/季/年复盘",
		automated: true,
		badge_en: "4-tier",
		badge_zh: "四层",
	},
];
---

<PageLayout meta={meta}>
	<link
		slot="head"
		rel="preload"
		href="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"
		as="script"
	/>

<section class="portfolio-page">
	<div class="mb-6">
			<a
				href="/lab/"
				class="portfolio-breadcrumb font-serif text-sm transition-colors"
			>
				← Lab
			</a>
		</div>

		{/* ═══ Hero ═══ */}
		<section class="portfolio-hero">
			<p class="portfolio-eyebrow">
				<span class="lang-en">Build in Public · Portfolio</span>
				<span class="lang-zh">公开建造 · 持仓驾驶舱</span>
			</p>
			<div class="portfolio-hero-row">
				<div class="portfolio-hero-text">
					<h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">
						<span class="lang-en">Portfolio · Conviction on Display</span>
						<span class="lang-zh">持仓 · 公开的决策</span>
					</h1>
					<p class="portfolio-subtitle font-serif text-lg leading-relaxed sm:text-xl">
						<span class="lang-en">
							No amounts. Just sectors, theses, stages, and the scorecard behind every position.
						</span>
						<span class="lang-zh">
							不公开金额。只展示板块、逻辑、阶段，以及每个仓位背后的评分卡。
						</span>
					</p>
				</div>
				<div
					class="portfolio-regime-badge"
					style={`--regime-color: ${regimeColors[regime?.current?.label] || "#8953d1"}`}
				>
					<span class="portfolio-regime-eyebrow">
						<span class="lang-en">Current Regime</span>
						<span class="lang-zh">当前宏观</span>
					</span>
					<strong class="portfolio-regime-label font-serif">
						<span class="lang-en">{regime?.current?.label_en || "—"}</span>
						<span class="lang-zh">{regime?.current?.label || "—"}</span>
					</strong>
					<span class="portfolio-regime-meta">
						<span class="lang-en">
							{regime?.current?.green_count ?? 0} / {regime?.current?.total_signals ?? 5} green ·
							Aggression {regime?.current?.aggression ?? "—"}
						</span>
						<span class="lang-zh">
							{regime?.current?.green_count ?? 0}/{regime?.current?.total_signals ?? 5} 绿灯 ·
							激进度 {regime?.current?.aggression ?? "—"}
						</span>
					</span>
				</div>
			</div>

			<div class="portfolio-hero-stats" aria-label="Portfolio statistics">
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Active Positions</span>
						<span class="lang-zh">活跃持仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={activePositionCount}
					>
						{activePositionCount}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Markets</span>
						<span class="lang-zh">市场</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.markets}>
						{stats.markets}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Tracked Rules</span>
						<span class="lang-zh">监控规则</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.tracked_rules}>
						{stats.tracked_rules}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Upcoming Events</span>
						<span class="lang-zh">预告事件</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.upcoming_events}>
						{stats.upcoming_events}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Scan Hits (≥5)</span>
						<span class="lang-zh">扫描信号</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.weekly_scan_hits}>
						{stats.weekly_scan_hits}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Last Clearance</span>
						<span class="lang-zh">上次清仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.days_since_last_clearance ?? 0}
						data-count-suffix="d ago"
					>
						{stats.days_since_last_clearance ?? "—"}d ago
					</strong>
				</article>
			</div>

		<p class="portfolio-updated">
				<span class="lang-en">Last updated: {updatedLabel}</span>
				<span class="lang-zh">最后更新: {updatedLabel}</span>
			</p>
		</section>

		<nav class="portfolio-section-nav" aria-label="Section navigation">
			<a href="#allocation-section"><span class="lang-en">Allocation</span><span class="lang-zh">配置</span></a>
			<a href="#regime-section"><span class="lang-en">Regime</span><span class="lang-zh">宏观</span></a>
			<a href="#positions-section"><span class="lang-en">Positions</span><span class="lang-zh">持仓</span></a>
			{cryptoMonitor && <a href="#crypto-mgmt-section"><span class="lang-en">Crypto</span><span class="lang-zh">加密</span></a>}
			<a href="#gold-tracker-section"><span class="lang-en">Gold</span><span class="lang-zh">黄金</span></a>
			<a href="#supply-chain-section"><span class="lang-en">Chain</span><span class="lang-zh">链上</span></a>
			<a href="#watchlist-section"><span class="lang-en">Watchlist</span><span class="lang-zh">观察池</span></a>
			<a href="#sector-research-section"><span class="lang-en">Sectors</span><span class="lang-zh">行业</span></a>
			<a href="#deep-research-section"><span class="lang-en">Research</span><span class="lang-zh">深度</span></a>
			<a href="#roundtable-section"><span class="lang-en">Roundtable</span><span class="lang-zh">圆桌</span></a>
			<a href="#clearance-section"><span class="lang-en">Trades</span><span class="lang-zh">交易</span></a>
			<a href="#methodology-section"><span class="lang-en">Methodology</span><span class="lang-zh">方法论</span></a>
			<button class="collapse-control" type="button" data-collapse-action="expand"><span class="lang-en">Expand all</span><span class="lang-zh">全部展开</span></button>
			<button class="collapse-control" type="button" data-collapse-action="collapse"><span class="lang-en">Collapse all</span><span class="lang-zh">全部折叠</span></button>
		</nav>

		{/* ═══ Allocation ═══ */}
		<section class="portfolio-section fade-in-up" data-collapse id="regime-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Macro Thermometer</span>
					<span class="lang-zh">宏观温度计</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">The market temperature we're trading against</span>
					<span class="lang-zh">我们在和什么样的市场做交易</span>
				</h2>
				<span class="section-summary"><span class="lang-en">Defensive · 1/4 green</span><span class="lang-zh">防御期 · 1/4 绿灯</span></span>
			</header>

			<div class="regime-lights">
				{Object.entries(regime?.current?.signals || {}).map(([, sig]) => (
					<div class="regime-light-card" style={`--light: ${lightColors[sig.light] || "#9ca3af"}`}>
						<span class="regime-light-label">{sig.label}</span>
						<strong class="regime-light-value font-serif">{sig.value}</strong>
						<span class="regime-light-dot" aria-hidden="true"></span>
					</div>
				))}
			</div>

			<div class="regime-chart-wrap">
				<div class="regime-chart-head">
					<h3 class="font-serif text-lg">
						<span class="lang-en">VIX & Regime · 60 days</span>
						<span class="lang-zh">VIX 与 Regime · 60 天</span>
					</h3>
					<p class="portfolio-note">
						<span class="lang-en">
							Shaded bands mark regime transitions (green = offensive, amber = neutral, red =
							defensive). VIX line is the mood overlay.
						</span>
						<span class="lang-zh">
							色段为 regime 状态（绿=进攻、黄=中性、红=防御）。VIX 折线是情绪指标。
						</span>
					</p>
				</div>
				{regime?.history_60d && regime.history_60d.length >= 7 ? (
					<div class="regime-chart-canvas-wrap">
						<canvas id="regimeChart" aria-hidden="true"></canvas>
					</div>
					<div id="regimeTooltip" class="regime-tooltip" style="display:none;">
						<div class="regime-tooltip-date"></div>
						<div class="regime-tooltip-regime"></div>
						<div class="regime-tooltip-signals"></div>
					</div>
				) : regime?.history_60d && regime.history_60d.length > 0 ? (
					<div
						class="regime-grid-fallback"
						aria-label="Signal history grid"
						style={`--days: ${regime.history_60d.length}`}
					>
						<div class="regime-grid-head-row">
							<div class="regime-grid-corner"></div>
							{regime.history_60d.map((h: any) => (
								<div class="regime-grid-date-label" title={h.date}>
									{h.date.slice(5)}
								</div>
							))}
						</div>
						{SIGNAL_ORDER.map((sig) => {
							const label = SIGNAL_LABELS[sig] || { en: sig.toUpperCase(), zh: sig.toUpperCase() };
							return (
								<div class="regime-grid-row">
									<div class="regime-grid-signal-label">
										<span class="lang-en">{label.en}</span>
										<span class="lang-zh">{label.zh}</span>
									</div>
									{regime.history_60d.map((h: any) => {
										const light = h.lights?.[sig] || "gray";
