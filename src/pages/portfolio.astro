---
import rawPortfolioData from "@/data/portfolio-public.json";
import PageLayout from "@/layouts/Base.astro";
import type { PortfolioData } from "@/components/portfolio/types";


const portfolioData = rawPortfolioData as unknown as PortfolioData;

const {
	regime,
	allocation,
	positions,
	crypto,
	crypto_monitor: cryptoMonitor,
	gold_tracker: goldTracker,
	watchlist_heatmap: heatmap,
	clearances,
	roundtables,
	sector_research = [],
	deep_research = [],
	stats,
	generated_at,
} = portfolioData;

// Derived: Fear & Greed Index
const fgi = cryptoMonitor?.macro?.fear_greed;

// Derived: BTC ETF daily flow


// Derived: Crypto timeseries for master chart
const cryptoTS = (portfolioData as any)?.crypto_timeseries;


const cryptoPositions = crypto?.positions ?? [];
const activePositionCount = positions.length + cryptoPositions.length;

// Derived: Gold Tracker
const goldSignal = goldTracker?.signal?.status ?? goldTracker?.signal?.signal ?? "yellow";
const goldSignalLabel = goldTracker?.signal?.label_en ?? goldTracker?.signal?.signal_label_en ?? "Watch";
const goldSignalLabelZh = goldTracker?.signal?.label_zh ?? goldTracker?.signal?.signal_label_zh ?? "观察";
const goldXau = goldTracker?.price?.xau_usd;
const goldDay = goldTracker?.price?.day_change_pct;
const goldPeak = goldTracker?.price?.peak_price ?? goldTracker?.price?.week_52_high;
const goldDrawdown = goldTracker?.price?.drawdown_from_peak_pct;
const goldM2Pct = Math.min(100, Math.max(0, goldTracker?.monetary?.m2_to_trigger_pct ?? 0));
const goldM2Label = goldTracker?.monetary?.inversion_label_en ?? goldSignalLabel;
const goldM2LabelZh = goldTracker?.monetary?.inversion_label_zh ?? goldSignalLabelZh;
const goldPremium = goldTracker?.premium?.premium_pct ?? goldTracker?.metrics?.premium_shanghai_pct;
const goldPremiumDate = goldTracker?.premium?.updated_at ?? goldTracker?.metrics?.premium_date ?? "manual";
const goldCycle = goldTracker?.metrics?.cycle_label_en ?? "Cycle watch";
const goldCycleZh = goldTracker?.metrics?.cycle_label_zh ?? "周期观察";
const goldStop = goldTracker?.signal?.stop_loss ?? goldTracker?.signal?.aisc_range?.[0] ?? goldTracker?.cost_floor?.aisc_usd ?? 1750;
const goldRangeHigh = goldTracker?.signal?.aisc_range?.[1] ?? goldStop;

// Group deep research by sector for organized display
const deepBySector = deep_research.reduce((acc: Record<string, { sector_en: string; sector_zh: string; items: any[] }>, d: any) => {
	const key = d.sector_en || "Unclassified";
	if (!acc[key]) acc[key] = { sector_en: d.sector_en || "Unclassified", sector_zh: d.sector_zh || "未分类", items: [] };
	acc[key].items.push(d);
	return acc;
}, {} as Record<string, { sector_en: string; sector_zh: string; items: any[] }>);
const deepSectors = Object.values(deepBySector);

const regimeColors: Record<string, string> = {
	进攻期: "#10b981",
	中性期: "#f59e0b",
	防御期: "#ef4444",
	Offensive: "#10b981",
	Neutral: "#f59e0b",
	Defensive: "#ef4444",
};

const lightColors: Record<string, string> = {
	green: "#10b981",
	yellow: "#f59e0b",
	red: "#ef4444",
	gray: "#9ca3af",
};
const conviction: Record<string, string> = { high: "🔥", medium: "🌱", low: "❄️" };

// Signal ordering + labels for the regime 5×N history grid (used when
// less than ~7 days of thermometer history are available — before the
// full 60-day line chart kicks in).
const SIGNAL_ORDER = ["tnx", "dxy", "vix", "naaim", "policy"] as const;
const SIGNAL_LABELS: Record<string, { en: string; zh: string }> = {
	tnx: { en: "10Y", zh: "10年美债" },
	dxy: { en: "DXY", zh: "美元指数" },
	vix: { en: "VIX", zh: "恐慌指数" },
	naaim: { en: "NAAIM", zh: "主动管理" },
	policy: { en: "Policy", zh: "政策" },
};

// Conviction bar colors (used for position confidence fill).
const convictionStroke: Record<string, string> = {
	high: "#8953d1",
	medium: "#10b981",
	low: "#9ca3af",
};

// ─── Topology layer data (dynamic from JSON, not hardcoded) ──
// const TOPO_LAYERS = [
// 	{ id: "L5", widthPct: 32, label_en: "AI Compute", label_zh: "AI 算力", sub_en: null, sub_zh: null },
// 	{ id: "L4", widthPct: 44, label_en: "Data Centers", label_zh: "数据中心", sub_en: "Demand Driver", sub_zh: "需求引擎" },
// 	{ id: "L3", widthPct: 58, label_en: "Power Equipment", label_zh: "电力设备", sub_en: null, sub_zh: null },
// 	{ id: "L2", widthPct: 74, label_en: "Transmission & Distribution", label_zh: "输配电", sub_en: null, sub_zh: null },
// 	{ id: "L1", widthPct: 100, label_en: "Baseload Generation", label_zh: "基荷发电", sub_en: null, sub_zh: null },
// ] as const;

// Build topology nodes from positions that have a layer assignment
const topoNodesByLayer: Record<string, { symbol: string; status: string }[]> = {};
for (const p of positions) {
	if (!p.layer) continue;
	const layerKey = p.layer;
	if (!topoNodesByLayer[layerKey]) topoNodesByLayer[layerKey] = [];
	// Determine tag style: held = active position, watch = watchlist candidate
	const status = "held";
	topoNodesByLayer[layerKey].push({ symbol: p.symbol, status });
}

// Add watchlist tickers that aren't in positions (e.g. ETN, HUBB at L3)
// These come from deep_research entries marked as in_portfolio=false
for (const d of deep_research) {
	if (!d.in_portfolio && d.ticker) {
		// Extract layer from sector_en like "Electrical (L3 Conversion)"
		const layerMatch = (d.sector_en || "").match(/\(L(\d)/);
		const layer = layerMatch ? `L${layerMatch[1]}` : null;
		if (layer) {
			if (!topoNodesByLayer[layer]) topoNodesByLayer[layer] = [];
			// Avoid duplicates
			if (!topoNodesByLayer[layer].some((n) => n.symbol === d.ticker)) {
				topoNodesByLayer[layer].push({ symbol: d.ticker, status: "watch" });
			}
		}
	}
}

const dataJson = JSON.stringify({
	regime,
	allocation,
	heatmap,
	positions,
	clearances,
	crypto_timeseries: cryptoTS,
	crypto_portfolio_history: (portfolioData as any)?.crypto_portfolio_history,
	allocation_history: (portfolioData as any)?.allocation_history,
});

const updatedLabel = new Date(generated_at).toISOString().split("T")[0];

const meta = {
	title: "Portfolio · Rex Liu",
	description:
		"Public portfolio dashboard — sectors, theses, stage-gated decisions, and trade replays. No amounts, just conviction.",
};

// Stage metadata (from investment decision framework v2.0)
const stages = [
	{
		num: 0,
		title_en: "Macro Thermometer",
		title_zh: "宏观温度计",
		purpose_en: "Read market regime: offensive / neutral / defensive",
		purpose_zh: "判断市场温度：进攻 / 中性 / 防御",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 1,
		title_en: "Sector Research",
		title_zh: "赛道研究",
		purpose_en: "1-2 day deep report before picking stocks",
		purpose_zh: "选股之前先做重度赛道报告",
		automated: false,
		badge_en: "Manual",
		badge_zh: "手动",
	},
	{
		num: 2,
		title_en: "Watchlist Scan",
		title_zh: "个股池初筛",
		purpose_en: "15 tickers, 5-dimension filter → 10-20 names",
		purpose_zh: "15 只标的五维扫描 → 10-20 家观察名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 3,
		title_en: "Short List",
		title_zh: "短名单",
		purpose_en: "Valuation + catalyst + technicals → 3-5 names",
		purpose_zh: "估值 + 催化 + 技术面 → 3-5 家可操作短名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 4,
		title_en: "Deep Research",
		title_zh: "深度研究",
		purpose_en: "Skill: 4+1 card per company, 3 hard theses",
		purpose_zh: "Skill：每家公司 4+1 段名片 + 三条硬结论",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 5,
		title_en: "Roundtable",
		title_zh: "圆桌讨论",
		purpose_en: "6-seat masters challenge the theses; dissent required",
		purpose_zh: "6 席位大师挑战结论；反方必选",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 6,
		title_en: "Execution Plan",
		title_zh: "执行计划",
		purpose_en: "10-point scorecard ≥7, R:R ≥ 2.0, 3 stop-lines",
		purpose_zh: "10 分评分卡 ≥7，R:R ≥ 2.0，3 条撤退线",
		automated: true,
		badge_en: "Scorecard",
		badge_zh: "评分卡",
	},
	{
		num: 7,
		title_en: "Position Management",
		title_zh: "持仓管理 + 复盘",
		purpose_en: "L0-L3 monitoring + monthly/quarterly/annual reviews",
		purpose_zh: "L0-L3 四层监控 + 月/季/年复盘",
		automated: true,
		badge_en: "4-tier",
		badge_zh: "四层",
	},
];
---

<PageLayout meta={meta}>
	<link
		slot="head"
		rel="preload"
		href="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"
		as="script"
	/>

<section class="portfolio-page">
	<div class="mb-6">
			<a
				href="/lab/"
				class="portfolio-breadcrumb font-serif text-sm transition-colors"
			>
				← Lab
			</a>
		</div>

		{/* ═══ Hero ═══ */}
		<section class="portfolio-hero">
			<p class="portfolio-eyebrow">
				<span class="lang-en">Build in Public · Portfolio</span>
				<span class="lang-zh">公开建造 · 持仓驾驶舱</span>
			</p>
			<div class="portfolio-hero-row">
				<div class="portfolio-hero-text">
					<h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">
						<span class="lang-en">Portfolio · Conviction on Display</span>
						<span class="lang-zh">持仓 · 公开的决策</span>
					</h1>
					<p class="portfolio-subtitle font-serif text-lg leading-relaxed sm:text-xl">
						<span class="lang-en">
							No amounts. Just sectors, theses, stages, and the scorecard behind every position.
						</span>
						<span class="lang-zh">
							不公开金额。只展示板块、逻辑、阶段，以及每个仓位背后的评分卡。
						</span>
					</p>
				</div>
				<div
					class="portfolio-regime-badge"
					style={`--regime-color: ${regimeColors[regime?.current?.label] || "#8953d1"}`}
				>
					<span class="portfolio-regime-eyebrow">
						<span class="lang-en">Current Regime</span>
						<span class="lang-zh">当前宏观</span>
					</span>
					<strong class="portfolio-regime-label font-serif">
						<span class="lang-en">{regime?.current?.label_en || "—"}</span>
						<span class="lang-zh">{regime?.current?.label || "—"}</span>
					</strong>
					<span class="portfolio-regime-meta">
						<span class="lang-en">
							{regime?.current?.green_count ?? 0} / {regime?.current?.total_signals ?? 5} green ·
							Aggression {regime?.current?.aggression ?? "—"}
						</span>
						<span class="lang-zh">
							{regime?.current?.green_count ?? 0}/{regime?.current?.total_signals ?? 5} 绿灯 ·
							激进度 {regime?.current?.aggression ?? "—"}
						</span>
					</span>
				</div>
			</div>

			<div class="portfolio-hero-stats" aria-label="Portfolio statistics">
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Active Positions</span>
						<span class="lang-zh">活跃持仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={activePositionCount}
					>
						{activePositionCount}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Markets</span>
						<span class="lang-zh">市场</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.markets}>
						{stats.markets}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Tracked Rules</span>
						<span class="lang-zh">监控规则</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.tracked_rules}>
						{stats.tracked_rules}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Upcoming Events</span>
						<span class="lang-zh">预告事件</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.upcoming_events}>
						{stats.upcoming_events}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Scan Hits (≥5)</span>
						<span class="lang-zh">扫描信号</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.weekly_scan_hits}>
						{stats.weekly_scan_hits}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Last Clearance</span>
						<span class="lang-zh">上次清仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.days_since_last_clearance ?? 0}
						data-count-suffix="d ago"
					>
						{stats.days_since_last_clearance ?? "—"}d ago
					</strong>
				</article>
			</div>

		<p class="portfolio-updated">
				<span class="lang-en">Last updated: {updatedLabel}</span>
				<span class="lang-zh">最后更新: {updatedLabel}</span>
			</p>
		</section>

		<nav class="portfolio-section-nav" aria-label="Section navigation">
			<a href="#allocation-section"><span class="lang-en">Allocation</span><span class="lang-zh">配置</span></a>
			<a href="#regime-section"><span class="lang-en">Regime</span><span class="lang-zh">宏观</span></a>
			<a href="#positions-section"><span class="lang-en">Positions</span><span class="lang-zh">持仓</span></a>
			{cryptoMonitor && <a href="#crypto-mgmt-section"><span class="lang-en">Crypto</span><span class="lang-zh">加密</span></a>}
			<a href="#gold-tracker-section"><span class="lang-en">Gold</span><span class="lang-zh">黄金</span></a>
			<a href="#supply-chain-section"><span class="lang-en">Chain</span><span class="lang-zh">链上</span></a>
			<a href="#watchlist-section"><span class="lang-en">Watchlist</span><span class="lang-zh">观察池</span></a>
			<a href="#sector-research-section"><span class="lang-en">Sectors</span><span class="lang-zh">行业</span></a>
			<a href="#deep-research-section"><span class="lang-en">Research</span><span class="lang-zh">深度</span></a>
			<a href="#roundtable-section"><span class="lang-en">Roundtable</span><span class="lang-zh">圆桌</span></a>
			<a href="#clearance-section"><span class="lang-en">Trades</span><span class="lang-zh">交易</span></a>
			<a href="#methodology-section"><span class="lang-en">Methodology</span><span class="lang-zh">方法论</span></a>
			<button class="collapse-control" type="button" data-collapse-action="expand"><span class="lang-en">Expand all</span><span class="lang-zh">全部展开</span></button>
			<button class="collapse-control" type="button" data-collapse-action="collapse"><span class="lang-en">Collapse all</span><span class="lang-zh">全部折叠</span></button>
		</nav>

		{/* ═══ Allocation ═══ */}
		<section class="portfolio-section fade-in-up" data-collapse id="regime-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Macro Thermometer</span>
					<span class="lang-zh">宏观温度计</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">The market temperature we're trading against</span>
					<span class="lang-zh">我们在和什么样的市场做交易</span>
				</h2>
				<span class="section-summary"><span class="lang-en">Defensive · 1/4 green</span><span class="lang-zh">防御期 · 1/4 绿灯</span></span>
			</header>

			<div class="regime-lights">
				{Object.entries(regime?.current?.signals || {}).map(([, sig]) => (
					<div class="regime-light-card" style={`--light: ${lightColors[sig.light] || "#9ca3af"}`}>
						<span class="regime-light-label">{sig.label}</span>
						<strong class="regime-light-value font-serif">{sig.value}</strong>
						<span class="regime-light-dot" aria-hidden="true"></span>
					</div>
				))}
			</div>

			<div class="regime-chart-wrap">
				<div class="regime-chart-head">
					<h3 class="font-serif text-lg">
						<span class="lang-en">VIX & Regime · 60 days</span>
						<span class="lang-zh">VIX 与 Regime · 60 天</span>
					</h3>
					<p class="portfolio-note">
						<span class="lang-en">
							Shaded bands mark regime transitions (green = offensive, amber = neutral, red =
							defensive). VIX line is the mood overlay.
						</span>
						<span class="lang-zh">
							色段为 regime 状态（绿=进攻、黄=中性、红=防御）。VIX 折线是情绪指标。
						</span>
					</p>
				</div>
				{regime?.history_60d && regime.history_60d.length >= 7 ? (
					<div class="regime-chart-canvas-wrap">
						<canvas id="regimeChart" aria-hidden="true"></canvas>
					</div>
					<div id="regimeTooltip" class="regime-tooltip" style="display:none;">
						<div class="regime-tooltip-date"></div>
						<div class="regime-tooltip-regime"></div>
						<div class="regime-tooltip-signals"></div>
					</div>
				) : regime?.history_60d && regime.history_60d.length > 0 ? (
					<div
						class="regime-grid-fallback"
						aria-label="Signal history grid"
						style={`--days: ${regime.history_60d.length}`}
					>
						<div class="regime-grid-head-row">
							<div class="regime-grid-corner"></div>
							{regime.history_60d.map((h: any) => (
								<div class="regime-grid-date-label" title={h.date}>
									{h.date.slice(5)}
								</div>
							))}
						</div>
						{SIGNAL_ORDER.map((sig) => {
							const label = SIGNAL_LABELS[sig] || { en: sig.toUpperCase(), zh: sig.toUpperCase() };
							return (
								<div class="regime-grid-row">
									<div class="regime-grid-signal-label">
										<span class="lang-en">{label.en}</span>
										<span class="lang-zh">{label.zh}</span>
									</div>
									{regime.history_60d.map((h: any) => {
										const light = h.lights?.[sig] || "gray";
										return (
											<div
												class={`regime-grid-cell light-${light}`}
												title={`${label.en} · ${h.date} · ${light}`}
											></div>
										);
									})}
								</div>
							);
							})}
						<p class="regime-grid-note">
							<span class="lang-en">
								{regime.history_60d.length} day(s) tracked · line chart activates at 7 days
							</span>
							<span class="lang-zh">
								已累积 {regime.history_60d.length} 天 · 满 7 天后切换为折线图
							</span>
						</p>
					</div>
				) : (
					<div class="portfolio-empty-overlay">
						<span class="lang-en">
							No history yet · check back after a few daily runs.
						</span>
						<span class="lang-zh">历史数据还未累积 · 日度任务跑几天后回来看。</span>
					</div>
				)}
			</div>
		</section>
	{/* ═══ Crypto Asset Management ═══ */}
	{cryptoMonitor && (
		<section class="portfolio-section fade-in-up" data-collapse id="crypto-mgmt-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Crypto Dashboard</span>
					<span class="lang-zh">加密看板</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">Crypto Market Intelligence</span>
					<span class="lang-zh">加密市场全景</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">Crypto radar, market temperature, and on-chain metrics.</span>
					<span class="lang-zh">加密雷达、市场温度与链上指标。</span>
				</p>
				<span class="section-summary">
					<span class="lang-en">Composite {(cryptoTS?.latest?.composite ?? (100 - (cryptoMonitor?.bottom_tracker?.score ?? 50))) ?? "—"}/100 · FGI {fgi?.value ?? "—"}</span>
					<span class="lang-zh">综合 {(cryptoTS?.latest?.composite ?? (100 - (cryptoMonitor?.bottom_tracker?.score ?? 50))) ?? "—"}/100 · FGI {fgi?.value ?? "—"}</span>
				</span>
			</header>

		{cryptoMonitor && cryptoTS && (
			<div class="crypto-dash-v2">
				{/* ── Layer 1: Semicircular Sentiment Gauge ── */}
				<div class="crypto-gauge-wrap">
					<p class="crypto-dash-card-title">
						<span class="lang-en">Market Pulse</span>
						<span class="lang-zh">市场脉搏</span>
					</p>
					{(() => {
						const score = cryptoTS?.latest?.composite ?? (100 - (cryptoMonitor?.bottom_tracker?.score ?? 50));
						const delta = cryptoTS?.latest?.delta_composite ?? 0;
						const cx = 150, cy = 138, R = 108, rI = 90;
						const sA = Math.PI;
						const scoreA = sA + (score / 100) * Math.PI;
						const sColor = score < 25 ? "#ef4444" : score < 50 ? "#f59e0b" : score < 75 ? "#10b981" : "#22c55e";
						const sLabel = score < 25 ? "Extreme Fear" : score < 50 ? "Fear" : score < 75 ? "Greed" : "Extreme Greed";
					const sLabelZh = score < 25 ? "极度恐惧" : score < 50 ? "恐惧" : score < 75 ? "贪婪" : "极度贪婪";

						const arc = (from: number, to: number) => {
							const a1 = sA + (from / 100) * Math.PI;
							const a2 = sA + (to / 100) * Math.PI;
							const ox1 = cx + R * Math.cos(a1), oy1 = cy + R * Math.sin(a1);
							const ox2 = cx + R * Math.cos(a2), oy2 = cy + R * Math.sin(a2);
							const ix2 = cx + rI * Math.cos(a2), iy2 = cy + rI * Math.sin(a2);
							const ix1 = cx + rI * Math.cos(a1), iy1 = cy + rI * Math.sin(a1);
							return `M ${ox1.toFixed(1)} ${oy1.toFixed(1)} A ${R} ${R} 0 0 1 ${ox2.toFixed(1)} ${oy2.toFixed(1)} L ${ix2.toFixed(1)} ${iy2.toFixed(1)} A ${rI} ${rI} 0 0 0 ${ix1.toFixed(1)} ${iy1.toFixed(1)} Z`;
						};

						const nR = R - 20;
						const nx = cx + nR * Math.cos(scoreA);
						const ny = cy + nR * Math.sin(scoreA);

						return (
							<>
								<svg viewBox="0 0 300 165" class="crypto-gauge-svg">
									<path d={arc(0, 100)} fill="color-mix(in srgb, var(--p-border) 40%, transparent)" />
									<path d={arc(0, 25)} fill="#ef4444" opacity="0.65" />
									<path d={arc(25, 50)} fill="#f59e0b" opacity="0.65" />
									<path d={arc(50, 75)} fill="#10b981" opacity="0.65" />
									<path d={arc(75, 100)} fill="#22c55e" opacity="0.65" />
									{[0, 25, 50, 75, 100].map((v: number) => {
										const a = sA + (v / 100) * Math.PI;
										const t1x = cx + (R + 6) * Math.cos(a), t1y = cy + (R + 6) * Math.sin(a);
										const t2x = cx + (R - 2) * Math.cos(a), t2y = cy + (R - 2) * Math.sin(a);
										return <line x1={t1x.toFixed(1)} y1={t1y.toFixed(1)} x2={t2x.toFixed(1)} y2={t2y.toFixed(1)} stroke="color-mix(in srgb, var(--p-text-faint) 60%, transparent)" stroke-width="1.5" />;
									})}
									{Array.from({ length: 20 }, (_, i: number) => {
										if (i % 5 === 0) return null;
										const v = i * 5;
										const a = sA + (v / 100) * Math.PI;
										const t1x = cx + (R + 3) * Math.cos(a), t1y = cy + (R + 3) * Math.sin(a);
										const t2x = cx + (R - 1) * Math.cos(a), t2y = cy + (R - 1) * Math.sin(a);
										return <line x1={t1x.toFixed(1)} y1={t1y.toFixed(1)} x2={t2x.toFixed(1)} y2={t2y.toFixed(1)} stroke="color-mix(in srgb, var(--p-text-faint) 25%, transparent)" stroke-width="0.7" />;
									})}
									<line x1={cx} y1={cy} x2={nx.toFixed(1)} y2={ny.toFixed(1)} stroke={sColor} stroke-width="2.5" stroke-linecap="round" />
									<circle cx={cx} cy={cy} r="5.5" fill={sColor} />
									<circle cx={cx} cy={cy} r="2.5" fill="var(--p-card)" />
										<text x="32" y="155" font-size="8.5" fill="color-mix(in srgb, var(--p-text-faint) 65%, transparent)" text-anchor="middle" font-family="var(--font-serif)"><tspan class="lang-en">Extreme Fear</tspan><tspan class="lang-zh">极度恐惧</tspan></text>
											<text x="268" y="155" font-size="8.5" fill="color-mix(in srgb, var(--p-text-faint) 65%, transparent)" text-anchor="middle" font-family="var(--font-serif)"><tspan class="lang-en">Extreme Greed</tspan><tspan class="lang-zh">极度贪婪</tspan></text>
								</svg>
							<div class="crypto-gauge-score">
								<span class="crypto-gauge-num" style={`color:${sColor}`}>{score}</span>
								<span class="crypto-gauge-max">/100</span>
								<span class="crypto-gauge-label" style={`color:${sColor}`}><span class="lang-en">{sLabel}</span><span class="lang-zh">{sLabelZh}</span></span>
							</div>
							{delta !== 0 && (
								<div class={`crypto-gauge-delta ${delta > 0 ? "up" : "down"}`}>
									{delta > 0 ? "↑" : "↓"} {Math.abs(delta)} <span class="lang-en">vs yesterday</span><span class="lang-zh">较昨日</span>
								</div>
							)}
							</>
						);
					})()}
				</div>

				{/* ── Layer 2: Bottom Tracker Indicator Table ── */}
						{(() => {
					const indicators = cryptoMonitor?.bottom_tracker?.indicators ?? [];
					if (indicators.length === 0) return null;
					return (
						<div class="crypto-indicators-wrap">
							<p class="crypto-dash-card-title">
								<span class="lang-en">Crypto Tracker Indicators</span>
								<span class="lang-zh">加密追踪指标</span>
							</p>
							<div class="crypto-ind-table">
								<div class="crypto-ind-row crypto-ind-header">
									<span class="crypto-ind-name"><span class="lang-en">Indicator</span><span class="lang-zh">指标</span></span>
									<span class="crypto-ind-status-head"><span class="lang-en">Status</span><span class="lang-zh">状态</span></span>
									<span class="crypto-ind-detail"><span class="lang-en">Detail</span><span class="lang-zh">详情</span></span>
									<span class="crypto-ind-delta-head"><span class="lang-en">Chg</span><span class="lang-zh">变化</span></span>
								</div>
							{indicators.map((ind: any) => {
								const stColor = ind.status === "green" ? "#10b981" : ind.status === "red" ? "#ef4444" : "#f59e0b";
								const d = ind.delta ?? ind.score_change;
								// Extract change value from detail text, move to CHG column
								const chgMatch = (ind.detail || "").match(/变化[:：]?\s*([+-]?\d+\.?\d*)/);
								const chgVal = chgMatch ? parseFloat(chgMatch[1]) : null;
								const chgColor = chgVal === null ? "var(--p-text-faint)" : chgVal > 0 ? "#10b981" : chgVal < 0 ? "#ef4444" : "var(--p-text-faint)";
								// Clean detail: remove the change portion
								const cleanDetail = chgMatch ? (ind.detail || "").replace(/[,，]?\s*变化[:：]?\s*[+-]?\d+\.?\d*/, "") : (ind.detail || "");
								const displayChg = chgVal !== null ? chgVal : d;
								return (
									<div class="crypto-ind-row" title={ind.desc_en || ind.desc_zh || ""}>
										<span class="crypto-ind-name"><span class="lang-en">{ind.name_en || ind.name}</span><span class="lang-zh">{ind.name_zh || ind.name}</span></span>
										<span class="crypto-ind-dot" style={`background:${stColor}`} />
										<span class="crypto-ind-detail">{cleanDetail || "—"}</span>
										{displayChg != null ? (
											<span class={`crypto-ind-chg-badge ${displayChg > 0 ? "up" : displayChg < 0 ? "down" : "flat"}`} style={displayChg !== null ? `color:${chgColor};background:${displayChg > 0 ? "rgba(16,185,129,.12)" : displayChg < 0 ? "rgba(239,68,68,.12)" : "rgba(107,114,128,.12)"}` : ""}>
												{displayChg > 0 ? "↑" : displayChg < 0 ? "↓" : "→"}{Math.abs(displayChg)}
											</span>
										) : (
											<span class="crypto-ind-chg-badge flat">—</span>
										)}
									</div>
								);
							})}
							</div>
						</div>
					);
				})()}

				{/* ── Layer 3: BTC Trend Chart + Side Cards ── */}
				<div class="crypto-chart-row">
					<div class="crypto-chart-wrap">
						<p class="crypto-dash-card-title">
							<span class="lang-en">BTC Price & Sentiment Trend</span>
							<span class="lang-zh">BTC 价格与情绪趋势</span>
						</p>
						<canvas id="cryptoBtcTrendChart" class="crypto-chart-canvas btc-trend-chart" aria-label="BTC Price and Sentiment Trend"></canvas>
						{(() => {
							const tsData = cryptoTS?.data ?? [];
							if (tsData.length < 2) return <p class="crypto-chart-empty"><span class="lang-en">Insufficient trend data</span><span class="lang-zh">趋势数据不足</span></p>;

							const W = 720, H = 280;
							const pad = { l: 48, r: 48, t: 14, b: 28 };
							const cW = W - pad.l - pad.r;
							const cH = H - pad.t - pad.b;

							const btcArr = tsData.map((d: any) => d.btc_close ?? 0).filter(Boolean);
							const btcMin = Math.min(...btcArr) * 0.97;
							const btcMax = Math.max(...btcArr) * 1.03;

							const xOf = (i: number) => pad.l + (i / Math.max(1, tsData.length - 1)) * cW;
							const yBtc = (v: number) => pad.t + cH - ((v - btcMin) / Math.max(1, btcMax - btcMin)) * cH;
							const yComp = (v: number) => pad.t + cH - (v / 100) * cH;

							const btcPts = tsData.map((d: any, i: number) => `${xOf(i).toFixed(1)},${yBtc(d.btc_close ?? 0).toFixed(1)}`).join(" ");
							const compPts = tsData.map((d: any, i: number) => d.composite != null ? `${xOf(i).toFixed(1)},${yComp(d.composite).toFixed(1)}` : null).filter(Boolean).join(" ");

							const gridRows = 4;
							const btcStep = (btcMax - btcMin) / gridRows;
							const labelStep = Math.max(1, Math.floor(tsData.length / 5));

							return (
								<svg viewBox={`0 0 ${W} ${H}`} class="crypto-chart-svg" preserveAspectRatio="xMidYMid meet">
									{Array.from({ length: gridRows + 1 }, (_, i: number) => {
										const y = (pad.t + (i / gridRows) * cH).toFixed(1);
										return <line x1={pad.l} y1={y} x2={W - pad.r} y2={y} stroke="color-mix(in srgb, var(--p-border) 35%, transparent)" stroke-width="0.5" />;
									})}
									<polygon
										points={`${pad.l},${(pad.t + cH).toFixed(1)} ${btcPts} ${xOf(tsData.length - 1).toFixed(1)},${(pad.t + cH).toFixed(1)}`}
										fill="color-mix(in srgb, #8953d1 8%, transparent)"
									/>
									<polyline points={btcPts} fill="none" stroke="#8953d1" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round" />
									{compPts && (
										<polyline points={compPts} fill="none" stroke="#f59e0b" stroke-width="1.2" stroke-dasharray="4 3" stroke-linejoin="round" stroke-linecap="round" opacity="0.85" />
									)}
									{Array.from({ length: gridRows + 1 }, (_, i: number) => {
										const val = btcMax - i * btcStep;
										const y = (pad.t + (i / gridRows) * cH).toFixed(1);
										return <text x={pad.l - 6} y={y} font-size="8" fill="color-mix(in srgb, var(--p-text-faint) 60%, transparent)" text-anchor="end" dominant-baseline="middle">{(val / 1000).toFixed(0)}K</text>;
									})}
									{[0, 25, 50, 75, 100].map((v: number) => (
										<text x={W - pad.r + 6} y={yComp(v).toFixed(1)} font-size="8" fill="#f59e0b" opacity="0.45" text-anchor="start" dominant-baseline="middle">{v}</text>
									))}
									{tsData.map((d: any, i: number) => {
										if (i % labelStep !== 0 && i !== tsData.length - 1) return null;
										const x = xOf(i).toFixed(1);
										const label = (d.date ?? "").slice(5);
										return <text x={x} y={H - 6} font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 50%, transparent)" text-anchor="middle">{label}</text>;
									})}
							<line x1={pad.l} y1="8" x2={pad.l + 16} y2="8" stroke="#8953d1" stroke-width="1.8" />
								<text x={pad.l + 20} y="8" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 70%, transparent)" dominant-baseline="middle"><tspan class="lang-en">BTC ($)</tspan><tspan class="lang-zh">BTC 价格</tspan></text>
								<line x1={pad.l + 62} y1="8" x2={pad.l + 78} y2="8" stroke="#f59e0b" stroke-width="1.2" stroke-dasharray="3 2" />
								<text x={pad.l + 82} y="8" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 70%, transparent)" dominant-baseline="middle"><tspan class="lang-en">Composite</tspan><tspan class="lang-zh">综合指数</tspan></text>
								</svg>
							);
						})()}
					</div>

{/* ── Layer 4: Portfolio Value Index + Metrics ── */}
				{(() => {
					const ph = (portfolioData as any)?.crypto_portfolio_history;
					if (!ph?.data || ph.data.length < 2) return null;
					const pts = ph.data;
					const met = ph.metrics;

					const W = 720, H = 240;
					const pad = { l: 44, r: 16, t: 14, b: 28 };
					const cW = W - pad.l - pad.r;
					const cH = H - pad.t - pad.b;

					const idxArr = pts.map((d: any) => d.index ?? 100);
					const iMin = Math.min(...idxArr) * 0.995;
					const iMax = Math.max(...idxArr) * 1.005;

					const xOf = (i: number) => pad.l + (i / Math.max(1, pts.length - 1)) * cW;
					const yIdx = (v: number) => pad.t + cH - ((v - iMin) / Math.max(0.1, iMax - iMin)) * cH;

					const linePts = pts.map((d: any, i: number) => `${xOf(i).toFixed(1)},${yIdx(d.index ?? 100).toFixed(1)}`).join(" ");

					const gridRows = 4;
					const labelStep = Math.max(1, Math.floor(pts.length / 6));

					return (
						<div class="crypto-portfolio-index-wrap">
							<p class="crypto-dash-card-title">
								<span class="lang-en">Portfolio Value Index</span>
								<span class="lang-zh">持仓价值指数</span>
							</p>
							<canvas id="cryptoPortfolioIndexChart" class="crypto-chart-canvas portfolio-index-chart" aria-label="Portfolio Value Index"></canvas>
							<svg viewBox={`0 0 ${W} ${H}`} class="crypto-chart-svg" preserveAspectRatio="xMidYMid meet">
								{Array.from({ length: gridRows + 1 }, (_, i: number) => {
									const y = (pad.t + (i / gridRows) * cH).toFixed(1);
									return <line x1={pad.l} y1={y} x2={W - pad.r} y2={y} stroke="color-mix(in srgb, var(--p-border) 35%, transparent)" stroke-width="0.5" />;
								})}
								<polygon
									points={`${pad.l},${(pad.t + cH).toFixed(1)} ${linePts} ${xOf(pts.length - 1).toFixed(1)},${(pad.t + cH).toFixed(1)}`}
									fill="color-mix(in srgb, #10b981 8%, transparent)"
								/>
								<polyline points={linePts} fill="none" stroke="#10b981" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round" />
								{Array.from({ length: gridRows + 1 }, (_, i: number) => {
									const val = iMax - (i / gridRows) * (iMax - iMin);
									const y = (pad.t + (i / gridRows) * cH).toFixed(1);
									return <text x={pad.l - 6} y={y} font-size="8" fill="color-mix(in srgb, var(--p-text-faint) 60%, transparent)" text-anchor="end" dominant-baseline="middle">{val.toFixed(1)}</text>;
								})}
								{pts.map((d: any, i: number) => {
									if (i % labelStep !== 0 && i !== pts.length - 1) return null;
									const x = xOf(i).toFixed(1);
									const label = (d.date ?? "").slice(2);
									return <text x={x} y={H - 6} font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 50%, transparent)" text-anchor="middle">{label}</text>;
								})}
								<text x={W - pad.r} y="10" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 50%, transparent)" text-anchor="end"><span class="lang-en">Indexed (base=100)</span><span class="lang-zh">基准=100</span></text>
							</svg>
							<div class="crypto-portfolio-metrics">
								<div class="cpm-item">
									<span class="cpm-label"><span class="lang-en">Max DD</span><span class="lang-zh">最大回撤</span></span>
									<span class="cpm-value" style={`color:${met.max_drawdown_pct < -5 ? "#ef4444" : "#10b981"}`}>{met.max_drawdown_pct}%</span>
								</div>
								<div class="cpm-item">
									<span class="cpm-label"><span class="lang-en">Current DD</span><span class="lang-zh">当前回撤</span></span>
									<span class="cpm-value" style={`color:${met.current_drawdown_pct < -3 ? "#ef4444" : met.current_drawdown_pct < 0 ? "#f59e0b" : "#10b981"}`}>{met.current_drawdown_pct > 0 ? "+" : ""}{met.current_drawdown_pct}%</span>
								</div>
								<div class="cpm-item">
									<span class="cpm-label"><span class="lang-en">BTC Beta</span><span class="lang-zh">BTC Beta</span></span>
									<span class="cpm-value" style={`color:${met.btc_beta < 0.3 ? "#10b981" : met.btc_beta < 0.7 ? "#f59e0b" : "#ef4444"}`}>{met.btc_beta}</span>
								</div>
								<div class="cpm-item">
									<span class="cpm-label"><span class="lang-en">Ann. Vol</span><span class="lang-zh">年化波动</span></span>
									<span class="cpm-value" style={`color:${met.annualized_volatility < 15 ? "#10b981" : met.annualized_volatility < 30 ? "#f59e0b" : "#ef4444"}`}>{met.annualized_volatility}%</span>
								</div>
							</div>
						</div>
					);
				})()}

{/* ── Layer 5: Allocation Drift Trend ── */}
				{(() => {
					const ah = (portfolioData as any)?.allocation_history?.history;
					if (!ah || ah.length < 2) return null;

					const buckets = allocation.current.categories;
					const idToKey = {
						"stablecoin": "stablecoin_yield",
						"funds": "funds_etf",
						"stocks": "stocks",
						"crypto": "crypto"
					};

					const W = 720, H = 220;
					const pad = { l: 44, r: 16, t: 14, b: 28 };
					const cW = W - pad.l - pad.r;
					const cH = H - pad.t - pad.b;

					const xOf = (i: number) => pad.l + (i / Math.max(1, ah.length - 1)) * cW;
					const yPct = (v: number) => pad.t + cH - (v / 60) * cH;

					return (
						<div class="crypto-alloc-trend-wrap">
							<p class="crypto-dash-card-title">
								<span class="lang-en">Allocation Drift</span>
								<span class="lang-zh">配置偏移趋势</span>
							</p>
							<canvas id="cryptoAllocationDriftChart" class="crypto-chart-canvas allocation-drift-chart" aria-label="Allocation Drift"></canvas>
							<svg viewBox={`0 0 ${W} ${H}`} class="crypto-chart-svg" preserveAspectRatio="xMidYMid meet">
								{[0, 15, 30, 45].map(v => (
									<>
										<line x1={pad.l} y1={yPct(v).toFixed(1)} x2={W - pad.r} y2={yPct(v).toFixed(1)} stroke="color-mix(in srgb, var(--p-border) 35%, transparent)" stroke-width="0.5" />
										<text x={pad.l - 6} y={yPct(v).toFixed(1)} font-size="8" fill="color-mix(in srgb, var(--p-text-faint) 60%, transparent)" text-anchor="end" dominant-baseline="middle">{v}%</text>
									</>
								))}
								{buckets.map((b: any) => {
									const key = idToKey[b.id as keyof typeof idToKey];
									if (!key) return null;
									const linePts = ah.map((h: any, i: number) => {
										const v = h.buckets?.[key] ?? 0;
										return `${xOf(i).toFixed(1)},${yPct(v).toFixed(1)}`;
									}).join(" ");
									const current = ah[ah.length - 1]?.buckets?.[key] ?? 0;
									const target = b.target_pct;
									const isDrifted = Math.abs(current - target) >= 5;
									return (
										<>
											<polyline points={linePts} fill="none" stroke={b.color} stroke-width={isDrifted ? "2.2" : "1.5"} stroke-linejoin="round" stroke-linecap="round" stroke-dasharray={isDrifted ? "none" : "4 2"} opacity={isDrifted ? "1" : "0.6"} />
											<line x1={pad.l} y1={yPct(target).toFixed(1)} x2={W - pad.r} y2={yPct(target).toFixed(1)} stroke={b.color} stroke-width="0.6" stroke-dasharray="2 4" opacity="0.35" />
										</>
									);
								})}
								{ah.map((h: any, i: number) => {
									const x = xOf(i).toFixed(1);
									return <text x={x} y={H - 6} font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 50%, transparent)" text-anchor="middle">{h.date}</text>;
								})}
								{buckets.map((b: any, i: number) => {
									const lx = pad.l + i * 110;
									return (
										<>
											<line x1={lx} y1="10" x2={lx + 14} y2="10" stroke={b.color} stroke-width="1.8" />
											<text x={lx + 18} y="10" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 70%, transparent)" dominant-baseline="middle"><tspan class="lang-en">{b.label_en}</tspan><tspan class="lang-zh">{b.label_zh}</tspan></text>
										</>
									);
								})}
								<text x={W - pad.r} y="10" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 45%, transparent)" text-anchor="end"><span class="lang-en">- - target</span><span class="lang-zh">- - 目标</span></text>
							</svg>
						</div>
					);
				})()}


</div>
			</div>
		)}
		</section>

		<section class="portfolio-section fade-in-up gold-tracker-section" data-collapse id="gold-tracker-section">
			<header class="portfolio-section-head">
