	[data-theme="light"] .crypto-ind-header span { border-bottom-color:rgba(0,0,0,0.06); }
	.crypto-ind-name { font-size:.82rem; padding:.35rem 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
	.crypto-ind-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
