	/* ── Layer 2: Indicator Table ── */
	.crypto-indicators-wrap { background:rgba(255,255,255,0.03); border-radius:.75rem; padding:1rem; }
	[data-theme="light"] .crypto-indicators-wrap { background:rgba(0,0,0,0.03); }
	.crypto-ind-table { display:grid; grid-template-columns:1.5fr auto 2fr auto; gap:0 .75rem; align-items:center; }
	.crypto-ind-row { display:contents; }
