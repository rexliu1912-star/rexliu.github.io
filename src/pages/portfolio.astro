	.crypto-portfolio-index-wrap > .crypto-chart-svg,
	.crypto-alloc-trend-wrap > .crypto-chart-svg,
	.crypto-portfolio-index-wrap > .lang-en,
	.crypto-portfolio-index-wrap > .lang-zh,
