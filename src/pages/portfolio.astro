												<span class="lang-en">{g.name_en || g.name}</span>
												<span class="lang-zh">{g.name}</span>
											</strong>
											{g.mbti && <span class="roundtable-guest-mbti">{g.mbti}</span>}
										</header>
										<span class="roundtable-guest-role">
											<span class="lang-en">{g.role_en}</span>
											<span class="lang-zh">{g.role_zh}</span>
										</span>
										{(g.position_en || g.position_zh) && (
											<p class="roundtable-guest-position">
												<span class="lang-en">{g.position_en}</span>
												<span class="lang-zh">{g.position_zh}</span>
											</p>
										)}
									</article>
								);
							})}
						</div>

						{r.rounds && r.rounds.length > 0 && (
							<ol class="roundtable-rounds">
								{r.rounds.map((rd: any, idx: number) => (
									<li class="round-card">
										<header class="round-head">
											<span class="round-index font-serif">{idx + 1}</span>
											<h4 class="round-title font-serif">
												<span class="lang-en">{rd.title_en}</span>
												<span class="lang-zh">{rd.title_zh}</span>
											</h4>
										</header>
										{(rd.core_tension_en || rd.core_tension_zh) && (
											<p class="round-tension">
												<span class="lang-en">{rd.core_tension_en}</span>
												<span class="lang-zh">{rd.core_tension_zh}</span>
											</p>
										)}
										{(rd.fork_en || rd.fork_zh) && (
											<p class="round-fork">
												<strong class="round-fork-label">
													<span class="lang-en">Fork ·</span>
													<span class="lang-zh">分岔 ·</span>
												</strong>{" "}
												<span class="lang-en">{rd.fork_en}</span>
												<span class="lang-zh">{rd.fork_zh}</span>
											</p>
										)}
									</li>
								))}
							</ol>
						)}

						<blockquote class="roundtable-verdict">
							<span class="roundtable-verdict-label">
								<span class="lang-en">Final Verdict</span>
								<span class="lang-zh">最终结论</span>
							</span>
							<span class="lang-en">{r.final_verdict_en || ""}</span>
							<span class="lang-zh">{r.final_verdict_zh || r.final_verdict_en || ""}</span>
						</blockquote>

						{((r.implications_en && r.implications_en.length > 0) ||
							(r.implications_zh && r.implications_zh.length > 0)) && (
							<div class="roundtable-implications">
								<h4 class="roundtable-implications-title font-serif">
									<span class="lang-en">Actionable Implications</span>
									<span class="lang-zh">可执行结论</span>
								</h4>
								<ul class="roundtable-implications-list">
									{(r.implications_en || r.implications_zh || []).map((_: any, i: number) => (
										<li class="roundtable-implication">
											<span class="lang-en">
												{r.implications_en?.[i] || r.implications_zh?.[i] || ""}
											</span>
											<span class="lang-zh">
												{r.implications_zh?.[i] || r.implications_en?.[i] || ""}
											</span>
										</li>
									))}
								</ul>
							</div>
						)}
					</article>
				))
				) : (
					<div class="portfolio-empty">
						<span class="lang-en">
							No roundtables yet. Roundtables are triggered when a position thesis needs stress-testing from multiple perspectives.
						</span>
						<span class="lang-zh">
							还没有圆桌记录。圆桌在持仓逻辑需要多视角压力测试时触发。
						</span>
					</div>
				)}
			</div>
		</section>
		<section class="portfolio-section fade-in-up" data-collapse id="methodology-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Methodology · 8-Stage Funnel</span>
					<span class="lang-zh">方法论 · 八阶段漏斗</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">From macro thermometer to post-trade review</span>
					<span class="lang-zh">从宏观温度计到持仓复盘</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Every position passes through these stages. Some are automated cron tasks, some
						require human judgment. Round-trip is weeks, not days.
					</span>
					<span class="lang-zh">
					每个持仓都要走过这些阶段。部分是自动 cron，部分需要人工判断。完整走一圈以周为单位，不是天。
				</span>
			</p>
			<span class="section-summary"><span class="lang-en">8-stage funnel · automated + manual</span><span class="lang-zh">八阶段漏斗 · 自动 + 人工</span></span>
		</header>

			<div class="stage-zigzag">
				{stages.map((s, i) => (
					<article class={`stage-card ${i % 2 === 0 ? "stage-left" : "stage-right"}`}>
						<div class="stage-number-wrap">
							<span class="stage-number font-serif">{s.num}</span>
						</div>
						<div class="stage-body">
							<header class="stage-head">
								<h3 class="stage-title font-serif">
									<span class="lang-en">{s.title_en}</span>
									<span class="lang-zh">{s.title_zh}</span>
								</h3>
								<span class={`stage-badge ${s.automated ? "automated" : "manual"}`}>
									{s.automated ? "✓" : "○"}{" "}
									<span class="lang-en">{s.badge_en}</span>
									<span class="lang-zh">{s.badge_zh}</span>
								</span>
							</header>
							<p class="stage-purpose">
								<span class="lang-en">{s.purpose_en}</span>
								<span class="lang-zh">{s.purpose_zh}</span>
							</p>
							{s.num === 0 && (
								<div class="stage-inline-thermo">
									{Object.entries(regime?.current?.signals || {}).map(([, sig]) => (
										<span
											class="stage-inline-light"
											style={`--mini-light: ${lightColors[sig.light] || "#9ca3af"}`}
											title={`${sig.label}: ${sig.value}`}
										></span>
									))}
								</div>
							)}
							{s.num === 2 && heatmap && heatmap.tickers.length > 0 && (
								<p class="stage-inline-meta">
									<span class="lang-en">{heatmap.tickers.length} tickers in scan pool</span>
									<span class="lang-zh">{heatmap.tickers.length} 只标的在观察池</span>
								</p>
							)}
							{s.num === 6 && (
								<div class="stage-scorecard">
									<span class="stage-scorecard-pill">MA200</span>
									<span class="stage-scorecard-pill">支撑</span>
									<span class="stage-scorecard-pill">RSI</span>
									<span class="stage-scorecard-pill">量价</span>
									<span class="stage-scorecard-pill stage-scorecard-pill-primary">
										R:R ≥ 2.0
									</span>
									<span class="stage-scorecard-hint">
										<span class="lang-en">Score ≥ 7 / 10 to trade</span>
										<span class="lang-zh">≥ 7/10 才下单</span>
									</span>
								</div>
							)}
							{s.num === 7 && (
								<div class="stage-cadence">
									<span class="stage-cadence-badge">
										<span class="lang-en">Monthly</span>
										<span class="lang-zh">月度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Quarterly</span>
										<span class="lang-zh">季度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Annual</span>
										<span class="lang-zh">年度</span>
									</span>
								</div>
							)}
						</div>
					</article>
				))}
			</div>
		</section>
	</section>

	<script is:inline id="portfolio-data" type="application/json" set:html={dataJson}></script>
	{/* Rain canvas effect — moved to Base.astro for site-wide support */}
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
	<script is:inline>
		function __initPortfolioAnimate() {
			const page = document.querySelector('.portfolio-page');
			if (!page || page.dataset.portfolioReady === 'true') return;
			page.dataset.portfolioReady = 'true';
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (!reduce) {
				const fadeIn = (el, delay, dur) => {
					if (!el) return;
					el.style.opacity = '0';
					el.style.animation = `lucky-fade-up ${dur || 420}ms ease ${delay}ms forwards`;
				};
				fadeIn(page.querySelector('.portfolio-eyebrow'), 280);
				const title = page.querySelector('.portfolio-hero h1');
				if (title && !title.dataset.animated) {
					title.dataset.animated = 'true';
					const zh = (document.documentElement.getAttribute('data-lang') || 'en') === 'zh';
					const span = title.querySelector(zh ? '.lang-zh' : '.lang-en');
					if (span) {
						const text = span.textContent || '';
						let d = 460;
						if (zh) {
							span.innerHTML = [...text]
								.map((c) => {
									if (!c.trim()) return c;
									const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up .38s ease ${d}ms forwards">${c}</span>`;
									d += 38;
									return s;
								})
								.join('');
						} else {
							span.innerHTML = text
								.trim()
								.split(/\s+/)
								.map((w) => {
									const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up .38s ease ${d}ms forwards">${w}</span>`;
									d += 38;
									return s;
								})
								.join(' ');
						}
					}
				}
				fadeIn(page.querySelector('.portfolio-subtitle'), 760);
				fadeIn(page.querySelector('.portfolio-regime-badge'), 820);
				const cards = Array.from(page.querySelectorAll('.portfolio-stat-card'));
				cards.forEach((c, i) => fadeIn(c, 900 + i * 62));
				fadeIn(page.querySelector('.portfolio-updated'), 900 + cards.length * 62 + 80);
			}

			// CountUp for stat cards
			setTimeout(() => {
				if (reduce) return;
				page.querySelectorAll('.portfolio-stat-value[data-count-target]').forEach((el) => {
					const target = Number(el.dataset.countTarget);
					if (!target || Number.isNaN(target)) return;
					const suffix = el.dataset.countSuffix || '';
					const prefix = el.dataset.countPrefix || '';
					const dur = 1100;
					const t0 = performance.now();
					el.textContent = `${prefix}0${suffix}`;
					const tick = (now) => {
						const p = Math.min((now - t0) / dur, 1);
						const e = 1 - (1 - p) ** 3;
						el.textContent = prefix + Math.round(target * e).toLocaleString() + suffix;
						if (p < 1) requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				});
			}, 900);

			// Scroll-triggered fade-up for non-hero sections. Each section has
			// `.portfolio-section.fade-in-up`; when it enters the viewport we
			// toggle `.is-visible` once (unobserve after). Reduce-motion skips.
			if (!reduce && 'IntersectionObserver' in window) {
				const sections = Array.from(
					page.querySelectorAll('.portfolio-section.fade-in-up')
				);
				if (sections.length) {
					const io = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('is-visible');
									io.unobserve(entry.target);
								}
							});
						},
						{ rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
					);
					sections.forEach((s) => io.observe(s));
				}
			} else {
				// Reduce-motion or no IO support — show everything immediately.
				page.querySelectorAll('.portfolio-section.fade-in-up').forEach((s) =>
					s.classList.add('is-visible')
				);
				// Also show animated sub-elements immediately
				page.querySelectorAll('.allocation-donut-wrap, .heatmap-wrap, .stage-zigzag').forEach((el) =>
					el.classList.add('is-visible')
				);
			}

			// Sub-section scroll animations: donut arcs, heatmap cells, methodology cards
			if (!reduce && 'IntersectionObserver' in window) {
				const animEls = Array.from(
					page.querySelectorAll('.allocation-donut-wrap, .heatmap-wrap, .stage-zigzag')
				);
				if (animEls.length) {
					const aio = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('is-visible');
									aio.unobserve(entry.target);
								}
							});
						},
						{ rootMargin: '0px 0px -8% 0px', threshold: 0.1 }
					);
					animEls.forEach((el) => aio.observe(el));
				}
			}

		// Collapsible portfolio sections — title-click toggle + summaries.
		if (page.dataset.portfolioCollapseReady !== 'true') {
			page.dataset.portfolioCollapseReady = 'true';
			const key = 'portfolio-sections';
			const defaultOpen = new Set([
				'allocation-section',
				'regime-section',
				'positions-section',
				'crypto-mgmt-section',
				'gold-tracker-section',
			]);
			const allSections = () => /** @type {HTMLElement[]} */ ([...page.querySelectorAll('[data-collapse]')].filter(s => s.id));
			let state = {};
			try { state = JSON.parse(localStorage.getItem(key) || '{}') || {}; } catch {}
			const sectionIsOpen = (section) => Object.prototype.hasOwnProperty.call(state, section.id)
				? Boolean(state[section.id])
				: defaultOpen.has(section.id);
			const persist = () => localStorage.setItem(key, JSON.stringify(state));

			// Toggle one section
			const toggleSection = (section, forceOpen) => {
				const willBeCollapsed = forceOpen !== undefined ? !forceOpen : !section.classList.contains('is-collapsed');
				section.classList.toggle('is-collapsed', willBeCollapsed);
				const chevron = section.querySelector('.section-chevron');
				if (chevron) chevron.textContent = willBeCollapsed ? '▶' : '▼';
				state[section.id] = !willBeCollapsed;
				persist();
			};

			// Init each section: add chevron to h2, make header clickable
			page.querySelectorAll('[data-collapse]').forEach((section) => {
				const head = section.querySelector('.portfolio-section-head');
				if (!head || !section.id) return;
				const h2 = head.querySelector('h2');
				if (!h2) return;

				// Add chevron
				const chevron = document.createElement('span');
				chevron.className = 'section-chevron';
				h2.appendChild(chevron);

				// Header click toggles (but not if clicking a link inside)
				head.style.cursor = 'pointer';
				head.addEventListener('click', (e) => {
					if (e.target.closest('a, button')) return;
					toggleSection(section);
				});

				// Initial state
				const collapsed = !sectionIsOpen(section);
				section.classList.toggle('is-collapsed', collapsed);
				chevron.textContent = collapsed ? '▶' : '▼';
			});

			// Expand / Collapse all buttons
			page.querySelectorAll('[data-collapse-action]').forEach((btn) => btn.addEventListener('click', () => {
				const open = btn.dataset.collapseAction === 'expand';
				allSections().forEach(s => toggleSection(s, open));
			}));


			// Anchor highlight — brief pulse when clicking a nav link
			page.querySelectorAll('a[href^="#"]').forEach((link) => {
				link.addEventListener('click', () => {
					const id = link.getAttribute('href')?.slice(1);
					if (!id) return;
					const target = document.getElementById(id);
					if (!target) return;
					// Ensure section is open if it's a collapsible section
					if (target.hasAttribute('data-collapse') && target.classList.contains('is-collapsed')) {
						toggleSection(target, true);
					}
					target.classList.remove('section-highlight');
					void target.offsetWidth; // reflow to restart animation
					target.classList.add('section-highlight');
					target.addEventListener('animationend', () => target.classList.remove('section-highlight'), { once: true });
				});
			});
		}

		}


		function __initGoldTracker() {
			const page = document.querySelector('.portfolio-page');
			if (!page || page.dataset.goldTrackerReady === 'true') return;
			page.dataset.goldTrackerReady = 'true';
			page.querySelectorAll('.gold-tracker-dash').forEach((dash) => {
				const slider = dash.querySelector('[data-gold-slider]');
				const rr = dash.querySelector('[data-gold-rr]');
				const entryLabel = dash.querySelector('[data-gold-entry]');
				if (!slider || !rr || !entryLabel) return;
				const stop = Number(dash.dataset.stop || 0);
				const target = Number(dash.dataset.target || 0);
				const fmt = (n) => '$' + Math.round(n).toLocaleString();
				const update = () => {
					const entry = Number(slider.value || dash.dataset.entry || 0);
					const risk = Math.max(1, entry - stop);
					const reward = Math.max(0, target - entry);
					rr.textContent = (reward / risk).toFixed(2) + '×';
					entryLabel.textContent = fmt(entry);
				};
				slider.addEventListener('input', update);
				update();
			});
		}

		function __initPortfolioCharts() {
			if (typeof window.Chart === 'undefined') return;
			const dataEl = document.getElementById('portfolio-data');
			if (!dataEl) return;
			let data;
			try {
				data = JSON.parse(dataEl.textContent || '{}');
			} catch {
				return;
			}

			const isDark = () => document.documentElement.getAttribute('data-theme') !== 'light';
			const axisColor = () => (isDark() ? 'rgba(255,255,255,0.48)' : 'rgba(30,20,50,0.52)');
			const gridColor = () => (isDark() ? 'rgba(255,255,255,0.08)' : 'rgba(30,20,50,0.08)');

			const chartFont = () => ({ family: 'Inter, system-ui, sans-serif', size: 11 });
			const chartOptions = (extra = {}) => ({
				responsive: true,
				maintainAspectRatio: false,
				animation: { duration: 700, easing: 'easeOutQuart' },
				interaction: { mode: 'index', intersect: false },
				plugins: {
					legend: {
						display: true,
						position: 'top',
						align: 'start',
						labels: { color: axisColor(), usePointStyle: true, pointStyle: 'line', boxWidth: 28, font: chartFont() },
					},
					tooltip: {
						backgroundColor: isDark() ? 'rgba(21,21,21,0.94)' : 'rgba(255,248,235,0.96)',
						titleColor: isDark() ? '#f5f3ed' : '#171717',
						bodyColor: axisColor(),
						borderColor: gridColor(),
						borderWidth: 1,
						displayColors: true,
					},
				},
				...extra,
			});

			const btcTrendCanvas = document.getElementById('cryptoBtcTrendChart');
			const cryptoTsData = data.crypto_timeseries?.data || [];
			if (btcTrendCanvas && cryptoTsData.length >= 2) {
				if (Chart.getChart(btcTrendCanvas)) Chart.getChart(btcTrendCanvas).destroy();
				new Chart(btcTrendCanvas, {
					type: 'line',
					data: {
						labels: cryptoTsData.map((d) => d.date),
						datasets: [
							{
								label: 'BTC',
								data: cryptoTsData.map((d) => d.btc_close || null),
								borderColor: '#8953d1',
								backgroundColor: 'rgba(137,83,209,0.12)',
								borderWidth: 2.2,
								tension: 0.32,
								fill: true,
								pointRadius: 0,
								pointHoverRadius: 4,
								yAxisID: 'y',
							},
							{
								label: 'Composite',
								data: cryptoTsData.map((d) => d.composite == null ? null : d.composite),
								borderColor: '#f59e0b',
								backgroundColor: 'rgba(245,158,11,0.05)',
								borderWidth: 1.8,
								borderDash: [5, 4],
								tension: 0.28,
								spanGaps: true,
								pointRadius: 0,
								pointHoverRadius: 4,
								yAxisID: 'y1',
							},
						],
					},
					options: chartOptions({
						scales: {
							x: { ticks: { color: axisColor(), maxTicksLimit: 7, font: chartFont() }, grid: { color: gridColor() } },
							y: { position: 'left', ticks: { color: axisColor(), callback: (v) => '$' + Math.round(v / 1000) + 'K', font: chartFont() }, grid: { color: gridColor() } },
							y1: { position: 'right', min: 0, max: 100, ticks: { color: '#f59e0b', font: chartFont() }, grid: { drawOnChartArea: false } },
						},
					}),
				});
			}

			const portfolioIndexCanvas = document.getElementById('cryptoPortfolioIndexChart');
			const portfolioHistory = data.crypto_portfolio_history?.data || [];
			if (portfolioIndexCanvas && portfolioHistory.length >= 2) {
				if (Chart.getChart(portfolioIndexCanvas)) Chart.getChart(portfolioIndexCanvas).destroy();
				new Chart(portfolioIndexCanvas, {
					type: 'line',
					data: {
						labels: portfolioHistory.map((d) => d.date),
						datasets: [{
							label: 'Index',
							data: portfolioHistory.map((d) => d.index || null),
							borderColor: '#10b981',
							backgroundColor: 'rgba(16,185,129,0.12)',
							borderWidth: 2.2,
							tension: 0.32,
							fill: true,
							pointRadius: 0,
							pointHoverRadius: 4,
						}],
					},
					options: chartOptions({
						plugins: { legend: { display: false } },
						scales: {
							x: { ticks: { color: axisColor(), maxTicksLimit: 7, font: chartFont() }, grid: { color: gridColor() } },
							y: { ticks: { color: axisColor(), font: chartFont() }, grid: { color: gridColor() } },
						},
					}),
				});
			}

			const allocationDriftCanvas = document.getElementById('cryptoAllocationDriftChart');
			const allocationHistory = data.allocation_history?.history || [];
			const allocationBuckets = data.allocation?.current?.categories || [];
			if (allocationDriftCanvas && allocationHistory.length >= 2 && allocationBuckets.length) {
				if (Chart.getChart(allocationDriftCanvas)) Chart.getChart(allocationDriftCanvas).destroy();
				const datasets = [];
				allocationBuckets.forEach((bucket) => {
					const color = bucket.color || '#8953d1';
					datasets.push({
						label: bucket.label_en || bucket.id,
						data: allocationHistory.map((h) => h.buckets?.[bucket.id] ?? null),
						borderColor: color,
						backgroundColor: color,
						borderWidth: Math.abs((bucket.current_pct || 0) - (bucket.target_pct || 0)) >= 5 ? 2.4 : 1.7,
						tension: 0.3,
						fill: false,
						pointRadius: 2,
						pointHoverRadius: 5,
					});
					datasets.push({
						label: (bucket.label_en || bucket.id) + ' target',
						data: allocationHistory.map(() => bucket.target_pct),
						borderColor: color,
						backgroundColor: color,
						borderWidth: 1,
						borderDash: [3, 5],
						pointRadius: 0,
						tension: 0,
					});
				});
				new Chart(allocationDriftCanvas, {
					type: 'line',
					data: { labels: allocationHistory.map((h) => h.date), datasets },
					options: chartOptions({
						plugins: {
							legend: {
								display: true,
								position: 'top',
								align: 'start',
								labels: {
									color: axisColor(),
									font: chartFont(),
									filter: (item) => !String(item.text || '').includes(' target'),
								},
							},
						},
						scales: {
							x: { ticks: { color: axisColor(), font: chartFont() }, grid: { color: gridColor() } },
							y: { suggestedMin: 0, suggestedMax: 45, ticks: { color: axisColor(), callback: (v) => v + '%', font: chartFont() }, grid: { color: gridColor() } },
						},
					}),
				});
			}


			// Regime VIX chart (interactive version)
			const regimeCanvas = document.getElementById('regimeChart');
			if (regimeCanvas && data.regime?.history_60d?.length >= 2) {
				if (Chart.getChart(regimeCanvas)) Chart.getChart(regimeCanvas).destroy();
				const history = data.regime.history_60d;

				const regimeColors = {
					'进攻期': { bg: 'rgba(16, 185, 129, 0.10)', border: 'rgba(16, 185, 129, 0.35)', label: 'Offensive' },
					'中性期': { bg: 'rgba(245, 158, 11, 0.08)', border: 'rgba(245, 158, 11, 0.30)', label: 'Neutral' },
					'防御期': { bg: 'rgba(239, 68, 68, 0.08)', border: 'rgba(239, 68, 68, 0.30)', label: 'Defensive' },
				};

				const signalLabels = {
					tnx: { en: '10Y UST', zh: '10年美债' },
					dxy: { en: 'DXY', zh: '美元指数' },
					vix: { en: 'VIX', zh: '恐慌指数' },
					naaim: { en: 'NAAIM', zh: '主动管理' },
					policy: { en: 'Policy', zh: '政策' },
				};
				const lightDotColors = { green: '#10b981', yellow: '#f59e0b', red: '#ef4444', gray: '#9ca3af' };

				// Plugin: regime background bands
				const regimeBandsPlugin = {
					id: 'regimeBands',
					beforeDraw(chart) {
						const { ctx, chartArea, scales } = chart;
						if (!chartArea) return;
						const xScale = scales.x;

						// Group consecutive days by regime
						let segments = [];
						let segStart = 0;
						for (let i = 1; i <= history.length; i++) {
							const curRegime = history[i]?.regime;
							const prevRegime = history[i - 1]?.regime;
							if (i === history.length || curRegime !== prevRegime) {
								segments.push({ start: segStart, end: i - 1, regime: prevRegime });
								segStart = i;
							}
						}

						segments.forEach(seg => {
							const colors = regimeColors[seg.regime] || regimeColors['中性期'];
							const x1 = xScale.getPixelForValue(seg.start);
							const x2 = xScale.getPixelForValue(seg.end);
							ctx.save();
							ctx.fillStyle = colors.bg;
							ctx.fillRect(x1, chartArea.top, x2 - x1, chartArea.bottom - chartArea.top);
							// Top border line
							ctx.strokeStyle = colors.border;
							ctx.lineWidth = 2;
							ctx.beginPath();
							ctx.moveTo(x1, chartArea.top);
							ctx.lineTo(x2, chartArea.top);
							ctx.stroke();
							ctx.restore();
						});
					}
				};

				// External HTML tooltip. Render from the nearest active point, not from raw cursor position.
				const tooltipEl = document.getElementById('regimeTooltip');

				const normalizeSignalDetail = (detail) => {
					if (typeof detail === 'string') return { light: detail, value: '-', status: null };
					return detail || { light: 'gray', value: '-', status: null };
				};

				const renderRegimeTooltip = (chart, idx, pointX, pointY) => {
					if (!tooltipEl) return;
					const h = history[idx];
					if (!h) {
						tooltipEl.style.display = 'none';
						return;
					}

					const colors = regimeColors[h.regime] || regimeColors['中性期'];
					const isZh = document.documentElement.getAttribute('data-lang') !== 'en';
					const signals = h.signalDetails || h.lights || {};
					let signalsHtml = '';

					for (const [key, labelObj] of Object.entries(signalLabels)) {
						const detail = normalizeSignalDetail(signals[key]);
						const light = detail.light || 'gray';
						const value = detail.value ?? '-';
						const status = detail.status ? ` <span class="regime-signal-status">${detail.status}</span>` : '';
						const dotColor = lightDotColors[light] || lightDotColors.gray;
						const label = isZh ? labelObj.zh : labelObj.en;
						signalsHtml += `<div class="regime-signal-row">
							<span class="regime-signal-dot" style="background:${dotColor}"></span>
							<span class="regime-signal-name">${label}</span>
							<span class="regime-signal-value">${value}${status}</span>
						</div>`;
					}

					const regimeLabel = isZh ? h.regime : (colors.label || h.regime);
					const totalSignals = Object.keys(signals).length || 5;
					const greenInfo = `${h.green_count}/${totalSignals} ${isZh ? '绿灯' : 'green'}`;

					tooltipEl.innerHTML = `
						<div class="regime-tooltip-date">${h.date} · VIX ${h.vix ?? '-'}</div>
						<div class="regime-tooltip-regime" style="--regime-color:${colors.border}">
							<strong>${regimeLabel}</strong> · ${greenInfo}
						</div>
						<div class="regime-tooltip-signals">${signalsHtml}</div>
					`;
					tooltipEl.style.display = 'block';

					const canvasRect = chart.canvas.getBoundingClientRect();
					const tooltipRect = tooltipEl.getBoundingClientRect();
					const x = Number.isFinite(pointX) ? pointX : chart.scales.x.getPixelForValue(idx);
					const y = Number.isFinite(pointY) ? pointY : chart.scales.y.getPixelForValue(h.vix);
					let left = canvasRect.left + x + 12;
					let top = canvasRect.top + y - tooltipRect.height / 2;

					if (left + tooltipRect.width > window.innerWidth - 16) {
						left = canvasRect.left + x - tooltipRect.width - 12;
					}
					if (top < 8) top = 8;
					if (top + tooltipRect.height > window.innerHeight - 8) top = window.innerHeight - tooltipRect.height - 8;

					tooltipEl.style.left = left + 'px';
					tooltipEl.style.top = top + 'px';
				};

				const externalTooltipHandler = (context) => {
					const { chart, tooltip } = context;
					if (!tooltipEl) return;
					if (tooltip.opacity === 0) {
						tooltipEl.style.display = 'none';
						return;
					}
					const point = tooltip.dataPoints?.[0];
					if (!point) return;
					renderRegimeTooltip(chart, point.dataIndex, tooltip.caretX, tooltip.caretY);
				};

				const regimeChart = new Chart(regimeCanvas, {
					type: 'line',
					data: {
						labels: history.map((h) => h.date),
						datasets: [
							{
								label: 'VIX',
								data: history.map((h) => h.vix),
								borderColor: '#8953d1',
								backgroundColor: 'rgba(137, 83, 209, 0.12)',
								fill: true,
								tension: 0.28,
								pointRadius: 2,
								pointHoverRadius: 5,
								pointHitRadius: 10,
								borderWidth: 2,
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						interaction: {
							mode: 'index',
							intersect: false,
						},
						plugins: {
							legend: { display: false },
							tooltip: {
								enabled: false,
								external: externalTooltipHandler,
							},
						},
						scales: {
							x: {
								ticks: { color: axisColor(), maxTicksLimit: 8 },
								grid: { color: gridColor() },
							},
							y: {
								ticks: { color: axisColor() },
								grid: { color: gridColor() },
							},
						},
					},
					plugins: [regimeBandsPlugin],
				});

				regimeCanvas.addEventListener('mousemove', (event) => {
					const points = regimeChart.getElementsAtEventForMode(event, 'nearest', { intersect: false }, false);
					const point = points?.[0];
					if (!point) return;
					const element = regimeChart.getDatasetMeta(point.datasetIndex).data[point.index];
					regimeChart.setActiveElements([{ datasetIndex: point.datasetIndex, index: point.index }]);
					regimeChart.tooltip?.setActiveElements(
						[{ datasetIndex: point.datasetIndex, index: point.index }],
						{ x: element.x, y: element.y }
					);
					regimeChart.update('none');
					renderRegimeTooltip(regimeChart, point.index, element.x, element.y);
				});

				// Hide tooltip on mouse leave
				regimeCanvas.addEventListener('mouseleave', () => {
					if (tooltipEl) tooltipEl.style.display = 'none';
					regimeChart.setActiveElements([]);
					regimeChart.tooltip?.setActiveElements([], { x: 0, y: 0 });
					regimeChart.update('none');
				});
			}

			// Clearance mini-charts (trade-points scatter + connecting line)
			document.querySelectorAll('.clearance-chart').forEach((canvas) => {
				const idx = Number(canvas.dataset.clearanceIdx);
				const c = data.clearances?.[idx];
				if (!c || !c.trade_points || c.trade_points.length < 2) return;
				if (Chart.getChart(canvas)) Chart.getChart(canvas).destroy();
				// Build a price timeline from trade points. Fallback to index-based x if no dates.
				const pts = c.trade_points
					.filter((tp) => tp.price != null)
					.map((tp) => ({
						x: tp.date,
						y: tp.price,
						label: tp.action_zh || tp.action_en || tp.action || '',
						kind: tp.kind || '',
					}));
				if (pts.length < 2) {
					// No price history — show placeholder instead of misleading synthetic curve
					const wrap = canvas.parentElement;
					if (wrap) {
						wrap.innerHTML = `
							<div class="clearance-chart-empty">
								<span class="lang-en">No price history</span>
								<span class="lang-zh">无逐笔价格记录</span>
							</div>`;
					}
					return;
				}
				new Chart(canvas, {
					type: 'line',
					data: {
						labels: pts.map((p) => p.x),
						datasets: [
							{
								label: c.ticker,
								data: pts.map((p) => p.y),
								borderColor: '#8953d1',
								backgroundColor: 'rgba(137, 83, 209, 0.12)',
								fill: true,
								tension: 0.3,
								pointRadius: 5,
								pointBackgroundColor: (ctx) => {
									const p = pts[ctx.dataIndex] || {};
									const k = p.kind || '';
									const act = p.label || '';
									if (k === 'entry' || k === 'add' || act.includes('建仓') || act.includes('买') || act.includes('加仓')) return '#10b981';
									if (k === 'exit' || k === 'sell' || k === 'stopped' || act.includes('清仓') || act.includes('卖') || act.includes('减仓')) return '#ef4444';
									return '#f59e0b';
								},
								pointBorderColor: '#fff',
								pointBorderWidth: 2,
								borderWidth: 2,
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								callbacks: {
									label: (ctx) => `${pts[ctx.dataIndex].label}: ${ctx.parsed.y}`,
								},
							},
						},
						scales: {
							x: { ticks: { color: axisColor(), maxTicksLimit: 6 }, grid: { color: gridColor() } },
							y: { ticks: { color: axisColor() }, grid: { color: gridColor() } },
						},
					},
				});
			});
		}

		function __runPortfolio() {
			__initPortfolioAnimate();
			__initPortfolioCharts();
			__initGoldTracker();
			__initCatalystCountdown();
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', __runPortfolio, { once: true });
		} else {
			__runPortfolio();
		}
		document.addEventListener('astro:page-load', __runPortfolio);
		// Re-init charts on theme change
		document.addEventListener('themechange', __initPortfolioCharts);

		function __initCatalystCountdown() {
			const now = new Date();
			now.setHours(0, 0, 0, 0);
			const isZh = (document.documentElement.getAttribute('data-lang') || 'en') === 'zh';

			// Position card pills
			const pills = document.querySelectorAll('.position-event[data-event-date]');
			pills.forEach((pill) => {
				const d = pill.getAttribute('data-event-date');
				if (!d) return;
				const target = new Date(d + 'T00:00:00');
				const diff = Math.ceil((target - now) / 86400000);
				const cd = pill.querySelector('.event-countdown');
				if (!cd) return;
				if (diff < 0) {
					pill.classList.add('event-past');
					return;
				}
				if (diff === 0) {
					cd.textContent = isZh ? '⏱ 今天' : '⏱ Today';
				} else if (diff === 1) {
					cd.textContent = isZh ? '⏱ 明天' : '⏱ Tomorrow';
				} else {
					cd.textContent = isZh ? `⏱ ${diff}天后` : `⏱ ${diff}d`;
				}
				const label = pill.querySelector('.event-label');
				if (label) label.title = d + ' · ' + (pill.getAttribute('data-event-label') || '');
		});
		}
	</script>

