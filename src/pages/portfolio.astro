			color: var(--p-text-faint);
		}
		.portfolio-regime-label {
			font-size: clamp(1.8rem, 4vw, 2.4rem);
			line-height: 1;
			color: var(--regime-color, #8953d1);
		}
		.portfolio-regime-meta {
			font-size: 0.84rem;
			color: var(--p-text-soft);
		}
		.portfolio-hero-stats {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.85rem;
		}
		@media (min-width: 640px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		@media (min-width: 1024px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(6, minmax(0, 1fr));
			}
		}
		.portfolio-stat-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			backdrop-filter: blur(16px);
			border-radius: 1.1rem;
			padding: 0.9rem 1rem;
		}
		.portfolio-stat-label {
			display: block;
			margin-bottom: 0.35rem;
			font-size: 0.68rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.portfolio-stat-value {
			font-size: clamp(1.35rem, 2.6vw, 1.85rem);
			line-height: 1.05;
		}
		.portfolio-updated {
			margin: 0;
			font-size: 0.78rem;
			color: var(--p-text-faint);
		}

		/* ── Section head ────────────────────────── */
		.portfolio-section {
			display: grid;
			gap: 1.5rem;
		}
		.portfolio-section-head {
			display: grid;
			gap: 0.55rem;
			max-width: 52rem;
		}
		.portfolio-note {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.94rem;
			line-height: 1.7;
		}

		/* ── Regime lights ───────────────────────── */
		.regime-lights {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.7rem;
		}
		@media (min-width: 640px) {
			.regime-lights {
				grid-template-columns: repeat(5, minmax(0, 1fr));
			}
		}
		.regime-light-card {
			position: relative;
			padding: 0.9rem 1rem;
			border-radius: 1.15rem;
			border: 1px solid color-mix(in srgb, var(--light) 35%, var(--p-border));
			background: color-mix(in srgb, var(--light) 8%, var(--p-card));
			display: grid;
			gap: 0.35rem;
		}
		.regime-light-label {
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.regime-light-value {
			font-size: clamp(1.1rem, 2.2vw, 1.4rem);
			color: var(--p-text);
		}
		.regime-light-dot {
			position: absolute;
			top: 0.85rem;
			right: 0.9rem;
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			background: var(--light);
			box-shadow: 0 0 14px color-mix(in srgb, var(--light) 80%, transparent);
		}

		.regime-chart-wrap {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.25rem 1.25rem 1rem;
			display: grid;
			gap: 0.8rem;
		}
		.regime-chart-head {
			display: grid;
			gap: 0.4rem;
		}
		.regime-chart-canvas-wrap {
			position: relative;
			height: 220px;
		}
		#regimeChart {
			width: 100%;
			height: 100%;
		}
		.portfolio-empty-overlay {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			padding: 1rem;
			text-align: center;
			font-size: 0.9rem;
			color: var(--p-text-faint);
			background: color-mix(in srgb, var(--p-card) 88%, transparent);
			border-radius: 0.75rem;
		}

		/* ── Allocation ──────────────────────────── */
		.allocation-bar {
			display: flex;
			height: 3.5rem;
			border-radius: 1.1rem;
			overflow: hidden;
			box-shadow: 0 8px 32px rgba(137, 83, 209, 0.12);
		}
		.allocation-segment {
			position: relative;
			display: grid;
			place-items: center;
			color: #fff;
			text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
		}
		.allocation-segment-label {
			display: grid;
			justify-items: center;
			gap: 0.1rem;
			font-size: 0.74rem;
			letter-spacing: 0.08em;
		}
		.allocation-segment-pct {
			font-family: Georgia, serif;
			font-size: 0.95rem;
		}
		.allocation-subcards {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 768px) {
			.allocation-subcards {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.allocation-subcards {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}
		}
		.allocation-subcard {
			border: 1px solid color-mix(in srgb, var(--cat-color) 25%, var(--p-border));
			background: color-mix(in srgb, var(--cat-color) 5%, var(--p-card));
			border-radius: 1.15rem;
			padding: 1rem 1.1rem;
			display: grid;
			gap: 0.65rem;
		}
		.allocation-subcard-head {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.allocation-subcard-dot {
			width: 0.6rem;
			height: 0.6rem;
			border-radius: 999px;
			background: var(--cat-color);
			box-shadow: 0 0 12px var(--cat-color);
		}
		.allocation-subcard-title {
			margin: 0;
			font-size: 1.05rem;
			flex: 1;
		}
		.allocation-drift-chip {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			font-weight: 600;
		}
		.allocation-drift-chip.positive {
			color: #10b981;
			background: rgba(16, 185, 129, 0.12);
		}
		.allocation-drift-chip.negative {
			color: #ef4444;
			background: rgba(239, 68, 68, 0.12);
		}
		.allocation-subcard-stats {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.6rem;
		}
		.allocation-subcard-stats > div {
			display: grid;
			gap: 0.2rem;
		}
		.allocation-subcard-eyebrow {
			font-size: 0.66rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.allocation-subcard-stats strong {
			font-size: 1.4rem;
			line-height: 1;
		}
		.allocation-subcard-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.allocation-tag {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: color-mix(in srgb, var(--cat-color) 16%, transparent);
			color: var(--p-text-soft);
		}
		.allocation-subcard-note {
			margin: 0;
			font-size: 0.85rem;
			color: var(--p-text-soft);
			line-height: 1.55;
		}
		.allocation-sub-mini {
			display: grid;
			gap: 0.35rem;
			padding-top: 0.55rem;
			border-top: 1px dashed color-mix(in srgb, var(--cat-color) 30%, transparent);
		}
		.allocation-sub-mini-row {
			display: grid;
			grid-template-columns: auto 1fr auto;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.78rem;
			color: var(--p-text-soft);
		}
		.allocation-sub-mini-bar {
			height: 0.45rem;
			border-radius: 999px;
			background: linear-gradient(
				90deg,
				var(--cat-color) 0,
				var(--cat-color) var(--sub-pct, 0%),
				color-mix(in srgb, var(--cat-color) 14%, transparent) var(--sub-pct, 0%)
			);
		}

		/* ── 8-Stage Zigzag ──────────────────────── */
		.stage-zigzag {
			display: grid;
			gap: 1.1rem;
		}
		.stage-card {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 1rem;
			padding: 1.15rem 1.25rem;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			backdrop-filter: blur(18px);
		}
		@media (min-width: 900px) {
			.stage-card.stage-left {
				margin-right: 18%;
			}
			.stage-card.stage-right {
				margin-left: 18%;
			}
		}
		.stage-number-wrap {
			display: grid;
			place-items: center;
			width: 3.2rem;
			height: 3.2rem;
			border-radius: 1rem;
			background: linear-gradient(135deg, rgba(137, 83, 209, 0.25), rgba(137, 83, 209, 0.05));
			border: 1px solid rgba(137, 83, 209, 0.35);
		}
		.stage-number {
			font-size: 1.8rem;
			line-height: 1;
			color: #8953d1;
		}
		.stage-body {
			display: grid;
			gap: 0.55rem;
		}
		.stage-head {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.6rem;
		}
		.stage-title {
			margin: 0;
			font-size: 1.15rem;
		}
		.stage-badge {
			font-size: 0.72rem;
			padding: 0.18rem 0.55rem;
			border-radius: 999px;
			letter-spacing: 0.04em;
		}
		.stage-badge.automated {
			background: rgba(16, 185, 129, 0.15);
			color: #10b981;
			border: 1px solid rgba(16, 185, 129, 0.3);
		}
		.stage-badge.manual {
			background: rgba(156, 163, 175, 0.15);
			color: #9ca3af;
			border: 1px solid rgba(156, 163, 175, 0.3);
		}
		.stage-purpose {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.92rem;
			line-height: 1.6;
		}
		.stage-inline-thermo {
			display: flex;
			gap: 0.35rem;
			margin-top: 0.35rem;
		}
		.stage-inline-light {
			width: 0.8rem;
			height: 0.8rem;
			border-radius: 999px;
			background: var(--mini-light);
			box-shadow: 0 0 10px color-mix(in srgb, var(--mini-light) 70%, transparent);
		}
		.stage-inline-meta {
			margin: 0.35rem 0 0;
			font-size: 0.82rem;
			color: var(--p-text-faint);
		}
		.stage-scorecard {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
			align-items: center;
			margin-top: 0.3rem;
		}
		.stage-scorecard-pill {
			font-size: 0.7rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.12);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
		}
		.stage-scorecard-pill-primary {
			background: rgba(137, 83, 209, 0.28);
			color: #fff;
			border-color: rgba(137, 83, 209, 0.5);
		}
		.stage-scorecard-hint {
			font-size: 0.74rem;
			color: var(--p-text-faint);
		}
		.stage-cadence {
			display: flex;
			gap: 0.4rem;
			margin-top: 0.3rem;
		}
		.stage-cadence-badge {
			font-size: 0.74rem;
			padding: 0.22rem 0.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.14);
			color: var(--p-text-soft);
		}

		/* ── Heatmap ─────────────────────────────── */
		.heatmap-wrap {
			overflow-x: auto;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 0.9rem;
		}
		.heatmap-grid {
			display: grid;
			gap: 3px;
			min-width: fit-content;
		}
		.heatmap-corner {
			grid-column: 1;
			grid-row: 1;
		}
		.heatmap-date-label {
			font-size: 0.62rem;
			color: var(--p-text-faint);
			text-align: center;
			writing-mode: vertical-rl;
			transform: rotate(180deg);
			padding: 0.2rem 0;
			min-width: 1.2rem;
		}
		.heatmap-ticker-label {
			font-size: 0.78rem;
			font-weight: 600;
			color: var(--p-text);
			padding-right: 0.6rem;
			text-align: right;
			white-space: nowrap;
			display: grid;
			align-items: center;
		}
		.heatmap-ticker-label small {
			display: block;
			font-size: 0.64rem;
			font-weight: 400;
			color: var(--p-text-faint);
		}
		.heatmap-cell {
			min-width: 1.2rem;
			height: 1.8rem;
			border-radius: 3px;
			position: relative;
			display: grid;
			place-items: center;
		}
		.heatmap-cell-mark {
			color: #fff;
			font-size: 0.6rem;
			line-height: 1;
		}

		/* ── Positions Grid ──────────────────────── */
		.positions-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 720px) {
			.positions-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.positions-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		.position-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.1rem 1.15rem;
			display: grid;
			gap: 0.7rem;
			transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
		}
		.position-card:hover {
			transform: translateY(-2px);
			border-color: rgba(137, 83, 209, 0.35);
			box-shadow: 0 12px 40px rgba(137, 83, 209, 0.12);
		}
		.position-card.conviction-high {
			border-color: rgba(137, 83, 209, 0.28);
		}
		.position-head {
			display: grid;
			gap: 0.55rem;
		}
		.position-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
		}
		.position-symbol {
			font-size: 1.55rem;
			line-height: 1;
		}
		.position-flag {
			font-size: 1rem;
		}
		.position-conviction-icon {
			margin-left: auto;
			font-size: 1rem;
		}
		.position-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.3rem;
		}
		.position-tag {
			font-size: 0.7rem;
			padding: 0.18rem 0.5rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.13);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
		}
		.position-thesis {
			margin: 0;
			font-size: 0.9rem;
			line-height: 1.6;
			color: var(--p-text-soft);
			border-left: 2px solid rgba(137, 83, 209, 0.4);
			padding-left: 0.85rem;
		}
		.position-meta {
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.position-stage-badge {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.2);
			color: #c9b4f5;
		}
		.position-status {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.08);
			color: var(--p-text-faint);
		}
		:global(html[data-theme='light']) .position-status {
			background: rgba(30, 20, 50, 0.06);
		}
		.position-foot {
			display: flex;
			flex-direction: column;
			gap: 0.45rem;
			padding-top: 0.55rem;
			border-top: 1px dashed var(--p-border);
			font-size: 0.82rem;
		}
		.position-stop {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
		}
		.position-stop.severity-red {
			color: #ef4444;
		}
		.position-stop.severity-yellow {
			color: #f59e0b;
		}
		.position-stop.severity-gray {
			color: var(--p-text-faint);
		}
		.position-stop-empty,
		.position-event-empty {
			color: var(--p-text-faint);
			font-size: 0.78rem;
		}
		.position-event {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			color: var(--p-text-soft);
		}
		.position-event time {
			font-weight: 600;
		}
		.position-event.urgency-3 time {
			color: #ef4444;
		}

		/* ── Clearance Gallery ───────────────────── */
		.clearance-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		@media (min-width: 900px) {
			.clearance-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		.clearance-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.35rem;
			padding: 1.3rem;
			display: grid;
			gap: 0.95rem;
		}
		.clearance-card.outcome-win {
			border-color: rgba(16, 185, 129, 0.28);
		}
		.clearance-card.outcome-loss {
			border-color: rgba(239, 68, 68, 0.28);
		}
		.clearance-head {
			display: grid;
			gap: 0.5rem;
		}
		.clearance-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.65rem;
		}
		.clearance-symbol {
			font-size: 1.4rem;
			color: var(--p-text);
		}
		.clearance-name {
			font-size: 0.95rem;
			color: var(--p-text-soft);
		}
		.clearance-meta-row {
			display: flex;
			align-items: center;
			gap: 0.7rem;
		}
		.clearance-pct {
			font-family: Georgia, serif;
			font-size: 1.6rem;
			font-weight: 700;
			line-height: 1;
		}
		.clearance-card.outcome-win .clearance-pct {
			color: #10b981;
		}
		.clearance-card.outcome-loss .clearance-pct {
			color: #ef4444;
		}
		.clearance-days {
			font-size: 0.82rem;
			color: var(--p-text-faint);
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.05);
		}
		:global(html[data-theme='light']) .clearance-days {
			background: rgba(30, 20, 50, 0.06);
		}
		.clearance-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.clearance-chart-wrap {
			height: 180px;
			position: relative;
		}
		.clearance-chart {
			width: 100% !important;
			height: 100% !important;
		}
		.clearance-trade-points {
			display: grid;
			gap: 0.35rem;
			padding: 0.75rem 0.8rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.05);
		}
		.trade-point-row {
			display: grid;
			grid-template-columns: auto auto auto 1fr;
			gap: 0.55rem;
			align-items: baseline;
			font-size: 0.76rem;
		}
		@media (max-width: 600px) {
			.trade-point-row {
				grid-template-columns: auto 1fr;
				grid-template-areas: 'd a' 'p n' 'n n';
			}
			.trade-point-row time {
				grid-area: d;
			}
			.trade-point-row strong {
				grid-area: a;
			}
		}
		.trade-point-date {
			color: var(--p-text-faint);
			font-family: Georgia, serif;
		}
		.trade-point-action {
			color: var(--p-text);
			font-weight: 600;
		}
		.trade-point-price {
			color: var(--p-text-soft);
			font-family: Georgia, serif;
		}
		.trade-point-note {
			color: var(--p-text-faint);
			font-size: 0.74rem;
		}
		.clearance-foot {
			display: grid;
			gap: 0.55rem;
