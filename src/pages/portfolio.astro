---
import rawPortfolioData from "@/data/portfolio-public.json";
import PageLayout from "@/layouts/Base.astro";

// ─── Public portfolio shape ──────────────────────────────
// The generated JSON has many optional/null fields (stop=null when no stop
// rule, watchlist_heatmap=null until scan data accrues, etc.). TypeScript's
// inference from the JSON literal would lock these into `null` types and
// break narrowing at every call site; so we hand-type the surface we use.
interface PortfolioSignal {
	label: string;
	value: string;
	light: string;
}
interface PortfolioStop {
	level_pct_from_current: string;
	severity: string;
	description?: string;
}
interface PortfolioTarget {
	price_pct_from_current: string | null;
	description?: string;
	optimistic_price?: string | null;
}
interface PortfolioNextEvent {
	date: string;
	label: string;
	urgency: string;
}
interface PortfolioPosition {
	symbol: string;
	market: string;
	flag: string;
	sector_tags_en: string[];
	sector_tags_zh: string[];
	thesis_en: string;
	thesis_zh: string;
	stage: number;
	status_en: string;
	status_zh: string;
	conviction: string;
	entry_year?: number;
	horizon?: string;
	stop?: PortfolioStop | null;
	target?: PortfolioTarget | null;
	next_event?: PortfolioNextEvent | null;
}
interface PortfolioHeatmap {
	tickers: string[];
	dates: string[];
	scores: (number | null)[][];
	ticker_names: Record<string, string>;
}
interface PortfolioRegimeCurrent {
	label: string;
	label_en: string;
	aggression: string;
	green_count: number;
	total_signals?: number;
	signals: Record<string, PortfolioSignal>;
}
interface PortfolioRegimeHistoryPoint {
	date: string;
	regime: string;
	green_count: number;
	vix: number | null;
}
interface PortfolioData {
	regime: { current: PortfolioRegimeCurrent; history_60d: PortfolioRegimeHistoryPoint[] };
	allocation: { current: { categories: any[] } };
	positions: PortfolioPosition[];
	watchlist_heatmap: PortfolioHeatmap | null;
	clearances: any[];
	roundtables: any[];
	sector_research?: any[];
	deep_research?: any[];
	short_list?: any[];
	stats: {
		active_positions: number;
		markets: number;
		tracked_rules: number;
		upcoming_events: number;
		weekly_scan_hits: number;
		days_since_last_clearance: number | null;
	};
	generated_at: string;
}

const portfolioData = rawPortfolioData as unknown as PortfolioData;

const {
	regime,
	allocation,
	positions,
	watchlist_heatmap: heatmap,
	clearances,
	roundtables,
	sector_research = [],
	deep_research = [],
	stats,
	generated_at,
} = portfolioData;

const regimeColors: Record<string, string> = {
	进攻期: "#10b981",
	中性期: "#f59e0b",
	防御期: "#ef4444",
	Offensive: "#10b981",
	Neutral: "#f59e0b",
	Defensive: "#ef4444",
};

const lightColors: Record<string, string> = {
	green: "#10b981",
	yellow: "#f59e0b",
	red: "#ef4444",
	gray: "#9ca3af",
};
const conviction: Record<string, string> = { high: "🔥", medium: "🌱", low: "❄️" };

// Signal ordering + labels for the regime 5×N history grid (used when
// less than ~7 days of thermometer history are available — before the
// full 60-day line chart kicks in).
const SIGNAL_ORDER = ["tnx", "dxy", "vix", "naaim", "policy"] as const;
const SIGNAL_LABELS: Record<string, string> = {
	tnx: "10Y",
	dxy: "DXY",
	vix: "VIX",
	naaim: "NAAIM",
	policy: "Policy",
};

// Deterministic per-position trajectory SVG path (visual filler — NOT
// financial data). Seeded off the ticker so each card gets a stable,
// unique-looking smooth curve; conviction nudges the end-point upward.
// Height / width are the SVG viewport values.
function trajectoryPath(seed: string, conviction: string, w: number, h: number): string {
	let hash = 0;
	for (let i = 0; i < seed.length; i++) hash = ((hash * 31 + seed.charCodeAt(i)) >>> 0) >>> 0;
	const steps = 12;
	const raw: number[] = [];
	for (let i = 0; i < steps; i++) {
		hash = (hash * 1103515245 + 12345) >>> 0;
		raw.push((hash % 10000) / 10000);
	}
	// Light smoothing (3-point moving average). Indices are always in bounds
	// (clamped with Math.max/min) so the `?? 0` fallbacks only satisfy TS's
	// noUncheckedIndexedAccess — they shouldn't trigger at runtime.
	const smooth = raw.map((_, i) => {
		const a = raw[Math.max(0, i - 1)] ?? 0;
		const b = raw[i] ?? 0;
		const c = raw[Math.min(raw.length - 1, i + 1)] ?? 0;
		return (a + b + c) / 3;
	});
	// Bias: high conviction = rising, medium = gentle rise, low = flat-ish.
	const bias = conviction === "high" ? 0.4 : conviction === "medium" ? 0.2 : 0.05;
	const biased = smooth.map((v, i) => v * (1 - bias) + (i / (smooth.length - 1)) * bias);
	// Pad top/bottom so stroke doesn't touch edge
	const pad = 4;
	const inner = h - pad * 2;
	return biased
		.map((v, i) => {
			const x = (i / (biased.length - 1)) * w;
			const y = pad + (1 - v) * inner;
			return `${i === 0 ? "M" : "L"}${x.toFixed(1)},${y.toFixed(1)}`;
		})
		.join(" ");
}

const convictionStroke: Record<string, string> = {
	high: "#8953d1",
	medium: "#10b981",
	low: "#9ca3af",
};

const dataJson = JSON.stringify({
	regime,
	allocation,
	heatmap,
	positions,
	clearances,
});

const updatedLabel = new Date(generated_at).toISOString().split("T")[0];

const meta = {
	title: "Portfolio · Rex Liu",
	description:
		"Public portfolio dashboard — sectors, theses, stage-gated decisions, and trade replays. No amounts, just conviction.",
};

// Stage metadata (from investment decision framework v2.0)
const stages = [
	{
		num: 0,
		title_en: "Macro Thermometer",
		title_zh: "宏观温度计",
		purpose_en: "Read market regime: offensive / neutral / defensive",
		purpose_zh: "判断市场温度：进攻 / 中性 / 防御",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 1,
		title_en: "Sector Research",
		title_zh: "赛道研究",
		purpose_en: "1-2 day deep report before picking stocks",
		purpose_zh: "选股之前先做重度赛道报告",
		automated: false,
		badge_en: "Manual",
		badge_zh: "手动",
	},
	{
		num: 2,
		title_en: "Watchlist Scan",
		title_zh: "个股池初筛",
		purpose_en: "15 tickers, 5-dimension filter → 10-20 names",
		purpose_zh: "15 只标的五维扫描 → 10-20 家观察名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 3,
		title_en: "Short List",
		title_zh: "短名单",
		purpose_en: "Valuation + catalyst + technicals → 3-5 names",
		purpose_zh: "估值 + 催化 + 技术面 → 3-5 家可操作短名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 4,
		title_en: "Deep Research",
		title_zh: "深度研究",
		purpose_en: "Skill: 4+1 card per company, 3 hard theses",
		purpose_zh: "Skill：每家公司 4+1 段名片 + 三条硬结论",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 5,
		title_en: "Roundtable",
		title_zh: "圆桌讨论",
		purpose_en: "6-seat masters challenge the theses; dissent required",
		purpose_zh: "6 席位大师挑战结论；反方必选",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 6,
		title_en: "Execution Plan",
		title_zh: "执行计划",
		purpose_en: "10-point scorecard ≥7, R:R ≥ 2.0, 3 stop-lines",
		purpose_zh: "10 分评分卡 ≥7，R:R ≥ 2.0，3 条撤退线",
		automated: true,
		badge_en: "Scorecard",
		badge_zh: "评分卡",
	},
	{
		num: 7,
		title_en: "Position Management",
		title_zh: "持仓管理 + 复盘",
		purpose_en: "L0-L3 monitoring + monthly/quarterly/annual reviews",
		purpose_zh: "L0-L3 四层监控 + 月/季/年复盘",
		automated: true,
		badge_en: "4-tier",
		badge_zh: "四层",
	},
];
---

<PageLayout meta={meta}>
	<link
		slot="head"
		rel="preload"
		href="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"
		as="script"
	/>

	<section class="portfolio-page">
		<div class="mb-6">
			<a
				href="/lab/"
				class="portfolio-breadcrumb font-serif text-sm transition-colors"
			>
				← Lab
			</a>
		</div>

		{/* ═══ Section 0: Hero ═══ */}
		<section class="portfolio-hero">
			<p class="portfolio-eyebrow">
				<span class="lang-en">Build in Public · Portfolio</span>
				<span class="lang-zh">公开建造 · 持仓驾驶舱</span>
			</p>
			<div class="portfolio-hero-row">
				<div class="portfolio-hero-text">
					<h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">
						<span class="lang-en">Portfolio · Conviction on Display</span>
						<span class="lang-zh">持仓 · 公开的决策</span>
					</h1>
					<p class="portfolio-subtitle font-serif text-lg leading-relaxed sm:text-xl">
						<span class="lang-en">
							No amounts. Just sectors, theses, stages, and the scorecard behind every position.
						</span>
						<span class="lang-zh">
							不公开金额。只展示板块、逻辑、阶段，以及每个仓位背后的评分卡。
						</span>
					</p>
				</div>
				<div
					class="portfolio-regime-badge"
					style={`--regime-color: ${regimeColors[regime?.current?.label] || "#8953d1"}`}
				>
					<span class="portfolio-regime-eyebrow">
						<span class="lang-en">Current Regime</span>
						<span class="lang-zh">当前宏观</span>
					</span>
					<strong class="portfolio-regime-label font-serif">
						<span class="lang-en">{regime?.current?.label_en || "—"}</span>
						<span class="lang-zh">{regime?.current?.label || "—"}</span>
					</strong>
					<span class="portfolio-regime-meta">
						<span class="lang-en">
							{regime?.current?.green_count ?? 0} / {regime?.current?.total_signals ?? 5} green ·
							Aggression {regime?.current?.aggression ?? "—"}
						</span>
						<span class="lang-zh">
							{regime?.current?.green_count ?? 0}/{regime?.current?.total_signals ?? 5} 绿灯 ·
							激进度 {regime?.current?.aggression ?? "—"}
						</span>
					</span>
				</div>
			</div>

			<div class="portfolio-hero-stats" aria-label="Portfolio statistics">
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Active Positions</span>
						<span class="lang-zh">活跃持仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.active_positions}
					>
						{stats.active_positions}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Markets</span>
						<span class="lang-zh">市场</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.markets}>
						{stats.markets}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Tracked Rules</span>
						<span class="lang-zh">监控规则</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.tracked_rules}>
						{stats.tracked_rules}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Upcoming Events</span>
						<span class="lang-zh">预告事件</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.upcoming_events}>
						{stats.upcoming_events}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Scan Hits (≥5)</span>
						<span class="lang-zh">扫描信号</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.weekly_scan_hits}>
						{stats.weekly_scan_hits}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Last Clearance</span>
						<span class="lang-zh">上次清仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.days_since_last_clearance ?? 0}
						data-count-suffix="d ago"
					>
						{stats.days_since_last_clearance ?? "—"}d ago
					</strong>
				</article>
			</div>

			<p class="portfolio-updated">
				<span class="lang-en">Last updated: {updatedLabel}</span>
				<span class="lang-zh">最后更新: {updatedLabel}</span>
			</p>
		</section>

		{/* ═══ Section 5: Current Positions ═══ */}
		<section class="portfolio-section fade-in-up" id="positions-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Stage 7 · Active Positions</span>
					<span class="lang-zh">阶段 7 · 当前持仓</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">The 6 names that earned conviction</span>
					<span class="lang-zh">值得信念的 6 只</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Each card shows sector tags, one-line thesis, stage badge, distance to stop, and the
						next catalyst on the calendar.
					</span>
					<span class="lang-zh">
						每张卡片显示板块标签、一句逻辑、阶段徽章、距止损线距离、日历上最近的催化事件。
					</span>
				</p>
			</header>

			<div class="positions-grid">
				{positions.map((p) => (
					<article class={`position-card conviction-${p.conviction}`}>
						<header class="position-head">
							<div class="position-symbol-row">
								<strong class="position-symbol font-serif">{p.symbol}</strong>
								<span class="position-flag" aria-label={p.market}>
									{p.flag}
								</span>
								<span class="position-conviction-icon">
									{conviction[p.conviction] || ""}
								</span>
							</div>
							<div class="position-tags">
								{p.sector_tags_en.map((tag, i) => (
									<span class="position-tag">
										<span class="lang-en">{tag}</span>
										<span class="lang-zh">{p.sector_tags_zh[i] || tag}</span>
									</span>
								))}
							</div>
						</header>

						<p class="position-thesis">
							<span class="lang-en">{p.thesis_en}</span>
							<span class="lang-zh">{p.thesis_zh}</span>
						</p>

						<svg
							class="position-trajectory"
							viewBox="0 0 200 40"
							preserveAspectRatio="none"
							role="img"
							aria-label="Conviction trajectory"
						>
							<path
								d={trajectoryPath(p.symbol, p.conviction, 200, 40)}
								fill="none"
								stroke={convictionStroke[p.conviction] || "#9ca3af"}
								stroke-width="1.6"
								stroke-linecap="round"
								stroke-linejoin="round"
								opacity="0.85"
							/>
						</svg>

						<div class="position-meta">
							<span class="position-stage-badge">
								<span class="lang-en">Stage {p.stage}</span>
								<span class="lang-zh">阶段 {p.stage}</span>
							</span>
							<span class="position-status">
								<span class="lang-en">{p.status_en}</span>
								<span class="lang-zh">{p.status_zh}</span>
							</span>
						</div>

					<footer class="position-foot">
						{p.stop ? (
							<span
								class={`position-stop severity-${p.stop.severity}`}
								title={p.stop.description || ""}
							>
								<span class="lang-en">Stop: {p.stop.level_pct_from_current} away</span>
								<span class="lang-zh">止损距 {p.stop.level_pct_from_current}</span>
							</span>
						) : (
							<span class="position-stop-empty">
								<span class="lang-en">No stop rule</span>
								<span class="lang-zh">无撤退规则</span>
							</span>
						)}
						{p.target ? (
							<span
								class="position-target"
								title={p.target.description || ""}
							>
								<span class="lang-en">🎯 Target: {p.target.price_pct_from_current || "—"}</span>
								<span class="lang-zh">🎯 目标 {p.target.price_pct_from_current || "—"}</span>
							</span>
						) : (
							<span class="position-target-empty">
								<span class="lang-en">No target</span>
								<span class="lang-zh">无目标价</span>
							</span>
						)}
							{p.next_event ? (
								<span class={`position-event urgency-${p.next_event.urgency}`}>
									<time>{p.next_event.date}</time>
									<span>{p.next_event.label}</span>
								</span>
							) : (
								<span class="position-event-empty">
									<span class="lang-en">No pending events</span>
									<span class="lang-zh">无预告事件</span>
								</span>
							)}
						</footer>
					</article>
				))}
			</div>
		</section>

		{/* ═══ Section 7: Closed Positions Gallery ═══ */}
		<section class="portfolio-section fade-in-up" id="clearance-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Trade Replays · Closed Positions</span>
					<span class="lang-zh">交易回放 · 已清仓</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">Wins, near-misses, and the lesson attached to each</span>
					<span class="lang-zh">每笔清仓都带一条 lesson</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Trade points marked: first entry, add, sell, stop-triggered exit. The annotation is
						the reasoning at the time — not edited after the fact.
					</span>
					<span class="lang-zh">
						每个关键交易点都标注：首次建仓、加仓、减仓、触发止损。备注是当时的判断，事后不改。
					</span>
				</p>
			</header>

			<div class="clearance-grid">
				{clearances.map((c, idx) => (
					<article
						class={`clearance-card outcome-${c.outcome_pct_rounded >= 0 ? "win" : "loss"}`}
					>
						<header class="clearance-head">
							<div class="clearance-symbol-row">
								<strong class="clearance-symbol font-serif">
									{c.ticker}
								</strong>
								<span class="clearance-name font-serif">
									<span class="lang-en">{c.name_en}</span>
									<span class="lang-zh">{c.name_zh}</span>
								</span>
							</div>
							<div class="clearance-meta-row">
								<span class="clearance-pct">
									{c.outcome_pct_rounded >= 0 ? "+" : ""}
									{c.outcome_pct_rounded}%
								</span>
								<span class="clearance-days">
									<span class="lang-en">{c.holding_days}d</span>
									<span class="lang-zh">{c.holding_days}天</span>
								</span>
								{c.win_rate_pct != null && (
									<span class="clearance-chip">
										<span class="lang-en">Win {c.win_rate_pct}%</span>
										<span class="lang-zh">胜率 {c.win_rate_pct}%</span>
									</span>
								)}
								{c.trade_count != null && (
									<span class="clearance-chip">
										<span class="lang-en">{c.trade_count} trades</span>
										<span class="lang-zh">{c.trade_count} 笔</span>
									</span>
								)}
							</div>
						</header>

						<div class="clearance-tags">
							{(c.sector_tags_en || []).map((t: string, i: number) => (
								<span class="position-tag">
									<span class="lang-en">{t}</span>
									<span class="lang-zh">{(c.sector_tags_zh || [])[i] || t}</span>
								</span>
							))}
						</div>

						{c.sub_tickers && c.sub_tickers.length > 0 && (
							<div class="clearance-sub-tickers">
								<span class="clearance-sub-label">
									<span class="lang-en">Basket</span>
									<span class="lang-zh">组合成分</span>
								</span>
								<div class="clearance-sub-list">
									{c.sub_tickers.map((st: any) => (
										<span class="clearance-sub-item">
											<strong class="clearance-sub-ticker font-serif">{st.ticker}</strong>
											<span class="clearance-sub-name">
												<span class="lang-en">{st.name_en || st.name_zh || ""}</span>
												<span class="lang-zh">{st.name_zh || st.name_en || ""}</span>
											</span>
											{st.outcome_pct != null && (
												<em
													class={`clearance-sub-pct ${st.outcome_pct >= 0 ? "positive" : "negative"}`}
												>
													{st.outcome_pct >= 0 ? "+" : ""}
