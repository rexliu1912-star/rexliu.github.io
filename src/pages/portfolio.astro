					</div>
					<div class="daily-briefing-list">
						{positions.map((p) => {
							const chg = p.daily_change_pct ?? null;
							const chgStr = chg != null ? ` (${chg >= 0 ? '+' : ''}${chg.toFixed(1)}%)` : '';
							const chgClass = chg != null ? (chg >= 0 ? 'briefing-up' : 'briefing-down') : '';
							const sentEmoji = p.news?.sentiment === 'positive' ? '🟢' : p.news?.sentiment === 'negative' ? '🔴' : '🟡';
							const ev = p.next_event;
							let countdown = '';
						if (ev?.date) {
							const diff = Math.round((new Date(ev.date).getTime() - new Date(today).getTime()) / 86400000);
							countdown = diff === 0 ? '(Today)' : diff === 1 ? '(Tomorrow)' : `(${diff}d)`;
						}
							return (
								<div class="briefing-row">
									<div class="briefing-price-row">
										<span class={`briefing-change ${chgClass}`}>
											{chg != null ? (chg >= 0 ? '🟢' : '🔴') : '⚪'} {p.symbol} ${p.price?.toFixed(2) ?? '—'}{chgStr}
