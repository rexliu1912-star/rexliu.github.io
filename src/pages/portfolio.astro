	.crypto-ind-chg-badge { font-size:.7rem; font-weight:600; padding:.1rem .35rem; border-radius:.3rem; white-space:nowrap; flex-shrink:0; }
	.crypto-ind-delta-head { text-align:right; }

	/* ── Layer 3: Chart + Side Cards ── */
	.crypto-chart-row { display:block; }
