	.action-signals-icon { font-size:1.2rem; }
	.action-signals-list { display:flex; gap:.4rem; flex-wrap:wrap; }
	.action-signal-chip { font-size:.75rem; padding:.2rem .5rem; border-radius:1rem; background:rgba(255,255,255,.08); }
	.action-signal-chip.priority-1 { background:rgba(239,68,68,.15); color:#fca5a5; }
	.action-signals-micro { display:flex; gap:.5rem; margin-left:auto; flex-wrap:wrap; }
	.action-micro-badge { font-size:.7rem; padding:.15rem .4rem; border-radius:.3rem; background:rgba(255,255,255,.05); opacity:.8; }
	.action-micro-badge.ok { background:rgba(16,185,129,.15); color:#6ee7b7; }
	.action-micro-badge.warn { background:rgba(245,158,11,.15); color:#fbbf24; }

	/* ═══ Crypto Dashboard v2 ═══ */
	.crypto-dash-v2 { display:flex; flex-direction:column; gap:1.25rem; margin-top:1rem; }

	/* ── Layer 1: Gauge ── */
	.crypto-gauge-wrap { background:rgba(255,255,255,0.03); border-radius:.75rem; padding:1rem 1rem .75rem; display:flex; flex-direction:column; align-items:center; }
	[data-theme="light"] .crypto-gauge-wrap { background:rgba(0,0,0,0.03); }
	.crypto-gauge-svg { width:100%; max-width:320px; height:auto; }
	.crypto-gauge-score { display:flex; align-items:baseline; gap:.15rem; margin-top:-.15rem; }
