									<span class="stage-scorecard-pill">MA200</span>
									<span class="stage-scorecard-pill">支撑</span>
									<span class="stage-scorecard-pill">RSI</span>
									<span class="stage-scorecard-pill">量价</span>
									<span class="stage-scorecard-pill stage-scorecard-pill-primary">
										R:R ≥ 2.0
									</span>
									<span class="stage-scorecard-hint">
										<span class="lang-en">Score ≥ 7 / 10 to trade</span>
										<span class="lang-zh">≥ 7/10 才下单</span>
									</span>
								</div>
							)}
							{s.num === 7 && (
								<div class="stage-cadence">
									<span class="stage-cadence-badge">
										<span class="lang-en">Monthly</span>
										<span class="lang-zh">月度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Quarterly</span>
										<span class="lang-zh">季度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Annual</span>
										<span class="lang-zh">年度</span>
									</span>
								</div>
							)}
						</div>
					</article>
				))}
			</div>
		</section>
	</section>

	<script is:inline id="portfolio-data" type="application/json" set:html={dataJson}></script>
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
	<script is:inline>
		function __initPortfolioAnimate() {
			const page = document.querySelector('.portfolio-page');
			if (!page || page.dataset.portfolioReady === 'true') return;
			page.dataset.portfolioReady = 'true';
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (!reduce) {
				const fadeIn = (el, delay, dur) => {
					if (!el) return;
					el.style.opacity = '0';
					el.style.animation = `lucky-fade-up ${dur || 420}ms ease ${delay}ms forwards`;
				};
				fadeIn(page.querySelector('.portfolio-eyebrow'), 280);
				const title = page.querySelector('.portfolio-hero h1');
				if (title && !title.dataset.animated) {
					title.dataset.animated = 'true';
					const zh = (document.documentElement.getAttribute('data-lang') || 'en') === 'zh';
					const span = title.querySelector(zh ? '.lang-zh' : '.lang-en');
					if (span) {
						const text = span.textContent || '';
						let d = 460;
						if (zh) {
							span.innerHTML = [...text]
								.map((c) => {
									if (!c.trim()) return c;
									const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up .38s ease ${d}ms forwards">${c}</span>`;
									d += 38;
									return s;
								})
								.join('');
						} else {
							span.innerHTML = text
								.trim()
								.split(/\s+/)
								.map((w) => {
									const s = `<span style="opacity:0;display:inline-block;animation:lucky-fade-up .38s ease ${d}ms forwards">${w}</span>`;
									d += 38;
									return s;
								})
								.join(' ');
						}
					}
				}
				fadeIn(page.querySelector('.portfolio-subtitle'), 760);
				fadeIn(page.querySelector('.portfolio-regime-badge'), 820);
				const cards = Array.from(page.querySelectorAll('.portfolio-stat-card'));
				cards.forEach((c, i) => fadeIn(c, 900 + i * 62));
				fadeIn(page.querySelector('.portfolio-updated'), 900 + cards.length * 62 + 80);
			}

			// CountUp for stat cards
			setTimeout(() => {
				if (reduce) return;
				page.querySelectorAll('.portfolio-stat-value[data-count-target]').forEach((el) => {
					const target = Number(el.dataset.countTarget);
					if (!target || Number.isNaN(target)) return;
					const suffix = el.dataset.countSuffix || '';
					const prefix = el.dataset.countPrefix || '';
					const dur = 1100;
					const t0 = performance.now();
					el.textContent = `${prefix}0${suffix}`;
					const tick = (now) => {
						const p = Math.min((now - t0) / dur, 1);
						const e = 1 - (1 - p) ** 3;
						el.textContent = prefix + Math.round(target * e).toLocaleString() + suffix;
						if (p < 1) requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				});
			}, 900);

			// Scroll-triggered fade-up for non-hero sections. Each section has
			// `.portfolio-section.fade-in-up`; when it enters the viewport we
			// toggle `.is-visible` once (unobserve after). Reduce-motion skips.
			if (!reduce && 'IntersectionObserver' in window) {
				const sections = Array.from(
					page.querySelectorAll('.portfolio-section.fade-in-up')
				);
				if (sections.length) {
					const io = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('is-visible');
									io.unobserve(entry.target);
								}
							});
						},
						{ rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
					);
					sections.forEach((s) => io.observe(s));
				}
			} else {
				// Reduce-motion or no IO support — show everything immediately.
				page.querySelectorAll('.portfolio-section.fade-in-up').forEach((s) =>
					s.classList.add('is-visible')
				);
			}
		}

		function __initPortfolioCharts() {
			if (typeof window.Chart === 'undefined') return;
			const dataEl = document.getElementById('portfolio-data');
			if (!dataEl) return;
			let data;
			try {
				data = JSON.parse(dataEl.textContent || '{}');
			} catch {
				return;
			}

			const isDark = () => document.documentElement.getAttribute('data-theme') !== 'light';
			const axisColor = () => (isDark() ? 'rgba(255,255,255,0.48)' : 'rgba(30,20,50,0.52)');
			const gridColor = () => (isDark() ? 'rgba(255,255,255,0.08)' : 'rgba(30,20,50,0.08)');

			// Regime VIX chart
			const regimeCanvas = document.getElementById('regimeChart');
			if (regimeCanvas && data.regime?.history_60d?.length >= 2) {
				if (Chart.getChart(regimeCanvas)) Chart.getChart(regimeCanvas).destroy();
				const history = data.regime.history_60d;
				new Chart(regimeCanvas, {
					type: 'line',
					data: {
						labels: history.map((h) => h.date),
						datasets: [
							{
								label: 'VIX',
								data: history.map((h) => h.vix),
								borderColor: '#8953d1',
								backgroundColor: 'rgba(137, 83, 209, 0.15)',
								fill: true,
								tension: 0.28,
								pointRadius: 0,
								pointHoverRadius: 4,
								borderWidth: 2,
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								callbacks: {
									afterLabel: (ctx) => {
										const h = history[ctx.dataIndex];
										return `Regime: ${h.regime} · ${h.green_count}/5 green`;
									},
								},
							},
						},
						scales: {
							x: {
								ticks: { color: axisColor(), maxTicksLimit: 8 },
								grid: { color: gridColor() },
							},
							y: {
								ticks: { color: axisColor() },
								grid: { color: gridColor() },
							},
						},
					},
				});
			}

			// Clearance mini-charts (trade-points scatter + connecting line)
			document.querySelectorAll('.clearance-chart').forEach((canvas) => {
				const idx = Number(canvas.dataset.clearanceIdx);
				const c = data.clearances?.[idx];
				if (!c || !c.trade_points || c.trade_points.length < 2) return;
				if (Chart.getChart(canvas)) Chart.getChart(canvas).destroy();
				// Build a price timeline from trade points. Fallback to index-based x if no dates.
				const pts = c.trade_points
					.filter((tp) => tp.price != null)
					.map((tp) => ({
						x: tp.date,
						y: tp.price,
						label: tp.action_zh || tp.action_en || tp.action || '',
						kind: tp.kind || '',
					}));
				if (pts.length < 2) {
					// no prices, draw a % journey from 0 to outcome_pct
					const start = new Date(c.entry_date).getTime();
					const end = new Date(c.exit_date).getTime();
					const steps = 8;
					const synthetic = Array.from({ length: steps }, (_, i) => {
						const t = start + ((end - start) * i) / (steps - 1);
						const pct = (c.outcome_pct_rounded * i) / (steps - 1);
						return { x: new Date(t).toISOString().split('T')[0], y: pct };
					});
					new Chart(canvas, {
						type: 'line',
						data: {
							labels: synthetic.map((p) => p.x),
							datasets: [
								{
									label: `${c.ticker} %`,
									data: synthetic.map((p) => p.y),
									borderColor: c.outcome_pct_rounded >= 0 ? '#10b981' : '#ef4444',
									backgroundColor:
										c.outcome_pct_rounded >= 0
											? 'rgba(16, 185, 129, 0.12)'
											: 'rgba(239, 68, 68, 0.12)',
									fill: true,
									tension: 0.35,
									pointRadius: 0,
									borderWidth: 2,
								},
							],
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							plugins: { legend: { display: false }, tooltip: { enabled: false } },
							scales: {
								x: { display: false },
								y: {
									ticks: { color: axisColor(), callback: (v) => `${v}%` },
									grid: { color: gridColor() },
								},
							},
						},
					});
					return;
				}
				new Chart(canvas, {
					type: 'line',
					data: {
						labels: pts.map((p) => p.x),
						datasets: [
							{
								label: c.ticker,
								data: pts.map((p) => p.y),
								borderColor: '#8953d1',
								backgroundColor: 'rgba(137, 83, 209, 0.12)',
								fill: true,
								tension: 0.3,
								pointRadius: 5,
								pointBackgroundColor: (ctx) => {
									const p = pts[ctx.dataIndex] || {};
									const k = p.kind || '';
									const act = p.label || '';
									if (k === 'entry' || k === 'add' || act.includes('建仓') || act.includes('买') || act.includes('加仓')) return '#10b981';
									if (k === 'exit' || k === 'sell' || k === 'stopped' || act.includes('清仓') || act.includes('卖') || act.includes('减仓')) return '#ef4444';
									return '#f59e0b';
								},
								pointBorderColor: '#fff',
								pointBorderWidth: 2,
								borderWidth: 2,
							},
						],
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								callbacks: {
									label: (ctx) => `${pts[ctx.dataIndex].label}: ${ctx.parsed.y}`,
								},
							},
						},
						scales: {
							x: { ticks: { color: axisColor(), maxTicksLimit: 6 }, grid: { color: gridColor() } },
							y: { ticks: { color: axisColor() }, grid: { color: gridColor() } },
						},
					},
				});
			});
		}

		function __runPortfolio() {
			__initPortfolioAnimate();
			__initPortfolioCharts();
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', __runPortfolio, { once: true });
		} else {
			__runPortfolio();
		}
		document.addEventListener('astro:page-load', __runPortfolio);
		// Re-init charts on theme change
		document.addEventListener('themechange', __initPortfolioCharts);
	</script>

	<style>
		/* Align with site-wide theme (global.css):
		   body bg is #151515 (dark) / #fff8eb (light), inherited from base.
		   Use a fixed pseudo-element overlay for the subtle purple+blue glow
		   so we don't REPLACE the site's body background — same pattern as
		   lucky.astro after its 2026-04-16 fix. */
		.portfolio-page {
			position: relative;
		}
		.portfolio-page::before {
			content: "";
			position: fixed;
			inset: 0;
			z-index: -1;
			pointer-events: none;
			background:
				radial-gradient(circle at top left, rgba(137, 83, 209, 0.14), transparent 26%),
				radial-gradient(circle at 80% 10%, rgba(59, 130, 246, 0.09), transparent 24%);
		}
		:global(html[data-theme='light']) .portfolio-page::before {
			background:
				radial-gradient(circle at top left, rgba(137, 83, 209, 0.06), transparent 26%),
				radial-gradient(circle at 80% 10%, rgba(59, 130, 246, 0.04), transparent 24%);
		}

		.portfolio-page {
			--p-border: rgba(137, 83, 209, 0.18);
			/* Card palette matches ActivityGraph + /lucky: #181818 / #fffaef. */
			--p-card: #181818;
			--p-card-strong: #202020;
			--p-text: rgba(255, 255, 255, 0.88);
			--p-text-soft: rgba(255, 255, 255, 0.7);
			--p-text-faint: rgba(255, 255, 255, 0.52);
			display: grid;
			gap: 3.5rem;
			padding-bottom: 5rem;
			color: var(--p-text);
		}
		:global(html[data-theme='light']) .portfolio-page {
			--p-border: rgba(137, 83, 209, 0.2);
			--p-card: #fffaef;
			--p-card-strong: #fffdf5;
			--p-text: #1a1025;
			--p-text-soft: rgba(30, 20, 50, 0.72);
			--p-text-faint: rgba(30, 20, 50, 0.5);
			color: #1a1025;
		}

		/* ── Breadcrumb ──────────────────────────── */
		.portfolio-breadcrumb {
			color: var(--p-text-faint);
		}
		.portfolio-breadcrumb:hover {
			color: #c9b4f5;
		}
		:global(html[data-theme='light']) .portfolio-breadcrumb:hover {
			color: #8953d1;
		}

		/* ── Hero ────────────────────────────────── */
		.portfolio-hero {
			display: grid;
			gap: 1.2rem;
		}
		.portfolio-eyebrow,
		.portfolio-kicker {
			margin: 0;
			font-size: 0.76rem;
			letter-spacing: 0.24em;
			text-transform: uppercase;
			color: rgba(137, 83, 209, 0.88);
		}
		:global(html[data-theme='light']) .portfolio-eyebrow,
		:global(html[data-theme='light']) .portfolio-kicker {
			color: #8953d1;
		}
		.portfolio-hero-row {
			display: grid;
			gap: 1.5rem;
			grid-template-columns: 1fr;
			align-items: start;
		}
		@media (min-width: 900px) {
			.portfolio-hero-row {
				grid-template-columns: 1.6fr 1fr;
				gap: 2.5rem;
			}
		}
		.portfolio-hero-text {
			display: grid;
			gap: 0.85rem;
		}
		.portfolio-subtitle {
			max-width: 44rem;
			color: var(--p-text-soft);
		}
		.portfolio-regime-badge {
			display: grid;
			gap: 0.45rem;
			padding: 1.35rem 1.4rem;
			border-radius: 1.5rem;
			border: 1px solid color-mix(in srgb, var(--regime-color, #8953d1) 42%, transparent);
			background: color-mix(in srgb, var(--regime-color, #8953d1) 12%, var(--p-card));
			backdrop-filter: blur(20px);
			box-shadow: 0 12px 40px
				color-mix(in srgb, var(--regime-color, #8953d1) 18%, transparent);
		}
		.portfolio-regime-eyebrow {
			font-size: 0.72rem;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.portfolio-regime-label {
			font-size: clamp(1.8rem, 4vw, 2.4rem);
			line-height: 1;
			color: var(--regime-color, #8953d1);
		}
		.portfolio-regime-meta {
			font-size: 0.84rem;
			color: var(--p-text-soft);
		}
		.portfolio-hero-stats {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.85rem;
		}
		@media (min-width: 640px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		@media (min-width: 1024px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(6, minmax(0, 1fr));
			}
		}
		.portfolio-stat-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			backdrop-filter: blur(16px);
			border-radius: 1.1rem;
			padding: 0.9rem 1rem;
		}
		.portfolio-stat-label {
			display: block;
			margin-bottom: 0.35rem;
			font-size: 0.68rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.portfolio-stat-value {
			font-size: clamp(1.35rem, 2.6vw, 1.85rem);
			line-height: 1.05;
		}
		.portfolio-updated {
			margin: 0;
			font-size: 0.78rem;
			color: var(--p-text-faint);
		}

		/* ── Section head ────────────────────────── */
		.portfolio-section {
			display: grid;
			gap: 1.5rem;
		}
		.portfolio-section-head {
			display: grid;
			gap: 0.55rem;
			max-width: 52rem;
		}
		.portfolio-note {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.94rem;
			line-height: 1.7;
		}

		/* ── Regime lights ───────────────────────── */
		.regime-lights {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.7rem;
		}
		@media (min-width: 640px) {
			.regime-lights {
				grid-template-columns: repeat(5, minmax(0, 1fr));
			}
		}
		.regime-light-card {
			position: relative;
			padding: 0.9rem 1rem;
			border-radius: 1.15rem;
			border: 1px solid color-mix(in srgb, var(--light) 35%, var(--p-border));
			background: color-mix(in srgb, var(--light) 8%, var(--p-card));
			display: grid;
			gap: 0.35rem;
		}
		.regime-light-label {
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.regime-light-value {
			font-size: clamp(1.1rem, 2.2vw, 1.4rem);
			color: var(--p-text);
		}
		.regime-light-dot {
			position: absolute;
			top: 0.85rem;
			right: 0.9rem;
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			background: var(--light);
			box-shadow: 0 0 14px color-mix(in srgb, var(--light) 80%, transparent);
		}

		.regime-chart-wrap {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.25rem 1.25rem 1rem;
			display: grid;
			gap: 0.8rem;
		}
		.regime-chart-head {
			display: grid;
			gap: 0.4rem;
		}
		.regime-chart-canvas-wrap {
			position: relative;
			height: 220px;
		}

		/* 5 × N signals history fallback (shown when <7 days of data) */
		.regime-grid-fallback {
			display: grid;
			gap: 0.35rem;
		}
		.regime-grid-head-row,
		.regime-grid-row {
			display: grid;
			grid-template-columns: 5rem repeat(var(--days, 5), minmax(28px, 1fr));
			gap: 0.35rem;
			align-items: center;
		}
		.regime-grid-corner {
			/* spacer */
		}
		.regime-grid-date-label {
			font-family: Georgia, serif;
			font-size: 0.68rem;
			color: var(--p-text-faint);
			text-align: center;
			letter-spacing: 0.04em;
		}
		.regime-grid-signal-label {
			font-size: 0.72rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.regime-grid-cell {
			aspect-ratio: 1;
			min-height: 28px;
			border-radius: 0.5rem;
			background: rgba(137, 83, 209, 0.08);
			transition: transform 0.2s ease;
		}
		.regime-grid-cell:hover {
			transform: scale(1.08);
		}
		.regime-grid-cell.light-green {
			background: rgba(16, 185, 129, 0.28);
			box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.55);
		}
		.regime-grid-cell.light-yellow {
			background: rgba(245, 158, 11, 0.28);
			box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.55);
		}
		.regime-grid-cell.light-red {
			background: rgba(239, 68, 68, 0.28);
			box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.55);
		}
		.regime-grid-cell.light-gray {
			background: rgba(156, 163, 175, 0.14);
		}
		.regime-grid-note {
			margin: 0.5rem 0 0;
			font-size: 0.8rem;
			color: var(--p-text-faint);
			line-height: 1.5;
		}
		#regimeChart {
			width: 100%;
			height: 100%;
		}
		.portfolio-empty-overlay {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			padding: 1rem;
			text-align: center;
			font-size: 0.9rem;
			color: var(--p-text-faint);
			background: color-mix(in srgb, var(--p-card) 88%, transparent);
			border-radius: 0.75rem;
		}

		/* ── Allocation Donut (replaces old horizontal bar) ─────── */
		.allocation-donut-wrap {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
			align-items: center;
			padding: 1.5rem;
			border-radius: 1.25rem;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			backdrop-filter: blur(16px);
		}
		@media (min-width: 720px) {
			.allocation-donut-wrap {
				grid-template-columns: auto 1fr;
				gap: 2.25rem;
				padding: 2rem 2.25rem;
			}
		}
		.allocation-donut {
			width: 100%;
			max-width: 260px;
			height: auto;
			justify-self: center;
			filter: drop-shadow(0 8px 28px rgba(137, 83, 209, 0.18));
		}
		.allocation-arc-outer,
		.allocation-arc-inner {
			transition: stroke-width 0.25s ease, stroke-opacity 0.25s ease;
		}
		.allocation-arc-outer:hover {
			stroke-width: 26;
		}
		.allocation-donut-label-top {
			font-family: Georgia, serif;
			font-size: 0.72rem;
			letter-spacing: 0.28em;
			fill: var(--p-text-faint);
		}
		.allocation-donut-label-bot {
			font-family: Georgia, serif;
			font-size: 0.72rem;
			letter-spacing: 0.28em;
			fill: var(--p-text-soft);
		}
		.allocation-donut-legend {
			display: grid;
			gap: 0.6rem;
		}
		.allocation-legend-item {
			display: grid;
			grid-template-columns: auto 1fr auto auto;
			align-items: baseline;
			gap: 0.7rem;
			padding: 0.55rem 0.75rem;
			border-radius: 0.85rem;
			background: color-mix(in srgb, var(--cat-color) 5%, transparent);
			border-left: 3px solid var(--cat-color);
		}
		.allocation-legend-dot {
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			background: var(--cat-color);
			box-shadow: 0 0 12px var(--cat-color);
		}
		.allocation-legend-label {
			font-size: 0.9rem;
			color: var(--p-text);
			font-family: Georgia, serif;
		}
		.allocation-legend-target {
			font-family: Georgia, serif;
			font-size: 0.95rem;
			font-weight: 600;
			color: var(--p-text);
		}
		.allocation-legend-drift {
			font-size: 0.72rem;
			padding: 0.15rem 0.5rem;
			border-radius: 999px;
			font-weight: 600;
			min-width: 2.75rem;
			text-align: center;
		}
		.allocation-legend-drift.positive {
			color: #10b981;
			background: rgba(16, 185, 129, 0.12);
		}
		.allocation-legend-drift.negative {
			color: #ef4444;
			background: rgba(239, 68, 68, 0.12);
		}
		.allocation-subcards {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 768px) {
			.allocation-subcards {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.allocation-subcards {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}
		}
		.allocation-subcard {
			border: 1px solid color-mix(in srgb, var(--cat-color) 25%, var(--p-border));
			background: color-mix(in srgb, var(--cat-color) 5%, var(--p-card));
			border-radius: 1.15rem;
			padding: 1rem 1.1rem;
			display: grid;
			gap: 0.65rem;
		}
		.allocation-subcard-head {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.allocation-subcard-dot {
			width: 0.6rem;
			height: 0.6rem;
			border-radius: 999px;
			background: var(--cat-color);
			box-shadow: 0 0 12px var(--cat-color);
		}
		.allocation-subcard-title {
			margin: 0;
			font-size: 1.05rem;
			flex: 1;
		}
		.allocation-drift-chip {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			font-weight: 600;
		}
		.allocation-drift-chip.positive {
			color: #10b981;
			background: rgba(16, 185, 129, 0.12);
		}
		.allocation-drift-chip.negative {
			color: #ef4444;
			background: rgba(239, 68, 68, 0.12);
		}
		.allocation-subcard-stats {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.6rem;
		}
		.allocation-subcard-stats > div {
			display: grid;
			gap: 0.2rem;
		}
		.allocation-subcard-eyebrow {
			font-size: 0.66rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.allocation-subcard-stats strong {
			font-size: 1.4rem;
			line-height: 1;
		}
		.allocation-subcard-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.allocation-tag {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: color-mix(in srgb, var(--cat-color) 16%, transparent);
			color: var(--p-text-soft);
		}
		.allocation-subcard-note {
			margin: 0;
			font-size: 0.85rem;
			color: var(--p-text-soft);
			line-height: 1.55;
		}
		.allocation-sub-mini {
			display: grid;
			gap: 0.35rem;
			padding-top: 0.55rem;
			border-top: 1px dashed color-mix(in srgb, var(--cat-color) 30%, transparent);
		}
		.allocation-sub-mini-row {
			display: grid;
			grid-template-columns: auto 1fr auto;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.78rem;
			color: var(--p-text-soft);
		}
		.allocation-sub-mini-bar {
			height: 0.45rem;
			border-radius: 999px;
			background: linear-gradient(
				90deg,
				var(--cat-color) 0,
				var(--cat-color) var(--sub-pct, 0%),
				color-mix(in srgb, var(--cat-color) 14%, transparent) var(--sub-pct, 0%)
			);
		}

		/* ── 8-Stage Zigzag ──────────────────────── */
		.stage-zigzag {
			display: grid;
			gap: 1.1rem;
		}
		.stage-card {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 1rem;
			padding: 1.15rem 1.25rem;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			backdrop-filter: blur(18px);
		}
		@media (min-width: 900px) {
			.stage-card.stage-left {
				margin-right: 18%;
			}
			.stage-card.stage-right {
				margin-left: 18%;
			}
		}
		.stage-number-wrap {
			display: grid;
			place-items: center;
			width: 3.2rem;
			height: 3.2rem;
			border-radius: 1rem;
			background: linear-gradient(135deg, rgba(137, 83, 209, 0.25), rgba(137, 83, 209, 0.05));
			border: 1px solid rgba(137, 83, 209, 0.35);
		}
		.stage-number {
			font-size: 1.8rem;
			line-height: 1;
			color: #8953d1;
		}
		.stage-body {
			display: grid;
			gap: 0.55rem;
		}
		.stage-head {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.6rem;
		}
		.stage-title {
			margin: 0;
			font-size: 1.15rem;
		}
		.stage-badge {
			font-size: 0.72rem;
			padding: 0.18rem 0.55rem;
			border-radius: 999px;
			letter-spacing: 0.04em;
		}
		.stage-badge.automated {
			background: rgba(16, 185, 129, 0.15);
			color: #10b981;
			border: 1px solid rgba(16, 185, 129, 0.3);
		}
		.stage-badge.manual {
			background: rgba(156, 163, 175, 0.15);
			color: #9ca3af;
			border: 1px solid rgba(156, 163, 175, 0.3);
		}
		.stage-purpose {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.92rem;
			line-height: 1.6;
		}
		.stage-inline-thermo {
			display: flex;
			gap: 0.35rem;
			margin-top: 0.35rem;
		}
		.stage-inline-light {
			width: 0.8rem;
			height: 0.8rem;
			border-radius: 999px;
			background: var(--mini-light);
			box-shadow: 0 0 10px color-mix(in srgb, var(--mini-light) 70%, transparent);
		}
		.stage-inline-meta {
			margin: 0.35rem 0 0;
			font-size: 0.82rem;
			color: var(--p-text-faint);
		}
		.stage-scorecard {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
			align-items: center;
			margin-top: 0.3rem;
		}
		.stage-scorecard-pill {
			font-size: 0.7rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.12);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
		}
		.stage-scorecard-pill-primary {
			background: rgba(137, 83, 209, 0.28);
			color: #fff;
			border-color: rgba(137, 83, 209, 0.5);
		}
		.stage-scorecard-hint {
			font-size: 0.74rem;
			color: var(--p-text-faint);
		}
		.stage-cadence {
			display: flex;
			gap: 0.4rem;
			margin-top: 0.3rem;
		}
		.stage-cadence-badge {
			font-size: 0.74rem;
			padding: 0.22rem 0.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.14);
			color: var(--p-text-soft);
		}

		/* ── Heatmap ─────────────────────────────── */
		.heatmap-wrap {
			overflow-x: auto;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 0.9rem;
		}
		.heatmap-grid {
			display: grid;
			gap: 3px;
			min-width: fit-content;
		}
		.heatmap-corner {
			grid-column: 1;
			grid-row: 1;
		}
		.heatmap-date-label {
			font-size: 0.62rem;
			color: var(--p-text-faint);
			text-align: center;
			writing-mode: vertical-rl;
			transform: rotate(180deg);
			padding: 0.2rem 0;
			min-width: 1.2rem;
		}
		.heatmap-ticker-label {
			font-size: 0.78rem;
			font-weight: 600;
			color: var(--p-text);
			padding-right: 0.6rem;
			text-align: right;
			white-space: nowrap;
			display: grid;
			align-items: center;
		}
		.heatmap-ticker-label small {
			display: block;
			font-size: 0.64rem;
			font-weight: 400;
			color: var(--p-text-faint);
		}
		.heatmap-cell {
			min-width: 1.2rem;
			height: 1.8rem;
			border-radius: 3px;
			position: relative;
			display: grid;
			place-items: center;
		}
		.heatmap-cell-mark {
			color: #fff;
			font-size: 0.6rem;
			line-height: 1;
		}

		/* ── Positions Grid ──────────────────────── */
		.positions-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 720px) {
			.positions-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.positions-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		.position-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.1rem 1.15rem;
			display: grid;
			gap: 0.7rem;
			transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
		}
		.position-card:hover {
			transform: translateY(-2px);
			border-color: rgba(137, 83, 209, 0.35);
			box-shadow: 0 12px 40px rgba(137, 83, 209, 0.12);
		}
		.position-card.conviction-high {
			border-color: rgba(137, 83, 209, 0.28);
		}
		.position-head {
			display: grid;
			gap: 0.55rem;
		}
		.position-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
		}
		.position-symbol {
			font-size: 1.55rem;
			line-height: 1;
		}
		.position-flag {
			font-size: 1rem;
		}
		.position-conviction-icon {
			margin-left: auto;
			font-size: 1rem;
		}
		.position-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.3rem;
		}
		.position-tag {
			display: inline-flex;
			align-items: center;
			align-self: center;
			flex: 0 0 auto;
			font-size: 0.7rem;
			line-height: 1.3;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.13);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
			white-space: nowrap;
		}
		.position-thesis {
			margin: 0;
			font-size: 0.9rem;
			line-height: 1.6;
			color: var(--p-text-soft);
			border-left: 2px solid rgba(137, 83, 209, 0.4);
			padding-left: 0.85rem;
		}
		.position-trajectory {
			display: block;
			width: 100%;
			height: 38px;
			margin: -0.25rem 0 0.25rem;
			opacity: 0.75;
		}
		.position-meta {
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.position-stage-badge {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.2);
			color: #c9b4f5;
		}
		.position-status {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.08);
			color: var(--p-text-faint);
		}
		:global(html[data-theme='light']) .position-status {
			background: rgba(30, 20, 50, 0.06);
		}
		.position-foot {
			display: flex;
			flex-direction: column;
			gap: 0.45rem;
			padding-top: 0.55rem;
			border-top: 1px dashed var(--p-border);
			font-size: 0.82rem;
		}
		.position-stop {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
		}
		.position-target {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			color: #10b981;
		}
		.position-stop.severity-red {
			color: #ef4444;
		}
		.position-stop.severity-yellow {
			color: #f59e0b;
		}
		.position-stop.severity-gray {
			color: var(--p-text-faint);
		}
		.position-stop-empty,
		.position-target-empty,
		.position-event-empty {
			color: var(--p-text-faint);
			font-size: 0.78rem;
		}
		.position-event {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			color: var(--p-text-soft);
		}
		.position-event time {
			font-weight: 600;
		}
		.position-event.urgency-3 time {
			color: #ef4444;
		}

		/* ── Clearance Gallery ───────────────────── */
		.clearance-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		@media (min-width: 900px) {
			.clearance-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		.clearance-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.35rem;
			padding: 1.3rem;
			display: grid;
			gap: 0.95rem;
		}
		.clearance-card.outcome-win {
			border-color: rgba(16, 185, 129, 0.28);
		}
		.clearance-card.outcome-loss {
			border-color: rgba(239, 68, 68, 0.28);
		}
		.clearance-head {
			display: grid;
			gap: 0.5rem;
		}
		.clearance-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.65rem;
		}
		.clearance-symbol {
			font-size: 1.4rem;
			color: var(--p-text);
		}
		.clearance-name {
			font-size: 0.95rem;
			color: var(--p-text-soft);
		}
		.clearance-meta-row {
			display: flex;
			align-items: center;
			gap: 0.7rem;
		}
		.clearance-pct {
			font-family: Georgia, serif;
			font-size: 1.6rem;
			font-weight: 700;
			line-height: 1;
		}
		.clearance-card.outcome-win .clearance-pct {
			color: #10b981;
		}
		.clearance-card.outcome-loss .clearance-pct {
			color: #ef4444;
		}
		.clearance-days {
			font-size: 0.82rem;
			color: var(--p-text-faint);
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.05);
		}
		:global(html[data-theme='light']) .clearance-days {
			background: rgba(30, 20, 50, 0.06);
		}
		.clearance-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.clearance-chart-wrap {
			height: 180px;
			position: relative;
		}
		.clearance-chart {
			width: 100% !important;
			height: 100% !important;
		}
		.clearance-trade-points {
			display: grid;
			gap: 0.5rem;
			padding: 0.75rem 0.8rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.05);
		}
		/* Each trade point is a compact stacked card rather than a cramped
		   3-column grid. Top row: date + kind chip + price; action bold
		   under it; note as secondary smaller text. Left-border stripe
		   colors each row by kind. */
		.trade-point-row {
			display: grid;
			gap: 0.2rem;
			padding: 0.55rem 0.75rem;
			border-radius: 0.55rem;
			background: color-mix(in srgb, var(--p-card) 85%, transparent);
			border-left: 3px solid rgba(137, 83, 209, 0.35);
		}
		.trade-point-row.kind-entry,
		.trade-point-row.kind-add {
			border-left-color: rgba(16, 185, 129, 0.55);
		}
		.trade-point-row.kind-exit,
		.trade-point-row.kind-sell,
		.trade-point-row.kind-trim,
		.trade-point-row.kind-stopped {
			border-left-color: rgba(239, 68, 68, 0.55);
		}
		.trade-point-row.kind-catalyst,
		.trade-point-row.kind-external {
			border-left-color: rgba(245, 158, 11, 0.55);
		}
		.trade-point-row.kind-methodology {
			border-left-color: rgba(137, 83, 209, 0.55);
		}
		.trade-point-top {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0.5rem;
			font-size: 0.72rem;
		}
		.trade-point-date {
			color: var(--p-text-faint);
			font-family: Georgia, serif;
		}
		.trade-point-kind {
			font-size: 0.6rem;
			padding: 0.1rem 0.45rem;
			border-radius: 999px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			background: rgba(137, 83, 209, 0.14);
			color: var(--p-text-soft);
			font-weight: 600;
		}
		.trade-point-price {
			margin-left: auto;
			color: var(--p-text);
			font-family: Georgia, serif;
			font-weight: 600;
		}
		.trade-point-action {
			font-size: 0.88rem;
			font-weight: 600;
			color: var(--p-text);
			line-height: 1.45;
		}
		.trade-point-note {
			font-size: 0.78rem;
			color: var(--p-text-soft);
			line-height: 1.55;
		}
		.clearance-foot {
			display: grid;
			gap: 0.55rem;
			padding-top: 0.9rem;
			border-top: 1px dashed var(--p-border);
		}
		.clearance-foot p {
			margin: 0;
			font-size: 0.86rem;
			line-height: 1.6;
			color: var(--p-text-soft);
		}
		.clearance-foot strong {
			color: var(--p-text);
		}
		.clearance-article-link {
			display: inline-block;
			margin-top: 0.25rem;
			font-size: 0.86rem;
			color: var(--p-accent);
			text-decoration: none;
			transition: opacity 0.2s;
		}
		.clearance-article-link:hover {
			opacity: 0.7;
		}

		/* ── Roundtable ──────────────────────────── */
		.roundtable-list {
			display: grid;
			gap: 1rem;
		}
		.roundtable-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.3rem;
			display: grid;
			gap: 0.85rem;
		}
		.roundtable-head {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0.7rem;
		}
		.roundtable-date {
			font-family: Georgia, serif;
			font-size: 1.1rem;
			color: var(--p-text-soft);
		}
		.roundtable-cadence-tag {
			font-size: 0.7rem;
			padding: 0.15rem 0.5rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			text-transform: uppercase;
			letter-spacing: 0.08em;
		}
		.roundtable-title {
			margin: 0;
			flex: 1;
			font-size: 1.2rem;
		}
		.roundtable-guests {
			display: flex;
			flex-wrap: wrap;
			gap: 0.4rem;
		}
		.roundtable-guest {
			font-size: 0.84rem;
			padding: 0.4rem 0.7rem;
			border-radius: 0.75rem;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			display: grid;
			gap: 0.1rem;
		}
		.roundtable-guest small {
			font-size: 0.66rem;
			letter-spacing: 0.08em;
			color: var(--p-text-faint);
			text-transform: uppercase;
		}
		.roundtable-verdict {
			margin: 0;
			padding: 0.8rem 1rem;
			border-left: 3px solid rgba(137, 83, 209, 0.5);
			font-size: 0.95rem;
			line-height: 1.7;
			color: var(--p-text);
			background: rgba(137, 83, 209, 0.06);
			border-radius: 0 0.75rem 0.75rem 0;
		}

		/* ── Clearance chips (win rate / trade count) ── */
		.clearance-chip {
			font-size: 0.72rem;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.12);
			color: var(--p-text-soft);
			letter-spacing: 0.04em;
		}

		/* ── Clearance sub-tickers (basket) ── */
		.clearance-sub-tickers {
			display: grid;
			gap: 0.45rem;
			padding: 0.7rem 0.85rem;
			border-radius: 0.85rem;
			background: color-mix(in srgb, var(--p-card) 86%, transparent);
			border: 1px dashed var(--p-border);
		}
		.clearance-sub-label {
			font-size: 0.66rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.clearance-sub-list {
			display: grid;
			gap: 0.35rem;
		}
		.clearance-sub-item {
			display: grid;
			grid-template-columns: auto 1fr auto auto;
			align-items: baseline;
			gap: 0.55rem;
			font-size: 0.82rem;
		}
		.clearance-sub-ticker {
			font-size: 0.88rem;
			color: var(--p-text);
		}
		.clearance-sub-name {
			color: var(--p-text-soft);
		}
		.clearance-sub-pct {
			font-family: Georgia, serif;
			font-style: normal;
			font-weight: 600;
		}
		.clearance-sub-pct.positive {
			color: #10b981;
		}
		.clearance-sub-pct.negative {
			color: #ef4444;
		}
		.clearance-sub-days {
			font-size: 0.72rem;
			color: var(--p-text-faint);
		}

		/* ── Clearance AI-context ── */
		.clearance-ai-context {
			margin: 0;
			padding: 0.75rem 0.9rem;
			border-radius: 0.85rem;
			background: linear-gradient(
				135deg,
				rgba(137, 83, 209, 0.09),
				rgba(161, 117, 232, 0.05)
			);
			border-left: 3px solid rgba(137, 83, 209, 0.55);
			font-size: 0.85rem;
			line-height: 1.65;
			color: var(--p-text-soft);
			display: grid;
			gap: 0.35rem;
		}
		.clearance-ai-badge {
			display: inline-block;
			align-self: start;
			font-size: 0.64rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			padding: 0.18rem 0.5rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			font-weight: 700;
		}
		:global(html[data-theme='light']) .clearance-ai-badge {
			color: #8953d1;
		}

		/* ── Sector Research (Stage 1) ─────────── */
		.sector-research-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 900px) {
			.sector-research-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		.sector-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.2rem 1.25rem;
			display: grid;
			gap: 0.7rem;
		}
		.sector-card-head {
			display: grid;
			gap: 0.4rem;
		}
		.sector-card-date {
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
			font-family: Georgia, serif;
		}
		.sector-card-title {
			margin: 0;
			font-size: 1.2rem;
			line-height: 1.3;
			color: var(--p-text);
		}
		.sector-card-eyebrow {
			display: block;
			margin-bottom: 0.25rem;
			font-size: 0.64rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.sector-card-scope {
			margin: 0;
			font-size: 0.88rem;
			color: var(--p-text-soft);
			line-height: 1.65;
		}
		.sector-card-conclusion {
			margin: 0;
			padding: 0.75rem 0.9rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.08);
			border-left: 3px solid rgba(137, 83, 209, 0.55);
			font-size: 0.92rem;
			line-height: 1.65;
			color: var(--p-text);
			font-weight: 500;
		}
		.sector-card-layers {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
			padding-top: 0.4rem;
			border-top: 1px dashed var(--p-border);
		}
		.sector-layer-chip {
			font-size: 0.7rem;
			padding: 0.28rem 0.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			letter-spacing: 0.04em;
		}

		/* ── Deep Research (Stage 4) ───────────── */
		.deep-research-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.9rem;
		}
		@media (min-width: 700px) {
			.deep-research-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.deep-research-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		.deep-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.15rem;
			padding: 1rem 1.1rem;
			display: grid;
			gap: 0.55rem;
		}
		.deep-card.held {
			border-color: rgba(137, 83, 209, 0.4);
			background: color-mix(in srgb, rgba(137, 83, 209, 0.08) 60%, var(--p-card));
		}
		.deep-card-head {
			display: grid;
			gap: 0.3rem;
		}
		.deep-card-ticker-row {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 0.45rem;
		}
		.deep-card-ticker {
			font-size: 1.25rem;
			color: var(--p-text);
			letter-spacing: 0.02em;
		}
		.deep-card-market {
			font-size: 0.64rem;
			letter-spacing: 0.14em;
			padding: 0.16rem 0.45rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.06);
			color: var(--p-text-faint);
			font-weight: 600;
		}
		:global(html[data-theme='light']) .deep-card-market {
			background: rgba(30, 20, 50, 0.06);
		}
		.deep-card-status {
			margin-left: auto;
			font-size: 0.68rem;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			font-weight: 600;
		}
		.deep-card-status.held {
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
		}
		:global(html[data-theme='light']) .deep-card-status.held {
			color: #8953d1;
		}
		.deep-card-status.watching {
			background: rgba(245, 158, 11, 0.14);
			color: #f59e0b;
		}
		.deep-card-name {
			font-size: 0.92rem;
			color: var(--p-text-soft);
		}
		.deep-card-sector {
			font-size: 0.72rem;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			justify-self: start;
			letter-spacing: 0.03em;
		}
		.deep-card-thesis {
			margin: 0;
			font-size: 0.88rem;
			color: var(--p-text);
			line-height: 1.65;
		}
		.deep-card-foot {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.6rem;
			padding-top: 0.5rem;
			border-top: 1px dashed var(--p-border);
		}
		.deep-card-conf-label {
			font-size: 0.66rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.deep-card-stars {
			font-size: 0.95rem;
			letter-spacing: 0.08em;
		}
		.deep-card-star {
			color: rgba(137, 83, 209, 0.22);
		}
		.deep-card-star.filled {
			color: #c9b4f5;
			text-shadow: 0 0 8px rgba(137, 83, 209, 0.4);
		}
		:global(html[data-theme='light']) .deep-card-star.filled {
			color: #8953d1;
			text-shadow: none;
		}

		/* ── Roundtable extended (topic / guest-cards / rounds / implications) ── */
		.roundtable-topic {
			margin: 0;
			padding: 0.7rem 0.85rem;
			border-radius: 0.75rem;
			background: rgba(137, 83, 209, 0.06);
			font-size: 0.92rem;
			line-height: 1.6;
			color: var(--p-text);
			display: grid;
			gap: 0.25rem;
		}
		.roundtable-topic-label {
			font-size: 0.64rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}

		/* Guests layout: responsive grid below 1024px, radial circle above. */
		.roundtable-guests-radial {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
		.roundtable-guests-center {
			display: none;
		}
		@media (min-width: 640px) {
			.roundtable-guests-radial {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1024px) {
			.roundtable-guests-radial {
				display: block;
				position: relative;
				width: 100%;
				max-width: 640px;
				aspect-ratio: 1 / 1;
				margin: 1.5rem auto 2rem;
			}
			.roundtable-guests-radial .roundtable-guest-card,
			.roundtable-guests-radial .roundtable-guest-pill {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 210px;
				transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y)));
				transition: transform 0.35s ease;
