		}
		@media (min-width: 640px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		@media (min-width: 1024px) {
			.portfolio-hero-stats {
				grid-template-columns: repeat(6, minmax(0, 1fr));
			}
		}
		.portfolio-stat-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			backdrop-filter: blur(16px);
			border-radius: 1.1rem;
			padding: 0.9rem 1rem;
		}
		.portfolio-stat-label {
			display: block;
			margin-bottom: 0.35rem;
			font-size: 0.68rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.portfolio-stat-value {
			font-size: clamp(1.35rem, 2.6vw, 1.85rem);
			line-height: 1.05;
		}
		.portfolio-updated {
			margin: 0;
			font-size: 0.78rem;
			color: var(--p-text-faint);
		}

		/* ── Section head ────────────────────────── */
		.portfolio-section {
			display: grid;
			gap: 1.5rem;
			scroll-margin-top: 2rem;
		}
		.portfolio-section-head {
			display: grid;
			gap: 0.55rem;
			max-width: 52rem;
		}
		.portfolio-note {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.94rem;
			line-height: 1.7;
		}

		/* ── Regime lights ───────────────────────── */
		.regime-lights {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.7rem;
		}
		@media (min-width: 640px) {
			.regime-lights {
				grid-template-columns: repeat(5, minmax(0, 1fr));
			}
		}
		.regime-light-card {
			position: relative;
			padding: 0.9rem 1rem;
			border-radius: 1.15rem;
			border: 1px solid color-mix(in srgb, var(--light) 35%, var(--p-border));
			background: color-mix(in srgb, var(--light) 8%, var(--p-card));
			display: grid;
			gap: 0.35rem;
		}
		.regime-light-label {
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.regime-light-value {
			font-size: clamp(1.1rem, 2.2vw, 1.4rem);
			color: var(--p-text);
		}
		.regime-light-dot {
			position: absolute;
			top: 0.85rem;
			right: 0.9rem;
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			background: var(--light);
			box-shadow: 0 0 14px color-mix(in srgb, var(--light) 80%, transparent);
		}

		.regime-chart-wrap {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.25rem 1.25rem 1rem;
			display: grid;
			gap: 0.8rem;
		}
		.regime-chart-head {
			display: grid;
			gap: 0.4rem;
		}
		.regime-chart-canvas-wrap {
			position: relative;
			height: 220px;
		}

		/* 5 × N signals history fallback (shown when <7 days of data) */
		.regime-grid-fallback {
			display: grid;
			gap: 0.35rem;
		}
		.regime-grid-head-row,
		.regime-grid-row {
			display: grid;
			grid-template-columns: 5rem repeat(var(--days, 5), minmax(28px, 1fr));
			gap: 0.35rem;
			align-items: center;
		}
		.regime-grid-corner {
			/* spacer */
		}
		.regime-grid-date-label {
			font-family: Georgia, serif;
			font-size: 0.68rem;
			color: var(--p-text-faint);
			text-align: center;
			letter-spacing: 0.04em;
		}
		.regime-grid-signal-label {
			font-size: 0.72rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.regime-grid-cell {
			aspect-ratio: 1;
			min-height: 28px;
			border-radius: 0.5rem;
			background: rgba(137, 83, 209, 0.08);
			transition: transform 0.2s ease;
		}
		.regime-grid-cell:hover {
			transform: scale(1.08);
		}
		.regime-grid-cell.light-green {
			background: rgba(16, 185, 129, 0.28);
			box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.55);
		}
		.regime-grid-cell.light-yellow {
			background: rgba(245, 158, 11, 0.28);
			box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.55);
		}
		.regime-grid-cell.light-red {
			background: rgba(239, 68, 68, 0.28);
			box-shadow: inset 0 0 0 1px rgba(239, 68, 68, 0.55);
		}
		.regime-grid-cell.light-gray {
			background: rgba(156, 163, 175, 0.14);
		}
		.regime-grid-note {
			margin: 0.5rem 0 0;
			font-size: 0.8rem;
			color: var(--p-text-faint);
			line-height: 1.5;
		}
		#regimeChart {
			width: 100%;
			height: 100%;
		}
		/* Interactive regime tooltip */
		.regime-tooltip {
			position: fixed;
			z-index: 100;
			background: color-mix(in srgb, var(--p-card) 96%, black);
			border: 1px solid var(--p-border);
			border-radius: 0.75rem;
			padding: 0.75rem 1rem;
			pointer-events: none;
			min-width: 180px;
			box-shadow: 0 8px 24px rgba(0,0,0,0.18);
			backdrop-filter: blur(8px);
		}
		.regime-tooltip-date {
			font-family: Georgia, serif;
			font-size: 0.82rem;
			color: var(--p-text-faint);
			letter-spacing: 0.04em;
			margin-bottom: 0.3rem;
		}
		.regime-tooltip-regime {
			font-size: 0.88rem;
			margin-bottom: 0.5rem;
			color: var(--regime-color, var(--p-text));
		}
		.regime-tooltip-regime strong {
			color: var(--regime-color, var(--p-text));
		}
		.regime-tooltip-signals {
			display: grid;
			gap: 0.25rem;
		}
		.regime-signal-row {
			display: flex;
			align-items: center;
			gap: 0.4rem;
			font-size: 0.78rem;
		}
		.regime-signal-dot {
			width: 6px;
			height: 6px;
			border-radius: 50%;
			flex-shrink: 0;
		}
		.regime-signal-name {
			color: var(--p-text-faint);
			flex: 1;
		}
		.regime-signal-value {
			font-family: Georgia, serif;
			color: var(--p-text);
		}
		.regime-signal-status {
			margin-left: 0.25rem;
			font-family: Inter, system-ui, sans-serif;
			font-size: 0.68rem;
			color: var(--p-text-faint);
		}
		.portfolio-empty-overlay {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			padding: 1rem;
			text-align: center;
			font-size: 0.9rem;
			color: var(--p-text-faint);
			background: color-mix(in srgb, var(--p-card) 88%, transparent);
			border-radius: 0.75rem;
		}

		/* ── Allocation Donut (replaces old horizontal bar) ─────── */
		.allocation-donut-wrap {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
			align-items: center;
			padding: 1.5rem;
			border-radius: 1.25rem;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			backdrop-filter: blur(16px);
		}
		@media (min-width: 720px) {
			.allocation-donut-wrap {
				grid-template-columns: auto 1fr;
				gap: 2.25rem;
				padding: 2rem 2.25rem;
			}
		}
		.allocation-donut {
			width: 100%;
			max-width: 260px;
			height: auto;
			justify-self: center;
			filter: drop-shadow(0 8px 28px rgba(137, 83, 209, 0.18));
		}
		.allocation-arc-outer,
		.allocation-arc-inner {
			transition: stroke-width 0.25s ease, stroke-opacity 0.25s ease;
		}
		.allocation-arc-outer:hover {
			stroke-width: 26;
		}
		.allocation-donut-label-top {
			font-family: Georgia, serif;
			font-size: 0.72rem;
			letter-spacing: 0.28em;
			fill: var(--p-text-faint);
		}
		.allocation-donut-label-bot {
			font-family: Georgia, serif;
			font-size: 0.72rem;
			letter-spacing: 0.28em;
			fill: var(--p-text-soft);
		}
		.allocation-donut-legend {
			display: grid;
			gap: 0.6rem;
		}
		.allocation-legend-item {
			display: grid;
			grid-template-columns: auto 1fr auto auto;
			align-items: baseline;
			gap: 0.7rem;
			padding: 0.55rem 0.75rem;
			border-radius: 0.85rem;
			background: color-mix(in srgb, var(--cat-color) 5%, transparent);
			border-left: 3px solid var(--cat-color);
		}
		.allocation-legend-dot {
			width: 0.7rem;
			height: 0.7rem;
			border-radius: 999px;
			background: var(--cat-color);
			box-shadow: 0 0 12px var(--cat-color);
		}
		.allocation-legend-label {
			font-size: 0.9rem;
			color: var(--p-text);
			font-family: Georgia, serif;
		}
		.allocation-legend-target {
			font-family: Georgia, serif;
			font-size: 0.95rem;
			font-weight: 600;
			color: var(--p-text);
		}
		.allocation-legend-drift {
			font-size: 0.72rem;
			padding: 0.15rem 0.5rem;
			border-radius: 999px;
			font-weight: 600;
			min-width: 2.75rem;
			text-align: center;
		}
		.allocation-legend-drift.positive {
			color: #10b981;
			background: rgba(16, 185, 129, 0.12);
		}
		.allocation-legend-drift.negative {
			color: #ef4444;
			background: rgba(239, 68, 68, 0.12);
		}
		.allocation-subcards {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 768px) {
			.allocation-subcards {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.allocation-subcards {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}
		}
		.allocation-subcard {
			border: 1px solid color-mix(in srgb, var(--cat-color) 25%, var(--p-border));
			background: color-mix(in srgb, var(--cat-color) 5%, var(--p-card));
			border-radius: 1.15rem;
			padding: 1rem 1.1rem;
			display: grid;
			gap: 0.65rem;
		}
		.allocation-subcard-head {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.allocation-subcard-dot {
			width: 0.6rem;
			height: 0.6rem;
			border-radius: 999px;
			background: var(--cat-color);
			box-shadow: 0 0 12px var(--cat-color);
		}
		.allocation-subcard-title {
			margin: 0;
			font-size: 1.05rem;
			flex: 1;
		}
		.allocation-drift-chip {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			font-weight: 600;
		}
		.allocation-drift-chip.positive {
			color: #10b981;
			background: rgba(16, 185, 129, 0.12);
		}
		.allocation-drift-chip.negative {
			color: #ef4444;
			background: rgba(239, 68, 68, 0.12);
		}
		.allocation-subcard-stats {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.6rem;
		}
		.allocation-subcard-stats > div {
			display: grid;
			gap: 0.2rem;
		}
		.allocation-subcard-eyebrow {
			font-size: 0.66rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.allocation-subcard-stats strong {
			font-size: 1.4rem;
			line-height: 1;
		}
		.allocation-subcard-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.allocation-tag {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: color-mix(in srgb, var(--cat-color) 16%, transparent);
			color: var(--p-text-soft);
		}
		.allocation-subcard-note {
			margin: 0;
			font-size: 0.85rem;
			color: var(--p-text-soft);
			line-height: 1.55;
		}
		.allocation-sub-mini {
			display: grid;
			gap: 0.35rem;
			padding-top: 0.55rem;
			border-top: 1px dashed color-mix(in srgb, var(--cat-color) 30%, transparent);
		}
		.allocation-sub-mini-row {
			display: grid;
			grid-template-columns: auto 1fr auto;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.78rem;
			color: var(--p-text-soft);
		}
		.allocation-sub-mini-bar {
			height: 0.45rem;
			border-radius: 999px;
			background: linear-gradient(
				90deg,
				var(--cat-color) 0,
				var(--cat-color) var(--sub-pct, 0%),
				color-mix(in srgb, var(--cat-color) 14%, transparent) var(--sub-pct, 0%)
			);
		}

		/* ── 8-Stage Zigzag ──────────────────────── */
		.stage-zigzag {
			display: grid;
			gap: 1.1rem;
		}
		.stage-card {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 1rem;
			padding: 1.15rem 1.25rem;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			backdrop-filter: blur(18px);
		}
		@media (min-width: 900px) {
			.stage-card.stage-left {
				margin-right: 18%;
			}
			.stage-card.stage-right {
				margin-left: 18%;
			}
		}
		.stage-number-wrap {
			display: grid;
			place-items: center;
			width: 3.2rem;
			height: 3.2rem;
			border-radius: 1rem;
			background: linear-gradient(135deg, rgba(137, 83, 209, 0.25), rgba(137, 83, 209, 0.05));
			border: 1px solid rgba(137, 83, 209, 0.35);
		}
		.stage-number {
			font-size: 1.8rem;
			line-height: 1;
			color: #8953d1;
		}
		.stage-body {
			display: grid;
			gap: 0.55rem;
		}
		.stage-head {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.6rem;
		}
		.stage-title {
			margin: 0;
			font-size: 1.15rem;
		}
		.stage-badge {
			font-size: 0.72rem;
			padding: 0.18rem 0.55rem;
			border-radius: 999px;
			letter-spacing: 0.04em;
		}
		.stage-badge.automated {
			background: rgba(16, 185, 129, 0.15);
			color: #10b981;
			border: 1px solid rgba(16, 185, 129, 0.3);
		}
		.stage-badge.manual {
			background: rgba(156, 163, 175, 0.15);
			color: #9ca3af;
			border: 1px solid rgba(156, 163, 175, 0.3);
		}
		.stage-purpose {
			margin: 0;
			color: var(--p-text-soft);
			font-size: 0.92rem;
			line-height: 1.6;
		}
		.stage-inline-thermo {
			display: flex;
			gap: 0.35rem;
			margin-top: 0.35rem;
		}
		.stage-inline-light {
			width: 0.8rem;
			height: 0.8rem;
			border-radius: 999px;
			background: var(--mini-light);
			box-shadow: 0 0 10px color-mix(in srgb, var(--mini-light) 70%, transparent);
		}
		.stage-inline-meta {
			margin: 0.35rem 0 0;
			font-size: 0.82rem;
			color: var(--p-text-faint);
		}
		.stage-scorecard {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
			align-items: center;
			margin-top: 0.3rem;
		}
		.stage-scorecard-pill {
			font-size: 0.7rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.12);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
		}
		.stage-scorecard-pill-primary {
			background: rgba(137, 83, 209, 0.28);
			color: #fff;
			border-color: rgba(137, 83, 209, 0.5);
		}
		.stage-scorecard-hint {
			font-size: 0.74rem;
			color: var(--p-text-faint);
		}
		.stage-cadence {
			display: flex;
			gap: 0.4rem;
			margin-top: 0.3rem;
		}
		.stage-cadence-badge {
			font-size: 0.74rem;
			padding: 0.22rem 0.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.14);
			color: var(--p-text-soft);
		}

		/* ── Heatmap ─────────────────────────────── */
		.heatmap-wrap {
			overflow-x: auto;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 0.9rem;
		}
		.heatmap-grid {
			display: grid;
			gap: 3px;
			min-width: fit-content;
		}
		.heatmap-corner {
			grid-column: 1;
			grid-row: 1;
		}
		.heatmap-date-label {
			font-size: 0.62rem;
			color: var(--p-text-faint);
			text-align: center;
			writing-mode: vertical-rl;
			transform: rotate(180deg);
			padding: 0.2rem 0;
			min-width: 1.2rem;
		}
		.heatmap-ticker-label {
			font-size: 0.78rem;
			font-weight: 600;
			color: var(--p-text);
			padding-right: 0.6rem;
			text-align: right;
			white-space: nowrap;
			display: grid;
			align-items: center;
		}
		.heatmap-ticker-label small {
			display: block;
			font-size: 0.64rem;
			font-weight: 400;
			color: var(--p-text-faint);
		}
		.heatmap-cell {
			min-width: 1.2rem;
			height: 1.8rem;
			border-radius: 3px;
			position: relative;
			display: grid;
			place-items: center;
		}
		.heatmap-cell-mark {
			color: #fff;
			font-size: 0.6rem;
			line-height: 1;
		}

		/* ── Positions Grid ──────────────────────── */
		.positions-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 720px) {
			.positions-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.positions-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		.position-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.1rem 1.15rem;
			display: grid;
			gap: 0.7rem;
			transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
		}
		.position-card:hover {
			transform: translateY(-2px);
			border-color: rgba(137, 83, 209, 0.35);
			box-shadow: 0 12px 40px rgba(137, 83, 209, 0.12);
		}
		.position-card.conviction-high {
			border-color: rgba(137, 83, 209, 0.28);
		}
		.position-head {
			display: grid;
			gap: 0.55rem;
		}
		.position-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.5rem;
		}
		.position-symbol {
			font-size: 1.55rem;
			line-height: 1;
		}
		.position-flag {
			font-size: 1rem;
		}
		.position-conviction-icon {
			margin-left: auto;
			font-size: 1rem;
		}
		.position-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.3rem;
		}
		.position-tag {
			display: inline-flex;
			align-items: center;
			align-self: center;
			flex: 0 0 auto;
			font-size: 0.7rem;
			line-height: 1.3;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.13);
			color: var(--p-text-soft);
			border: 1px solid rgba(137, 83, 209, 0.2);
			white-space: nowrap;
		}
		.position-thesis {
			margin: 0;
			font-size: 0.9rem;
			line-height: 1.6;
			color: var(--p-text-soft);
			border-left: 2px solid rgba(137, 83, 209, 0.4);
			padding-left: 0.85rem;
		}
		.position-conviction-bar {
			display: block;
			width: 100%;
			height: 6px;
			margin: 0.6rem 0 0.3rem;
			border-radius: 3px;
			background: color-mix(in srgb, var(--p-text-faint) 25%, transparent);
			overflow: hidden;
		}
		.position-conviction-fill {
			display: block;
			height: 100%;
			border-radius: 3px;
			transition: width 0.6s ease;
		}
		.position-meta {
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.position-stage-badge {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.2);
			color: #c9b4f5;
		}
		.position-status {
			font-size: 0.72rem;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.08);
			color: var(--p-text-faint);
		}
		:global(html[data-theme='light']) .position-status {
			background: rgba(30, 20, 50, 0.06);
	}
	.position-foot {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding-top: 0.55rem;
		border-top: 1px dashed var(--p-border);
		font-size: 0.82rem;
	}

	/* ── Crypto-specific styles ─────────────── */
	.portfolio-updated {
		text-align: right;
		font-size: 0.72rem;
		opacity: 0.45;
		margin-top: 1rem;
	}

	.position-rail {
			display: flex;
			align-items: center;
			gap: 0.45rem;
		}
		/* ── Range Track (Stop → Target) ──────── */
		.position-range-track {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.75rem;
			font-variant-numeric: tabular-nums;
		}
		.range-label {
			white-space: nowrap;
			opacity: 0.7;
			font-size: 0.72rem;
		}
		.range-stop { color: #f87171; }
		.range-target { color: #34d399; }
		.range-bar {
			flex: 1;
			position: relative;
			height: 5px;
			border-radius: 999px;
			background: linear-gradient(to right, rgba(248,113,113,0.25), rgba(52,211,153,0.25));
			overflow: visible;
		}
		.range-bar-danger {
			position: absolute;
			left: 0;
			top: 0;
			bottom: 0;
			border-radius: 999px 0 0 999px;
			background: rgba(248,113,113,0.15);
			width: var(--danger-width, 50%);
		}
		.range-marker {
			position: absolute;
			top: 50%;
			transform: translate(-50%, -50%);
			width: 9px;
			height: 9px;
			border-radius: 50%;
			background: var(--p-text);
			border: 2px solid var(--p-bg);
			box-shadow: 0 0 0 1px rgba(137, 83, 209, 0.5);
			z-index: 1;
			transition: left 0.3s ease;
		}

		/* ── Supply Chain Topology ────────────── */
		/* ── Sector Topology Cake (Layered Pyramid) ─── */
		.topology-cake {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 3px;
			padding: 1rem 0;
		}
		.topo-cake-layer {
			width: var(--cake-w);
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 0.3rem;
			padding: 0.55rem 1rem;
			background: linear-gradient(180deg, rgba(137,83,209,0.10) 0%, rgba(137,83,209,0.04) 100%);
			border: 1px solid rgba(137,83,209,0.18);
			border-radius: 8px;
			transition: border-color 0.2s, box-shadow 0.2s;
			text-align: center;
		}
		.topo-cake-layer:hover {
			border-color: rgba(137,83,209,0.45);
			box-shadow: 0 0 16px rgba(137,83,209,0.12);
		}
		.topo-cake-label {
			font-size: 0.78rem;
			font-weight: 600;
			color: var(--p-text);
			white-space: nowrap;
		}
		.topo-cake-sub {
			font-size: 0.65rem;
			font-weight: 400;
			color: var(--p-text-faint);
			margin-left: 0.4rem;
		}
		.topo-cake-nodes {
			display: flex;
			flex-wrap: wrap;
			gap: 0.3rem;
			justify-content: center;
		}
		.topo-tag {
			display: inline-flex;
			align-items: center;
			padding: 0.12rem 0.5rem;
			border-radius: 6px;
			font-size: 0.68rem;
			font-weight: 700;
			font-family: var(--font-mono);
			letter-spacing: 0.03em;
		}
		.topo-tag-held {
			background: rgba(137, 83, 209, 0.22);
			color: rgba(190, 160, 240, 0.95);
			border: 1px solid rgba(137, 83, 209, 0.35);
		}
		.topo-tag-watch {
			background: transparent;
			color: rgba(137, 83, 209, 0.55);
			border: 1px dashed rgba(137, 83, 209, 0.4);
		}
		/* Ghost layer (L4) — dashed + dim */
		.topo-ghost {
			opacity: 0.5;
			border-style: dashed;
		}
		/* Watch layer — softer */
		.topo-watch .topo-cake-label { color: var(--p-text-soft); }
		/* Light theme overrides */
		:global(html[data-theme='light']) .topo-cake-layer {
			background: linear-gradient(180deg, rgba(137,83,209,0.06) 0%, rgba(137,83,209,0.02) 100%);
			border-color: rgba(137,83,209,0.15);
		}
		:global(html[data-theme='light']) .topo-tag-held {
			background: rgba(137, 83, 209, 0.12);
			color: rgba(100, 50, 170, 0.95);
			border-color: rgba(137, 83, 209, 0.35);
		}
		:global(html[data-theme='light']) .topo-tag-watch {
			color: rgba(100, 50, 170, 0.5);
			border-color: rgba(137, 83, 209, 0.3);
		}
		.topology-legend {
			display: flex;
			gap: 1.25rem;
			justify-content: center;
			font-size: 0.72rem;
			opacity: 0.6;
			margin-top: 0.5rem;
		}
		.legend-item {
			display: flex;
			align-items: center;
			gap: 0.35rem;
		}
		.legend-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			flex-shrink: 0;
		}
		.legend-held { background: rgba(137, 83, 209, 0.85); }
		.legend-watch {
			background: transparent;
			border: 2px dashed rgba(137, 83, 209, 0.5);
		}
		.legend-ghost {
			background: transparent;
			border: 2px dashed rgba(137, 83, 209, 0.2);
		}
		.rail-label {
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			opacity: 0.6;
		}
		.rail-value {
			font-variant-numeric: tabular-nums;
			font-weight: 600;
		}
		.rail-sep {
			color: var(--p-border);
			font-size: 0.7rem;
			margin: 0 0.1rem;
		}
		.rail-icon {
			flex-shrink: 0;
			opacity: 0.85;
		}
		.position-stop {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
			font-variant-numeric: tabular-nums;
		}
		.position-target {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
			color: #10b981;
			font-variant-numeric: tabular-nums;
		}
		.position-stop.severity-red {
			color: #ef4444;
		}
		.position-stop.severity-yellow {
			color: #f59e0b;
		}
		.position-stop.severity-gray {
			color: var(--p-text-faint);
		}
		.position-stop-empty,
		.position-target-empty,
		.position-event-empty {
			color: var(--p-text-faint);
			font-size: 0.78rem;
		}
		.position-event {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
			padding: 0.2rem 0.6rem;
			border-radius: 999px;
			font-size: 0.75rem;
			line-height: 1.3;
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 90%, transparent);
			transition: border-color 0.3s, box-shadow 0.3s;
		}
		.event-countdown {
			font-weight: 700;
			white-space: nowrap;
			color: var(--p-text-soft);
		}
		.event-label {
			color: var(--p-text-faint);
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
			max-width: 14ch;
		}
		/* urgency tiers */
		.position-event.urgency-4,
		.position-event.urgency-5 {
			border-color: rgba(251, 146, 60, 0.45);
		}
		.position-event.urgency-4 .event-countdown,
		.position-event.urgency-5 .event-countdown {
			color: #fb923c;
		}
		.position-event.urgency-5 {
			animation: event-pulse 2.4s ease-in-out infinite;
		}
		.position-event.urgency-3 {
			border-color: rgba(239, 68, 68, 0.3);
		}
		.position-event.urgency-3 .event-countdown {
			color: #ef4444;
		}
		.position-event.urgency-1,
		.position-event.urgency-2 {
			border-color: rgba(100, 116, 139, 0.25);
		}
		.position-event.urgency-1 .event-countdown,
		.position-event.urgency-2 .event-countdown {
			color: #64748b;
		}
		.position-event.event-past {
			display: none;
		}
		@keyframes event-pulse {
			0%, 100% { box-shadow: 0 0 0 0 rgba(251, 146, 60, 0); }
			50% { box-shadow: 0 0 8px 2px rgba(251, 146, 60, 0.25); }
		}

		/* ── Position News Digest ───────────────── */
		.position-news {
			display: flex;
			align-items: flex-start;
			gap: 0.4rem;
			margin-top: 0.4rem;
			padding: 0.35rem 0.5rem;
			border-radius: 0.4rem;
			font-size: 0.72rem;
			line-height: 1.35;
			color: var(--p-text-secondary);
			background: color-mix(in srgb, var(--p-surface) 60%, transparent);
		}
		.news-sentiment-icon { flex-shrink: 0; font-size: 0.65rem; margin-top: 0.1rem; }
		.news-summary {
			flex: 1;
			overflow: hidden;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
		}
		.position-news.sentiment-positive { border-left: 2px solid #22c55e40; }
		.position-news.sentiment-negative { border-left: 2px solid #ef444440; }
		.position-news.sentiment-neutral  { border-left: 2px solid #eab30840; }

		/* ── Daily Briefing ─────────────────────── */
		.daily-briefing {
			margin: 0.5rem 0 1.25rem;
			padding: 0.85rem 1rem;
			border-radius: 0.75rem;
			border: 1px solid var(--p-border);
			background: var(--p-card);
		}
		.daily-briefing-head {
			font-size: 0.8rem;
			font-weight: 600;
			color: var(--p-muted);
			text-transform: uppercase;
			letter-spacing: 0.04em;
			margin-bottom: 0.75rem;
		}
		.daily-briefing-list {
			display: flex;
			flex-direction: column;
			gap: 0.6rem;
		}
		.briefing-row {
			padding: 0.5rem 0;
			border-bottom: 1px solid var(--p-border);
		}
		.briefing-row:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}
		.briefing-price-row {
			font-size: 0.9rem;
			font-weight: 600;
		}
		.briefing-change {
			font-family: var(--font-mono);
			color: var(--p-heading);
		}
		.briefing-up {
			color: #22c55e;
		}
		.briefing-down {
			color: #ef4444;
		}
		.briefing-news {
			font-size: 0.82rem;
			color: var(--p-body);
			margin-top: 0.15rem;
			line-height: 1.5;
		}
		.briefing-event {
			font-size: 0.78rem;
			color: var(--p-muted);
			margin-top: 0.1rem;
		}

		/* ── Clearance Gallery ───────────────────── */
		.clearance-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		@media (min-width: 900px) {
			.clearance-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		.clearance-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.35rem;
			padding: 1.3rem;
			display: grid;
			gap: 0.95rem;
		}
		.clearance-card.outcome-win {
			border-color: rgba(16, 185, 129, 0.28);
		}
		.clearance-card.outcome-loss {
			border-color: rgba(239, 68, 68, 0.28);
		}
		.clearance-head {
			display: grid;
			gap: 0.5rem;
		}
		.clearance-symbol-row {
			display: flex;
			align-items: baseline;
			gap: 0.65rem;
		}
		.clearance-symbol {
			font-size: 1.4rem;
			color: var(--p-text);
		}
		.clearance-name {
			font-size: 0.95rem;
			color: var(--p-text-soft);
		}
		.clearance-meta-row {
			display: flex;
			align-items: center;
			gap: 0.7rem;
		}
		.clearance-pct {
			font-family: Georgia, serif;
			font-size: 1.6rem;
			font-weight: 700;
			line-height: 1;
		}
		.clearance-card.outcome-win .clearance-pct {
			color: #10b981;
		}
		.clearance-card.outcome-loss .clearance-pct {
			color: #ef4444;
		}
		.clearance-days {
			font-size: 0.82rem;
			color: var(--p-text-faint);
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.05);
		}
		:global(html[data-theme='light']) .clearance-days {
			background: rgba(30, 20, 50, 0.06);
		}
		.clearance-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		.clearance-chart-wrap {
			height: 180px;
			position: relative;
		}
		.clearance-chart {
			width: 100% !important;
			height: 100% !important;
		}
		.clearance-chart-empty {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			height: 100%;
			color: var(--p-muted);
			font-size: 0.85rem;
			gap: 0.25rem;
		}
		.clearance-trade-points {
			display: grid;
			gap: 0.5rem;
			padding: 0.75rem 0.8rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.05);
		}
		/* Each trade point is a compact stacked card rather than a cramped
		   3-column grid. Top row: date + kind chip + price; action bold
		   under it; note as secondary smaller text. Left-border stripe
		   colors each row by kind. */
		.trade-point-row {
			display: grid;
			gap: 0.2rem;
			padding: 0.55rem 0.75rem;
			border-radius: 0.55rem;
			background: color-mix(in srgb, var(--p-card) 85%, transparent);
			border-left: 3px solid rgba(137, 83, 209, 0.35);
		}
		.trade-point-row.kind-entry,
		.trade-point-row.kind-add {
			border-left-color: rgba(16, 185, 129, 0.55);
		}
		.trade-point-row.kind-exit,
		.trade-point-row.kind-sell,
		.trade-point-row.kind-trim,
		.trade-point-row.kind-stopped {
			border-left-color: rgba(239, 68, 68, 0.55);
		}
		.trade-point-row.kind-catalyst,
		.trade-point-row.kind-external {
			border-left-color: rgba(245, 158, 11, 0.55);
		}
		.trade-point-row.kind-methodology {
			border-left-color: rgba(137, 83, 209, 0.55);
		}
		.trade-point-top {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0.5rem;
			font-size: 0.72rem;
		}
		.trade-point-date {
			color: var(--p-text-faint);
			font-family: Georgia, serif;
		}
		.trade-point-kind {
			font-size: 0.6rem;
			padding: 0.1rem 0.45rem;
			border-radius: 999px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			background: rgba(137, 83, 209, 0.14);
			color: var(--p-text-soft);
			font-weight: 600;
		}
		.trade-point-price {
			margin-left: auto;
			color: var(--p-text);
			font-family: Georgia, serif;
			font-weight: 600;
		}
		.trade-point-action {
			font-size: 0.88rem;
			font-weight: 600;
			color: var(--p-text);
			line-height: 1.45;
		}
		.trade-point-note {
			font-size: 0.78rem;
			color: var(--p-text-soft);
			line-height: 1.55;
		}
		.clearance-foot {
			display: grid;
			gap: 0.55rem;
			padding-top: 0.9rem;
			border-top: 1px dashed var(--p-border);
		}
		.clearance-foot p {
			margin: 0;
			font-size: 0.86rem;
			line-height: 1.6;
			color: var(--p-text-soft);
		}
		.clearance-foot strong {
			color: var(--p-text);
		}
		.clearance-article-link {
			display: inline-block;
			margin-top: 0.25rem;
			font-size: 0.86rem;
			color: var(--p-accent);
			text-decoration: none;
			transition: opacity 0.2s;
		}
		.clearance-article-link:hover {
			opacity: 0.7;
		}

		/* ── Roundtable ──────────────────────────── */
		.roundtable-list {
			display: grid;
			gap: 1rem;
		}
		.roundtable-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.3rem;
			display: grid;
			gap: 0.85rem;
		}
		.roundtable-head {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0.7rem;
		}
		.roundtable-date {
			font-family: Georgia, serif;
			font-size: 1.1rem;
			color: var(--p-text-soft);
		}
		.roundtable-cadence-tag {
			font-size: 0.7rem;
			padding: 0.15rem 0.5rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			text-transform: uppercase;
			letter-spacing: 0.08em;
		}
		.roundtable-title {
			margin: 0;
			flex: 1;
			font-size: 1.2rem;
		}
		.roundtable-guests {
			display: flex;
			flex-wrap: wrap;
			gap: 0.4rem;
		}
		.roundtable-guest {
			font-size: 0.84rem;
			padding: 0.4rem 0.7rem;
			border-radius: 0.75rem;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			display: grid;
			gap: 0.1rem;
		}
		.roundtable-guest small {
			font-size: 0.66rem;
			letter-spacing: 0.08em;
			color: var(--p-text-faint);
			text-transform: uppercase;
		}
		.roundtable-verdict {
			margin: 0;
			padding: 0.8rem 1rem;
			border-left: 3px solid rgba(137, 83, 209, 0.5);
			font-size: 0.95rem;
			line-height: 1.7;
			color: var(--p-text);
			background: rgba(137, 83, 209, 0.06);
			border-radius: 0 0.75rem 0.75rem 0;
		}

		/* ── Clearance chips (win rate / trade count) ── */
		.clearance-chip {
			font-size: 0.72rem;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.12);
			color: var(--p-text-soft);
			letter-spacing: 0.04em;
		}

		/* ── Clearance sub-tickers (basket) ── */
		.clearance-sub-tickers {
			display: grid;
			gap: 0.45rem;
			padding: 0.7rem 0.85rem;
			border-radius: 0.85rem;
			background: color-mix(in srgb, var(--p-card) 86%, transparent);
			border: 1px dashed var(--p-border);
		}
		.clearance-sub-label {
			font-size: 0.66rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.clearance-sub-list {
			display: grid;
			gap: 0.35rem;
		}
		.clearance-sub-item {
			display: grid;
			grid-template-columns: auto 1fr auto auto;
			align-items: baseline;
			gap: 0.55rem;
			font-size: 0.82rem;
		}
		.clearance-sub-ticker {
			font-size: 0.88rem;
			color: var(--p-text);
		}
		.clearance-sub-name {
			color: var(--p-text-soft);
		}
		.clearance-sub-pct {
			font-family: Georgia, serif;
			font-style: normal;
			font-weight: 600;
		}
		.clearance-sub-pct.positive {
			color: #10b981;
		}
		.clearance-sub-pct.negative {
			color: #ef4444;
		}
		.clearance-sub-days {
			font-size: 0.72rem;
			color: var(--p-text-faint);
		}

		/* ── Clearance AI-context ── */
		.clearance-ai-context {
			margin: 0;
			padding: 0.75rem 0.9rem;
			border-radius: 0.85rem;
			background: linear-gradient(
				135deg,
				rgba(137, 83, 209, 0.09),
				rgba(161, 117, 232, 0.05)
			);
			border-left: 3px solid rgba(137, 83, 209, 0.55);
			font-size: 0.85rem;
			line-height: 1.65;
			color: var(--p-text-soft);
			display: grid;
			gap: 0.35rem;
		}
		.clearance-ai-badge {
			display: inline-block;
			align-self: start;
			font-size: 0.64rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			padding: 0.18rem 0.5rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			font-weight: 700;
		}
		:global(html[data-theme='light']) .clearance-ai-badge {
			color: #8953d1;
		}

		/* ── Sector Research (Stage 1) ─────────── */
		.sector-research-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		@media (min-width: 900px) {
			.sector-research-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		.sector-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.25rem;
			padding: 1.2rem 1.25rem;
			display: grid;
			gap: 0.7rem;
		}
		.sector-card-head {
			display: grid;
			gap: 0.4rem;
		}
		.sector-card-date {
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
			font-family: Georgia, serif;
		}
		.sector-card-title {
			margin: 0;
			font-size: 1.2rem;
			line-height: 1.3;
			color: var(--p-text);
		}
		.sector-card-eyebrow {
			display: block;
			margin-bottom: 0.25rem;
			font-size: 0.64rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.sector-card-scope {
			margin: 0;
			font-size: 0.88rem;
			color: var(--p-text-soft);
			line-height: 1.65;
		}
		.sector-card-conclusion {
			margin: 0;
			padding: 0.75rem 0.9rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.08);
			border-left: 3px solid rgba(137, 83, 209, 0.55);
			font-size: 0.92rem;
			line-height: 1.65;
			color: var(--p-text);
			font-weight: 500;
		}
		.sector-card-layers {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35rem;
			padding-top: 0.4rem;
			border-top: 1px dashed var(--p-border);
		}
		.sector-layer-chip {
			font-size: 0.7rem;
			padding: 0.28rem 0.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			letter-spacing: 0.04em;
		}

		/* ── Deep Research (Stage 4) ───────────── */
		.deep-research-group {
			display: grid;
			gap: 0.75rem;
		}
		.deep-research-group-title {
			font-size: 0.82rem;
			font-weight: 600;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--p-text-faint);
			padding-bottom: 0.3rem;
			border-bottom: 1px solid color-mix(in srgb, var(--p-border) 40%, transparent);
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}
		.deep-research-group-count {
			font-size: 0.7rem;
			background: color-mix(in srgb, var(--p-accent) 20%, transparent);
			color: var(--p-text-soft);
			padding: 0.1rem 0.45rem;
			border-radius: 8px;
		}
		.deep-research-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.9rem;
		}
		@media (min-width: 700px) {
			.deep-research-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1100px) {
			.deep-research-grid {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
		}
		.deep-card {
			border: 1px solid var(--p-border);
			background: color-mix(in srgb, var(--p-card) 94%, transparent);
			border-radius: 1.15rem;
			padding: 1rem 1.1rem;
			display: grid;
			gap: 0.55rem;
		}
		.deep-card.held {
			border-color: rgba(137, 83, 209, 0.4);
			background: color-mix(in srgb, rgba(137, 83, 209, 0.08) 60%, var(--p-card));
		}
		.deep-card-head {
			display: grid;
			gap: 0.3rem;
		}
		.deep-card-ticker-row {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 0.45rem;
		}
		.deep-card-ticker {
			font-size: 1.25rem;
			color: var(--p-text);
			letter-spacing: 0.02em;
		}
		.deep-card-market {
			font-size: 0.64rem;
			letter-spacing: 0.14em;
			padding: 0.16rem 0.45rem;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.06);
			color: var(--p-text-faint);
			font-weight: 600;
		}
		:global(html[data-theme='light']) .deep-card-market {
			background: rgba(30, 20, 50, 0.06);
		}
		.deep-card-status {
			margin-left: auto;
			font-size: 0.68rem;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			padding: 0.2rem 0.55rem;
			border-radius: 999px;
			font-weight: 600;
		}
		.deep-card-status.held {
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
		}
		:global(html[data-theme='light']) .deep-card-status.held {
			color: #8953d1;
		}
		.deep-card-status.watching {
			background: rgba(245, 158, 11, 0.14);
			color: #f59e0b;
		}
		.deep-card-name {
			font-size: 0.92rem;
			color: var(--p-text-soft);
		}
		.deep-card-sector {
			font-size: 0.72rem;
			padding: 0.22rem 0.6rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
			justify-self: start;
			letter-spacing: 0.03em;
		}
		.deep-card-thesis {
			margin: 0;
			font-size: 0.88rem;
			color: var(--p-text);
			line-height: 1.65;
		}
		.deep-card-foot {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.6rem;
			padding-top: 0.5rem;
			border-top: 1px dashed var(--p-border);
		}
		.deep-card-conf-label {
			font-size: 0.66rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.deep-card-stars {
			font-size: 0.95rem;
			letter-spacing: 0.08em;
		}
		.deep-card-star {
			color: rgba(137, 83, 209, 0.22);
		}
		.deep-card-star.filled {
			color: #c9b4f5;
			text-shadow: 0 0 8px rgba(137, 83, 209, 0.4);
		}
		:global(html[data-theme='light']) .deep-card-star.filled {
			color: #8953d1;
			text-shadow: none;
		}

		/* ── Roundtable extended (topic / guest-cards / rounds / implications) ── */
		.roundtable-topic {
			margin: 0;
			padding: 0.7rem 0.85rem;
			border-radius: 0.75rem;
			background: rgba(137, 83, 209, 0.06);
			font-size: 0.92rem;
			line-height: 1.6;
			color: var(--p-text);
			display: grid;
			gap: 0.25rem;
		}
		.roundtable-topic-label {
			font-size: 0.64rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}

		/* Guests layout: responsive grid below 1024px, radial circle above. */
		.roundtable-guests-radial {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
		.roundtable-guests-center {
			display: none;
		}
		@media (min-width: 640px) {
			.roundtable-guests-radial {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}
		@media (min-width: 1024px) {
			.roundtable-guests-radial {
				display: block;
				position: relative;
				width: 100%;
				max-width: 640px;
				aspect-ratio: 1 / 1;
				margin: 1.5rem auto 2rem;
			}
			.roundtable-guests-radial .roundtable-guest-card,
			.roundtable-guests-radial .roundtable-guest-pill {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 210px;
				transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y)));
				transition: transform 0.35s ease;
			}
			.roundtable-guests-radial .roundtable-guest-card:hover {
				transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y))) scale(1.04);
				z-index: 2;
			}
			.roundtable-guests-center {
				display: grid;
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				text-align: center;
				font-family: Georgia, serif;
				font-size: 0.74rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--p-text-faint);
				max-width: 140px;
				gap: 0.15rem;
				padding: 1rem 1.25rem;
				border-radius: 999px;
				border: 1px dashed var(--p-border);
			}
		}
		.roundtable-guest-card {
			padding: 0.75rem 0.85rem;
			border-radius: 0.85rem;
			background: rgba(137, 83, 209, 0.08);
			border: 1px solid rgba(137, 83, 209, 0.18);
			display: grid;
			gap: 0.35rem;
		}
		.roundtable-guest-head {
			display: flex;
			align-items: baseline;
			gap: 0.45rem;
		}
		.roundtable-guest-name {
			margin: 0;
			font-size: 1rem;
			color: var(--p-text);
		}
		.roundtable-guest-mbti {
			font-size: 0.6rem;
			letter-spacing: 0.1em;
			padding: 0.12rem 0.4rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			font-weight: 700;
		}
		:global(html[data-theme='light']) .roundtable-guest-mbti {
			color: #8953d1;
		}
		.roundtable-guest-role {
			font-size: 0.66rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}
		.roundtable-guest-position {
			margin: 0;
			font-size: 0.82rem;
			line-height: 1.55;
			color: var(--p-text-soft);
		}
		.roundtable-guest-pill {
			font-size: 0.84rem;
			padding: 0.4rem 0.7rem;
			border-radius: 0.75rem;
			background: rgba(137, 83, 209, 0.1);
			color: var(--p-text-soft);
		}

		.roundtable-rounds {
			list-style: none;
			margin: 0;
			padding: 0;
			display: grid;
			gap: 0.7rem;
			counter-reset: round;
		}
		.round-card {
			border: 1px solid var(--p-border);
			border-radius: 0.9rem;
			padding: 0.85rem 1rem;
			background: color-mix(in srgb, var(--p-card) 96%, transparent);
			display: grid;
			gap: 0.45rem;
		}
		.round-head {
			display: flex;
			align-items: center;
			gap: 0.6rem;
		}
		.round-index {
			display: grid;
			place-items: center;
			width: 1.65rem;
			height: 1.65rem;
			border-radius: 999px;
			background: rgba(137, 83, 209, 0.18);
			color: #c9b4f5;
			font-size: 0.85rem;
			font-weight: 700;
		}
		:global(html[data-theme='light']) .round-index {
			color: #8953d1;
		}
		.round-title {
			margin: 0;
			font-size: 1rem;
			color: var(--p-text);
		}
		.round-tension {
			margin: 0;
			font-size: 0.86rem;
			color: var(--p-text-soft);
			line-height: 1.6;
		}
		.round-fork {
			margin: 0;
			font-size: 0.8rem;
			color: var(--p-text-faint);
			line-height: 1.55;
			padding-top: 0.35rem;
			border-top: 1px dashed var(--p-border);
		}
		.round-fork-label {
			color: var(--p-text-soft);
			font-weight: 600;
			letter-spacing: 0.06em;
			margin-right: 0.15rem;
		}

		.roundtable-verdict-label {
			display: block;
			margin-bottom: 0.35rem;
			font-size: 0.64rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: var(--p-text-faint);
		}

		.roundtable-implications {
			padding: 0.9rem 1rem;
			border-radius: 0.85rem;
			background: color-mix(in srgb, var(--p-card) 92%, transparent);
			border: 1px solid var(--p-border);
			display: grid;
			gap: 0.5rem;
		}
		.roundtable-implications-title {
			margin: 0;
			font-size: 0.82rem;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: var(--p-text-soft);
		}
		.roundtable-implications-list {
			margin: 0;
			padding: 0;
			list-style: none;
			display: grid;
			gap: 0.35rem;
		}
		.roundtable-implication {
			position: relative;
			padding-left: 1.1rem;
			font-size: 0.85rem;
			line-height: 1.55;
			color: var(--p-text);
		}
		.roundtable-implication::before {
			content: '→';
			position: absolute;
			left: 0;
			top: 0;
			color: rgba(137, 83, 209, 0.7);
			font-weight: 700;
		}

		/* ── Empty state ─────────────────────────── */
		.portfolio-empty {
			padding: 2.5rem 1.5rem;
			text-align: center;
			border: 1px dashed var(--p-border);
			border-radius: 1.25rem;
			background: color-mix(in srgb, var(--p-card) 70%, transparent);
		}

		.portfolio-empty {
			color: var(--p-text-faint);
			font-size: 0.9rem;
		}

		/* ── Phase 5 portfolio controls ───────────────── */
		.collapse-control { border: none; border-radius: 4px; background: transparent; color: var(--p-text-faint); padding: 0.25rem 0.55rem; font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase; cursor: pointer; transition: color 0.2s, background 0.2s; white-space: nowrap; flex-shrink: 0; }
		.collapse-control:hover { color: var(--p-text); background: color-mix(in srgb, var(--p-accent, #8953d1) 12%, transparent); }
		.section-collapse-toggle { display: none; }
	.section-chevron { display: inline-block; margin-left: .3rem; font-size: .38rem; opacity: .4; transition: opacity .2s; vertical-align: middle; line-height: 1; }
		.portfolio-section-head:hover .section-chevron { opacity: .8; }
		.section-summary { display: none; font-size: .78rem; color: var(--p-text-faint); letter-spacing: .02em; margin-top: .35rem; padding: .35rem .7rem; border-left: 2px solid var(--p-border); }
		.portfolio-section.is-collapsed .section-summary { display: block; }
		.portfolio-section-head { position: relative; cursor: pointer; -webkit-user-select: none; user-select: none; }
		.portfolio-section.is-collapsed > *:not(.portfolio-section-head) { display: none !important; }
		@keyframes section-pulse { 0% { box-shadow: 0 0 0 0 rgba(137,83,209,.4); } 70% { box-shadow: 0 0 0 6px rgba(137,83,209,0); } 100% { box-shadow: none; } }
		.section-highlight { animation: section-pulse .8s ease-out; border-radius: .8rem; }
		.bucket-bars { display: grid; gap: 1rem; }
		.bucket-row, .crypto-mgmt-card { border: 1px solid var(--p-border); background: var(--p-card); border-radius: 1rem; padding: 1rem; }
		.bucket-label { display: flex; align-items: baseline; gap: .7rem; margin-bottom: .6rem; }
		.bucket-name { font-weight: 700; color: var(--p-text); }
		.bucket-pct { margin-left: auto; font-family: var(--font-serif); font-size: 1.2rem; color: var(--p-text); }
		.bucket-target { font-size: .78rem; font-weight: 700; }
		.bucket-bar-track { position: relative; height: .55rem; border-radius: 999px; background: color-mix(in srgb, var(--p-border) 45%, transparent); overflow: hidden; }
		.bucket-bar-fill { height: 100%; border-radius: 999px; }
		.bucket-bar-target-marker { position: absolute; top: -.25rem; width: 2px; height: 1.05rem; background: var(--p-text); opacity: .55; }
		.bucket-note, .bucket-crypto-summary { margin-top: .7rem; color: var(--p-text-soft); font-size: .88rem; }
		.bucket-action-signals { margin-top: 1rem; display: grid; gap: .55rem; }
		.bucket-signals-title { font-size: .78rem; letter-spacing: .14em; text-transform: uppercase; color: var(--p-text-faint); }
		.bucket-signal { display: flex; gap: .5rem; align-items: center; border-radius: .8rem; padding: .65rem .8rem; color: var(--p-text); text-decoration: none; transition: background .15s; }
		.bucket-signal:hover { background: rgba(255,255,255,.04); }
		.signal-dot { width: .45rem; height: .45rem; border-radius: 50%; flex-shrink: 0; }
		/* priority-1 = ACTION (≥5pp drift or critical) */
		.bucket-signal.priority-1 { border: 1px solid rgba(239,68,68,.32); background: rgba(239,68,68,.08); }
		.bucket-signal.priority-1 .signal-dot { background: #ef4444; box-shadow: 0 0 4px rgba(239,68,68,.4); }
		/* priority-2 = WATCH (≥3pp drift) */
		.bucket-signal.priority-2 { border: 1px solid rgba(245,158,11,.28); background: rgba(245,158,11,.08); }
		.bucket-signal.priority-2 .signal-dot { background: #f59e0b; }
		.crypto-position-card { border-color: rgba(245,158,11,.24); }
		.crypto-position-tag, .crypto-stage-badge { background: rgba(245,158,11,.1); color: #92400e; }
		.crypto-position-link { color: var(--p-accent); font-size: .82rem; }
		.crypto-portfolio-index-wrap,
		.crypto-alloc-trend-wrap { border: 1px solid var(--p-border); background: var(--p-card); border-radius: 1rem; padding: 1rem; margin-top: 1rem; }
		.crypto-portfolio-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: .6rem; margin-top: .75rem; }
		.cpm-item { display: flex; flex-direction: column; gap: .15rem; text-align: center; }
		.cpm-label { font-size: .7rem; color: var(--p-text-faint); letter-spacing: .08em; text-transform: uppercase; }
		.cpm-value { font-size: 1.15rem; font-weight: 700; font-variant-numeric: tabular-nums; }
		.crypto-mgmt-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
		.crypto-mgmt-card strong { display: block; margin: .3rem 0; font-family: var(--font-serif); font-size: 1.8rem; color: var(--p-text); }
		.crypto-mgmt-label { color: var(--p-text-faint); font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; }
		.crypto-mgmt-card p { color: var(--p-text-soft); font-size: .85rem; }
		.crypto-conditions { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: .5rem; }
		.crypto-condition { border: 1px solid var(--p-border); border-radius: 999px; padding: .35rem .65rem; color: var(--p-text-soft); font-size: .78rem; }
		.crypto-condition.met { color: #047857; background: rgba(16,185,129,.1); }
		.crypto-condition.miss { color: var(--p-text-faint); }
		@media (max-width: 820px) { .crypto-mgmt-grid { grid-template-columns: 1fr 1fr; } .bucket-label { flex-wrap: wrap; } }
		@media (max-width: 520px) { .crypto-mgmt-grid { grid-template-columns: 1fr; } }

		/* ── Fade-in-up animation (shared with lucky) ── */
		/* Scroll-triggered fade-up for non-hero portfolio sections. JS toggles
		   `.is-visible` when the section enters viewport. Reduce-motion skip
		   is handled by the observer block in the script (falls back to
		   always-visible). The initial state below means un-observed /
		   un-scripted pages still render content (JS is required for the
		   transition; without JS all sections stay fully visible). */
		.portfolio-section.fade-in-up.is-visible {
			opacity: 1;
			transform: translateY(0);
			transition: opacity 0.65s ease, transform 0.65s ease;
		}
		@media (prefers-reduced-motion: no-preference) {
			.portfolio-section.fade-in-up:not(.is-visible) {
				opacity: 0;
				transform: translateY(24px);
			}
		}

	@keyframes lucky-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ── 1. Allocation donut: arcs fade-scale in + legend hover ── */
	@keyframes donut-arc-in {
		from { opacity: 0; transform: scale(0.7); }
		to   { opacity: 1; transform: scale(1); }
	}
	.allocation-donut-wrap:not(.is-visible) .allocation-arc-outer,
	.allocation-donut-wrap:not(.is-visible) .allocation-arc-inner {
		opacity: 0;
	}
	.allocation-donut-wrap.is-visible .allocation-arc-outer,
	.allocation-donut-wrap.is-visible .allocation-arc-inner {
		opacity: 0;
		animation: donut-arc-in 0.9s cubic-bezier(.4,0,.2,1) forwards;
		transform-origin: 120px 120px;
	}
	.allocation-donut-wrap.is-visible .allocation-arc-outer:nth-child(1),
	.allocation-donut-wrap.is-visible .allocation-arc-inner:nth-child(1) { animation-delay: 100ms; }
	.allocation-donut-wrap.is-visible .allocation-arc-outer:nth-child(2),
	.allocation-donut-wrap.is-visible .allocation-arc-inner:nth-child(2) { animation-delay: 200ms; }
	.allocation-donut-wrap.is-visible .allocation-arc-outer:nth-child(3),
	.allocation-donut-wrap.is-visible .allocation-arc-inner:nth-child(3) { animation-delay: 300ms; }
	.allocation-donut-wrap.is-visible .allocation-arc-outer:nth-child(4),
	.allocation-donut-wrap.is-visible .allocation-arc-inner:nth-child(4) { animation-delay: 400ms; }
	.allocation-donut-wrap.is-visible .allocation-arc-outer:nth-child(5),
	.allocation-donut-wrap.is-visible .allocation-arc-inner:nth-child(5) { animation-delay: 500ms; }
	/* Legend hover → dim other arcs, highlight matching */
	.allocation-donut-wrap:has(.allocation-legend-item:hover) .allocation-arc-outer,
	.allocation-donut-wrap:has(.allocation-legend-item:hover) .allocation-arc-inner {
		stroke-opacity: 0.15;
		transition: stroke-opacity 0.3s ease;
	}
	.allocation-legend-item {
		transition: background 0.2s ease, transform 0.2s ease;
		cursor: pointer;
	}
	.allocation-legend-item:hover {
		background: color-mix(in srgb, var(--cat-color, #8953d1) 14%, transparent);
		transform: translateX(4px);
	}
	/* When hovering a legend item, highlight matching arc */
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(1):hover) .allocation-arc-outer:nth-child(1),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(1):hover) .allocation-arc-inner:nth-child(1),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(2):hover) .allocation-arc-outer:nth-child(2),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(2):hover) .allocation-arc-inner:nth-child(2),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(3):hover) .allocation-arc-outer:nth-child(3),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(3):hover) .allocation-arc-inner:nth-child(3),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(4):hover) .allocation-arc-outer:nth-child(4),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(4):hover) .allocation-arc-inner:nth-child(4),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(5):hover) .allocation-arc-outer:nth-child(5),
	.allocation-donut-wrap:has(.allocation-legend-item:nth-child(5):hover) .allocation-arc-inner:nth-child(5) {
		stroke-opacity: 1 !important;
		stroke-width: 28;
		transition: stroke-opacity 0.3s ease, stroke-width 0.3s ease;
	}

	/* ── 2. Regime: light cards stagger + grid cells ──────────── */
	@keyframes regime-light-in {
		from { opacity: 0; transform: scale(0.85) translateY(8px); }
		to   { opacity: 1; transform: scale(1) translateY(0); }
	}
	.regime-section.is-visible .regime-light-card {
		opacity: 0;
		animation: regime-light-in 0.5s cubic-bezier(.4,0,.2,1) forwards;
	}
	.regime-section.is-visible .regime-light-card:nth-child(1) { animation-delay: 100ms; }
	.regime-section.is-visible .regime-light-card:nth-child(2) { animation-delay: 180ms; }
	.regime-section.is-visible .regime-light-card:nth-child(3) { animation-delay: 260ms; }
	.regime-section.is-visible .regime-light-card:nth-child(4) { animation-delay: 340ms; }
	.regime-section.is-visible .regime-light-card:nth-child(5) { animation-delay: 420ms; }

	/* Regime grid cells: pulse-in stagger */
	@keyframes regime-cell-in {
		from { opacity: 0; transform: scale(0.6); }
		to   { opacity: 1; transform: scale(1); }
	}
	.regime-section.is-visible .regime-grid-cell {
		opacity: 0;
		animation: regime-cell-in 0.35s cubic-bezier(.4,0,.2,1) forwards;
	}
	/* Stagger by column (via nth-child on the row's cells) */
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(1)  { animation-delay: 80ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(2)  { animation-delay: 110ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(3)  { animation-delay: 140ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(4)  { animation-delay: 170ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(5)  { animation-delay: 200ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(6)  { animation-delay: 230ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(7)  { animation-delay: 260ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(8)  { animation-delay: 290ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(9)  { animation-delay: 320ms; }
	.regime-section.is-visible .regime-grid-row .regime-grid-cell:nth-child(10) { animation-delay: 350ms; }

	/* Regime light cards: glow pulse on the dot */
	@keyframes light-pulse {
		0%, 100% { box-shadow: 0 0 0 0 var(--light); }
		50%      { box-shadow: 0 0 8px 3px var(--light); }
	}
	.regime-light-dot {
		animation: light-pulse 2.5s ease-in-out infinite;
	}

	/* ── 3. Heatmap: cell stagger + ticker row hover ─────────── */
	@keyframes heatmap-cell-in {
		from { opacity: 0; transform: scale(0.5); }
		to   { opacity: 1; transform: scale(1); }
	}
	.heatmap-wrap.is-visible .heatmap-cell {
		opacity: 0;
		animation: heatmap-cell-in 0.3s cubic-bezier(.4,0,.2,1) forwards;
	}
	/* Stagger by column position using nth-child on the grid */
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(1)  { animation-delay: 50ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(2)  { animation-delay: 70ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(3)  { animation-delay: 90ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(4)  { animation-delay: 110ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(5)  { animation-delay: 130ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(6)  { animation-delay: 150ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(7)  { animation-delay: 170ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(8)  { animation-delay: 190ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(9)  { animation-delay: 210ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(10) { animation-delay: 230ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(11) { animation-delay: 250ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(12) { animation-delay: 270ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(13) { animation-delay: 290ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(14) { animation-delay: 310ms; }
	.heatmap-wrap.is-visible .heatmap-cell:nth-child(15) { animation-delay: 330ms; }

	/* Heatmap ticker row hover highlight */
	.heatmap-grid {
		position: relative;
	}
	.heatmap-ticker-label {
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.heatmap-ticker-label:hover {
		color: #8953d1;
		transform: translateX(3px);
	}
	/* Star cells: subtle pulse */
	@keyframes star-pulse {
		0%, 100% { opacity: 1; }
		50%      { opacity: 0.5; }
	}
	.heatmap-cell-mark {
		animation: star-pulse 2s ease-in-out infinite;
	}

	/* ── 4. Methodology: stage cards stagger + connector ─────── */
	@keyframes stage-slide-left {
		from { opacity: 0; transform: translateX(-40px); }
		to   { opacity: 1; transform: translateX(0); }
	}
	@keyframes stage-slide-right {
		from { opacity: 0; transform: translateX(40px); }
		to   { opacity: 1; transform: translateX(0); }
	}
	.stage-zigzag.is-visible .stage-card {
		opacity: 0;
	}
	.stage-zigzag.is-visible .stage-card.stage-left {
		animation: stage-slide-left 0.6s cubic-bezier(.4,0,.2,1) forwards;
	}
	.stage-zigzag.is-visible .stage-card.stage-right {
		animation: stage-slide-right 0.6s cubic-bezier(.4,0,.2,1) forwards;
	}
	.stage-zigzag.is-visible .stage-card:nth-child(1) { animation-delay: 80ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(2) { animation-delay: 160ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(3) { animation-delay: 240ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(4) { animation-delay: 320ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(5) { animation-delay: 400ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(6) { animation-delay: 480ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(7) { animation-delay: 560ms; }
	.stage-zigzag.is-visible .stage-card:nth-child(8) { animation-delay: 640ms; }

	/* Connector line between stage cards */
	.stage-zigzag .stage-card + .stage-card {
		position: relative;
	}
	.stage-zigzag .stage-card + .stage-card::before {
		content: '';
		position: absolute;
		top: -0.85rem;
		left: 2.8rem;
		width: 2px;
		height: 0.85rem;
		background: linear-gradient(to bottom, rgba(137, 83, 209, 0.3), rgba(137, 83, 209, 0.08));
	}
	/* Stage number glow on hover */
	.stage-card:hover .stage-number-wrap {
		box-shadow: 0 0 12px rgba(137, 83, 209, 0.35);
		transition: box-shadow 0.3s ease;
	}
	.stage-card {
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.stage-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(137, 83, 209, 0.12);
	}
	/* ── Action Signals Bar ── */
