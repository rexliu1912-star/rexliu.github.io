									<>
										<line x1={pad.l} y1={yPct(v).toFixed(1)} x2={W - pad.r} y2={yPct(v).toFixed(1)} stroke="color-mix(in srgb, var(--p-border) 35%, transparent)" stroke-width="0.5" />
										<text x={pad.l - 6} y={yPct(v).toFixed(1)} font-size="8" fill="color-mix(in srgb, var(--p-text-faint) 60%, transparent)" text-anchor="end" dominant-baseline="middle">{v}%</text>
									</>
								))}
								{buckets.map((b: any) => {
									const key = idToKey[b.id as keyof typeof idToKey];
									if (!key) return null;
									const linePts = ah.map((h: any, i: number) => {
										const v = h.buckets?.[key] ?? 0;
										return `${xOf(i).toFixed(1)},${yPct(v).toFixed(1)}`;
									}).join(" ");
									const current = ah[ah.length - 1]?.buckets?.[key] ?? 0;
									const target = b.target_pct;
									const isDrifted = Math.abs(current - target) >= 5;
									return (
										<>
											<polyline points={linePts} fill="none" stroke={b.color} stroke-width={isDrifted ? "2.2" : "1.5"} stroke-linejoin="round" stroke-linecap="round" stroke-dasharray={isDrifted ? "none" : "4 2"} opacity={isDrifted ? "1" : "0.6"} />
											<line x1={pad.l} y1={yPct(target).toFixed(1)} x2={W - pad.r} y2={yPct(target).toFixed(1)} stroke={b.color} stroke-width="0.6" stroke-dasharray="2 4" opacity="0.35" />
										</>
									);
								})}
								{ah.map((h: any, i: number) => {
									const x = xOf(i).toFixed(1);
									return <text x={x} y={H - 6} font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 50%, transparent)" text-anchor="middle">{h.date}</text>;
								})}
								{buckets.map((b: any, i: number) => {
									const lx = pad.l + i * 110;
									return (
										<>
											<line x1={lx} y1="10" x2={lx + 14} y2="10" stroke={b.color} stroke-width="1.8" />
											<text x={lx + 18} y="10" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 70%, transparent)" dominant-baseline="middle"><tspan class="lang-en">{b.label_en}</tspan><tspan class="lang-zh">{b.label_zh}</tspan></text>
										</>
									);
								})}
								<text x={W - pad.r} y="10" font-size="7.5" fill="color-mix(in srgb, var(--p-text-faint) 45%, transparent)" text-anchor="end"><span class="lang-en">- - target</span><span class="lang-zh">- - 目标</span></text>
							</svg>
						</div>
					);
				})()}


</div>
