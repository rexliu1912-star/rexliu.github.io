			<div class="roundtable-list">
				{roundtables.map((r) => (
					<article class="roundtable-card">
						<header class="roundtable-head">
							<time class="roundtable-date">{r.date}</time>
							<span class="roundtable-cadence-tag">{r.cadence}</span>
							<h3 class="roundtable-title font-serif">
								<span class="lang-en">{r.title_en}</span>
								<span class="lang-zh">{r.title_zh}</span>
