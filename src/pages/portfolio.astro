						</header>

						{(r.topic_en || r.topic_zh) && (
							<p class="roundtable-topic">
								<span class="roundtable-topic-label">
									<span class="lang-en">Question</span>
									<span class="lang-zh">议题</span>
								</span>
								<span class="lang-en">{r.topic_en}</span>
								<span class="lang-zh">{r.topic_zh}</span>
							</p>
						)}

						<div class="roundtable-guests-radial">
							<div class="roundtable-guests-center" aria-hidden="true">
								<span class="lang-en">Six-master debate</span>
								<span class="lang-zh">六家辩论</span>
							</div>
							{r.guests.map((g: any, i: number) => {
								const count = r.guests.length || 1;
								const angle = (i / count) * 2 * Math.PI - Math.PI / 2;
								const radius = 230;
								const x = Math.cos(angle) * radius;
								const y = Math.sin(angle) * radius;
								const style = `--x: ${x.toFixed(1)}px; --y: ${y.toFixed(1)}px`;
								if (typeof g === "string") {
									return (
										<span class="roundtable-guest-pill" style={style}>
											{g}
										</span>
									);
								}
								return (
									<article class="roundtable-guest-card" style={style}>
										<header class="roundtable-guest-head">
											<strong class="roundtable-guest-name font-serif">{g.name}</strong>
											{g.mbti && <span class="roundtable-guest-mbti">{g.mbti}</span>}
										</header>
										<span class="roundtable-guest-role">
											<span class="lang-en">{g.role_en}</span>
											<span class="lang-zh">{g.role_zh}</span>
										</span>
										{(g.position_en || g.position_zh) && (
											<p class="roundtable-guest-position">
												<span class="lang-en">{g.position_en}</span>
												<span class="lang-zh">{g.position_zh}</span>
											</p>
										)}
									</article>
								);
							})}
						</div>

						{r.rounds && r.rounds.length > 0 && (
							<ol class="roundtable-rounds">
								{r.rounds.map((rd: any, idx: number) => (
									<li class="round-card">
										<header class="round-head">
											<span class="round-index font-serif">{idx + 1}</span>
											<h4 class="round-title font-serif">
												<span class="lang-en">{rd.title_en}</span>
												<span class="lang-zh">{rd.title_zh}</span>
											</h4>
										</header>
										{(rd.core_tension_en || rd.core_tension_zh) && (
											<p class="round-tension">
												<span class="lang-en">{rd.core_tension_en}</span>
												<span class="lang-zh">{rd.core_tension_zh}</span>
											</p>
										)}
										{(rd.fork_en || rd.fork_zh) && (
											<p class="round-fork">
												<strong class="round-fork-label">
													<span class="lang-en">Fork ·</span>
													<span class="lang-zh">分岔 ·</span>
												</strong>{" "}
												<span class="lang-en">{rd.fork_en}</span>
												<span class="lang-zh">{rd.fork_zh}</span>
											</p>
										)}
									</li>
								))}
							</ol>
						)}

						<blockquote class="roundtable-verdict">
							<span class="roundtable-verdict-label">
								<span class="lang-en">Final Verdict</span>
								<span class="lang-zh">最终结论</span>
							</span>
							<span class="lang-en">{r.final_verdict_en || ""}</span>
							<span class="lang-zh">{r.final_verdict_zh || r.final_verdict_en || ""}</span>
						</blockquote>

						{((r.implications_en && r.implications_en.length > 0) ||
							(r.implications_zh && r.implications_zh.length > 0)) && (
							<div class="roundtable-implications">
								<h4 class="roundtable-implications-title font-serif">
									<span class="lang-en">Actionable Implications</span>
									<span class="lang-zh">可执行结论</span>
								</h4>
								<ul class="roundtable-implications-list">
									{(r.implications_en || r.implications_zh || []).map((_: any, i: number) => (
										<li class="roundtable-implication">
											<span class="lang-en">
												{r.implications_en?.[i] || r.implications_zh?.[i] || ""}
											</span>
											<span class="lang-zh">
												{r.implications_zh?.[i] || r.implications_en?.[i] || ""}
											</span>
										</li>
									))}
								</ul>
							</div>
						)}
					</article>
				))}
			</div>
		</section>

		{/* ═══ Section 3: 8-Stage Methodology ═══ */}
		<section class="portfolio-section fade-in-up" id="methodology-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Methodology · 8-Stage Funnel</span>
					<span class="lang-zh">方法论 · 八阶段漏斗</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">From macro thermometer to post-trade review</span>
					<span class="lang-zh">从宏观温度计到持仓复盘</span>
				</h2>
