---
import portfolioData from "@/data/portfolio-public.json";
import PageLayout from "@/layouts/Base.astro";

const {
	regime,
	allocation,
	positions,
	watchlist_heatmap: heatmap,
	clearances,
	roundtables,
	stats,
	generated_at,
} = portfolioData;

const regimeColors = {
	进攻期: "#10b981",
	中性期: "#f59e0b",
	防御期: "#ef4444",
	Offensive: "#10b981",
	Neutral: "#f59e0b",
	Defensive: "#ef4444",
};

const lightColors = { green: "#10b981", yellow: "#f59e0b", red: "#ef4444", gray: "#9ca3af" };
const conviction = { high: "🔥", medium: "🌱", low: "❄️" };

const dataJson = JSON.stringify({
	regime,
	allocation,
	heatmap,
	positions,
	clearances,
});

const updatedLabel = new Date(generated_at).toISOString().split("T")[0];

const meta = {
	title: "Portfolio · Rex Liu",
	description:
		"Public portfolio dashboard — sectors, theses, stage-gated decisions, and trade replays. No amounts, just conviction.",
};

// Stage metadata (from investment decision framework v2.0)
const stages = [
	{
		num: 0,
		title_en: "Macro Thermometer",
		title_zh: "宏观温度计",
		purpose_en: "Read market regime: offensive / neutral / defensive",
		purpose_zh: "判断市场温度：进攻 / 中性 / 防御",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 1,
		title_en: "Sector Research",
		title_zh: "赛道研究",
		purpose_en: "1-2 day deep report before picking stocks",
		purpose_zh: "选股之前先做重度赛道报告",
		automated: false,
		badge_en: "Manual",
		badge_zh: "手动",
	},
	{
		num: 2,
		title_en: "Watchlist Scan",
		title_zh: "个股池初筛",
		purpose_en: "15 tickers, 5-dimension filter → 10-20 names",
		purpose_zh: "15 只标的五维扫描 → 10-20 家观察名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 3,
		title_en: "Short List",
		title_zh: "短名单",
		purpose_en: "Valuation + catalyst + technicals → 3-5 names",
		purpose_zh: "估值 + 催化 + 技术面 → 3-5 家可操作短名单",
		automated: true,
		badge_en: "Daily",
		badge_zh: "每日",
	},
	{
		num: 4,
		title_en: "Deep Research",
		title_zh: "深度研究",
		purpose_en: "Skill: 4+1 card per company, 3 hard theses",
		purpose_zh: "Skill：每家公司 4+1 段名片 + 三条硬结论",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 5,
		title_en: "Roundtable",
		title_zh: "圆桌讨论",
		purpose_en: "6-seat masters challenge the theses; dissent required",
		purpose_zh: "6 席位大师挑战结论；反方必选",
		automated: false,
		badge_en: "Skill",
		badge_zh: "Skill",
	},
	{
		num: 6,
		title_en: "Execution Plan",
		title_zh: "执行计划",
		purpose_en: "10-point scorecard ≥7, R:R ≥ 2.0, 3 stop-lines",
		purpose_zh: "10 分评分卡 ≥7，R:R ≥ 2.0，3 条撤退线",
		automated: true,
		badge_en: "Scorecard",
		badge_zh: "评分卡",
	},
	{
		num: 7,
		title_en: "Position Management",
		title_zh: "持仓管理 + 复盘",
		purpose_en: "L0-L3 monitoring + monthly/quarterly/annual reviews",
		purpose_zh: "L0-L3 四层监控 + 月/季/年复盘",
		automated: true,
		badge_en: "4-tier",
		badge_zh: "四层",
	},
];
---

<PageLayout meta={meta}>
	<link
		slot="head"
		rel="preload"
		href="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"
		as="script"
	/>

	<section class="portfolio-page">
		<div class="mb-6">
			<a
				href="/lab/"
				class="font-serif text-sm text-white/60 transition-colors hover:text-[#c9b4f5]"
			>
				← Lab
			</a>
		</div>

		{/* ═══ Section 0: Hero ═══ */}
		<section class="portfolio-hero">
			<p class="portfolio-eyebrow">
				<span class="lang-en">Build in Public · Portfolio</span>
				<span class="lang-zh">公开建造 · 持仓驾驶舱</span>
			</p>
			<div class="portfolio-hero-row">
				<div class="portfolio-hero-text">
					<h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">
						<span class="lang-en">Portfolio · Conviction on Display</span>
						<span class="lang-zh">持仓 · 公开的决策</span>
					</h1>
					<p class="portfolio-subtitle font-serif text-lg leading-relaxed sm:text-xl">
						<span class="lang-en">
							No amounts. Just sectors, theses, stages, and the scorecard behind every position.
						</span>
						<span class="lang-zh">
							不公开金额。只展示板块、逻辑、阶段，以及每个仓位背后的评分卡。
						</span>
					</p>
				</div>
				<div
					class="portfolio-regime-badge"
					style={`--regime-color: ${regimeColors[regime?.current?.label] || "#8953d1"}`}
				>
					<span class="portfolio-regime-eyebrow">
						<span class="lang-en">Current Regime</span>
						<span class="lang-zh">当前宏观</span>
					</span>
					<strong class="portfolio-regime-label font-serif">
						<span class="lang-en">{regime?.current?.label_en || "—"}</span>
						<span class="lang-zh">{regime?.current?.label || "—"}</span>
					</strong>
					<span class="portfolio-regime-meta">
						<span class="lang-en">
							{regime?.current?.green_count ?? 0} / {regime?.current?.total_signals ?? 5} green ·
							Aggression {regime?.current?.aggression ?? "—"}
						</span>
						<span class="lang-zh">
							{regime?.current?.green_count ?? 0}/{regime?.current?.total_signals ?? 5} 绿灯 ·
							激进度 {regime?.current?.aggression ?? "—"}
						</span>
					</span>
				</div>
			</div>

			<div class="portfolio-hero-stats" aria-label="Portfolio statistics">
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Active Positions</span>
						<span class="lang-zh">活跃持仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.active_positions}
					>
						{stats.active_positions}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Markets</span>
						<span class="lang-zh">市场</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.markets}>
						{stats.markets}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Tracked Rules</span>
						<span class="lang-zh">监控规则</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.tracked_rules}>
						{stats.tracked_rules}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Upcoming Events</span>
						<span class="lang-zh">预告事件</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.upcoming_events}>
						{stats.upcoming_events}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Scan Hits (≥5)</span>
						<span class="lang-zh">扫描信号</span>
					</span>
					<strong class="portfolio-stat-value font-serif" data-count-target={stats.weekly_scan_hits}>
						{stats.weekly_scan_hits}
					</strong>
				</article>
				<article class="portfolio-stat-card">
					<span class="portfolio-stat-label">
						<span class="lang-en">Last Clearance</span>
						<span class="lang-zh">上次清仓</span>
					</span>
					<strong
						class="portfolio-stat-value font-serif"
						data-count-target={stats.days_since_last_clearance ?? 0}
						data-count-suffix="d ago"
					>
						{stats.days_since_last_clearance ?? "—"}d ago
					</strong>
				</article>
			</div>

			<p class="portfolio-updated">
				<span class="lang-en">Last updated: {updatedLabel}</span>
				<span class="lang-zh">最后更新: {updatedLabel}</span>
			</p>
		</section>

		{/* ═══ Section 1: Macro Regime ═══ */}
		<section class="portfolio-section fade-in-up" id="regime-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Stage 0 · Macro Thermometer</span>
					<span class="lang-zh">阶段 0 · 宏观温度计</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">The market temperature we're trading against</span>
					<span class="lang-zh">我们在和什么样的市场做交易</span>
				</h2>
			</header>

			<div class="regime-lights">
				{Object.entries(regime?.current?.signals || {}).map(([key, sig]) => (
					<div class="regime-light-card" style={`--light: ${lightColors[sig.light] || "#9ca3af"}`}>
						<span class="regime-light-label">{sig.label}</span>
						<strong class="regime-light-value font-serif">{sig.value}</strong>
						<span class="regime-light-dot" aria-hidden="true"></span>
					</div>
				))}
			</div>

			<div class="regime-chart-wrap">
				<div class="regime-chart-head">
					<h3 class="font-serif text-lg">
						<span class="lang-en">VIX & Regime · 60 days</span>
						<span class="lang-zh">VIX 与 Regime · 60 天</span>
					</h3>
					<p class="portfolio-note">
						<span class="lang-en">
							Shaded bands mark regime transitions (green = offensive, amber = neutral, red =
							defensive). VIX line is the mood overlay.
						</span>
						<span class="lang-zh">
							色段为 regime 状态（绿=进攻、黄=中性、红=防御）。VIX 折线是情绪指标。
						</span>
					</p>
				</div>
				<div class="regime-chart-canvas-wrap">
					<canvas id="regimeChart" aria-hidden="true"></canvas>
					{regime?.history_60d?.length < 7 && (
						<div class="portfolio-empty-overlay">
							<span class="lang-en">
								Accumulating history · need ~7 days before chart renders (daily cron started
								2026-04-16)
							</span>
							<span class="lang-zh">历史数据累积中 · 约 7 天后渲染图表（日度 cron 已启动）</span>
						</div>
					)}
				</div>
			</div>
		</section>

		{/* ═══ Section 2: Allocation ═══ */}
		<section class="portfolio-section fade-in-up" id="allocation-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Allocation · Target vs Current</span>
					<span class="lang-zh">资产配置 · 目标 vs 当前</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">Four buckets, five percentage points of drift</span>
					<span class="lang-zh">四桶资产，五个百分点的偏移</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Dalio three-bucket framework. Percentages are strategic targets; drift chips show
						current distance from each target.
					</span>
					<span class="lang-zh">
						达利欧三桶法框架。百分比是战略目标，偏差 chip 显示当前距目标的距离。
					</span>
				</p>
			</header>

			<div class="allocation-bar" aria-label="Target allocation">
				{allocation.current.categories.map((cat) => (
					<div
						class="allocation-segment"
						style={`flex: ${cat.target_pct}; background: ${cat.color}`}
					>
						<span class="allocation-segment-label">
							<span class="lang-en">{cat.label_en}</span>
							<span class="lang-zh">{cat.label_zh}</span>
							<strong class="allocation-segment-pct">{cat.target_pct}%</strong>
						</span>
					</div>
				))}
			</div>

			<div class="allocation-subcards">
				{allocation.current.categories.map((cat) => (
					<article class="allocation-subcard" style={`--cat-color: ${cat.color}`}>
						<header class="allocation-subcard-head">
							<span class="allocation-subcard-dot"></span>
							<h3 class="allocation-subcard-title font-serif">
								<span class="lang-en">{cat.label_en}</span>
								<span class="lang-zh">{cat.label_zh}</span>
							</h3>
							<span
								class={`allocation-drift-chip ${cat.drift_pp >= 0 ? "positive" : "negative"}`}
							>
								{cat.drift_pp >= 0 ? "+" : ""}
								{cat.drift_pp}pp
							</span>
						</header>
						<div class="allocation-subcard-stats">
							<div>
								<span class="allocation-subcard-eyebrow">
									<span class="lang-en">Target</span>
									<span class="lang-zh">目标</span>
								</span>
								<strong class="font-serif">{cat.target_pct}%</strong>
							</div>
							<div>
								<span class="allocation-subcard-eyebrow">
									<span class="lang-en">Current</span>
									<span class="lang-zh">当前</span>
								</span>
								<strong class="font-serif">{cat.current_pct}%</strong>
							</div>
						</div>
						{cat.sub_tags_en && (
							<div class="allocation-subcard-tags">
								{cat.sub_tags_en.map((tag, i) => (
									<span class="allocation-tag">
										<span class="lang-en">{tag}</span>
										<span class="lang-zh">{cat.sub_tags_zh[i] || tag}</span>
									</span>
								))}
							</div>
						)}
						<p class="allocation-subcard-note">
							<span class="lang-en">{cat.note_en}</span>
							<span class="lang-zh">{cat.note_zh}</span>
						</p>
						{cat.sub && (
							<div class="allocation-sub-mini">
								{cat.sub.map((s) => (
									<div
										class="allocation-sub-mini-row"
										style={`--sub-pct: ${(s.pct / cat.target_pct) * 100}%`}
									>
										<span>
											<span class="lang-en">{s.label_en}</span>
											<span class="lang-zh">{s.label_zh}</span>
										</span>
										<span class="allocation-sub-mini-bar"></span>
										<strong class="font-serif">{s.pct}%</strong>
									</div>
								))}
							</div>
						)}
					</article>
				))}
			</div>
		</section>

		{/* ═══ Section 3: 8-Stage Methodology ═══ */}
		<section class="portfolio-section fade-in-up" id="methodology-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Methodology · 8-Stage Funnel</span>
					<span class="lang-zh">方法论 · 八阶段漏斗</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">From macro thermometer to post-trade review</span>
					<span class="lang-zh">从宏观温度计到持仓复盘</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Every position passes through these stages. Some are automated cron tasks, some
						require human judgment. Round-trip is weeks, not days.
					</span>
					<span class="lang-zh">
						每个持仓都要走过这些阶段。部分是自动 cron，部分需要人工判断。完整走一圈以周为单位，不是天。
					</span>
				</p>
			</header>

			<div class="stage-zigzag">
				{stages.map((s, i) => (
					<article class={`stage-card ${i % 2 === 0 ? "stage-left" : "stage-right"}`}>
						<div class="stage-number-wrap">
							<span class="stage-number font-serif">{s.num}</span>
						</div>
						<div class="stage-body">
							<header class="stage-head">
								<h3 class="stage-title font-serif">
									<span class="lang-en">{s.title_en}</span>
									<span class="lang-zh">{s.title_zh}</span>
								</h3>
								<span class={`stage-badge ${s.automated ? "automated" : "manual"}`}>
									{s.automated ? "✓" : "○"}{" "}
									<span class="lang-en">{s.badge_en}</span>
									<span class="lang-zh">{s.badge_zh}</span>
								</span>
							</header>
							<p class="stage-purpose">
								<span class="lang-en">{s.purpose_en}</span>
								<span class="lang-zh">{s.purpose_zh}</span>
							</p>
							{s.num === 0 && (
								<div class="stage-inline-thermo">
									{Object.entries(regime?.current?.signals || {}).map(([key, sig]) => (
										<span
											class="stage-inline-light"
											style={`--mini-light: ${lightColors[sig.light] || "#9ca3af"}`}
											title={`${sig.label}: ${sig.value}`}
										></span>
									))}
								</div>
							)}
							{s.num === 2 && heatmap?.tickers?.length > 0 && (
								<p class="stage-inline-meta">
									<span class="lang-en">{heatmap.tickers.length} tickers in scan pool</span>
									<span class="lang-zh">{heatmap.tickers.length} 只标的在观察池</span>
								</p>
							)}
							{s.num === 6 && (
								<div class="stage-scorecard">
									<span class="stage-scorecard-pill">MA200</span>
									<span class="stage-scorecard-pill">支撑</span>
									<span class="stage-scorecard-pill">RSI</span>
									<span class="stage-scorecard-pill">量价</span>
									<span class="stage-scorecard-pill stage-scorecard-pill-primary">
										R:R ≥ 2.0
									</span>
									<span class="stage-scorecard-hint">
										<span class="lang-en">Score ≥ 7 / 10 to trade</span>
										<span class="lang-zh">≥ 7/10 才下单</span>
									</span>
								</div>
							)}
							{s.num === 7 && (
								<div class="stage-cadence">
									<span class="stage-cadence-badge">
										<span class="lang-en">Monthly</span>
										<span class="lang-zh">月度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Quarterly</span>
										<span class="lang-zh">季度</span>
									</span>
									<span class="stage-cadence-badge">
										<span class="lang-en">Annual</span>
										<span class="lang-zh">年度</span>
									</span>
								</div>
							)}
						</div>
					</article>
				))}
			</div>
		</section>

		{/* ═══ Section 4: Watchlist Heatmap ═══ */}
		<section class="portfolio-section fade-in-up" id="watchlist-section">
			<header class="portfolio-section-head">
				<p class="portfolio-kicker">
					<span class="lang-en">Stage 2-3 · Watchlist Opportunity Scan</span>
					<span class="lang-zh">阶段 2-3 · 观察池机会扫描</span>
				</p>
				<h2 class="font-serif text-3xl font-semibold">
					<span class="lang-en">Who's moving into upgrade range</span>
					<span class="lang-zh">谁在靠近升级区</span>
				</h2>
				<p class="portfolio-note">
					<span class="lang-en">
						Daily 10-point scan across 15 tickers. Darker = closer to the 7-point upgrade
						threshold. Empty cells are days before the scan started.
					</span>
					<span class="lang-zh">
						每日对 15 只标的跑 10 分评分卡。颜色越深越接近 7 分升级门槛。空格是扫描启动前的日期。
					</span>
				</p>
			</header>

			{heatmap?.tickers?.length > 0 ? (
				<div class="heatmap-wrap">
					<div
						class="heatmap-grid"
						style={`grid-template-columns: auto repeat(${heatmap.dates.length}, 1fr)`}
					>
						<div class="heatmap-corner"></div>
						{heatmap.dates.map((d) => (
							<div class="heatmap-date-label">{d.slice(5)}</div>
						))}
						{heatmap.tickers.map((ticker, ti) => (
							<>
								<div class="heatmap-ticker-label">
									{ticker}
									<small>{heatmap.ticker_names[ticker] || ""}</small>
								</div>
								{heatmap.dates.map((d, di) => {
									const score = heatmap.scores[di]?.[ti] ?? -1;
									const title = `${ticker} · ${d} · ${score >= 0 ? `${score}/10` : "—"}`;
									let bg = "transparent";
									if (score >= 7) bg = `rgba(137, 83, 209, 0.95)`;
									else if (score >= 5) bg = `rgba(137, 83, 209, ${0.3 + (score - 5) * 0.1})`;
									else if (score >= 0) bg = `rgba(137, 83, 209, ${0.05 + score * 0.02})`;
									return (
										<div class="heatmap-cell" style={`background: ${bg}`} title={title}>
											{score >= 7 && <span class="heatmap-cell-mark">★</span>}
										</div>
									);
								})}
							</>
						))}
