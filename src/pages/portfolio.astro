				.map((c: any) => ({
					priority: Math.abs(c.drift_pp) >= 5 ? 1 : 2,
					type: "allocation_drift",
					detail: `${c.label_en} ${c.current_pct}% (target ${c.target_pct}%), drift ${c.drift_pp >= 0 ? "+" : ""}${c.drift_pp}pp`,
					href: "#allocation-section",
				}));

			/* Crypto monitor signals */
			const cryptoSignals = (cryptoMonitor?.action_signals ?? []).map((sig: any) => ({
				...sig,
				href: "#crypto-mgmt-section",
			}));

			/* Merge & sort: priority 1 (action) first */
			const allSignals = [...rebalanceSignals, ...cryptoSignals].sort(
				(a: any, b: any) => a.priority - b.priority,
			);

			return allSignals.length > 0 ? (
				<div class="bucket-action-signals">
					<p class="bucket-signals-title">⚡ <span class="lang-en">Action Signals</span><span class="lang-zh">行动信号</span></p>
