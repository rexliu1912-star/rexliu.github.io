---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

export const getStaticPaths = (async () => {
	const logs = await getCollection("builder-log");
	return logs.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const { Content } = await render(entry);

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }).replace(",", "");
}

const meta = {
	title: `${entry.data.title} — Builder's Log`,
	description: entry.data.summary,
};
---

<PageLayout meta={meta}>
	<div class="mb-8">
		<a href="/lab/builder-log/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
			← All Logs
		</a>
	</div>

	<article>
		<h1 class="hero-reveal-text mb-4 font-serif text-3xl font-bold leading-tight dark:text-white">
			{entry.data.title}
		</h1>

		<div class="mb-6 flex flex-wrap items-center gap-4 font-serif text-sm text-gray-400 dark:text-gray-500">
			<time datetime={entry.data.date.toISOString()}>
				{formatDate(entry.data.date)}
			</time>
		</div>

		{entry.data.agents.length > 0 && (
			<div class="mb-8 flex flex-wrap gap-1.5">
				{entry.data.agents.map((agent: string) => (
					<span class="rounded-full bg-[#8953d1]/15 px-2.5 py-0.5 font-serif text-xs font-medium text-[#8953d1] dark:bg-[#8953d1]/25 dark:text-[#a175e8]">
						{agent}
					</span>
				))}
			</div>
		)}

		{entry.data.highlights.length > 0 && (
			<div class="mb-8 rounded-lg border border-gray-200 bg-gray-50 p-4 dark:border-gray-800 dark:bg-gray-900/50">
				<h3 class="mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">Highlights</h3>
				<ul class="space-y-1">
					{entry.data.highlights.map((h: string) => (
						<li class="font-serif text-sm text-gray-600 dark:text-gray-400">• {h}</li>
					))}
				</ul>
			</div>
		)}

		<div class="prose prose-cactus prose-headings:font-serif">
			<Content />
		</div>
	</article>
</PageLayout>
