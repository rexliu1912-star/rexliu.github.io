---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

const allTimelineEvents = await getCollection("ai-timeline");
const latestEvents = allTimelineEvents
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 8);

const timelineCategoryColors: Record<string, string> = {
	model: "text-purple-500",
	funding: "text-green-500",
	industry: "text-blue-500",
	robotics: "text-orange-500",
	"crypto-ai": "text-yellow-500",
	product: "text-cyan-500",
};

const timelineCategoryLabels: Record<string, { en: string; zh: string }> = {
	model: { en: "Model", zh: "模型" },
	funding: { en: "Funding", zh: "融资" },
	industry: { en: "Industry", zh: "行业" },
	robotics: { en: "Robotics", zh: "机器人" },
	"crypto-ai": { en: "Crypto×AI", zh: "Crypto×AI" },
	product: { en: "Product", zh: "产品" },
};

const allDigests = await getCollection("digest");
const sortedDigests = allDigests
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 3);

const allSnekDaily = await getCollection("snek-daily");
const latestSnek = allSnekDaily
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 3);

const allBuilderLogs = await getCollection("builder-log");
const latestLogs = allBuilderLogs
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 3);

const allBookmarks = await getCollection("bookmarks");
const latestBookmarks = allBookmarks
	.sort((a, b) => new Date(b.data.bookmarked_at).valueOf() - new Date(a.data.bookmarked_at).valueOf()
		|| new Date(b.data.created_at).valueOf() - new Date(a.data.created_at).valueOf())
	.slice(0, 5);

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const meta = {
	title: "Rex's Lab",
	description: "Rex's Lab — AI Timeline, Digest, SNEK Daily, Builder's Log & Projects",
};

function formatShortDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

const statusColors: Record<string, string> = {
	running: "text-green-500",
	building: "text-yellow-500",
	planning: "text-gray-400",
};

const statusLabels: Record<string, { en: string; zh: string }> = {
	running: { en: "running", zh: "运行中" },
	building: { en: "building", zh: "开发中" },
	planning: { en: "planning", zh: "规划中" },
};
---

<PageLayout meta={meta}>
	<section class="mb-12">
		<h1 class="hero-reveal-text mb-4 font-serif text-4xl font-bold dark:text-white">
			Rex's Lab
		</h1>
		<p class="hero-reveal-subtitle lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			Every moment of the AI era, curated readings, and experiments in crypto & AI.
		</p>
		<p class="hero-reveal-subtitle lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			AI 时代的每个瞬间，精选阅读，以及加密与 AI 的实验。
		</p>
	</section>

	<!-- AI Timeline — Hero Section -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
			<span class="lang-en">AI Timeline</span><span class="lang-zh">AI 大事记</span>
		</h2>
		<div class="relative border-l-2 border-gray-200 pl-6 dark:border-gray-700">
			{latestEvents.map((ev, i) => (
				<div class="fade-in-up relative mb-6 last:mb-0" style={`--delay: ${150 + i * 60}ms`}>
					<div class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full border-2 border-gray-200 bg-[var(--color-global-bg)] dark:border-gray-700" />
					<div class="flex flex-wrap items-baseline gap-2">
						<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={ev.data.date.toISOString()}>
							{formatShortDate(ev.data.date)}
						</time>
						<span class={`shrink-0 rounded-sm px-1.5 py-0.5 font-serif text-[10px] font-medium uppercase ${timelineCategoryColors[ev.data.category] || "text-gray-400"} bg-gray-100 dark:bg-gray-800`}>
							<span class="lang-en">{timelineCategoryLabels[ev.data.category]?.en || ev.data.category}</span><span class="lang-zh">{timelineCategoryLabels[ev.data.category]?.zh || ev.data.category}</span>
						</span>
					</div>
					{ev.data.source ? (
						<a href={ev.data.source} target="_blank" rel="noopener noreferrer" class="mt-1 block font-serif text-base leading-relaxed text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							<span class="lang-en">{ev.data.title}</span><span class="lang-zh">{ev.data.title_zh || ev.data.title}</span> ↗
						</a>
					) : (
						<p class="mt-1 font-serif text-base leading-relaxed text-black dark:text-white">
							<span class="lang-en">{ev.data.title}</span><span class="lang-zh">{ev.data.title_zh || ev.data.title}</span>
						</p>
					)}
					{ev.body && ev.body.trim() && (
						<p class="mt-0.5 font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
							<span class="lang-en">{ev.body.trim().slice(0, 120)}{ev.body.trim().length > 120 ? "…" : ""}</span>
							<span class="lang-zh">{(ev.data.body_zh || ev.body).trim().slice(0, 120)}{(ev.data.body_zh || ev.body).trim().length > 120 ? "…" : ""}</span>
						</p>
					)}
				</div>
			))}
		</div>
		<div class="mt-8">
			<a href="/lab/ai-timeline/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				<span class="lang-en">View full timeline →</span><span class="lang-zh">查看完整时间线 →</span>
			</a>
		</div>
	</section>

	<!-- Daily Section: Digest + SNEK Daily -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			<span class="lang-en">Daily</span><span class="lang-zh">每日更新</span>
		</h2>

		<div class="grid gap-8 lg:grid-cols-2">
			<!-- Digest Column -->
			<div>
				<h3 class="mb-4 font-serif text-base font-medium tracking-wide text-gray-500 dark:text-gray-400"><span class="lang-en">Digest</span><span class="lang-zh">精选阅读</span></h3>
				<div class="space-y-6">
					{sortedDigests.map((d, i) => (
						<article class="glow-card fade-in-up" style={`--delay: ${250 + i * 60}ms`}>
							<div class="mb-1 flex items-baseline justify-between gap-2">
								<a href={`/lab/digest/${d.id}/`} class="font-serif text-base font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
									<span class="lang-en">{d.data.title}</span><span class="lang-zh">{d.data.title_zh || d.data.title}</span>
								</a>
								<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={d.data.date.toISOString()}>
									{formatShortDate(d.data.date)}
								</time>
							</div>
							{d.data.summary && (
								<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
									<span class="lang-en">{d.data.summary}</span><span class="lang-zh">{d.data.summary_zh || d.data.summary}</span>
								</p>
							)}
							{d.data.tags.length > 0 && (
								<div class="mt-1.5 flex flex-wrap items-center gap-2 font-serif text-sm text-gray-400">
									{d.data.tags.map((tag: string) => (
										<span class="capitalize before:content-['#']">{tag}</span>
									))}
								</div>
							)}
						</article>
					))}
				</div>
				<div class="mt-4">
					<a href="/lab/digest/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
						<span class="lang-en">View all digests →</span><span class="lang-zh">查看全部精选 →</span>
					</a>
				</div>
			</div>

			<!-- SNEK Daily Column -->
			<div>
				<h3 class="mb-4 font-serif text-base font-medium tracking-wide text-gray-500 dark:text-gray-400"><span class="lang-en">SNEK Daily</span><span class="lang-zh">SNEK 日报</span></h3>
				<div class="space-y-6">
					{latestSnek.map((d, i) => (
						<article class="glow-card fade-in-up" style={`--delay: ${250 + i * 60}ms`}>
							<div class="mb-1 flex items-baseline justify-between gap-2">
								{d.data.btc_price && (
									<a href={`/lab/snek-daily/${d.id}/`} class="font-serif text-base font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
										BTC {d.data.btc_price} {d.data.btc_change}
									</a>
								)}
								<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={d.data.date.toISOString()}>
									{formatShortDate(d.data.date)}
								</time>
							</div>
							{d.data.summary && (
								<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
									<span class="lang-en">{d.data.summary}</span><span class="lang-zh">{d.data.summary_zh || d.data.summary}</span>
								</p>
							)}
							{d.data.ada_price && (
								<div class="mt-1.5 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
									<span>ADA {d.data.ada_price}</span>
									{d.data.snek_price && <span>SNEK {d.data.snek_price}</span>}
								</div>
							)}
						</article>
					))}
				</div>
				<div class="mt-4">
					<a href="/lab/snek-daily/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
						<span class="lang-en">View all dailies →</span><span class="lang-zh">查看全部日报 →</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Builder's Log -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			<span class="lang-en">Builder's Log</span><span class="lang-zh">Builder's Log</span>
		</h2>
		<div class="space-y-6">
			{latestLogs.map((log, i) => (
				<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-1 flex items-baseline justify-between gap-2">
						<a href={`/lab/builder-log/${log.id}/`} class="font-serif text-base font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							<span class="lang-en">{log.data.title}</span><span class="lang-zh">{log.data.title_zh || log.data.title}</span>
						</a>
						<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={log.data.date.toISOString()}>
							{formatShortDate(log.data.date)}
						</time>
					</div>
					<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
						<span class="lang-en">{log.data.summary}</span><span class="lang-zh">{log.data.summary_zh || log.data.summary}</span>
					</p>
					{log.data.agents.length > 0 && (
						<div class="mt-1.5 flex flex-wrap items-center gap-2 font-serif text-sm text-gray-400">
							{log.data.agents.map((agent: string) => (
								<span class="capitalize before:content-['@']">{agent}</span>
							))}
						</div>
					)}
				</article>
			))}
		</div>
		<div class="mt-6">
			<a href="/lab/builder-log/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				<span class="lang-en">View all logs →</span><span class="lang-zh">查看全部日志 →</span>
			</a>
		</div>
	</section>

	<!-- Bookmarks -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			<span class="lang-en">Bookmarks</span><span class="lang-zh">收藏夹</span>
		</h2>
		<div class="space-y-6">
			{latestBookmarks.map((bm, i) => (
				<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 60}ms`}>
					<div class="mb-1 flex items-baseline justify-between gap-2">
						<a href={bm.data.url} target="_blank" rel="noopener noreferrer" class="font-serif text-base font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							@{bm.data.author}
						</a>
						<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={bm.data.bookmarked_at.toISOString()}>
							{formatShortDate(bm.data.bookmarked_at)}
						</time>
					</div>
					<p class="line-clamp-2 font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
						{bm.data.text.length > 150 ? bm.data.text.slice(0, 150).trimEnd() + "…" : bm.data.text}
					</p>
					<div class="mt-1.5 flex flex-wrap items-center gap-2 font-serif text-sm text-gray-400">
						{bm.data.categories.map((cat: string) => (
							<span class="rounded-sm bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium uppercase dark:bg-gray-800">{cat}</span>
						))}
						<span class="ml-auto text-xs">❤️ {bm.data.likes.toLocaleString()}</span>
					</div>
				</article>
			))}
		</div>
		<div class="mt-6">
			<a href="/lab/bookmarks/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				<span class="lang-en">View all bookmarks →</span><span class="lang-zh">查看全部收藏 →</span>
			</a>
		</div>
	</section>

	<!-- Projects -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			<span class="lang-en">Projects</span><span class="lang-zh">项目</span>
		</h2>
		<div class="grid gap-4 sm:grid-cols-2">
			{sortedProjects.map((p, i) => {
				const hasUrl = !!p.data.url;
				const isExternal = hasUrl && p.data.url!.startsWith("http");
				const Tag = hasUrl ? "a" : "div";
				const linkProps = hasUrl
					? isExternal
						? { href: p.data.url, target: "_blank", rel: "noopener noreferrer" }
						: { href: p.data.url }
					: {};
				return (
				<Tag {...linkProps} class={`glow-card fade-in-up rounded-lg border p-5 transition-all ${hasUrl ? "group block cursor-pointer border-purple-500/20 hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122]" : "border-gray-200 dark:border-gray-800"}`} style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-2 flex items-center gap-2">
						{p.data.icon && <span class="text-lg">{p.data.icon}</span>}
						<h3 class={`font-serif text-lg font-medium text-black dark:text-white ${hasUrl ? "group-hover:text-[#8953d1] dark:group-hover:text-[#a175e8]" : ""}`}>
							<span class="lang-en">{p.data.title}</span><span class="lang-zh">{p.data.title_zh || p.data.title}</span>
						</h3>
						<span class={`ml-auto font-serif text-sm ${statusColors[p.data.status] || "text-gray-400"}`}>
							<span class="lang-en">{statusLabels[p.data.status]?.en || p.data.status}</span><span class="lang-zh">{statusLabels[p.data.status]?.zh || p.data.status}</span>
						</span>
						{hasUrl && <span class="font-serif text-xs text-purple-400 transition-opacity group-hover:opacity-100">{isExternal ? "↗" : "→"}</span>}
					</div>
					<p class="font-serif text-base text-gray-500 dark:text-gray-400">
						<span class="lang-en">{p.data.description}</span><span class="lang-zh">{p.data.description_zh || p.data.description}</span>
					</p>
				</Tag>
				);
			})}
		</div>
	</section>
</PageLayout>
