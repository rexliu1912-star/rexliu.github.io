---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

const allTimelineEvents = await getCollection("ai-timeline");
const latestEvents = allTimelineEvents
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 5);

const timelineCategoryColors: Record<string, string> = {
	model: "text-purple-500",
	funding: "text-green-500",
	policy: "text-blue-500",
	robotics: "text-orange-500",
	"crypto-ai": "text-yellow-500",
	research: "text-gray-400",
	product: "text-cyan-500",
};

const allSnekDaily = await getCollection("snek-daily");
const latestSnek = allSnekDaily
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 3);

const allBuilderLogs = await getCollection("builder-log");
const latestLogs = allBuilderLogs
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 3);

const allDigests = await getCollection("digest");
const sortedDigests = allDigests
	.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
	.slice(0, 5);

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const meta = {
	title: "Lab",
	description: "Rex's Lab — Digest, Projects, and Experiments",
};

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }).replace(",", "");
}

const statusColors: Record<string, string> = {
	running: "text-green-500",
	building: "text-yellow-500",
	planning: "text-gray-400",
};
---

<PageLayout meta={meta}>
	<section class="mb-12">
		<h1 class="hero-reveal-text mb-4 font-serif text-4xl font-bold dark:text-white">
			Lab
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			Curated readings, ongoing projects, and experiments in crypto & AI.
		</p>
	</section>

	<!-- AI Timeline -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 150ms">
			AI Timeline
		</h2>
		<div class="space-y-4">
			{latestEvents.map((ev, i) => (
				<div class="fade-in-up flex items-baseline gap-3" style={`--delay: ${200 + i * 60}ms`}>
					<time class="shrink-0 font-serif text-xs text-gray-400 dark:text-gray-500" datetime={ev.data.date.toISOString()}>
						{ev.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
					</time>
					<span class={`shrink-0 font-serif text-[10px] font-medium uppercase ${timelineCategoryColors[ev.data.category] || "text-gray-400"}`}>
						{ev.data.category}
					</span>
					<span class="font-serif text-sm text-black dark:text-white">
						{ev.data.title}
					</span>
				</div>
			))}
		</div>
		<div class="mt-6">
			<a href="/lab/ai-timeline/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				View full timeline →
			</a>
		</div>
	</section>

	<!-- Latest Digest -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			Latest Digest
		</h2>
		<div class="space-y-8">
			{sortedDigests.map((d, i) => (
				<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-2 flex items-baseline justify-between">
						<a href={`/lab/digest/${d.id}/`} class="font-serif text-xl font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							{d.data.title}
						</a>
						<time class="shrink-0 pl-4 font-serif text-xs text-gray-400 dark:text-gray-500" datetime={d.data.date.toISOString()}>
							{formatDate(d.data.date)}
						</time>
					</div>
					{d.data.summary && (
						<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">{d.data.summary}</p>
					)}
					{d.data.tags.length > 0 && (
						<div class="mt-2 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
							{d.data.tags.map((tag: string) => (
								<span class="capitalize before:content-['#']">{tag}</span>
							))}
						</div>
					)}
				</article>
			))}
		</div>
		<div class="mt-8">
			<a href="/lab/digest/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				View all digests →
			</a>
		</div>
	</section>

	<!-- SNEK Daily -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			SNEK Daily
		</h2>
		<div class="space-y-8">
			{latestSnek.map((d, i) => (
				<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-2 flex items-baseline justify-between">
						<a href={`/lab/snek-daily/${d.id}/`} class="font-serif text-xl font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							{d.data.title}
						</a>
						<time class="shrink-0 pl-4 font-serif text-xs text-gray-400 dark:text-gray-500" datetime={d.data.date.toISOString()}>
							{formatDate(d.data.date)}
						</time>
					</div>
					{d.data.btc_price && (
						<div class="mt-1 flex flex-wrap items-center gap-4 font-serif text-sm text-gray-400">
							<span>BTC {d.data.btc_price} {d.data.btc_change}</span>
							{d.data.ada_price && <span>ADA {d.data.ada_price}</span>}
							{d.data.snek_price && <span>SNEK {d.data.snek_price}</span>}
						</div>
					)}
					{d.data.summary && (
						<p class="mt-2 font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">{d.data.summary}</p>
					)}
				</article>
			))}
		</div>
		<div class="mt-8">
			<a href="/lab/snek-daily/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				View all dailies →
			</a>
		</div>
	</section>

	<!-- Builder's Log -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			Builder's Log
		</h2>
		<div class="space-y-8">
			{latestLogs.map((log, i) => (
				<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-2 flex items-baseline justify-between">
						<a href={`/lab/builder-log/${log.id}/`} class="font-serif text-xl font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
							{log.data.title}
						</a>
						<time class="shrink-0 pl-4 font-serif text-xs text-gray-400 dark:text-gray-500" datetime={log.data.date.toISOString()}>
							{formatDate(log.data.date)}
						</time>
					</div>
					<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">{log.data.summary}</p>
					{log.data.agents.length > 0 && (
						<div class="mt-2 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
							{log.data.agents.map((agent: string) => (
								<span class="capitalize before:content-['@']">{agent}</span>
							))}
						</div>
					)}
				</article>
			))}
		</div>
		<div class="mt-8">
			<a href="/lab/builder-log/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				View all logs →
			</a>
		</div>
	</section>

	<!-- Projects -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 200ms">
			Projects
		</h2>
		<div class="grid gap-4 sm:grid-cols-2">
			{sortedProjects.map((p, i) => (
				<div class="glow-card fade-in-up rounded-lg border border-gray-200 p-5 transition-colors dark:border-gray-800" style={`--delay: ${300 + i * 80}ms`}>
					<div class="mb-2 flex items-center gap-2">
						{p.data.icon && <span class="text-lg">{p.data.icon}</span>}
						<h3 class="font-serif text-lg font-medium text-black dark:text-white">{p.data.title}</h3>
						<span class={`ml-auto font-serif text-xs ${statusColors[p.data.status] || "text-gray-400"}`}>
							{p.data.status}
						</span>
					</div>
					<p class="font-serif text-sm text-gray-500 dark:text-gray-400">{p.data.description}</p>
				</div>
			))}
		</div>
	</section>
</PageLayout>
