---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

// Fetch all collections for counts & previews
const allTimelineEvents = await getCollection("ai-timeline");
const allBookmarks = await getCollection("bookmarks");
const allDigests = await getCollection("digest");
const allBuilderLogs = await getCollection("builder-log");
const allSnekDaily = await getCollection("snek-daily");
const allProjects = await getCollection("projects");

// Counts for stat bar
const timelineCount = allTimelineEvents.length;
const bookmarkCount = allBookmarks.length;
const digestCount = allDigests.length;
const builderLogCount = allBuilderLogs.length;

// Sort helpers
const sortByDate = <T extends { data: { date: Date } }>(arr: T[]) =>
	arr.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const sortByCreatedAt = <T extends { data: { created_at: Date } }>(arr: T[]) =>
	arr.sort((a, b) => new Date(b.data.created_at).valueOf() - new Date(a.data.created_at).valueOf());

// Latest items for previews
const latestBookmark = sortByCreatedAt([...allBookmarks])[0];
const latestDigest = sortByDate([...allDigests])[0];
const latestBuilderLog = sortByDate([...allBuilderLogs])[0];

// Products: exclude Bookmarks and Library (they go in Curated)
const excludeFromProducts = ["bookmarks", "library", "content-pipeline"];
const otherProjects = allProjects
	.filter(p => p.id !== "rex-ai-hq" && !excludeFromProducts.includes(p.id))
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Timeline: latest 5
const latestEvents = sortByDate([...allTimelineEvents]).slice(0, 5);

// SNEK Daily: latest 3
const latestSnek = sortByDate([...allSnekDaily]).slice(0, 3);

// Category helpers for timeline
const timelineCategoryColors: Record<string, string> = {
	model: "text-purple-500",
	funding: "text-green-500",
	industry: "text-blue-500",
	robotics: "text-orange-500",
	"crypto-ai": "text-yellow-500",
	product: "text-cyan-500",
};
const timelineCategoryLabels: Record<string, { en: string; zh: string }> = {
	model: { en: "Model", zh: "模型" },
	funding: { en: "Funding", zh: "融资" },
	industry: { en: "Industry", zh: "行业" },
	robotics: { en: "Robotics", zh: "机器人" },
	"crypto-ai": { en: "Crypto×AI", zh: "Crypto×AI" },
	product: { en: "Product", zh: "产品" },
};

const statusColors: Record<string, string> = {
	running: "text-green-500",
	building: "text-yellow-500",
	planning: "text-gray-400",
};
const statusDots: Record<string, string> = {
	running: "bg-green-500",
	building: "bg-yellow-500",
	planning: "bg-gray-400",
};
const statusLabels: Record<string, { en: string; zh: string }> = {
	running: { en: "running", zh: "运行中" },
	building: { en: "building", zh: "开发中" },
	planning: { en: "planning", zh: "规划中" },
};

function formatShortDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}


const agentAvatars = ['samantha', 'loki', 'vision', 'jarvis', 'shuri', 'friday'];

const meta = {
	title: "Lab",
	description: "Lab — Products, curated content, and live data streams powered by AI.",
};
---

<PageLayout meta={meta}>
	<!-- ====== HERO ====== -->
	<section class="mb-16">
		<h1 class="hero-reveal-text mb-4 font-serif text-4xl font-bold dark:text-white">
			Lab
		</h1>
		<p class="hero-reveal-subtitle lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			Every moment of the AI era, curated readings, and experiments in crypto & AI.
		</p>
		<p class="hero-reveal-subtitle lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			AI 时代的每个瞬间，精选阅读，以及加密与 AI 的实验。
		</p>

		<!-- Stat Bar -->
		<div class="lab-stat-bar mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 font-serif text-sm">
			<span class="lang-en">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={timelineCount}>0</span>
				<span class="text-gray-400"> AI events</span>
			</span>
			<span class="lang-zh">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={timelineCount}>0</span>
				<span class="text-gray-400"> 条 AI 事件</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={bookmarkCount}>0</span>
				<span class="text-gray-400"> tweets curated</span>
			</span>
			<span class="lang-zh">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={bookmarkCount}>0</span>
				<span class="text-gray-400"> 条精选推文</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target="6">0</span>
				<span class="text-gray-400"> agents</span>
			</span>
			<span class="lang-zh">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target="6">0</span>
				<span class="text-gray-400"> 个 Agent</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={builderLogCount}>0</span>
				<span class="text-gray-400"> builder logs</span>
			</span>
			<span class="lang-zh">
				<span class="lab-counter font-bold" style="color:#8953d1" data-target={builderLogCount}>0</span>
				<span class="text-gray-400"> 篇 Builder Log</span>
			</span>
		</div>
		<!-- Player Stats — Hero identity card -->
		<a href="/lab/player/" class="lab-player-card fade-in-up group mt-8 flex flex-col gap-3 rounded-xl border border-purple-500/20 p-5 transition-all hover:border-purple-500/40 sm:flex-row sm:items-center sm:gap-6 sm:p-6" style="--delay: 200ms">
			<div class="flex items-center gap-3">
				<span class="text-xl">⚔️</span>
				<div>
					<h3 class="font-serif text-base font-bold text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8]">
						<span class="lang-en">Player Stats</span>
						<span class="lang-zh">江湖档案</span>
					</h3>
					<p class="font-serif text-xs text-gray-400">
						<span class="lang-en">Open-world cultivation dashboard — real data.</span>
						<span class="lang-zh">开放世界修行面板——真实数据驱动。</span>
					</p>
				</div>
			</div>
			<div class="flex items-center gap-1.5 sm:ml-auto">
				{["体","悟","心","剑","声","统"].map(s => (
					<span class="inline-flex h-7 w-7 items-center justify-center rounded border border-purple-500/30 bg-purple-500/10 font-serif text-xs text-purple-400">{s}</span>
				))}
				<span class="ml-1.5 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
			</div>
		</a>
	</section>

	<!-- ====== SECTION 1: PRODUCTS ====== -->
	<section class="mb-20">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
			<span class="lang-en">Products</span><span class="lang-zh">产品</span>
		</h2>

		<!-- Hero Card: Rex AI HQ -->
		<a href="/lab/agents/" class="lab-hero-card glow-card fade-in-up group mb-8 block rounded-xl border border-purple-500/20 p-6 transition-all hover:border-purple-500/40 sm:p-8" style="--delay: 150ms">
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="flex-1">
					<div class="mb-2 flex items-center gap-2">
						<span class="text-2xl">🏠</span>
						<h3 class="font-serif text-xl font-bold text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8] sm:text-2xl">
							Rex AI HQ
						</h3>
						<span class="ml-2 inline-flex items-center gap-1 rounded-full bg-green-500/10 px-2 py-0.5 font-serif text-xs font-medium text-green-500">
							<span class="inline-block h-1.5 w-1.5 rounded-full bg-green-500"></span>
							<span class="lang-en">running</span><span class="lang-zh">运行中</span>
						</span>
					</div>
					<p class="lang-en font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400">
						6 AI agents working 24/7 — writing, researching, coding, designing, analyzing.
					</p>
					<p class="lang-zh font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400">
						6 个 AI Agent 全天候运转：写作、研究、开发、设计、分析。
					</p>
				</div>
				<div class="flex items-center gap-2">
					{agentAvatars.map(avatar => (
						<img src={`/avatars/${avatar}.png`} alt={avatar} class="h-9 w-9 rounded-full object-cover border border-purple-500/20" />
					))}
					<span class="ml-2 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
				</div>
			</div>
		</a>

		<!-- Product Grid -->
		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{otherProjects.map((p, i) => {
				const hasUrl = !!p.data.url;
				const isExternal = hasUrl && p.data.url!.startsWith("http");
				const Tag = hasUrl ? "a" : "div";
				const linkProps = hasUrl
					? isExternal
						? { href: p.data.url, target: "_blank", rel: "noopener noreferrer" }
						: { href: p.data.url }
					: {};
				return (
					<Tag {...linkProps} class={`lab-product-card glow-card fade-in-up rounded-xl border p-5 transition-all ${hasUrl ? "group block cursor-pointer border-gray-200 hover:border-[#8953d1]/40 dark:border-gray-800 dark:hover:border-[#a175e8]/40" : "border-gray-200 dark:border-gray-800"}`} style={`--delay: ${200 + i * 80}ms`}>
						<div class="mb-2 flex items-center gap-2">
							{p.data.icon && <span class="text-lg">{p.data.icon}</span>}
							<h3 class={`font-serif text-base font-medium text-black dark:text-white ${hasUrl ? "group-hover:text-[#8953d1] dark:group-hover:text-[#a175e8]" : ""}`}>
								<span class="lang-en">{p.data.title}</span><span class="lang-zh">{p.data.title_zh || p.data.title}</span>
							</h3>
							<span class={`ml-auto inline-flex items-center gap-1 font-serif text-xs ${statusColors[p.data.status] || "text-gray-400"}`}>
								<span class={`inline-block h-1.5 w-1.5 rounded-full ${statusDots[p.data.status] || "bg-gray-400"}`}></span>
								<span class="lang-en">{statusLabels[p.data.status]?.en || p.data.status}</span><span class="lang-zh">{statusLabels[p.data.status]?.zh || p.data.status}</span>
							</span>
						</div>
						<p class="lab-desc-clamp font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
							<span class="lang-en">{p.data.description}</span><span class="lang-zh">{p.data.description_zh || p.data.description}</span>
						</p>
						{hasUrl && (
							<span class="mt-2 block font-serif text-xs text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">
								{isExternal ? "↗" : "→"}
							</span>
						)}
					</Tag>
				);
			})}
		</div>
	</section>

	<!-- ====== SECTION 2: CURATED ====== -->
	<section class="mb-20">
		<h2 class="fade-in-up mb-8 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
			<span class="lang-en">Curated</span><span class="lang-zh">精选</span>
		</h2>

		<div class="lab-curated-scroll flex gap-4 overflow-x-auto pb-4 lg:grid lg:grid-cols-4 lg:overflow-visible lg:pb-0">
			<!-- Library -->
			<a href="/os/library" class="lab-curated-card lab-slide-in fade-in-up group flex w-[280px] shrink-0 flex-col rounded-xl border border-gray-200 p-5 transition-all hover:border-[#8953d1]/40 dark:border-gray-800 dark:hover:border-[#a175e8]/40 lg:w-auto" style="--delay: 150ms">
				<span class="mb-3 text-2xl">📚</span>
				<h3 class="mb-1 font-serif text-base font-medium text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8]">
					Library
				</h3>
				<p class="font-serif text-sm text-gray-400">
					<span class="lang-en">Books, films & shows</span>
					<span class="lang-zh">书影记录</span>
				</p>
				<p class="mt-2 font-serif text-xs text-gray-400 dark:text-gray-500">
					<span class="lang-en">What shaped how I think</span>
					<span class="lang-zh">塑造思维的书与片</span>
				</p>
				<span class="mt-auto pt-3 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
			</a>

			<!-- Bookmarks -->
			<a href="/lab/bookmarks/" class="lab-curated-card lab-slide-in fade-in-up group flex w-[280px] shrink-0 flex-col rounded-xl border border-gray-200 p-5 transition-all hover:border-[#8953d1]/40 dark:border-gray-800 dark:hover:border-[#a175e8]/40 lg:w-auto" style="--delay: 230ms">
				<span class="mb-3 text-2xl">🔖</span>
				<h3 class="mb-1 font-serif text-base font-medium text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8]">
					Bookmarks
				</h3>
				<p class="font-serif text-sm text-gray-400">
					<span class="lang-en">{bookmarkCount} curated tweets</span>
					<span class="lang-zh">{bookmarkCount} 条精选推文</span>
				</p>
				{latestBookmark && (
					<p class="mt-2 line-clamp-1 font-serif text-xs text-gray-400 dark:text-gray-500">
						Latest: @{latestBookmark.data.author}
					</p>
				)}
				<span class="mt-auto pt-3 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
			</a>

			<!-- Digest -->
			<a href="/lab/digest/" class="lab-curated-card lab-slide-in fade-in-up group flex w-[280px] shrink-0 flex-col rounded-xl border border-gray-200 p-5 transition-all hover:border-[#8953d1]/40 dark:border-gray-800 dark:hover:border-[#a175e8]/40 lg:w-auto" style="--delay: 310ms">
				<span class="mb-3 text-2xl">📖</span>
				<h3 class="mb-1 font-serif text-base font-medium text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8]">
					Digest
				</h3>
				<p class="font-serif text-sm text-gray-400">
					<span class="lang-en">{digestCount} curated reads</span>
					<span class="lang-zh">{digestCount} 篇精选阅读</span>
				</p>
				{latestDigest && (
					<p class="mt-2 line-clamp-1 font-serif text-xs text-gray-400 dark:text-gray-500">
						<span class="lang-en">Latest: {latestDigest.data.title.slice(0, 40)}{latestDigest.data.title.length > 40 ? "…" : ""}</span>
						<span class="lang-zh">最新: {(latestDigest.data.title_zh || latestDigest.data.title).slice(0, 30)}{(latestDigest.data.title_zh || latestDigest.data.title).length > 30 ? "…" : ""}</span>
					</p>
				)}
				<span class="mt-auto pt-3 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
			</a>

			<!-- Builder's Log -->
			<a href="/lab/builder-log/" class="lab-curated-card lab-slide-in fade-in-up group flex w-[280px] shrink-0 flex-col rounded-xl border border-gray-200 p-5 transition-all hover:border-[#8953d1]/40 dark:border-gray-800 dark:hover:border-[#a175e8]/40 lg:w-auto" style="--delay: 390ms">
				<span class="mb-3 text-2xl">🔨</span>
				<h3 class="mb-1 font-serif text-base font-medium text-black group-hover:text-[#8953d1] dark:text-white dark:group-hover:text-[#a175e8]">
					Builder's Log
				</h3>
				<p class="font-serif text-sm text-gray-400">
					<span class="lang-en">{builderLogCount} build logs</span>
					<span class="lang-zh">{builderLogCount} 篇造物日志</span>
				</p>
				{latestBuilderLog && (
					<p class="mt-2 line-clamp-1 font-serif text-xs text-gray-400 dark:text-gray-500">
						<span class="lang-en">Latest: {latestBuilderLog.data.title.slice(0, 40)}{latestBuilderLog.data.title.length > 40 ? "…" : ""}</span>
						<span class="lang-zh">最新: {(latestBuilderLog.data.title_zh || latestBuilderLog.data.title).slice(0, 30)}{(latestBuilderLog.data.title_zh || latestBuilderLog.data.title).length > 30 ? "…" : ""}</span>
					</p>
				)}
				<span class="mt-auto pt-3 font-serif text-sm text-purple-400 opacity-0 transition-opacity group-hover:opacity-100">→</span>
			</a>
		</div>
	</section>

	<!-- ====== SECTION 3: DATA STREAMS ====== -->
	<section class="mb-16">
		<h2 class="fade-in-up mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500" style="--delay: 100ms">
			<span class="lang-en">Data Streams</span><span class="lang-zh">数据流</span>
		</h2>
		<p class="fade-in-up mb-8 font-serif text-sm text-gray-400 dark:text-gray-500" style="--delay: 150ms">
			<span class="lang-en">Automated feeds running 24/7.</span>
			<span class="lang-zh">全天候自动化数据。</span>
		</p>

		<div class="grid gap-8 lg:grid-cols-2">
			<!-- Left: AI Timeline -->
			<div class="fade-in-up" style="--delay: 200ms">
				<h3 class="mb-4 font-serif text-base font-medium tracking-wide text-gray-500 dark:text-gray-400">
					<span class="lang-en">AI Timeline</span><span class="lang-zh">AI 大事记</span>
				</h3>
				<div class="relative border-l-2 border-gray-200 pl-6 dark:border-gray-700">
					{latestEvents.map((ev, i) => (
						<div class="fade-in-up relative mb-6 last:mb-0" style={`--delay: ${250 + i * 60}ms`}>
							<div class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full border-2 border-gray-200 bg-[var(--color-global-bg)] dark:border-gray-700" />
							<div class="flex flex-wrap items-baseline gap-2">
								<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={ev.data.date.toISOString()}>
									{formatShortDate(ev.data.date)}
								</time>
								<span class={`shrink-0 rounded-sm px-1.5 py-0.5 font-serif text-[10px] font-medium uppercase ${timelineCategoryColors[ev.data.category] || "text-gray-400"} bg-gray-100 dark:bg-gray-800`}>
									<span class="lang-en">{timelineCategoryLabels[ev.data.category]?.en || ev.data.category}</span><span class="lang-zh">{timelineCategoryLabels[ev.data.category]?.zh || ev.data.category}</span>
								</span>
							</div>
							{ev.data.source ? (
								<a href={ev.data.source} target="_blank" rel="noopener noreferrer" class="mt-1 block font-serif text-base leading-relaxed text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
									<span class="lang-en">{ev.data.title}</span><span class="lang-zh">{ev.data.title_zh || ev.data.title}</span> ↗
								</a>
							) : (
								<p class="mt-1 font-serif text-base leading-relaxed text-black dark:text-white">
									<span class="lang-en">{ev.data.title}</span><span class="lang-zh">{ev.data.title_zh || ev.data.title}</span>
								</p>
							)}
						</div>
					))}
				</div>
				<div class="mt-6">
					<a href="/lab/ai-timeline/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
						<span class="lang-en">View full timeline →</span><span class="lang-zh">查看完整时间线 →</span>
					</a>
				</div>
			</div>

			<!-- Right: SNEK Daily -->
			<div class="fade-in-up" style="--delay: 250ms">
				<h3 class="mb-4 font-serif text-base font-medium tracking-wide text-gray-500 dark:text-gray-400">
					<span class="lang-en">SNEK Daily</span><span class="lang-zh">SNEK 日报</span>
				</h3>
				<div class="space-y-6">
					{latestSnek.map((d, i) => (
						<article class="glow-card fade-in-up" style={`--delay: ${300 + i * 60}ms`}>
							<div class="mb-1 flex items-baseline justify-between gap-2">
								{d.data.btc_price && (
									<a href={`/lab/snek-daily/${d.id}/`} class="font-serif text-base font-medium text-black transition-colors hover:text-[#8953d1] dark:text-white dark:hover:text-[#a175e8]">
										BTC {d.data.btc_price} {d.data.btc_change}
									</a>
								)}
								<time class="shrink-0 font-serif text-sm text-gray-400 dark:text-gray-500" datetime={d.data.date.toISOString()}>
									{formatShortDate(d.data.date)}
								</time>
							</div>
							{d.data.summary && (
								<p class="font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
									<span class="lang-en">{d.data.summary}</span><span class="lang-zh">{d.data.summary_zh || d.data.summary}</span>
								</p>
							)}
							{d.data.ada_price && (
								<div class="mt-1.5 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
									<span>ADA {d.data.ada_price}</span>
									{d.data.snek_price && <span>SNEK {d.data.snek_price}</span>}
								</div>
							)}
						</article>
					))}
				</div>
				<div class="mt-6">
					<a href="/lab/snek-daily/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
						<span class="lang-en">View all dailies →</span><span class="lang-zh">查看全部日报 →</span>
