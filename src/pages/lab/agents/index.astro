		var ACTIVITY_FEED = [];
		var overlay = document.getElementById('agent-detail');
		var closeBtn = document.getElementById('detail-close');

		function openDetail(agentId) {
			var d = AGENT_DATA[agentId];
			if (!d || !overlay) return;
			var isZh = document.documentElement.getAttribute('data-lang') === 'zh';

			document.getElementById('detail-dot').style.background = d.color;
			document.getElementById('detail-dot').style.boxShadow = '0 0 8px ' + d.color + '88';
			document.getElementById('detail-name').textContent = d.name;
			document.getElementById('detail-role').textContent = d.role;
			document.getElementById('detail-desc').textContent = isZh ? d.descZh : d.descEn;

			var statsEl = document.getElementById('detail-stats');
			if (statsEl) {
				statsEl.textContent = isZh ? (d.statsZh || '') : (d.statsEn || '');
				statsEl.style.color = d.color;
			}

			var ul = document.getElementById('detail-examples');
			ul.innerHTML = '';
			var examples = isZh ? d.examplesZh : d.examplesEn;
			examples.forEach(function(ex) {
				var li = document.createElement('li');
				li.textContent = ex;
				ul.appendChild(li);
			});

			var latestEl = document.getElementById('detail-latest');
			var agentActivities = ACTIVITY_FEED.filter(function(e) { return e.agentId === agentId; }).slice(0, 3);
			if (agentActivities.length > 0) {
				var heading = isZh ? '<strong>\u6700\u8fd1\u52a8\u6001</strong>' : '<strong>Recent</strong>';
				latestEl.innerHTML = heading + '<ul class="detail-recent-list">' +
					agentActivities.map(function(a) {
						var text = isZh ? a.descZh : a.descEn;
						return '<li><span class="detail-recent-time">' + a.time + '</span> ' + text + '</li>';
					}).join('') + '</ul>';
				latestEl.style.display = 'block';
			} else {
				latestEl.style.display = 'none';
			}

			overlay.classList.add('is-open');
			overlay.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		}

		function closeDetail() {
			if (!overlay) return;
			overlay.classList.remove('is-open');
			overlay.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		}

		closeBtn && closeBtn.addEventListener('click', closeDetail);
		overlay && overlay.addEventListener('click', function(e) {
			if (e.target === overlay) closeDetail();
		});
		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') closeDetail();
		});

		/* ══════════════════════════════════════════════════════════════
		   ACTIVITY FEED
		   ══════════════════════════════════════════════════════════════ */
		var feedList = document.getElementById('activity-feed-list');

		function timeAgo(isoStr) {
			try {
				var d = new Date(isoStr);
				var diff = Date.now() - d.getTime();
				var m = Math.floor(diff / 60000);
				if (m < 2) return 'just now';
				if (m < 60) return m + 'm ago';
				var h = Math.floor(diff / 3600000);
				if (h < 24) return h + 'h ago';
				return Math.floor(h / 24) + 'd ago';
			} catch (e) { return ''; }
		}

		function renderFeed(entries) {
			if (!feedList) return;
			if (!entries || entries.length === 0) {
				feedList.innerHTML = '<div class="feed-empty font-serif text-xs text-gray-500"><span class="lang-en">No recent activity</span><span class="lang-zh">\u6682\u65e0\u52a8\u6001</span></div>';
				return;
			}
			// Deduplicate: if two entries from same agent within 10s, keep the one with distinct EN/ZH
			var deduped = [];
			for (var i = 0; i < entries.length; i++) {
				var e = entries[i];
				var dominated = false;
				for (var j = 0; j < deduped.length; j++) {
					var d = deduped[j];
					if (d.agentId === e.agentId && Math.abs(new Date(d.timestamp) - new Date(e.timestamp)) < 120000) {
						// Keep the one where descEn != descZh (properly translated)
						if (d.descEn === d.descZh && e.descEn !== e.descZh) { deduped[j] = e; }
						dominated = true; break;
					}
				}
				if (!dominated) deduped.push(e);
			}
			entries = deduped;
			var isZh = document.documentElement.getAttribute('data-lang') === 'zh';
			feedList.innerHTML = entries.map(function(e) {
				var desc = isZh ? (e.descZh || e.descEn) : (e.descEn || e.descZh);
				return '<div class="feed-item">' +
					'<div class="feed-dot" style="background:' + e.color + ';box-shadow:0 0 6px ' + e.color + '66"></div>' +
					'<div class="feed-content">' +
						'<span class="feed-agent font-serif text-xs font-bold" style="color:' + e.color + '">' + e.agentName + '</span>' +
						'<span class="feed-desc font-serif text-sm text-gray-600 dark:text-gray-400">' + desc + '</span>' +
					'</div>' +
					'<span class="feed-time font-serif text-xs text-gray-400 shrink-0">' + timeAgo(e.timestamp) + '</span>' +
				'</div>';
			}).join('');

			ACTIVITY_FEED = entries.map(function(e) {
				return {
					agentId:   e.agentId,
					agentName: e.agentName,
					descEn:    e.descEn,
					descZh:    e.descZh,
					color:     e.color,
					time:      timeAgo(e.timestamp)
				};
			});
		}

		async function fetchActivity() {
			try {
				var controller = new AbortController();
				var timeout = setTimeout(function() { controller.abort(); }, 5000);
				var resp = await fetch(CONVEX_ACTIVITY_URL + '/api/query', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ path: 'activity:recent', args: { limit: 10 }, format: 'json' }),
					signal: controller.signal
				});
				clearTimeout(timeout);
				var data = await resp.json();
				if (data.status === 'success' && data.value) {
					var activities = Array.isArray(data.value) ? data.value.slice() : [];
					var latestTs = activities.length ? new Date(activities[0].timestamp).getTime() : 0;
					var sixHoursAgo = Date.now() - 6 * 60 * 60 * 1000;
					if (latestTs < sixHoursAgo) {
						var nowItem = {
							agentId: 'main',
							agentName: 'Team',
							color: '#8953d1',
							descEn: 'Pixel Office v3 — sprites, animations, interactions in progress',
							descZh: 'Pixel Office v3 — 角色精修、进场动画、互动系统持续开发中',
							timestamp: new Date().toISOString()
						};
						activities.unshift(nowItem);
					}
					renderFeed(activities);
				}
			} catch (e) {
				console.error('Activity feed fetch failed:', e);
				if (feedList && feedList.querySelector('.feed-loading')) {
					feedList.innerHTML = '<div class="feed-empty font-serif text-xs text-gray-500"><span class="lang-en">Unable to load \u2014 will retry</span><span class="lang-zh">\u52a0\u8f7d\u5931\u8d25\uff0c\u7a0d\u540e\u91cd\u8bd5</span></div>';
				}
			}
		}

		/* ══════════════════════════════════════════════════════════════
		   TEAM WORKLOAD
		   ══════════════════════════════════════════════════════════════ */
		function formatTokens(n) {
			if (n >= 1000000) return (n / 1000000).toFixed(2) + 'M';
			if (n >= 1000) return Math.round(n / 1000) + 'K';
			return String(n);
		}

		function timeAgoWorkload(isoStr) {
			try {
				var diff = Date.now() - new Date(isoStr).getTime();
				var m = Math.floor(diff / 60000);
				if (m < 2) return 'just now';
				if (m < 60) return m + 'm ago';
				var h = Math.floor(diff / 3600000);
				if (h < 24) return h + 'h ago';
				return Math.floor(h / 24) + 'd ago';
			} catch (e) { return ''; }
		}

		/* ── Count-up animation ── */
		function countUp(el, target, opts) {
			opts = opts || {};
			var prefix = opts.prefix || '';
			var suffix = opts.suffix || '';
			var decimals = opts.decimals || 0;
			var duration = opts.duration || 1200;
			var start = 0;
			var startTime = null;
			function step(ts) {
				if (!startTime) startTime = ts;
				var progress = Math.min((ts - startTime) / duration, 1);
				// easeOutCubic
				var eased = 1 - Math.pow(1 - progress, 3);
				var current = start + (target - start) * eased;
				el.textContent = prefix + current.toFixed(decimals) + suffix;
				if (progress < 1) requestAnimationFrame(step);
			}
			requestAnimationFrame(step);
		}

		function animateStatCounter(el, text, duration) {
			// For simple numeric values, animate from 0
			var match = text.match(/^([~$]?)(\d+\.?\d*)(.*)/);
			if (!match) { el.textContent = text; return; }
			var prefix = match[1] || '';
			var target = parseFloat(match[2]);
			var suffix = match[3] || '';
			var decimals = match[2].indexOf('.') >= 0 ? match[2].split('.')[1].length : 0;
			var startTime = null;
			function easeOutExpo(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }
			function step(ts) {
				if (!startTime) startTime = ts;
				var progress = Math.min((ts - startTime) / (duration || 1500), 1);
				var val = easeOutExpo(progress) * target;
				el.textContent = prefix + val.toFixed(decimals) + suffix;
				if (progress < 1) requestAnimationFrame(step);
			}
			requestAnimationFrame(step);
		}

		function renderTeamImpact(data) {
			var days = String(data.daysActive || 0);
			var tokenM = ((data.total || 0) / 1000000).toFixed(1) + 'M';
			var sessions = String(data.totalSessions || 0);
			var hours = '~' + (data.estimatedHoursSaved || 0);
			var cost = '$' + Math.round(data.estimatedCostUSD || 0);

			var pairs = [
				['stat-days', 'stat-days-zh', days, 1000],
				['stat-tokens', 'stat-tokens-zh', tokenM, 1500],
				['stat-sessions', 'stat-sessions-zh', sessions, 1200],
				['stat-hours', 'stat-hours-zh', hours, 1300],
				['stat-cost', 'stat-cost-zh', cost, 1100],
			];
			pairs.forEach(function(p) {
				var en = document.getElementById(p[0]);
				var zh = document.getElementById(p[1]);
				if (en) animateStatCounter(en, p[2], p[3]);
				if (zh) animateStatCounter(zh, p[2], p[3]);
			});

			// Fade in the stat bar
			var bar = document.getElementById('impact-stat-bar');
			if (bar) bar.style.opacity = '1';
		}

		function renderWorkload(data) {
			var chart = document.getElementById('workload-chart');
			var footer = document.getElementById('workload-footer');
			if (!chart) return;

			var agents = data.agents || [];
			if (agents.length === 0) {
				chart.innerHTML = '<div class="workload-loading font-serif text-xs text-gray-400"><span class="lang-en">No data</span><span class="lang-zh">暂无数据</span></div>';
				return;
			}

			var maxTokens = Math.max.apply(null, agents.map(function(a) { return a.tokens; }));
			var isZh = document.documentElement.getAttribute('data-lang') === 'zh';

			chart.innerHTML = agents.map(function(agent) {
				var color = (AGENT_DATA[agent.id] || {}).color || '#8953d1';
				var pct = maxTokens > 0 ? (agent.tokens / maxTokens * 100).toFixed(1) : 0;
				var sessionsLabel = isZh
					? agent.sessions + ' 个会话'
					: agent.sessions + ' session' + (agent.sessions !== 1 ? 's' : '');
				var modelLabel = agent.model || '';
				// Gradient: use CSS via inline style
				var gradientBg = 'linear-gradient(to right, ' + color + 'ff, ' + color + 'd9)';
				return '<div class="workload-row" style="--bar-color:' + color + '">' +
					'<div class="workload-label">' +
						'<span class="workload-name font-serif">' + agent.name + '</span>' +
						(modelLabel ? '<span class="workload-sessions font-serif">' + modelLabel + '</span>' : '') +
					'</div>' +
					'<div class="workload-bar-track" title="' + agent.name + ': ' + sessionsLabel + '">' +
						'<div class="workload-bar-fill" data-pct="' + pct + '" data-color="' + color + '" style="background:' + gradientBg + '"></div>' +
					'</div>' +
					'<span class="workload-tokens font-serif">' + formatTokens(agent.tokens) + '</span>' +
				'</div>';
			}).join('');

			// Staggered bar animations (100ms delay each)
			requestAnimationFrame(function() {
				requestAnimationFrame(function() {
					var bars = chart.querySelectorAll('.workload-bar-fill');
					bars.forEach(function(bar, idx) {
						var pct = bar.getAttribute('data-pct');
						setTimeout(function() {
							bar.style.width = pct + '%';
						}, idx * 100);
					});
				});
			});

			// Footer removed — data already shown in Team Impact section
		}

		async function fetchWorkload() {
			try {
				var resp = await fetch('/data/agent-workload.json?_=' + Math.floor(Date.now() / 60000));
				if (!resp.ok) throw new Error('HTTP ' + resp.status);
				var data = await resp.json();
				renderTeamImpact(data);
				renderWorkload(data);
			} catch (e) {
				console.error('Workload fetch failed:', e);
				var chart = document.getElementById('workload-chart');
				if (chart) {
					chart.innerHTML = '<div class="workload-loading font-serif text-xs text-gray-400"><span class="lang-en">Unable to load workload data</span><span class="lang-zh">加载失败</span></div>';
				}
			}
		}

		fetchWorkload();

		fetchActivity();
		_intervals.push(setInterval(fetchActivity, 30000));

		/* ══════════════════════════════════════════════════════════════
		   RESPONSIVE SCALE
		   ══════════════════════════════════════════════════════════════ */
		function scalePixelOffice() {
			var wrapper = document.getElementById('pixel-office-wrapper');
			var office = document.getElementById('pixel-office');
			if (!wrapper || !office) return;
			var containerWidth = wrapper.clientWidth;
			var officeWidth = 768;
			var scale = Math.min(1, containerWidth / officeWidth);
			office.style.transform = scale < 1 ? 'scale(' + scale + ')' : '';
			var officeHeight = 448;
			wrapper.style.height = scale < 1 ? Math.round(officeHeight * scale) + 'px' : '';
		}

		scalePixelOffice();
		window.addEventListener('resize', scalePixelOffice);

	} /* end initAgentPage */

	/* ── Bootstrap ── */
	initAgentPage();

	document.addEventListener('astro:page-load', function() {
		if (document.getElementById('office-canvas')) {
			initAgentPage();
		}
	});

})();
