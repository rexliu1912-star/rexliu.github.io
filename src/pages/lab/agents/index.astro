---
import PageLayout from "@/layouts/Base.astro";
const meta = {
	title: "Agent Activity — Rex's Lab",
	description: "Live pixel office — 6 AI agents working in real-time",
};
---

<PageLayout meta={meta}>
	<section class="mb-10">
		<a href="/lab/" class="fade-in-up font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" style="--delay: 50ms">
			<span class="lang-en">← Back to Lab</span><span class="lang-zh">← 返回 Lab</span>
		</a>
		<h1 class="hero-reveal-text mt-4 mb-3 font-serif text-4xl font-bold dark:text-white">
			<span class="lang-en">Agent Activity</span><span class="lang-zh">Agent 工作室</span>
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300" style="--delay: 80ms">
			<span class="lang-en">I run a 6-person AI team. They write, research, code, design, and analyze — 24/7, while I focus on decisions.</span>
			<span class="lang-zh">我有一支 6 人 AI 团队：写作、研究、开发、设计、分析，全天候运转，我只负责决策。</span>
		</p>
		<p class="hero-reveal-subtitle max-w-2xl mt-2 font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400" style="--delay: 120ms">
			<span class="lang-en">Each agent has a role, a personality, and a live status. Click any character to learn more.</span>
			<span class="lang-zh">每个 Agent 有独立角色和个性。点击角色查看详情。</span>
		</p>
		<!-- Stat Bar -->
		<div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 font-serif text-sm" id="impact-stat-bar" style="opacity:0;transition:opacity 0.4s ease">
			<span class="lang-en">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-days">—</span>
				<span class="text-gray-400"> days</span>
			</span>
			<span class="lang-zh">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-days-zh">—</span>
				<span class="text-gray-400"> 天</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-tokens">—</span>
				<span class="text-gray-400"> tokens</span>
			</span>
			<span class="lang-zh">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-tokens-zh">—</span>
				<span class="text-gray-400"> tokens</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-sessions">—</span>
				<span class="text-gray-400"> sessions</span>
			</span>
			<span class="lang-zh">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-sessions-zh">—</span>
				<span class="text-gray-400"> 个会话</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-hours">—</span>
				<span class="text-gray-400"> hours saved</span>
			</span>
			<span class="lang-zh">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-hours-zh">—</span>
				<span class="text-gray-400"> 小时节省</span>
			</span>
			<span class="text-gray-300 dark:text-gray-600">·</span>
			<span class="lang-en">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-cost">—</span>
				<span class="text-gray-400"> API cost</span>
			</span>
			<span class="lang-zh">
				<span class="impact-counter font-bold" style="color:#8953d1" id="stat-cost-zh">—</span>
				<span class="text-gray-400"> API 费用</span>
			</span>
		</div>
	</section>

	<!-- Detail overlay panel -->
	<div id="agent-detail" class="agent-detail-overlay" aria-hidden="true">
		<div class="agent-detail-card">
			<button class="detail-close" id="detail-close" aria-label="Close">×</button>
			<div class="detail-header">
				<span class="detail-dot" id="detail-dot"></span>
				<span class="detail-name font-serif" id="detail-name"></span>
				<span class="detail-role font-serif" id="detail-role"></span>
			</div>
			<p class="detail-stats font-serif" id="detail-stats"></p>
			<p class="detail-desc font-serif" id="detail-desc"></p>
			<ul class="detail-examples" id="detail-examples"></ul>
			<div class="detail-latest font-serif" id="detail-latest"></div>
		</div>
	</div>

	<!-- ═══ PIXEL OFFICE — Canvas 2D ═══ -->
	<section class="office-wrapper mb-16 fade-in-up" style="--delay: 200ms">
		<div class="pixel-office-scale-wrapper" id="pixel-office-wrapper">
			<div class="pixel-office" id="pixel-office">
				<canvas id="office-canvas" width="768" height="448"></canvas>
				<div id="connection-status" class="office-live-badge font-serif">
					<span class="live-dot"></span>
					<span class="lang-en">Live</span><span class="lang-zh">实时</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Team Workload -->
	<section class="team-workload mb-16 fade-in-up" style="--delay: 400ms" id="team-workload-section">
		<h2 class="mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
			<span class="lang-en">Team Workload</span><span class="lang-zh">团队工作量</span>
		</h2>
		<p class="mb-6 font-serif text-2xl font-semibold dark:text-white">
			<span class="lang-en">Token usage by agent.</span>
			<span class="lang-zh">各 Agent 的 Token 使用量。</span>
		</p>
		<div id="workload-chart" class="workload-chart">
			<div class="workload-loading font-serif text-xs text-gray-400">
				<span class="lang-en">Loading workload data...</span><span class="lang-zh">加载中...</span>
			</div>
		</div>

	</section>

	<!-- Activity Feed -->
	<section class="activity-feed mb-16 fade-in-up" style="--delay: 500ms">
		<h2 class="mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
			<span class="lang-en">Recent Activity</span><span class="lang-zh">团队动态</span>
		</h2>
		<p class="mb-6 font-serif text-2xl font-semibold dark:text-white">
			<span class="lang-en">What the team shipped today.</span>
			<span class="lang-zh">今天团队干了什么。</span>
		</p>
		<div class="feed-header-row">
			<a href="/lab/builder-log/" class="feed-link font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
				<span class="lang-en">Full build history →</span>
				<span class="lang-zh">完整构建日志 →</span>
			</a>
		</div>
		<div class="feed-list" id="activity-feed-list">
			<div class="feed-loading font-serif text-xs text-gray-400">
				<span class="lang-en">Loading activity...</span><span class="lang-zh">加载中...</span>
			</div>
		</div>
	</section>
</PageLayout>

<style is:global>
	/* ── Language toggle ──────────────────────────────────────── */
	html[data-lang="en"] .lang-zh,
	html:not([data-lang]) .lang-zh,
	html[data-lang="zh"] .lang-en { display: none !important; }

	/* ══════════════════════════════════════════════════════════════
	   PIXEL OFFICE — Canvas container
	   ══════════════════════════════════════════════════════════════ */
	.office-wrapper {
		overflow: hidden;
		-webkit-overflow-scrolling: touch;
	}
	.pixel-office {
		position: relative;
		width: 768px;
		height: 448px;
		margin: 0 auto;
		border: 3px solid #2a2a3a;
		border-radius: 6px;
		overflow: hidden;
		box-shadow: 0 0 30px #8953d122, 0 0 0 1px #8953d133;
	}
	:global([data-theme="light"]) .pixel-office {
		border-color: #ccc;
		box-shadow: 0 4px 32px rgba(0,0,0,0.08);
	}

	#office-canvas {
		display: block;
		image-rendering: pixelated;
		image-rendering: crisp-edges;
		cursor: default;
		width: 768px;
		height: 448px;
	}

	/* Live badge inside Pixel Office */
	.office-live-badge {
		position: absolute;
		top: 8px;
		left: 10px;
		display: flex;
		align-items: center;
		gap: 5px;
		font-size: 10px;
		color: #4ade80;
		letter-spacing: 0.05em;
		pointer-events: none;
		opacity: 0.85;
	}
	.live-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 6px #4ade8088;
		animation: live-pulse 2s ease-in-out infinite;
	}
	@keyframes live-pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* ── Responsive scale wrapper ─────────────────────────────── */
	.pixel-office-scale-wrapper {
		width: 100%;
		overflow: hidden;
	}
	.pixel-office {
		transform-origin: top left;
	}

	/* ── Detail overlay ─────────────────────────────────────────── */
	.agent-detail-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(0, 0, 0, 0.6);
		align-items: center;
		justify-content: center;
		padding: 1rem;
		backdrop-filter: blur(4px);
	}
	.agent-detail-overlay.is-open {
		display: flex;
		animation: overlay-in 0.2s ease-out;
	}
	@keyframes overlay-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	.agent-detail-card {
		background: #12122a;
		border: 2px solid #2a2a3a;
		border-radius: 8px;
		padding: 1.75rem;
		max-width: 480px;
		width: 100%;
		position: relative;
		animation: card-in 0.25s ease-out;
		box-shadow: 0 0 40px rgba(137, 83, 209, 0.2);
	}
	:global([data-theme="light"]) .agent-detail-card {
		background: #fffaef;
		border-color: #e5e7eb;
		box-shadow: 0 4px 32px rgba(0,0,0,0.10);
	}
	@keyframes card-in {
		from { opacity: 0; transform: translateY(12px) scale(0.97); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
	.detail-close {
		position: absolute;
		top: 1rem; right: 1rem;
		background: none; border: none;
		color: #888; font-size: 1.5rem;
		cursor: pointer; line-height: 1;
		transition: color 0.15s;
		padding: 0 0.25rem;
	}
	.detail-close:hover { color: white; }
	:global([data-theme="light"]) .detail-close:hover { color: #111; }
	.detail-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.85rem;
	}
	.detail-dot {
		width: 10px; height: 10px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.detail-name {
		font-size: 1.2rem;
		font-weight: 700;
		color: white;
	}
	:global([data-theme="light"]) .detail-name { color: #111; }
	.detail-role {
		font-size: 0.75rem;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.detail-stats {
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 0.6rem;
	}
	.detail-desc {
		font-size: 0.95rem;
		line-height: 1.65;
		color: #aaa;
		margin-bottom: 1.1rem;
	}
	:global([data-theme="light"]) .detail-desc { color: #555; }
	.detail-examples {
		list-style: none;
		margin: 0 0 1.1rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.detail-examples li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: serif;
		font-size: 0.85rem;
		color: #ccc;
	}
	:global([data-theme="light"]) .detail-examples li { color: #444; }
	.detail-examples li::before {
		content: '';
		width: 4px; height: 4px;
		border-radius: 50%;
		background: #8953d1;
		flex-shrink: 0;
	}
	.detail-latest {
		border-top: 1px solid #2a2a3a;
		padding-top: 0.75rem;
		font-size: 0.8rem;
		color: #666;
	}
	:global([data-theme="light"]) .detail-latest {
		border-top-color: #e5e7eb;
		color: #888;
	}
	.detail-latest strong { color: #8953d1; }
	.detail-recent-list {
		list-style: none;
		padding: 0;
		margin: 0.4rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.detail-recent-list li {
		font-size: 0.8rem;
		color: #888;
	}
	:global([data-theme="light"]) .detail-recent-list li { color: #666; }
	.detail-recent-time {
		color: #8953d1;
		font-weight: 600;
		margin-right: 0.3rem;
	}

	/* ── Team Workload ──────────────────────────────────────────── */
	.workload-chart {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.workload-row {
		display: grid;
		grid-template-columns: 140px 1fr 80px;
		align-items: center;
		gap: 0.75rem;
		transition: transform 0.15s;
	}
	.workload-row:hover {
		transform: scale(1.015);
	}
	.workload-row:hover .workload-bar-fill {
		filter: brightness(1.15);
		box-shadow: 0 0 14px var(--bar-color, #8953d1)66 !important;
	}
	.workload-label {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}
	.workload-name {
		font-size: 0.85rem;
		font-weight: 600;
		color: #ddd;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	:global([data-theme="light"]) .workload-name { color: #222; }
	.workload-model-tag {
		font-size: 0.6rem;
		color: #555;
		letter-spacing: 0.03em;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	:global([data-theme="light"]) .workload-model-tag { color: #aaa; }
	.workload-sessions {
		font-size: 0.65rem;
		color: #666;
		letter-spacing: 0.04em;
	}
	:global([data-theme="light"]) .workload-sessions { color: #999; }
	.workload-bar-track {
		background: #16162a;
		border-radius: 8px;
		height: 16px;
		overflow: hidden;
		position: relative;
	}
	:global([data-theme="light"]) .workload-bar-track { background: #f0f0f0; }
	.workload-bar-fill {
		height: 100%;
		border-radius: 8px;
		width: 0;
		transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
	}
	.workload-tokens {
		font-size: 0.8rem;
		color: #aaa;
		text-align: right;
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}
	:global([data-theme="light"]) .workload-tokens { color: #555; }
	.workload-footer {
		margin-top: 0.5rem;
	}
	.workload-loading {
		padding: 0.5rem 0;
	}

	/* ── Activity Feed ───────────────────────────────────────────── */
	.feed-header-row {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 0.75rem;
	}
	.feed-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.feed-item {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
		padding: 0.7rem 0;
		border-bottom: 1px solid #1f1f30;
	}
	:global([data-theme="light"]) .feed-item {
		border-bottom-color: #e5e7eb;
	}
	.feed-dot {
		width: 8px; height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
		margin-top: 5px;
	}
	.feed-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}
	.feed-agent {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.feed-desc {
		line-height: 1.5;
	}
	.feed-time {
		font-size: 0.7rem;
		white-space: nowrap;
		margin-top: 4px;
	}
</style>

<script is:inline src="/assets/pixel-office/engine.js?v=14scale"></script>
<script is:inline>
(function() {
	'use strict';

	var _intervals = [];

	function initAgentPage() {
		/* ── Clean up previous run ── */
		_intervals.forEach(function(id) { clearInterval(id); });
		_intervals = [];
		if (window.PixelOffice) window.PixelOffice.destroy();

		var CONVEX_URL = 'https://fleet-heron-880.convex.cloud';
		var CONVEX_ACTIVITY_URL = 'https://shiny-butterfly-744.convex.cloud';
		var statusEl = document.getElementById('connection-status');

		/* ── 初始化 Pixel Office 引擎 ── */
		var canvas = document.getElementById('office-canvas');
		if (canvas && window.PixelOffice) {
			window.PixelOffice.init(canvas);
		}

		/* ══════════════════════════════════════════════════════════════
		   CONVEX POLLING — drive character state + position
		   ══════════════════════════════════════════════════════════════ */
		function updateAgent(agent) {
			var status = agent.status || 'offline';
			var task = agent.currentTask || '';
			if (window.PixelOffice) {
				window.PixelOffice.updateAgent(agent.agentId, status, task);
			}
		}

		async function pollAgents() {
			try {
				var controller = new AbortController();
				var timeout = setTimeout(function() { controller.abort(); }, 5000);
				var resp = await fetch(CONVEX_URL + '/api/query', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ path: 'agents:list', args: {} }),
					signal: controller.signal
				});
				clearTimeout(timeout);
				var data = await resp.json();
				var agents = data.value || [];
				if (statusEl) {
					statusEl.style.color = '#4ade80';
					var dot = statusEl.querySelector('.live-dot');
					if (dot) { dot.style.background = '#4ade80'; dot.style.boxShadow = '0 0 6px #4ade8088'; }
				}
				agents.forEach(updateAgent);
			} catch (e) {
				console.error('Convex poll failed:', e);
				if (statusEl) {
					statusEl.style.color = '#888';
					var dot = statusEl.querySelector('.live-dot');
					if (dot) { dot.style.background = '#888'; dot.style.boxShadow = 'none'; }
					statusEl.querySelectorAll('.lang-en').forEach(function(el) { el.textContent = 'Cached'; });
					statusEl.querySelectorAll('.lang-zh').forEach(function(el) { el.textContent = '缓存'; });
				}
			}
		}

		pollAgents();
		_intervals.push(setInterval(pollAgents, 10000));

		/* ══════════════════════════════════════════════════════════════
		   CLICK + HOVER — canvas hit detection via engine
		   ══════════════════════════════════════════════════════════════ */
		function getCanvasCoords(e) {
			var rect = canvas.getBoundingClientRect();
			var scaleX = canvas.width / rect.width;
			var scaleY = canvas.height / rect.height;
			return {
				x: (e.clientX - rect.left) * scaleX,
				y: (e.clientY - rect.top) * scaleY,
			};
		}

		if (canvas) {
			canvas.addEventListener('click', function(e) {
				var c = getCanvasCoords(e);
				var hit = window.PixelOffice && window.PixelOffice.getAgentAt(c.x, c.y);
				if (hit) openDetail(hit);
			});

			canvas.addEventListener('mousemove', function(e) {
				var c = getCanvasCoords(e);
				var hit = window.PixelOffice && window.PixelOffice.getAgentAt(c.x, c.y);
				canvas.style.cursor = hit ? 'pointer' : 'default';
			});
		}

		/* ══════════════════════════════════════════════════════════════
		   AGENT DETAIL PANEL
		   ══════════════════════════════════════════════════════════════ */
		var AGENT_DATA = {
			main: {
				name: 'Samantha', role: 'Mastermind', color: '#ff6b35',
				descEn: 'Coordinates the team, routes tasks, delivers daily briefings and market reports. Makes sure nothing falls through the cracks.',
				descZh: '\u56e2\u961f\u534f\u8c03\u3001\u4efb\u52a1\u5206\u914d\u3001\u6bcf\u65e5\u65e9\u665a\u62a5\u548c\u5e02\u573a\u5feb\u62a5\u3002\u786e\u4fdd\u6bcf\u4ef6\u4e8b\u90fd\u6709\u4eba\u8d1f\u8d23\u3002',
				statsEn: '57 proposals routed \u00b7 30+ cron jobs \u00b7 daily briefings',
				statsZh: '\u5df2\u8def\u7531 57 \u4e2a\u63d0\u6848 \u00b7 30+ \u5b9a\u65f6\u4efb\u52a1 \u00b7 \u6bcf\u65e5\u65e9\u665a\u62a5',
				examplesEn: ['Morning / evening briefings', 'Market pulse reports', 'Task routing & escalation', 'Team health monitoring'],
				examplesZh: ['\u6bcf\u65e5\u65e9\u665a\u62a5', '\u5e02\u573a\u5feb\u62a5', '\u4efb\u52a1\u8def\u7531\u4e0e\u5347\u7ea7', '\u56e2\u961f\u5065\u5eb7\u76d1\u63a7'],
			},
			writer: {
				name: 'Loki', role: 'Writer', color: '#4a9e4a',
