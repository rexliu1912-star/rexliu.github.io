---
import PageLayout from "@/layouts/Base.astro";
const meta = {
	title: "Agent Activity — Rex's Lab",
	description: "Live pixel office — 6 AI agents working in real-time",
};
---

<PageLayout meta={meta}>
	<section class="mb-10">
		<a href="/lab/" class="fade-in-up font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" style="--delay: 50ms">
			<span class="lang-en">← Back to Lab</span><span class="lang-zh">← 返回 Lab</span>
		</a>
		<h1 class="hero-reveal-text mt-4 mb-3 font-serif text-4xl font-bold dark:text-white">
			<span class="lang-en">Agent Activity</span><span class="lang-zh">Agent 工作室</span>
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300" style="--delay: 80ms">
			<span class="lang-en">I run a 6-person AI team. They write, research, code, design, and analyze — 24/7, while I focus on decisions.</span>
			<span class="lang-zh">我有一支 6 人 AI 团队：写作、研究、开发、设计、分析，全天候运转，我只负责决策。</span>
		</p>
		<p class="hero-reveal-subtitle max-w-2xl mt-2 font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400" style="--delay: 120ms">
			<span class="lang-en">Each agent has a role, a personality, and a live status. Click any character to learn more.</span>
			<span class="lang-zh">每个 Agent 有独立角色和个性。点击角色查看详情。</span>
		</p>
		<div id="connection-status" class="mt-3 font-serif text-xs text-gray-400">
			<span class="lang-en">● Live</span><span class="lang-zh">● 实时</span>
		</div>
	</section>

	<!-- Detail overlay panel -->
	<div id="agent-detail" class="agent-detail-overlay" aria-hidden="true">
		<div class="agent-detail-card">
			<button class="detail-close" id="detail-close" aria-label="Close">×</button>
			<div class="detail-header">
				<span class="detail-dot" id="detail-dot"></span>
				<span class="detail-name font-serif" id="detail-name"></span>
				<span class="detail-role font-serif" id="detail-role"></span>
			</div>
			<p class="detail-stats font-serif" id="detail-stats"></p>
			<p class="detail-desc font-serif" id="detail-desc"></p>
			<ul class="detail-examples" id="detail-examples"></ul>
			<div class="detail-latest font-serif" id="detail-latest"></div>
		</div>
	</div>

	<!-- ═══ SHARED PIXEL OFFICE ═══ -->
	<section class="office-wrapper mb-16 fade-in-up" style="--delay: 100ms">
		<div class="pixel-office-scale-wrapper" id="pixel-office-wrapper">
		<div class="pixel-office" id="pixel-office">
			<!-- ═══ AGENT SPRITES ═══ -->
			<!-- Samantha -->
			<div class="agent-sprite-wrap" data-agent="main" id="sprite-main">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/samantha-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Samantha</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Loki -->
			<div class="agent-sprite-wrap" data-agent="writer" id="sprite-writer">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/loki-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Loki</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Vision -->
			<div class="agent-sprite-wrap" data-agent="researcher" id="sprite-researcher">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/vision-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Vision</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Jarvis -->
			<div class="agent-sprite-wrap" data-agent="coder" id="sprite-coder">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/jarvis-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Jarvis</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Shuri -->
			<div class="agent-sprite-wrap" data-agent="designer" id="sprite-designer">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/shuri-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Shuri</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Friday -->
			<div class="agent-sprite-wrap" data-agent="analyst" id="sprite-analyst">
				<div class="agent-sprite" data-state="idle">
					<div class="sprite-img" style="background-image:url('/sprites/friday-sprite.png')"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Friday</span><span class="sprite-status-dot"></span></div>
			</div>
		</div>
		</div><!-- end pixel-office-scale-wrapper -->
	</section>

	<!-- Activity Feed -->
	<section class="activity-feed mb-16 fade-in-up" style="--delay: 500ms">
			<h2 class="mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
				<span class="lang-en">Recent Activity</span><span class="lang-zh">团队动态</span>
			</h2>
			<p class="mb-6 font-serif text-2xl font-semibold dark:text-white">
				<span class="lang-en">What the team shipped today.</span>
				<span class="lang-zh">今天团队干了什么。</span>
			</p>
			<div class="feed-header-row">
				<a href="/lab/builder-log/" class="feed-link font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
					<span class="lang-en">Full build history →</span>
					<span class="lang-zh">完整构建日志 →</span>
				</a>
			</div>
			<div class="feed-list" id="activity-feed-list">
				<div class="feed-loading font-serif text-xs text-gray-400">
					<span class="lang-en">Loading activity...</span><span class="lang-zh">加载中...</span>
				</div>
			</div>
		</section>
</PageLayout>

<style is:global>
	/* ── Language toggle ──────────────────────────────────────── */
	html[data-lang="en"] .lang-zh,
	html:not([data-lang]) .lang-zh,
	html[data-lang="zh"] .lang-en { display: none !important; }

	/* ══════════════════════════════════════════════════════════════
	   PIXEL OFFICE — Shared workspace container
	   ══════════════════════════════════════════════════════════════ */
	.office-wrapper {
		overflow: hidden;
		-webkit-overflow-scrolling: touch;
	}
	.pixel-office {
		position: relative;
		width: 960px;
		height: 520px;
		margin: 0 auto;
		image-rendering: pixelated;
		border: 3px solid #2a2a3a;
		border-radius: 6px;
		overflow: hidden;
		box-shadow: 0 0 30px #8953d122, 0 0 0 1px #8953d133;
		/* Pixel art office background */
		background-image: url('/sprites/office-background.png');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}
	/* Light theme */
	:global([data-theme="light"]) .pixel-office {
		border-color: #ccc;
		box-shadow: 0 4px 32px rgba(0,0,0,0.08);
	}



	/* ══════════════════════════════════════════════════════════════
	   AGENT SPRITE WRAPPERS — positioned in the office
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite-wrap {
		position: absolute;
		z-index: 10;
		cursor: pointer;
		transition: left 0.5s ease, top 0.5s ease, opacity 0.4s ease;
	}
	.agent-sprite-wrap:hover { z-index: 20; }
	.agent-sprite-wrap:hover .sprite-label { opacity: 1; }

	/* Sprite label (name + dot) */
	.sprite-label {
		position: absolute;
		bottom: -16px; left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 3px;
		white-space: nowrap;
		opacity: 0.7;
		transition: opacity 0.2s;
		pointer-events: none;
	}
	.sprite-name {
		font-family: serif;
		font-size: 8px;
		color: #ccc;
		letter-spacing: 0.02em;
	}
	:global([data-theme="light"]) .sprite-name { color: #555; }
	.sprite-status-dot {
		width: 5px; height: 5px;
		border-radius: 50%;
		background: #666;
		flex-shrink: 0;
	}
	.sprite-status-dot.idle { background: #4ade80; }
	.sprite-status-dot.busy { background: #f59e0b; animation: pulse-dot 1.5s infinite; }
	.sprite-status-dot.error { background: #a78bfa; }
	.sprite-status-dot.offline { background: #666; }

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* ══════════════════════════════════════════════════════════════
	   SPRITE POSITIONS BY STATE
	   Each agent gets specific coordinates per state
	   ══════════════════════════════════════════════════════════════ */

	/* ── Default / idle: Lounge area (top-left) ── */
	#sprite-main[data-pos="idle"]        { top: 120px; left: 100px; }
	#sprite-writer[data-pos="idle"]      { top: 140px; left: 60px; }
	#sprite-researcher[data-pos="idle"]  { top: 118px; left: 148px; }
	#sprite-coder[data-pos="idle"]       { top: 155px; left: 115px; }
	#sprite-designer[data-pos="idle"]    { top: 128px; left: 170px; }
	#sprite-analyst[data-pos="idle"]     { top: 152px; left: 50px; }

	/* ── Busy: Workstations / Command ── */
	#sprite-main[data-pos="busy"]        { top: 138px; right: 148px; left: auto; }   /* Command center */
	#sprite-writer[data-pos="busy"]      { top: 248px; left: 226px; }   /* Desk 1 */
	#sprite-researcher[data-pos="busy"]  { top: 248px; left: 366px; }   /* Desk 2 */
	#sprite-coder[data-pos="busy"]       { top: 248px; left: 506px; }   /* Desk 3 */
	#sprite-designer[data-pos="busy"]    { top: 328px; left: 286px; }   /* Desk 4 */
	#sprite-analyst[data-pos="busy"]     { top: 328px; left: 446px; }   /* Desk 5 */

	/* ── Error: Arcade area (bottom-left), vacation mode ── */
	#sprite-main[data-pos="error"]       { top: 400px; left: 120px; }
	#sprite-writer[data-pos="error"]     { top: 415px; left: 60px; }
	#sprite-researcher[data-pos="error"] { top: 390px; left: 145px; }
	#sprite-coder[data-pos="error"]      { top: 410px; left: 90px; }
	#sprite-designer[data-pos="error"]   { top: 395px; left: 165px; }
	#sprite-analyst[data-pos="error"]    { top: 420px; left: 40px; }

	/* ── Offline: Sofa area, semi-transparent ── */
	#sprite-main[data-pos="offline"]        { top: 122px; left: 30px; }
	#sprite-writer[data-pos="offline"]      { top: 125px; left: 55px; }
	#sprite-researcher[data-pos="offline"]  { top: 128px; left: 80px; }
	#sprite-coder[data-pos="offline"]       { top: 160px; left: 38px; }
	#sprite-designer[data-pos="offline"]    { top: 163px; left: 62px; }
	#sprite-analyst[data-pos="offline"]     { top: 160px; left: 86px; }

	/* ══════════════════════════════════════════════════════════════
	   SPRITE IMAGE SYSTEM — PNG sprite sheets
	   ══════════════════════════════════════════════════════════════ */

	.agent-sprite {
		position: relative;
		width: 56px; height: 56px;
		z-index: 5;
	}

	/* Show first frame (top-left) of 4×2 sprite sheet (1408×768, each frame 352×384) */
	.sprite-img {
		width: 56px;
		height: 56px;
		background-size: 400% 200%;   /* 4 cols × 2 rows */
		background-position: 0% 0%;   /* first frame */
		background-repeat: no-repeat;
		image-rendering: pixelated;
		filter: drop-shadow(0 2px 2px rgba(0,0,0,0.35));
	}

	/* ══════════════════════════════════════════════════════════════
	   ANIMATIONS — Idle Breathe + State effects
	   ══════════════════════════════════════════════════════════════ */
	@keyframes idle-breathe {
		0%, 100% { transform: translateY(0); }
		25% { transform: translateY(-1px); }
		50% { transform: translateY(-1px); }
		75% { transform: translateY(0); }
	}
	.agent-sprite[data-state="idle"] .sprite-img,
	.agent-sprite[data-state="error"] .sprite-img {
		animation: idle-breathe 1s steps(4) infinite;
	}

	/* ══════════════════════════════════════════════════════════════
	   BUSY STATE — at desk, subtle bob
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite[data-state="busy"] .sprite-img {
		animation: work-bob 0.8s steps(2) infinite;
	}
	@keyframes work-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-2px); }
	}

		/* ══════════════════════════════════════════════════════════════
	   OFFLINE STATE — grayscale + ZZZ
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite[data-state="offline"] .sprite-img {
		filter: grayscale(80%) opacity(0.5);
		animation: none;
	}
	/* Semi-transparent wrapper for offline */
	.agent-sprite-wrap[data-pos="offline"] {
		opacity: 0.6;
	}

	.zzz-bubble {
		display: none;
		position: absolute;
		top: -10px; right: -8px;
		z-index: 15;
		font-family: monospace;
		font-weight: bold;
		color: #4a8ab544;
	}
	.agent-sprite[data-state="offline"] ~ .zzz-bubble {
		display: block;
	}
	.zzz-bubble::before {
		content: 'z';
		position: absolute;
		bottom: 0; right: 0;
		font-size: 6px;
		animation: zzz-float 2s steps(3) infinite;
	}
	.zzz-bubble::after {
		content: 'Z';
		position: absolute;
		bottom: 6px; right: 4px;
		font-size: 8px;
		animation: zzz-float 2s steps(3) infinite 0.5s;
	}
	@keyframes zzz-float {
		0% { opacity: 0; transform: translateY(0); }
		30% { opacity: 0.6; }
		100% { opacity: 0; transform: translateY(-8px); }
	}

	/* ══════════════════════════════════════════════════════════════
	   ERROR STATE — vacation mode, NO blink, NO !, just chill
	   ══════════════════════════════════════════════════════════════ */
	/* error uses idle-breathe (already assigned above), no extra styling */



	/* ── Detail overlay ─────────────────────────────────────────── */
	.agent-detail-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(0, 0, 0, 0.6);
		align-items: center;
		justify-content: center;
		padding: 1rem;
		backdrop-filter: blur(4px);
	}
	.agent-detail-overlay.is-open {
		display: flex;
		animation: overlay-in 0.2s ease-out;
	}
	@keyframes overlay-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	.agent-detail-card {
		background: #12122a;
		border: 2px solid #2a2a3a;
		border-radius: 8px;
		padding: 1.75rem;
		max-width: 480px;
		width: 100%;
		position: relative;
		animation: card-in 0.25s ease-out;
		box-shadow: 0 0 40px rgba(137, 83, 209, 0.2);
	}
	:global([data-theme="light"]) .agent-detail-card {
		background: #fffaef;
		border-color: #e5e7eb;
		box-shadow: 0 4px 32px rgba(0,0,0,0.10);
	}
	@keyframes card-in {
		from { opacity: 0; transform: translateY(12px) scale(0.97); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
	.detail-close {
		position: absolute;
		top: 1rem; right: 1rem;
		background: none; border: none;
		color: #888; font-size: 1.5rem;
		cursor: pointer; line-height: 1;
		transition: color 0.15s;
		padding: 0 0.25rem;
	}
	.detail-close:hover { color: white; }
	:global([data-theme="light"]) .detail-close:hover { color: #111; }
	.detail-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.85rem;
	}
	.detail-dot {
		width: 10px; height: 10px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.detail-name {
		font-size: 1.2rem;
		font-weight: 700;
		color: white;
	}
	:global([data-theme="light"]) .detail-name { color: #111; }
	.detail-role {
		font-size: 0.75rem;
		color: #888;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.detail-stats {
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 0.6rem;
	}
	.detail-desc {
		font-size: 0.95rem;
		line-height: 1.65;
		color: #aaa;
		margin-bottom: 1.1rem;
	}
	:global([data-theme="light"]) .detail-desc { color: #555; }
	.detail-examples {
		list-style: none;
		margin: 0 0 1.1rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.detail-examples li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: serif;
		font-size: 0.85rem;
		color: #ccc;
	}
	:global([data-theme="light"]) .detail-examples li { color: #444; }
	.detail-examples li::before {
		content: '';
		width: 4px; height: 4px;
		border-radius: 50%;
		background: #8953d1;
		flex-shrink: 0;
	}
	.detail-latest {
		border-top: 1px solid #2a2a3a;
		padding-top: 0.75rem;
		font-size: 0.8rem;
		color: #666;
	}
	:global([data-theme="light"]) .detail-latest {
		border-top-color: #e5e7eb;
		color: #888;
	}
	.detail-latest strong { color: #8953d1; }
	.detail-recent-list {
		list-style: none;
		padding: 0;
		margin: 0.4rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.detail-recent-list li {
		font-size: 0.8rem;
		color: #888;
	}
	:global([data-theme="light"]) .detail-recent-list li { color: #666; }
	.detail-recent-time {
		color: #8953d1;
		font-weight: 600;
		margin-right: 0.3rem;
	}

	/* ── Activity Feed ───────────────────────────────────────────── */
	.feed-header-row {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 0.75rem;
	}
	.feed-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.feed-item {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
		padding: 0.7rem 0;
		border-bottom: 1px solid #1f1f30;
	}
	:global([data-theme="light"]) .feed-item {
		border-bottom-color: #e5e7eb;
	}
	.feed-dot {
		width: 8px; height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
		margin-top: 5px;
	}
	.feed-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}
	.feed-agent {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.feed-desc {
		line-height: 1.5;
	}
	.feed-time {
		font-size: 0.7rem;
		white-space: nowrap;
		margin-top: 4px;
	}

	/* ── Responsive: JS-driven scale (see initPixelOfficeScale) ── */
	.pixel-office-scale-wrapper {
		width: 100%;
		overflow: hidden;
	}
	.pixel-office {
		transform-origin: top left;
		/* scale set dynamically by JS */
	}
</style>

<script is:inline>
	(function() {
		var _intervals = [];
		var _controllers = {};

		function initAgentPage() {
		// Clean up previous intervals (View Transitions re-entry)
		_intervals.forEach(function(id) { clearInterval(id); });
		_intervals = [];
		Object.values(_controllers).forEach(function(c) { if (c.stop) c.stop(); });
		_controllers = {};

		var CONVEX_URL = 'https://fleet-heron-880.convex.cloud';
		var statusEl = document.getElementById('connection-status');

		/* ── Idle Animation Controller ────────────────────────── */
		var IDLE_VARIANTS = {
			main:       ['idle-coffee', 'idle-phone'],
			writer:     ['idle-read', 'idle-plot'],
			researcher: ['idle-telescope', 'idle-think'],
			coder:      ['idle-tinker', 'idle-headbang'],
			designer:   ['idle-doodle', 'idle-palette'],
			analyst:    ['idle-data', 'idle-stretch']
		};
		var VARIANT_DURATIONS = {
			'idle-coffee': 2000, 'idle-phone': 1500,
			'idle-read': 1500, 'idle-plot': 1500,
			'idle-telescope': 2000, 'idle-think': 1000,
			'idle-tinker': 1000, 'idle-headbang': 1000,
			'idle-doodle': 1300, 'idle-palette': 1000,
			'idle-data': 1000, 'idle-stretch': 1000
		};

		var controllers = _controllers;

		function IdleController(wrap, agentId) {
			this.wrap = wrap;
			this.sprite = wrap.querySelector('.agent-sprite');
			this.agentId = agentId;
			this.variants = IDLE_VARIANTS[agentId] || [];
			this.timer = null;
			this.playing = false;
		}
		IdleController.prototype.start = function() {
			this.stop();
			this.clearVariantClass();
			this.scheduleTick();
		};
		IdleController.prototype.stop = function() {
			if (this.timer) { clearTimeout(this.timer); this.timer = null; }
			this.clearVariantClass();
			this.playing = false;
		};
		IdleController.prototype.clearVariantClass = function() {
			var sp = this.sprite;
			this.variants.forEach(function(v) { sp.classList.remove('playing-' + v); });
		};
		IdleController.prototype.scheduleTick = function() {
			var self = this;
			var delay = 3000 + Math.random() * 4000;
			this.timer = setTimeout(function() { self.tick(); }, delay);
		};
		IdleController.prototype.tick = function() {
			var state = this.sprite.getAttribute('data-state');
			if (state !== 'idle') { this.scheduleTick(); return; }

			if (Math.random() < 0.7 && this.variants.length > 0) {
				var v = this.variants[Math.floor(Math.random() * this.variants.length)];
				var dur = VARIANT_DURATIONS[v] || 1500;
				var self = this;
				this.playing = true;
				this.sprite.classList.add('playing-' + v);

				this.timer = setTimeout(function() {
					self.sprite.classList.remove('playing-' + v);
					self.playing = false;
					self.scheduleTick();
				}, dur);
			} else {
				this.scheduleTick();
			}
		};

		/* ── Random offset for idle/error positions ──────────── */
		function applyRandomOffset(wrap, status) {
			if (status === 'idle' || status === 'error') {
				var ox = Math.floor(Math.random() * 20) - 10;
				var oy = Math.floor(Math.random() * 12) - 6;
				wrap.style.marginLeft = ox + 'px';
				wrap.style.marginTop = oy + 'px';
			} else {
				wrap.style.marginLeft = '0';
				wrap.style.marginTop = '0';
			}
		}

		/* ── Initialize Idle Controllers ──────────────────────── */
		document.querySelectorAll('.agent-sprite-wrap').forEach(function(wrap) {
			var agentId = wrap.getAttribute('data-agent');
			var ctrl = new IdleController(wrap, agentId);
			controllers[agentId] = ctrl;
			ctrl.start();
			// Set initial position
			wrap.setAttribute('data-pos', 'idle');
			applyRandomOffset(wrap, 'idle');
		});

		/* ── Convex Polling ───────────────────────────────────── */
		function updateAgent(agent) {
			var wrap = document.querySelector('.agent-sprite-wrap[data-agent="' + agent.agentId + '"]');
			if (!wrap) return;

			var sprite = wrap.querySelector('.agent-sprite');
			var dot = wrap.querySelector('.sprite-status-dot');
			var status = agent.status || 'offline';

			if (sprite) {
				var prev = sprite.getAttribute('data-state');
				sprite.setAttribute('data-state', status);
				wrap.setAttribute('data-pos', status);
				applyRandomOffset(wrap, status);

				// Restart idle controller when transitioning to idle
				if (status === 'idle' && prev !== 'idle' && controllers[agent.agentId]) {
					controllers[agent.agentId].start();
				}
				if (status !== 'idle' && controllers[agent.agentId]) {
					controllers[agent.agentId].stop();
				}
			}
			if (dot) dot.className = 'sprite-status-dot ' + status;
		}

		function setOffline() {
			document.querySelectorAll('.agent-sprite-wrap').forEach(function(wrap) {
				var dot = wrap.querySelector('.sprite-status-dot');
				var sprite = wrap.querySelector('.agent-sprite');
				if (dot) dot.className = 'sprite-status-dot offline';
				if (sprite) sprite.setAttribute('data-state', 'offline');
				wrap.setAttribute('data-pos', 'offline');
			});
			if (statusEl) {
				statusEl.innerHTML = '<span class="lang-en" style="color:#ef4444">\u26a0 Offline</span><span class="lang-zh" style="color:#ef4444">\u26a0 离线</span>';
			}
		}

		async function pollAgents() {
			try {
				var controller = new AbortController();
				var timeout = setTimeout(function() { controller.abort(); }, 5000);
				var resp = await fetch(CONVEX_URL + '/api/query', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ path: 'agents:list', args: {} }),
					signal: controller.signal
				});
				clearTimeout(timeout);
				var data = await resp.json();
				var agents = data.value || [];
				if (statusEl) {
					statusEl.innerHTML = '<span class="lang-en" style="color:#4ade80">\u25cf Live</span><span class="lang-zh" style="color:#4ade80">\u25cf 实时</span>';
				}
				agents.forEach(updateAgent);
			} catch (e) {
				console.error('Convex poll failed:', e);
				if (statusEl) {
					statusEl.innerHTML = '<span class="lang-en" style="color:#888">\u25cb Cached</span><span class="lang-zh" style="color:#888">\u25cb 缓存</span>';
				}
			}
		}

		pollAgents();
		_intervals.push(setInterval(pollAgents, 10000));

		/* ── Agent Detail Panel ───────────────────────────────── */
		var AGENT_DATA = {
			main: {
