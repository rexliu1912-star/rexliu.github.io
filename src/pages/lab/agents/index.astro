---
import PageLayout from "@/layouts/Base.astro";
import activityData from "@/data/activity-feed.json";

const meta = {
	title: "Agent Activity — Rex's Lab",
	description: "Live pixel office — 6 AI agents working in real-time",
};

// ── Agent definitions ──────────────────────────────────────────────────────
const AGENT_INFO: Record<string, {
	nameEn: string; nameZh: string;
	roleEn: string; roleZh: string;
	descEn: string; descZh: string;
	color: string;
	examplesEn: string[]; examplesZh: string[];
}> = {
	main: {
		nameEn: "Samantha", nameZh: "Samantha",
		roleEn: "Mastermind", roleZh: "主脑",
		descEn: "Coordinates the team, routes tasks, delivers daily briefings and market reports. I make sure nothing falls through the cracks.",
		descZh: "团队协调、任务分配、每日早晚报和市场快报。确保每件事都有人负责。",
		color: "#ff6b35",
		examplesEn: ["Morning / evening briefings", "Market pulse reports", "Task routing & escalation", "Team health monitoring"],
		examplesZh: ["每日早晚报", "市场快报", "任务路由与升级", "团队健康监控"],
	},
	writer: {
		nameEn: "Loki", nameZh: "Loki",
		roleEn: "Writer", roleZh: "写手",
		descEn: "Writes tweet drafts, translates crypto/AI signals into Rex's voice, produces content that bridges English and Chinese audiences.",
		descZh: "撰写推文草稿，将加密/AI 信号转化为 Rex 的语气，制作中英双语内容。",
		color: "#4a9e4a",
		examplesEn: ["2× daily tweet drafts", "CN/EN content translation", "Signal-to-draft pipeline", "Builder's log entries"],
		examplesZh: ["每日 2 条推文草稿", "中英内容转化", "信号→草稿流水线", "构建日志"],
	},
	researcher: {
		nameEn: "Vision", nameZh: "Vision",
		roleEn: "Researcher", roleZh: "研究员",
		descEn: "Scans 16+ KOLs daily, tracks crypto/AI/Robotics projects, surfaces alpha signals before they go mainstream.",
		descZh: "每日扫描 16+ KOL，追踪加密/AI/机器人项目，在信息大众化前发现 Alpha 信号。",
		color: "#4a8ab5",
		examplesEn: ["Daily KOL intelligence scan", "Deep-dive research reports", "Alpha Radar feed", "Project tracking"],
		examplesZh: ["每日 KOL 情报扫描", "深度研究报告", "Alpha Radar 推送", "项目追踪"],
	},
	coder: {
		nameEn: "Jarvis", nameZh: "Jarvis",
		roleEn: "Coder", roleZh: "工程师",
		descEn: "Builds and maintains all automation: cron jobs, data pipelines, website features, and internal tools. The backbone of the system.",
		descZh: "构建和维护所有自动化：定时任务、数据管道、网站功能和内部工具。系统的骨架。",
		color: "#7a7a8a",
		examplesEn: ["30+ automated cron jobs", "This website", "Portfolio sync tools", "Content pipeline scripts"],
		examplesZh: ["30+ 自动化定时任务", "本站", "投资组合同步工具", "内容管道脚本"],
	},
	designer: {
		nameEn: "Shuri", nameZh: "Shuri",
		roleEn: "Designer", roleZh: "设计师",
		descEn: "Creates visuals for tweets, research covers, and brand assets. Every image that ships has passed through her.",
		descZh: "为推文、研究封面和品牌资产创作视觉设计。每张发出去的图都经过她的手。",
		color: "#c54ab5",
		examplesEn: ["Tweet cover images", "Research report covers", "Brand asset design", "16-bit pixel art"],
		examplesZh: ["推文配图", "研究报告封面", "品牌视觉", "16-bit 像素艺术"],
	},
	analyst: {
		nameEn: "Friday", nameZh: "Friday",
		roleEn: "Analyst", roleZh: "分析师",
		descEn: "Tracks Rex's portfolio, produces SNEK daily briefings, monitors market data and financial metrics.",
		descZh: "追踪 Rex 的投资组合，每日 SNEK 简报，监控市场数据和财务指标。",
		color: "#4ac5c5",
		examplesEn: ["Daily SNEK briefing", "Portfolio sync & tracking", "Market data monitoring", "Financial analysis"],
		examplesZh: ["每日 SNEK 简报", "投资组合同步追踪", "市场数据监控", "财务分析"],
	},
};

// ── Activity feed from pre-generated JSON ─────────────────────────────────
// Generated by scripts/sync-activity-feed.sh → src/data/activity-feed.json
interface ActivityEntry {
	time: string; agentId: string; agentName: string;
	descEn: string; descZh: string; color: string;
}

function formatTime(ts: string): string {
	try {
		const d = new Date(ts.replace(' ', 'T') + '+08:00');
		const hh = String(d.getUTCHours() + 8).padStart(2, '0'); // rough SGT
		const mm = String(d.getMinutes()).padStart(2, '0');
		return `${hh}:${mm}`;
	} catch { return ts; }
}

const recentActivity: ActivityEntry[] = ((activityData as any[]) || []).map(e => ({
	...e,
	time: formatTime(e.time),
}));

// Build per-agent latest from the feed (first entry per agent since feed is newest-first)
const perAgentLatest: Record<string, string> = {};
for (const entry of recentActivity) {
	if (!perAgentLatest[entry.agentId]) {
		perAgentLatest[entry.agentId] = entry.descEn;
	}
}
---

