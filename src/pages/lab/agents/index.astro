	/* ══════════════════════════════════════════════════════════════
	   PIXEL CHARACTER SYSTEM (unchanged from original)
	   ══════════════════════════════════════════════════════════════ */

	.agent-sprite {
		position: relative;
		width: 32px; height: 32px;
		transform: scale(2);
		transform-origin: bottom center;
		z-index: 5;
	}

	.pixel-char {
		position: relative;
		width: 32px; height: 32px;
	}

	/* ── Shared Pixel Parts ───────────────────────────────────── */
	.px-head {
		position: absolute;
		width: 14px; height: 12px;
		top: 4px; left: 9px;
		background: #ffd5b0;
		border-radius: 3px 3px 2px 2px;
		z-index: 3;
	}
	.px-eyes {
		position: absolute;
		top: 4px; left: 2px;
		width: 10px; height: 2px;
	}
	.px-eyes::before, .px-eyes::after {
		content: '';
		position: absolute;
		width: 2px; height: 2px;
		background: #2a1a0a;
	}
	.px-eyes::before { left: 1px; }
	.px-eyes::after { right: 1px; }
	.px-mouth {
		position: absolute;
		bottom: 2px; left: 50%; transform: translateX(-50%);
		width: 4px; height: 1px;
		background: #c8887a;
		border-radius: 0 0 1px 1px;
	}
	.px-shadow {
		position: absolute;
		bottom: 0; left: 50%; transform: translateX(-50%);
		width: 18px; height: 2px;
		background: rgba(0,0,0,0.3);
		border-radius: 50%;
	}
	.px-body {
		position: absolute;
		top: 16px; left: 8px;
		width: 16px; height: 12px;
		border-radius: 3px 3px 0 0;
		z-index: 2;
	}
	.idle-effect, .state-overlay {
		position: absolute;
		top: 0; left: 0;
		width: 32px; height: 32px;
		pointer-events: none;
		z-index: 10;
	}

