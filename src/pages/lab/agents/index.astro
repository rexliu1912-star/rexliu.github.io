---
import PageLayout from "@/layouts/Base.astro";
const meta = {
	title: "Agent Activity — Rex's Lab",
	description: "Live pixel office — 6 AI agents working in real-time",
};
---

<PageLayout meta={meta}>
	<section class="mb-10">
		<a href="/lab/" class="fade-in-up font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" style="--delay: 50ms">
			<span class="lang-en">← Back to Lab</span><span class="lang-zh">← 返回 Lab</span>
		</a>
		<h1 class="hero-reveal-text mt-4 mb-3 font-serif text-4xl font-bold dark:text-white">
			<span class="lang-en">Agent Activity</span><span class="lang-zh">Agent 工作室</span>
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300" style="--delay: 80ms">
			<span class="lang-en">I run a 6-person AI team. They write, research, code, design, and analyze — 24/7, while I focus on decisions.</span>
			<span class="lang-zh">我有一支 6 人 AI 团队：写作、研究、开发、设计、分析，全天候运转，我只负责决策。</span>
		</p>
		<p class="hero-reveal-subtitle max-w-2xl mt-2 font-serif text-base leading-relaxed text-gray-500 dark:text-gray-400" style="--delay: 120ms">
			<span class="lang-en">Each agent has a role, a personality, and a live status. Click any character to learn more.</span>
			<span class="lang-zh">每个 Agent 有独立角色和个性。点击角色查看详情。</span>
		</p>
		<div id="connection-status" class="mt-3 font-serif text-xs text-gray-400">
			<span class="lang-en">● Live</span><span class="lang-zh">● 实时</span>
		</div>
	</section>

	<!-- Detail overlay panel -->
	<div id="agent-detail" class="agent-detail-overlay" aria-hidden="true">
		<div class="agent-detail-card">
			<button class="detail-close" id="detail-close" aria-label="Close">×</button>
			<div class="detail-header">
				<span class="detail-dot" id="detail-dot"></span>
				<span class="detail-name font-serif" id="detail-name"></span>
				<span class="detail-role font-serif" id="detail-role"></span>
			</div>
			<p class="detail-stats font-serif" id="detail-stats"></p>
			<p class="detail-desc font-serif" id="detail-desc"></p>
			<ul class="detail-examples" id="detail-examples"></ul>
			<div class="detail-latest font-serif" id="detail-latest"></div>
		</div>
	</div>

	<!-- ═══ SHARED PIXEL OFFICE ═══ -->
	<section class="office-wrapper mb-16 fade-in-up" style="--delay: 100ms">
		<div class="pixel-office" id="pixel-office">
			<!-- ── Wall decorations ── -->
			<div class="wall-layer">
				<div class="wall-deco whiteboard"></div>
				<div class="wall-deco wall-clock"></div>
				<div class="wall-deco poster"></div>
				<div class="wall-deco bulletin"></div>
			</div>

			<!-- ── Zone labels ── -->
			<div class="zone-label zone-label-lounge"><span class="lang-en">☕ Lounge</span><span class="lang-zh">☕ 休息区</span></div>
			<div class="zone-label zone-label-command"><span class="lang-en">🎯 Command</span><span class="lang-zh">🎯 指挥台</span></div>
			<div class="zone-label zone-label-arcade"><span class="lang-en">🎮 Arcade</span><span class="lang-zh">🎮 娱乐区</span></div>
			<div class="zone-label zone-label-desks"><span class="lang-en">💻 Workstations</span><span class="lang-zh">💻 工位区</span></div>

			<!-- ── Lounge furniture (top-left) ── -->
			<div class="office-furniture lounge-sofa"></div>
			<div class="office-furniture lounge-sofa2"></div>
			<div class="office-furniture coffee-table"></div>
			<div class="office-furniture coffee-machine"></div>
			<div class="office-furniture plant plant-1"></div>

			<!-- ── Command center (top-center-right) ── -->
			<div class="office-furniture cmd-desk"></div>
			<div class="office-furniture cmd-monitor"></div>
			<div class="office-furniture cmd-monitor2"></div>
			<div class="office-furniture cmd-chair"></div>

			<!-- ── Workstation desks (middle band) ── -->
			<div class="office-furniture ws-desk ws-desk-1"></div>
			<div class="office-furniture ws-monitor ws-mon-1"></div>
			<div class="office-furniture ws-desk ws-desk-2"></div>
			<div class="office-furniture ws-monitor ws-mon-2"></div>
			<div class="office-furniture ws-desk ws-desk-3"></div>
			<div class="office-furniture ws-monitor ws-mon-3"></div>
			<div class="office-furniture ws-desk ws-desk-4"></div>
			<div class="office-furniture ws-monitor ws-mon-4"></div>
			<div class="office-furniture ws-desk ws-desk-5"></div>
			<div class="office-furniture ws-monitor ws-mon-5"></div>
			<div class="office-furniture plant plant-2"></div>
			<div class="office-furniture plant plant-3"></div>

			<!-- ── Arcade zone (bottom-left) ── -->
			<div class="office-furniture arcade-cabinet"></div>
			<div class="office-furniture pingpong-table"></div>
			<div class="office-furniture plant plant-4"></div>

			<!-- ── Floor pattern overlay ── -->
			<div class="floor-pattern"></div>

			<!-- ═══ AGENT SPRITES ═══ -->
			<!-- Samantha -->
			<div class="agent-sprite-wrap" data-agent="main" id="sprite-main">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-samantha">
						<div class="px-hair"></div>
						<div class="px-head"><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-scarf"></div>
						<div class="px-body"></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Samantha</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Loki -->
			<div class="agent-sprite-wrap" data-agent="writer" id="sprite-writer">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-loki">
						<div class="px-hair"></div>
						<div class="px-head"><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-cape"></div>
						<div class="px-body"><div class="px-brooch"></div></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Loki</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Vision -->
			<div class="agent-sprite-wrap" data-agent="researcher" id="sprite-researcher">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-vision">
						<div class="px-head-glow"></div>
						<div class="px-head"><div class="px-glasses"></div><div class="px-gem"></div><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-body"></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Vision</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Jarvis -->
			<div class="agent-sprite-wrap" data-agent="coder" id="sprite-coder">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-jarvis">
						<div class="px-hair"></div>
						<div class="px-head"><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-headphones"></div>
						<div class="px-body"><div class="px-terminal-icon"></div></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Jarvis</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Shuri -->
			<div class="agent-sprite-wrap" data-agent="designer" id="sprite-designer">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-shuri">
						<div class="px-buns"></div>
						<div class="px-head"><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-body"><div class="px-apron"></div><div class="px-paint-spots"></div></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Shuri</span><span class="sprite-status-dot"></span></div>
			</div>

			<!-- Friday -->
			<div class="agent-sprite-wrap" data-agent="analyst" id="sprite-analyst">
				<div class="agent-sprite" data-state="idle">
					<div class="pixel-char char-friday">
						<div class="px-hair"></div>
						<div class="px-head"><div class="px-eyes"></div><div class="px-mouth"></div></div>
						<div class="px-body"></div>
						<div class="px-accessory"></div>
						<div class="px-shadow"></div>
					</div>
					<div class="idle-effect"></div>
					<div class="state-overlay"></div>
				</div>
				<div class="zzz-bubble"></div>
				<div class="sprite-label"><span class="sprite-name">Friday</span><span class="sprite-status-dot"></span></div>
			</div>
		</div>
	</section>

	<!-- Activity Feed -->
	<section class="activity-feed mb-16 fade-in-up" style="--delay: 500ms">
			<h2 class="mb-2 font-serif text-xs font-bold tracking-widest text-gray-400 uppercase dark:text-gray-500">
				<span class="lang-en">Recent Activity</span><span class="lang-zh">团队动态</span>
			</h2>
			<p class="mb-6 font-serif text-2xl font-semibold dark:text-white">
				<span class="lang-en">What the team shipped today.</span>
				<span class="lang-zh">今天团队干了什么。</span>
			</p>
			<div class="feed-header-row">
				<a href="/lab/builder-log/" class="feed-link font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
					<span class="lang-en">Full build history →</span>
					<span class="lang-zh">完整构建日志 →</span>
				</a>
			</div>
			<div class="feed-list" id="activity-feed-list">
				<div class="feed-loading font-serif text-xs text-gray-400">
					<span class="lang-en">Loading activity...</span><span class="lang-zh">加载中...</span>
				</div>
			</div>
		</section>
</PageLayout>

<style is:global>
	/* ── Language toggle ──────────────────────────────────────── */
	html[data-lang="en"] .lang-zh,
	html:not([data-lang]) .lang-zh,
	html[data-lang="zh"] .lang-en { display: none !important; }

	/* ══════════════════════════════════════════════════════════════
	   PIXEL OFFICE — Shared workspace container
	   ══════════════════════════════════════════════════════════════ */
	.office-wrapper {
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.pixel-office {
		position: relative;
		width: 960px;
		height: 380px;
		margin: 0 auto;
		image-rendering: pixelated;
		border: 3px solid #2a2a3a;
		border-radius: 6px;
		overflow: hidden;
		box-shadow: 0 0 30px #8953d122, 0 0 0 1px #8953d133;
		/* Wall + floor background */
		background:
			linear-gradient(180deg,
				#1e1e3a 0%, #1e1e3a 15%,   /* wall */
				#2a2a4a 15%, #2a2a4a 16%,   /* baseboard */
				#1a1a2e 16%, #181828 100%    /* floor */
			);
	}
	/* Grid pattern on floor only */
	.floor-pattern {
		position: absolute;
		top: 16%; left: 0; right: 0; bottom: 0;
		background:
			repeating-linear-gradient(90deg, transparent 0 31px, #ffffff04 31px 32px),
			repeating-linear-gradient(0deg, transparent 0 31px, #ffffff04 31px 32px);
		pointer-events: none;
		z-index: 0;
	}
	/* Light theme */
	:global([data-theme="light"]) .pixel-office {
		background:
			linear-gradient(180deg,
				#e8e4dc 0%, #e8e4dc 15%,
				#bbb 15%, #bbb 16%,
				#d4cfc4 16%, #c8c0b0 100%
			);
		border-color: #ccc;
		box-shadow: 0 4px 32px rgba(0,0,0,0.08);
	}
	:global([data-theme="light"]) .floor-pattern {
		background:
			repeating-linear-gradient(90deg, transparent 0 31px, #00000008 31px 32px),
			repeating-linear-gradient(0deg, transparent 0 31px, #00000008 31px 32px);
	}

	/* ── Zone Labels ── */
	.zone-label {
		position: absolute;
		font-family: serif;
		font-size: 9px;
		letter-spacing: 0.06em;
		color: #ffffff22;
		z-index: 1;
		pointer-events: none;
		text-transform: uppercase;
	}
	:global([data-theme="light"]) .zone-label { color: #00000022; }
	.zone-label-lounge { top: 20%; left: 30px; }
	.zone-label-command { top: 20%; right: 180px; }
	.zone-label-arcade { bottom: 30px; left: 30px; }
	.zone-label-desks { top: 54%; left: 50%; transform: translateX(-50%); }

	/* ══════════════════════════════════════════════════════════════
	   WALL DECORATIONS
	   ══════════════════════════════════════════════════════════════ */
	.wall-layer { position: absolute; top: 0; left: 0; right: 0; height: 15%; z-index: 1; pointer-events: none; }
	.wall-deco { position: absolute; }
	/* Whiteboard */
	.whiteboard {
		top: 16px; left: 60px;
		width: 80px; height: 44px;
		background: #f0f0e8;
		border: 3px solid #ccc;
		border-radius: 2px;
		box-shadow: 0 2px 4px #0004;
	}
	.whiteboard::before {
		content: '';
		position: absolute;
		top: 6px; left: 8px;
		width: 40px; height: 2px;
		background: #e74c3c;
		box-shadow: 0 8px 0 #3498db, 0 16px 0 #2ecc71, 20px 4px 0 #f39c12;
	}
	.whiteboard::after {
		content: '';
		position: absolute;
		bottom: 4px; right: 6px;
		width: 8px; height: 4px;
		background: #e74c3c;
		border-radius: 1px;
	}
	:global([data-theme="light"]) .whiteboard { background: #fff; border-color: #aaa; }
	/* Clock */
	.wall-clock {
		top: 20px; left: 360px;
		width: 28px; height: 28px;
		background: #2a2a4a;
		border: 2px solid #555;
		border-radius: 50%;
	}
	.wall-clock::before {
		content: '';
		position: absolute;
		top: 50%; left: 50%;
		width: 1px; height: 8px;
		background: #8953d1;
		transform-origin: bottom center;
		transform: translate(-50%, -100%) rotate(30deg);
		animation: clock-tick 10s steps(60) infinite;
	}
	.wall-clock::after {
		content: '';
		position: absolute;
		top: 50%; left: 50%;
		width: 1px; height: 5px;
		background: #fff;
		transform-origin: bottom center;
		transform: translate(-50%, -100%) rotate(180deg);
		animation: clock-tick 120s steps(60) infinite;
	}
	@keyframes clock-tick { to { transform: translate(-50%, -100%) rotate(390deg); } }
	:global([data-theme="light"]) .wall-clock { background: #f5f5f0; border-color: #999; }
	:global([data-theme="light"]) .wall-clock::after { background: #333; }
	/* Poster */
	.poster {
		top: 18px; right: 100px;
		width: 36px; height: 48px;
		background: linear-gradient(135deg, #8953d1, #c54ab5);
		border: 2px solid #6a3da0;
		border-radius: 2px;
	}
	.poster::before {
		content: '⚡';
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		font-size: 14px;
	}
	/* Bulletin board */
	.bulletin {
		top: 22px; right: 260px;
		width: 50px; height: 36px;
		background: #5c3d2e;
		border: 2px solid #7a5640;
		border-radius: 2px;
	}
	.bulletin::before {
		content: '';
		position: absolute;
		top: 6px; left: 6px;
		width: 10px; height: 8px;
		background: #f39c12;
		box-shadow: 14px 0 0 #4ade80, 28px 0 0 #ef4444, 0 12px 0 #3498db, 14px 12px 0 #c54ab5;
	}
	:global([data-theme="light"]) .bulletin { background: #c4a882; border-color: #b09070; }

	/* ══════════════════════════════════════════════════════════════
	   OFFICE FURNITURE — CSS pixel art
	   ══════════════════════════════════════════════════════════════ */
	.office-furniture { position: absolute; z-index: 2; image-rendering: pixelated; }

	/* ── Lounge ── */
	.lounge-sofa {
		top: 95px; left: 20px;
		width: 80px; height: 28px;
		background: #3a3a5a;
		border-radius: 6px 6px 2px 2px;
		border-top: 4px solid #4a4a6a;
		box-shadow: 0 2px 0 #2a2a3a;
	}
	.lounge-sofa::before {
		content: '';
		position: absolute;
		top: -2px; left: 4px;
		width: 16px; height: 24px;
		background: #4a4a6a;
		border-radius: 4px 0 0 4px;
	}
	.lounge-sofa::after {
		content: '';
		position: absolute;
		top: -2px; right: 4px;
		width: 16px; height: 24px;
		background: #4a4a6a;
		border-radius: 0 4px 4px 0;
	}
	:global([data-theme="light"]) .lounge-sofa { background: #8b8ba0; border-top-color: #9a9ab0; }
	:global([data-theme="light"]) .lounge-sofa::before, :global([data-theme="light"]) .lounge-sofa::after { background: #9a9ab0; }

	.lounge-sofa2 {
		top: 123px; left: 30px;
		width: 60px; height: 20px;
		background: #3a3a5a;
		border-radius: 4px 4px 2px 2px;
		border-top: 3px solid #4a4a6a;
	}
	:global([data-theme="light"]) .lounge-sofa2 { background: #8b8ba0; border-top-color: #9a9ab0; }

	.coffee-table {
		top: 108px; left: 110px;
		width: 40px; height: 24px;
		background: #5c3d2e;
		border-top: 3px solid #7a5640;
		border-radius: 2px;
	}
	.coffee-table::before {
		content: '';
		position: absolute;
		top: -8px; left: 8px;
		width: 8px; height: 6px;
		background: #5c3d2e;
		border: 1px solid #3a2518;
		border-radius: 0 0 1px 1px;
	}
	.coffee-table::before {
		/* coffee cup on table */
		top: -10px; left: 10px;
		width: 8px; height: 8px;
		background: #5c3d2e;
		border: 1px solid #3a2518;
		border-radius: 0 0 2px 2px;
	}
	:global([data-theme="light"]) .coffee-table { background: #a07050; border-top-color: #c09070; }

	.coffee-machine {
		top: 78px; left: 170px;
		width: 24px; height: 32px;
		background: #2a2a3a;
		border: 2px solid #444;
		border-radius: 2px;
	}
	.coffee-machine::before {
		content: '';
		position: absolute;
		top: 4px; left: 4px;
		width: 14px; height: 8px;
		background: #5c3d2e;
		border-radius: 2px;
	}
	.coffee-machine::after {
		content: '';
		position: absolute;
		bottom: 4px; left: 50%; transform: translateX(-50%);
		width: 4px; height: 4px;
		background: #ef4444;
		border-radius: 50%;
		animation: coffee-light 2s ease-in-out infinite;
	}
	@keyframes coffee-light { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }
	:global([data-theme="light"]) .coffee-machine { background: #bbb; border-color: #999; }

	/* ── Command Center ── */
	.cmd-desk {
		top: 94px; right: 100px;
		width: 120px; height: 36px;
		background: #5c3d2e;
		border-top: 4px solid #7a5640;
		border-radius: 2px;
	}
	:global([data-theme="light"]) .cmd-desk { background: #a07050; border-top-color: #c09070; }
	.cmd-monitor {
		top: 68px; right: 140px;
		width: 40px; height: 28px;
		background: #1a1a2e;
		border: 2px solid #8953d1;
		border-radius: 3px;
	}
	.cmd-monitor::after {
		content: '';
		position: absolute;
		top: 3px; left: 3px; right: 3px; bottom: 3px;
		background: #8953d122;
		animation: screen-flicker 3s infinite;
	}
	.cmd-monitor2 {
		top: 72px; right: 106px;
		width: 32px; height: 24px;
		background: #1a1a2e;
		border: 2px solid #ff6b35;
		border-radius: 3px;
	}
	.cmd-monitor2::after {
		content: '';
		position: absolute;
		top: 3px; left: 3px; right: 3px; bottom: 3px;
		background: #ff6b3522;
		animation: screen-flicker 4s infinite;
	}
	:global([data-theme="light"]) .cmd-monitor, :global([data-theme="light"]) .cmd-monitor2 { background: #e0e0e0; }
	.cmd-chair {
		top: 132px; right: 140px;
		width: 28px; height: 16px;
		background: #333;
		border-radius: 50%;
		border-top: 2px solid #444;
	}

	/* ── Workstation desks (5 desks in a row) ── */
	.ws-desk {
		width: 80px; height: 28px;
		background: #5c3d2e;
		border-top: 3px solid #7a5640;
		border-radius: 2px;
	}
	:global([data-theme="light"]) .ws-desk { background: #a07050; border-top-color: #c09070; }
	.ws-monitor {
		width: 28px; height: 20px;
		background: #1a1a2e;
		border: 2px solid #555;
		border-radius: 2px;
	}
	.ws-monitor::after {
		content: '';
		position: absolute;
		top: 2px; left: 2px; right: 2px; bottom: 2px;
		background: #ffffff08;
		animation: screen-flicker 3s infinite;
	}
	:global([data-theme="light"]) .ws-monitor { background: #ddd; border-color: #999; }

	/* Position each desk — two rows */
	.ws-desk-1 { top: 205px; left: 200px; }
	.ws-mon-1  { top: 185px; left: 226px; border-color: #4a9e4a; }
	.ws-mon-1::after { background: #4a9e4a11; }
	.ws-desk-2 { top: 205px; left: 340px; }
	.ws-mon-2  { top: 185px; left: 366px; border-color: #4a8ab5; }
	.ws-mon-2::after { background: #4a8ab511; }
	.ws-desk-3 { top: 205px; left: 480px; }
	.ws-mon-3  { top: 185px; left: 506px; border-color: #7a7a8a; }
	.ws-mon-3::after { background: #7a7a8a11; }
	.ws-desk-4 { top: 270px; left: 260px; }
	.ws-mon-4  { top: 250px; left: 286px; border-color: #c54ab5; }
	.ws-mon-4::after { background: #c54ab511; }
	.ws-desk-5 { top: 270px; left: 420px; }
	.ws-mon-5  { top: 250px; left: 446px; border-color: #4ac5c5; }
	.ws-mon-5::after { background: #4ac5c511; }

	/* ── Plants ── */
	.plant {
		width: 16px; height: 24px;
		background: #5c3d2e;
		border-radius: 0 0 4px 4px;
		border-top: 3px solid #7a5640;
	}
	.plant::before {
		content: '';
		position: absolute;
		top: -12px; left: 50%; transform: translateX(-50%);
		width: 18px; height: 14px;
		background: radial-gradient(circle at 50% 80%, #2d6a2d 30%, #4a9e4a 70%, transparent 100%);
		border-radius: 50% 50% 30% 30%;
	}
	.plant-1 { top: 72px; left: 210px; }
	.plant-2 { top: 197px; left: 310px; }
	.plant-3 { top: 262px; left: 560px; }
	.plant-4 { bottom: 30px; left: 190px; }

	/* ── Arcade zone ── */
	.arcade-cabinet {
		bottom: 36px; left: 30px;
		width: 32px; height: 48px;
		background: linear-gradient(180deg, #2a2a4a 60%, #1a1a2e);
		border: 2px solid #8953d1;
		border-radius: 3px 3px 0 0;
	}
	.arcade-cabinet::before {
		content: '';
		position: absolute;
		top: 4px; left: 4px;
		width: 22px; height: 16px;
		background: #0a0a1e;
		border: 1px solid #4ade80;
		border-radius: 2px;
		animation: arcade-screen 1.5s steps(3) infinite;
	}
	.arcade-cabinet::after {
		content: '';
		position: absolute;
		bottom: 8px; left: 50%; transform: translateX(-50%);
		width: 6px; height: 6px;
		background: #ef4444;
		border-radius: 50%;
		box-shadow: 8px 0 0 #4ade80, -8px 0 0 #3498db;
	}
	@keyframes arcade-screen {
		0% { background: #0a0a1e; box-shadow: inset 0 0 4px #4ade8044; }
		33% { background: #0a1a0a; box-shadow: inset 0 0 6px #4ade8066; }
		66% { background: #0a0a1e; box-shadow: inset 0 0 4px #8953d144; }
	}
	:global([data-theme="light"]) .arcade-cabinet { background: linear-gradient(180deg, #888 60%, #777); border-color: #8953d1; }

	.pingpong-table {
		bottom: 44px; left: 80px;
		width: 80px; height: 40px;
		background: #1a5a3a;
		border: 2px solid #2a7a4a;
		border-radius: 2px;
	}
	.pingpong-table::before {
		/* net */
		content: '';
		position: absolute;
		top: 0; left: 50%; transform: translateX(-50%);
		width: 2px; height: 100%;
		background: #ffffff44;
	}
	.pingpong-table::after {
		/* ball */
		content: '';
		position: absolute;
		top: 10px; right: 12px;
		width: 4px; height: 4px;
		background: #fff;
		border-radius: 50%;
		animation: pp-ball 2s ease-in-out infinite;
	}
	@keyframes pp-ball {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(-40px, 8px); }
	}
	:global([data-theme="light"]) .pingpong-table { background: #2a8a5a; border-color: #3aaa6a; }

	@keyframes screen-flicker {
		0%, 90%, 100% { opacity: 1; }
		92% { opacity: 0.6; }
	}

	/* ══════════════════════════════════════════════════════════════
	   AGENT SPRITE WRAPPERS — positioned in the office
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite-wrap {
		position: absolute;
		z-index: 10;
		cursor: pointer;
		transition: left 0.5s ease, top 0.5s ease, opacity 0.4s ease;
	}
	.agent-sprite-wrap:hover { z-index: 20; }
	.agent-sprite-wrap:hover .sprite-label { opacity: 1; }

	/* Sprite label (name + dot) */
	.sprite-label {
		position: absolute;
		bottom: -16px; left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 3px;
		white-space: nowrap;
		opacity: 0.7;
		transition: opacity 0.2s;
		pointer-events: none;
	}
	.sprite-name {
		font-family: serif;
		font-size: 8px;
		color: #ccc;
		letter-spacing: 0.02em;
	}
	:global([data-theme="light"]) .sprite-name { color: #555; }
	.sprite-status-dot {
		width: 5px; height: 5px;
		border-radius: 50%;
		background: #666;
		flex-shrink: 0;
	}
	.sprite-status-dot.idle { background: #4ade80; }
	.sprite-status-dot.busy { background: #f59e0b; animation: pulse-dot 1.5s infinite; }
	.sprite-status-dot.error { background: #a78bfa; }
	.sprite-status-dot.offline { background: #666; }

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

