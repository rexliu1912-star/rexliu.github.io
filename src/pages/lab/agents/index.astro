	/* ══════════════════════════════════════════════════════════════
	   ANIMATIONS — Idle Breathe (universal)
	   ══════════════════════════════════════════════════════════════ */
	@keyframes idle-breathe {
		0%, 100% { transform: translateY(0); }
		25% { transform: translateY(-1px); }
		50% { transform: translateY(-1px); }
		75% { transform: translateY(0); }
	}
	.agent-sprite[data-state="idle"] .pixel-char,
	.agent-sprite[data-state="error"] .pixel-char {
		animation: idle-breathe 1s steps(4) infinite;
	}

	/* ── Personalized Idle Animations ─────────────────────────── */

	/* Samantha: idle-coffee — cup lifts up, steam puffs */
	@keyframes anim-coffee {
		0%, 12% { transform: translateY(0); }
		25%, 37% { transform: translateY(-2px); }
		50%, 62% { transform: translateY(-1px); }
		75%, 87% { transform: translateY(0); }
	}
	.agent-sprite.playing-idle-coffee .px-accessory {
		animation: anim-coffee 2s steps(1) 1;
	}
	.agent-sprite.playing-idle-coffee .px-accessory::after {
		width: 3px; height: 3px;
		border-top: none;
		background: #ffffff44;
		border-radius: 50%;
		animation: steam-puff 0.5s steps(2) infinite;
	}

	/* Samantha: idle-phone — head tilts down */
	@keyframes anim-phone-head {
		0%, 100% { transform: rotate(0); }
		20%, 80% { transform: rotate(5deg); }
	}
	.agent-sprite.playing-idle-phone .px-head {
		animation: anim-phone-head 1.5s steps(1) 1;
	}
	.agent-sprite.playing-idle-phone .px-accessory {
		top: 14px; right: 6px;
		width: 3px; height: 5px;
		background: #333;
		border: 1px solid #555;
		border-radius: 1px;
	}
	.agent-sprite.playing-idle-phone .px-accessory::after {
		content: '';
		position: absolute;
		top: 1px; left: 1px;
		width: 1px; height: 1px;
		background: #4ade80;
		animation: phone-blink 0.4s steps(2) infinite;
	}

	/* Loki: idle-read — book opens */
	@keyframes anim-read-body {
		0%, 100% { transform: none; }
		33%, 66% { transform: rotate(-3deg); }
	}
	.agent-sprite.playing-idle-read .pixel-char {
		animation: anim-read-body 1.5s steps(1) 1 !important;
	}
	.agent-sprite.playing-idle-read .idle-effect::before {
		content: '';
		position: absolute;
		top: 14px; right: 2px;
		width: 6px; height: 4px;
		background: #f5f5dc;
		border: 1px solid #ccc;
		border-radius: 0 1px 1px 0;
		animation: book-open 1.5s steps(3) 1;
	}

	/* Loki: idle-plot — crossed arms + lightbulb */
	.agent-sprite.playing-idle-plot .idle-effect::before {
		content: '💡';
		position: absolute;
		top: -2px; right: 4px;
		font-size: 6px;
		animation: bulb-pop 1.5s steps(1) 1;
		opacity: 0;
	}
	@keyframes bulb-pop {
		0%, 40% { opacity: 0; transform: translateY(0); }
		50%, 90% { opacity: 1; transform: translateY(-2px); }
		100% { opacity: 0; }
	}
	.agent-sprite.playing-idle-plot .px-mouth {
		width: 5px;
		border-radius: 0 0 2px 0;
		background: #c8887a;
	}

	/* Vision: idle-telescope — lean forward */
	@keyframes anim-telescope {
		0%, 100% { transform: translateX(0) rotate(0); }
		25%, 62% { transform: translateX(-2px) rotate(-5deg); }
		75% { transform: translateX(0) rotate(0); }
	}
	.agent-sprite.playing-idle-telescope .pixel-char {
		animation: anim-telescope 2s steps(1) 1 !important;
	}
	.agent-sprite.playing-idle-telescope .idle-effect::before {
		content: '✨';
		position: absolute;
		top: 6px; left: 0;
		font-size: 5px;
		animation: sparkle 0.6s steps(2) infinite;
	}

	/* Vision: idle-think — ? → ! bubble */
	.agent-sprite.playing-idle-think .idle-effect::before {
		content: '?';
		position: absolute;
		top: -2px; left: 50%;
		font-size: 8px;
		font-family: monospace;
		font-weight: bold;
		color: #4a8ab5;
		animation: think-swap 1s steps(1) 1;
	}
	@keyframes think-swap {
		0%, 40% { content: '?'; color: #4a8ab5; }
		50%, 90% { content: '!'; color: #4ade80; }
		100% { opacity: 0; }
	}

	/* Jarvis: idle-tinker — hands fiddle with part */
	@keyframes anim-tinker {
		0%, 100% { transform: translateY(0); }
		16%, 50% { transform: translateY(-1px) rotate(10deg); }
		66%, 83% { transform: translateY(0) rotate(-5deg); }
	}
	.agent-sprite.playing-idle-tinker .idle-effect::before {
		content: '';
		position: absolute;
		top: 18px; right: 6px;
		width: 3px; height: 3px;
		background: #aaa;
		border: 1px solid #888;
		animation: anim-tinker 1s steps(1) 1;
	}
	.agent-sprite.playing-idle-tinker .idle-effect::after {
		content: '';
		position: absolute;
		top: 17px; right: 4px;
		width: 1px; height: 1px;
		background: #ffd700;
		box-shadow: 2px -1px 0 #ffd700;
		animation: spark-flash 0.3s steps(2) infinite;
	}

	/* Jarvis: idle-headbang — head sways */
	@keyframes anim-headbang {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-1px); }
		75% { transform: translateX(1px); }
	}
	.agent-sprite.playing-idle-headbang .px-head {
		animation: anim-headbang 0.5s steps(2) 2;
	}
	.agent-sprite.playing-idle-headbang .px-headphones {
		top: 6px; /* headphones on head */
	}
	.agent-sprite.playing-idle-headbang .idle-effect::before {
		content: '♪';
		position: absolute;
		top: 0; right: 2px;
		font-size: 6px;
		color: #4ade80;
		animation: note-float 1s ease-out 1;
	}

	/* Shuri: idle-doodle — colorful trail */
	.agent-sprite.playing-idle-doodle .idle-effect::before {
		content: '';
		position: absolute;
		top: 10px; left: 2px;
		width: 2px; height: 2px;
		background: #e74c3c;
		border-radius: 50%;
		box-shadow:
			3px 2px 0 #3498db,
			6px -1px 0 #f39c12,
			9px 3px 0 #2ecc71,
			12px 0 0 #c54ab5;
		animation: doodle-trail 1.3s steps(4) 1;
	}
	@keyframes doodle-trail {
		0% { opacity: 0; clip-path: inset(0 100% 0 0); }
		20% { opacity: 1; clip-path: inset(0 80% 0 0); }
		40% { clip-path: inset(0 60% 0 0); }
		60% { clip-path: inset(0 30% 0 0); }
		80% { clip-path: inset(0 0 0 0); }
		100% { opacity: 0; }
	}

	/* Shuri: idle-palette — mix and flick */
	@keyframes anim-palette-mix {
		0%, 100% { transform: rotate(0); }
		25% { transform: rotate(10deg); }
		50% { transform: rotate(-10deg); }
		75% { transform: rotate(5deg); }
	}
	.agent-sprite.playing-idle-palette .px-accessory {
		animation: anim-palette-mix 1s steps(1) 1;
	}
	.agent-sprite.playing-idle-palette .idle-effect::before {
		content: '';
		position: absolute;
		top: 8px; right: 2px;
		width: 2px; height: 2px;
		background: #e74c3c;
		border-radius: 50%;
		animation: paint-flick 1s steps(1) 1;
	}
	@keyframes paint-flick {
		0%, 70% { opacity: 0; }
		75% { opacity: 1; transform: translate(0, 0); }
		100% { opacity: 0; transform: translate(4px, -4px); }
	}

	/* Friday: idle-data — tablet lights up, data scroll */
	.agent-sprite.playing-idle-data .px-accessory {
		background: #0a1a2e;
		border-color: #4ac5c5;
		box-shadow: 0 0 3px #4ac5c5;
	}
	.agent-sprite.playing-idle-data .px-accessory::after {
		background: #4ac5c5;
		height: 5px;
		animation: data-scroll 1s steps(3) 1;
	}
	@keyframes data-scroll {
		0% { transform: translateY(3px); opacity: 0.3; }
		50% { transform: translateY(0); opacity: 1; }
		100% { transform: translateY(-3px); opacity: 0; }
	}

	/* Friday: idle-stretch — body stretches up */
	@keyframes anim-stretch {
		0%, 100% { transform: scaleY(1) translateY(0); }
		30%, 60% { transform: scaleY(1.05) translateY(-2px); }
	}
	.agent-sprite.playing-idle-stretch .pixel-char {
		animation: anim-stretch 1s steps(2) 1 !important;
	}
	.agent-sprite.playing-idle-stretch .px-mouth {
		width: 4px; height: 3px;
		border-radius: 50%;
		background: #c8887a;
	}

	/* ── Small helper animations ──────────────────────────────── */
	@keyframes steam { from { opacity: 0.4; transform: translateY(0); } to { opacity: 0; transform: translateY(-3px); } }
	@keyframes steam-puff { 0% { opacity: 0.6; transform: scale(1); } 100% { opacity: 0; transform: scale(1.5) translateY(-2px); } }
	@keyframes phone-blink { 0% { background: #4ade80; } 100% { background: #3498db; } }
	@keyframes book-open { 0% { width: 3px; } 50% { width: 6px; } 100% { width: 3px; opacity: 0; } }
	@keyframes sparkle { 0% { opacity: 1; } 100% { opacity: 0.3; } }
	@keyframes spark-flash { 0% { opacity: 1; } 100% { opacity: 0; } }
	@keyframes note-float { 0% { opacity: 1; transform: translateY(0); } 100% { opacity: 0; transform: translateY(-8px); } }
	@keyframes data-flow { 0% { opacity: 0.3; } 50% { opacity: 1; } 100% { opacity: 0.3; } }

	/* ══════════════════════════════════════════════════════════════
	   BUSY STATE — at desk, working animation
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite[data-state="busy"] .pixel-char {
		animation: work-bob 0.8s steps(2) infinite;
	}
	@keyframes work-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-2px); }
	}

	/* Busy: Samantha — coordinating, typing */
	.room-samantha .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		bottom: 8px; left: 4px;
		width: 10px; height: 2px;
		background: #ff6b35;
		animation: type-hands 0.3s steps(2) infinite;
	}
	@keyframes type-hands { 0% { transform: translateX(0); } 100% { transform: translateX(2px); } }

	/* Busy: Loki — typing on typewriter */
	.room-loki .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		top: 4px; left: 0;
		width: 2px; height: 2px;
		background: #fff;
		animation: letter-fly 0.8s steps(4) infinite;
	}
	@keyframes letter-fly {
		0% { transform: translateY(0); opacity: 1; }
		100% { transform: translateY(-10px); opacity: 0; }
	}

	/* Busy: Vision — dual screen browsing */
	.room-vision .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		top: 8px; right: 2px;
		width: 4px; height: 4px;
		background: #4a8ab5;
		border-radius: 50%;
		animation: magnify-pulse 1s steps(2) infinite;
	}
	@keyframes magnify-pulse { 0% { transform: scale(1); } 100% { transform: scale(1.3); opacity: 0.5; } }

	/* Busy: Jarvis — keyboard mashing, green code rain */
	.room-jarvis .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		top: 2px; left: 8px;
		width: 1px; height: 4px;
		background: #0f0;
		box-shadow: 3px 2px 0 #0f0, 6px -1px 0 #0f0, 9px 3px 0 #0f0, 12px 1px 0 #0f0;
		animation: code-rain 0.6s steps(3) infinite;
	}
	@keyframes code-rain { 0% { transform: translateY(-4px); opacity: 0; } 50% { opacity: 1; } 100% { transform: translateY(4px); opacity: 0; } }

	/* Busy: Shuri — brush strokes on canvas */
	.room-shuri .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		top: 10px; left: 2px;
		width: 8px; height: 2px;
		background: linear-gradient(90deg, #e74c3c, #8953d1, #3498db);
		animation: brush-stroke 0.8s steps(3) infinite alternate;
	}
	@keyframes brush-stroke { 0% { width: 2px; } 100% { width: 10px; } }

	/* Busy: Friday — chart bars growing */
	.room-friday .agent-sprite[data-state="busy"] .idle-effect::before {
		content: '';
		position: absolute;
		bottom: 8px; left: 4px;
		width: 2px; height: 4px;
		background: #4ac5c5;
		box-shadow: 3px 0 0 #4ac5c5, 6px 2px 0 #4ac5c5, 9px -1px 0 #4ac5c5;
		animation: chart-grow 1s steps(3) infinite;
	}
	@keyframes chart-grow {
		0% { height: 2px; }
		50% { height: 6px; }
		100% { height: 2px; }
	}

	/* ══════════════════════════════════════════════════════════════
	   OFFLINE STATE — grayscale + ZZZ
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite[data-state="offline"] .pixel-char {
		filter: grayscale(80%) opacity(0.5);
		animation: none;
		transform: translateY(1px);
	}
	.zzz-bubble {
		display: none;
		position: absolute;
		right: 20px; bottom: 60px;
		z-index: 15;
		font-family: monospace;
		font-weight: bold;
		color: #4a8ab544;
	}
	.agent-sprite[data-state="offline"] ~ .zzz-bubble {
		display: block;
	}
	.zzz-bubble::before {
		content: 'z';
		position: absolute;
		bottom: 0; right: 0;
		font-size: 6px;
		animation: zzz-float 2s steps(3) infinite;
	}
	.zzz-bubble::after {
		content: 'Z';
		position: absolute;
		bottom: 6px; right: 4px;
		font-size: 8px;
		animation: zzz-float 2s steps(3) infinite 0.5s;
	}
	@keyframes zzz-float {
		0% { opacity: 0; transform: translateY(0); }
		30% { opacity: 0.6; }
		100% { opacity: 0; transform: translateY(-8px); }
	}

	/* ══════════════════════════════════════════════════════════════
	   ERROR STATE — blink + confusion + red particles
	   ══════════════════════════════════════════════════════════════ */
	.agent-sprite[data-state="error"] .pixel-char {
		animation: error-blink 0.5s steps(2) infinite !important;
	}
	@keyframes error-blink {
		0%, 100% { filter: none; }
		50% { filter: brightness(1.3) hue-rotate(-20deg); }
	}
	/* Confused face overlay */
	.agent-sprite[data-state="error"] .state-overlay::before {
		content: '!';
		position: absolute;
		top: -2px; left: 50%; transform: translateX(-50%);
		font-size: 8px;
		font-weight: bold;
		font-family: monospace;
		color: #ef4444;
		animation: error-mark 1s steps(2) infinite;
	}
	@keyframes error-mark {
		0%, 49% { content: '!'; }
		50%, 99% { content: '?'; }
	}
	/* Red particles */
	.error-particles {
		display: none;
		position: absolute;
		right: 10px; bottom: 30px;
		z-index: 15;
	}
	.agent-sprite[data-state="error"] ~ .error-particles {
		display: block;
	}
	.error-particles::before, .error-particles::after {
		content: '';
		position: absolute;
		width: 2px; height: 2px;
		background: #ef4444;
		border-radius: 50%;
	}
	.error-particles::before {
		animation: err-particle-1 1.2s steps(3) infinite;
	}
	.error-particles::after {
		animation: err-particle-2 1.5s steps(3) infinite 0.3s;
	}
	@keyframes err-particle-1 {
		0% { transform: translate(0, 0); opacity: 1; }
		100% { transform: translate(-6px, -12px); opacity: 0; }
	}
	@keyframes err-particle-2 {
		0% { transform: translate(8px, 0); opacity: 1; }
		100% { transform: translate(14px, -10px); opacity: 0; }
	}

	/* ══════════════════════════════════════════════════════════════
	   TASK BUBBLE
	   ══════════════════════════════════════════════════════════════ */
	.task-bubble {
		position: absolute;
		top: 8px; left: 50%; transform: translateX(-50%);
		max-width: 90%;
		padding: 4px 8px;
		background: #8953d1dd;
		color: white;
		font-family: serif;
		font-size: 10px;
		line-height: 1.3;
		border-radius: 4px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		z-index: 20;
		animation: bubble-in 0.3s ease-out;
	}
	.task-bubble::after {
		content: '';
		position: absolute;
		bottom: -4px; left: 50%; transform: translateX(-50%);
		width: 0; height: 0;
		border-left: 4px solid transparent;
		border-right: 4px solid transparent;
		border-top: 4px solid #8953d1dd;
	}
	@keyframes bubble-in {
		from { opacity: 0; transform: translateX(-50%) translateY(-4px); }
		to { opacity: 1; transform: translateX(-50%) translateY(0); }
	}

	/* ── Animation pause for off-screen (via JS class) ────────── */
	.agent-room.paused .agent-sprite,
	.agent-room.paused .agent-sprite *,
	.agent-room.paused .zzz-bubble,
	.agent-room.paused .zzz-bubble *,
	.agent-room.paused .error-particles,
	.agent-room.paused .error-particles *,
	.agent-room.paused .room-furniture *,
	.agent-room.paused .idle-effect,
	.agent-room.paused .idle-effect * {
		animation-play-state: paused !important;
	}
</style>

<script is:inline>
	(function() {
		var CONVEX_URL = 'https://fleet-heron-880.convex.cloud';
		var statusEl = document.getElementById('connection-status');

		/* ── Idle Animation Controller ────────────────────────── */
		var IDLE_VARIANTS = {
			main:       ['idle-coffee', 'idle-phone'],
			writer:     ['idle-read', 'idle-plot'],
			researcher: ['idle-telescope', 'idle-think'],
			coder:      ['idle-tinker', 'idle-headbang'],
			designer:   ['idle-doodle', 'idle-palette'],
			analyst:    ['idle-data', 'idle-stretch']
		};
		var VARIANT_DURATIONS = {
			'idle-coffee': 2000, 'idle-phone': 1500,
			'idle-read': 1500, 'idle-plot': 1500,
			'idle-telescope': 2000, 'idle-think': 1000,
			'idle-tinker': 1000, 'idle-headbang': 1000,
			'idle-doodle': 1300, 'idle-palette': 1000,
			'idle-data': 1000, 'idle-stretch': 1000
		};

		var controllers = {};

		function IdleController(room, agentId) {
			this.room = room;
			this.sprite = room.querySelector('.agent-sprite');
			this.agentId = agentId;
			this.variants = IDLE_VARIANTS[agentId] || [];
			this.timer = null;
			this.playing = false;
		}
		IdleController.prototype.start = function() {
			this.stop();
			this.clearVariantClass();
			this.scheduleTick();
		};
		IdleController.prototype.stop = function() {
			if (this.timer) { clearTimeout(this.timer); this.timer = null; }
			this.clearVariantClass();
			this.playing = false;
		};
		IdleController.prototype.clearVariantClass = function() {
			var sp = this.sprite;
			this.variants.forEach(function(v) { sp.classList.remove('playing-' + v); });
		};
		IdleController.prototype.scheduleTick = function() {
			var self = this;
			var delay = 8000 + Math.random() * 7000;
			this.timer = setTimeout(function() { self.tick(); }, delay);
		};
		IdleController.prototype.tick = function() {
			var state = this.sprite.getAttribute('data-state');
			if (state !== 'idle') { this.scheduleTick(); return; }

			if (Math.random() < 0.4 && this.variants.length > 0) {
				var v = this.variants[Math.floor(Math.random() * this.variants.length)];
				var dur = VARIANT_DURATIONS[v] || 1500;
				var self = this;
				this.playing = true;
				this.sprite.classList.add('playing-' + v);

				this.timer = setTimeout(function() {
					self.sprite.classList.remove('playing-' + v);
					self.playing = false;
					self.scheduleTick();
				}, dur);
			} else {
				this.scheduleTick();
			}
		};

		/* ── Initialize Idle Controllers ──────────────────────── */
		document.querySelectorAll('.agent-room').forEach(function(room) {
			var agentId = room.getAttribute('data-agent');
			var ctrl = new IdleController(room, agentId);
			controllers[agentId] = ctrl;
			ctrl.start();
		});

		/* ── Intersection Observer for perf ───────────────────── */
		if ('IntersectionObserver' in window) {
			var io = new IntersectionObserver(function(entries) {
				entries.forEach(function(entry) {
					if (entry.isIntersecting) {
						entry.target.classList.remove('paused');
					} else {
						entry.target.classList.add('paused');
					}
				});
			}, { rootMargin: '100px' });
			document.querySelectorAll('.agent-room').forEach(function(room) { io.observe(room); });
		}

		/* ── Convex Polling (unchanged logic) ─────────────────── */
		function updateRoom(agent) {
			var room = document.querySelector('[data-agent="' + agent.agentId + '"]');
			if (!room) return;

			var sprite = room.querySelector('.agent-sprite');
			var dot = room.querySelector('.agent-status-dot');
			var bubble = room.querySelector('.task-bubble');
			var status = agent.status || 'offline';

			if (sprite) {
				var prev = sprite.getAttribute('data-state');
				sprite.setAttribute('data-state', status);
				// Restart idle controller when transitioning to idle
				if (status === 'idle' && prev !== 'idle' && controllers[agent.agentId]) {
					controllers[agent.agentId].start();
				}
				if (status !== 'idle' && controllers[agent.agentId]) {
					controllers[agent.agentId].stop();
				}
			}
			if (dot) dot.className = 'agent-status-dot ' + status;

			if (bubble) {
				if (agent.currentTask && status === 'busy') {
					bubble.textContent = agent.currentTask;
					bubble.style.display = 'block';
				} else {
					bubble.style.display = 'none';
				}
			}
		}

		function setOffline() {
			document.querySelectorAll('.agent-room').forEach(function(room) {
				var dot = room.querySelector('.agent-status-dot');
				var sprite = room.querySelector('.agent-sprite');
				if (dot) dot.className = 'agent-status-dot offline';
				if (sprite) sprite.setAttribute('data-state', 'offline');
			});
			if (statusEl) {
				statusEl.innerHTML = '<span class="lang-en" style="color:#ef4444">\u26a0 Offline</span><span class="lang-zh" style="color:#ef4444">\u26a0 离线</span>';
			}
		}

		async function pollAgents() {
			try {
				var resp = await fetch(CONVEX_URL + '/api/query', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ path: 'agents:list', args: {} })
				});
				var data = await resp.json();
				var agents = data.value || [];
				if (statusEl) {
					statusEl.innerHTML = '<span class="lang-en" style="color:#4ade80">\u25cf Live</span><span class="lang-zh" style="color:#4ade80">\u25cf 实时</span>';
				}
				agents.forEach(updateRoom);
			} catch (e) {
				console.error('Convex poll failed:', e);
				setOffline();
			}
		}

		pollAgents();
		setInterval(pollAgents, 10000);
	})();
</script>
