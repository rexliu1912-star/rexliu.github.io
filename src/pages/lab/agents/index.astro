		var ACTIVITY_FEED = [];
		var overlay = document.getElementById('agent-detail');
		var closeBtn = document.getElementById('detail-close');

		function openDetail(agentId) {
			var d = AGENT_DATA[agentId];
			if (!d || !overlay) return;
			var isZh = document.documentElement.getAttribute('data-lang') === 'zh';

			document.getElementById('detail-dot').style.background = d.color;
			document.getElementById('detail-dot').style.boxShadow = '0 0 8px ' + d.color + '88';
			document.getElementById('detail-name').textContent = d.name;
			document.getElementById('detail-role').textContent = d.role;
			document.getElementById('detail-desc').textContent = isZh ? d.descZh : d.descEn;

			var statsEl = document.getElementById('detail-stats');
			if (statsEl) {
				statsEl.textContent = isZh ? (d.statsZh || '') : (d.statsEn || '');
				statsEl.style.color = d.color;
			}

			var ul = document.getElementById('detail-examples');
			ul.innerHTML = '';
			var examples = isZh ? d.examplesZh : d.examplesEn;
			examples.forEach(function(ex) {
				var li = document.createElement('li');
				li.textContent = ex;
				ul.appendChild(li);
			});

			var latestEl = document.getElementById('detail-latest');
			var agentActivities = ACTIVITY_FEED.filter(function(e) { return e.agentId === agentId; }).slice(0, 3);
			if (agentActivities.length > 0) {
				var heading = isZh ? '<strong>\u6700\u8fd1\u52a8\u6001</strong>' : '<strong>Recent</strong>';
				latestEl.innerHTML = heading + '<ul class="detail-recent-list">' +
					agentActivities.map(function(a) {
						var text = isZh ? a.descZh : a.descEn;
						return '<li><span class="detail-recent-time">' + a.time + '</span> ' + text + '</li>';
					}).join('') + '</ul>';
				latestEl.style.display = 'block';
			} else {
				latestEl.style.display = 'none';
			}

			overlay.classList.add('is-open');
			overlay.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		}

		function closeDetail() {
			if (!overlay) return;
			overlay.classList.remove('is-open');
			overlay.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		}

		closeBtn && closeBtn.addEventListener('click', closeDetail);
		overlay && overlay.addEventListener('click', function(e) {
			if (e.target === overlay) closeDetail();
		});
		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') closeDetail();
		});

		/* ══════════════════════════════════════════════════════════════
		   ACTIVITY FEED
		   ══════════════════════════════════════════════════════════════ */
		var feedList = document.getElementById('activity-feed-list');

		function timeAgo(isoStr) {
			try {
				var d = new Date(isoStr);
				var diff = Date.now() - d.getTime();
				var m = Math.floor(diff / 60000);
				if (m < 2) return 'just now';
				if (m < 60) return m + 'm ago';
				var h = Math.floor(diff / 3600000);
				if (h < 24) return h + 'h ago';
				return Math.floor(h / 24) + 'd ago';
			} catch (e) { return ''; }
		}

		function renderFeed(entries) {
			if (!feedList) return;
			if (!entries || entries.length === 0) {
				feedList.innerHTML = '<div class="feed-empty font-serif text-xs text-gray-500"><span class="lang-en">No recent activity</span><span class="lang-zh">\u6682\u65e0\u52a8\u6001</span></div>';
				return;
			}
			// Deduplicate: if two entries from same agent within 10s, keep the one with distinct EN/ZH
			var deduped = [];
			for (var i = 0; i < entries.length; i++) {
				var e = entries[i];
				var dominated = false;
				for (var j = 0; j < deduped.length; j++) {
					var d = deduped[j];
					if (d.agentId === e.agentId && Math.abs(new Date(d.timestamp) - new Date(e.timestamp)) < 10000) {
						// Keep the one where descEn != descZh (properly translated)
						if (d.descEn === d.descZh && e.descEn !== e.descZh) { deduped[j] = e; }
						dominated = true; break;
					}
				}
				if (!dominated) deduped.push(e);
			}
			entries = deduped;
			var isZh = document.documentElement.getAttribute('data-lang') === 'zh';
			feedList.innerHTML = entries.map(function(e) {
				var desc = isZh ? (e.descZh || e.descEn) : (e.descEn || e.descZh);
				return '<div class="feed-item">' +
					'<div class="feed-dot" style="background:' + e.color + ';box-shadow:0 0 6px ' + e.color + '66"></div>' +
					'<div class="feed-content">' +
						'<span class="feed-agent font-serif text-xs font-bold" style="color:' + e.color + '">' + e.agentName + '</span>' +
						'<span class="feed-desc font-serif text-sm text-gray-600 dark:text-gray-400">' + desc + '</span>' +
					'</div>' +
					'<span class="feed-time font-serif text-xs text-gray-400 shrink-0">' + timeAgo(e.timestamp) + '</span>' +
				'</div>';
			}).join('');

			ACTIVITY_FEED = entries.map(function(e) {
				return {
					agentId:   e.agentId,
					agentName: e.agentName,
					descEn:    e.descEn,
					descZh:    e.descZh,
					color:     e.color,
					time:      timeAgo(e.timestamp)
				};
			});
		}

		async function fetchActivity() {
			try {
				var controller = new AbortController();
				var timeout = setTimeout(function() { controller.abort(); }, 5000);
				var resp = await fetch(CONVEX_ACTIVITY_URL + '/api/query', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ path: 'activity:recent', args: { limit: 10 }, format: 'json' }),
					signal: controller.signal
				});
				clearTimeout(timeout);
				var data = await resp.json();
				if (data.status === 'success' && data.value) {
					renderFeed(data.value);
				}
			} catch (e) {
				console.error('Activity feed fetch failed:', e);
				if (feedList && feedList.querySelector('.feed-loading')) {
					feedList.innerHTML = '<div class="feed-empty font-serif text-xs text-gray-500"><span class="lang-en">Unable to load \u2014 will retry</span><span class="lang-zh">\u52a0\u8f7d\u5931\u8d25\uff0c\u7a0d\u540e\u91cd\u8bd5</span></div>';
				}
			}
		}

		fetchActivity();
		_intervals.push(setInterval(fetchActivity, 30000));

		/* ══════════════════════════════════════════════════════════════
		   RESPONSIVE SCALE
		   ══════════════════════════════════════════════════════════════ */
		function scalePixelOffice() {
			var wrapper = document.getElementById('pixel-office-wrapper');
			var office = document.getElementById('pixel-office');
			if (!wrapper || !office) return;
			var containerWidth = wrapper.clientWidth;
			var officeWidth = 960;
			var scale = Math.min(1, containerWidth / officeWidth);
			office.style.transform = scale < 1 ? 'scale(' + scale + ')' : '';
			var officeHeight = 528;
			wrapper.style.height = scale < 1 ? Math.round(officeHeight * scale) + 'px' : '';
		}

		scalePixelOffice();
		window.addEventListener('resize', scalePixelOffice);

	} /* end initAgentPage */

	/* ── Bootstrap ── */
	initAgentPage();

	document.addEventListener('astro:page-load', function() {
		if (document.getElementById('office-canvas')) {
			initAgentPage();
		}
	});

})();
</script>
