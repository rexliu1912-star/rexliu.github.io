---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

export const getStaticPaths = (async () => {
	const digests = await getCollection("digest");
	return digests.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const formatCustomDate = (date: Date) => {
	const day = date.getDate();
	const month = date.toLocaleDateString("en-US", { month: "short" });
	const year = date.getFullYear();
	const getOrdinal = (n: number) => {
		const s = ["th", "st", "nd", "rd"];
		const v = n % 100;
		return s[(v - 20) % 10] || s[v] || s[0];
	};
	return `${month} ${day}${getOrdinal(day)} ${year}`;
};

const meta = {
	title: `${entry.data.title} — Digest`,
	description: entry.data.summary || entry.data.title,
};
---

<PageLayout meta={meta}>
	<div class="mb-16 sm:mt-8">
		<div class="mb-8">
			<button
				onclick="history.back()"
				class="group flex items-center gap-1 font-serif text-sm text-gray-500 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><polyline points="15 18 9 12 15 6"></polyline></svg>
				Back
			</button>
		</div>

		<article class="flex flex-col gap-4">
			<h1 class="font-serif text-3xl leading-tight font-bold text-black sm:text-4xl dark:text-white">
				{entry.data.title}
			</h1>

			{entry.data.summary && (
				<p class="font-serif text-lg leading-relaxed text-gray-500 dark:text-gray-400">
					{entry.data.summary}
				</p>
			)}

			<div class="mt-2 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
				<time datetime={entry.data.date.toISOString()}>
					{formatCustomDate(entry.data.date)}
				</time>

				{entry.data.source && entry.data.source_name && (
					<>
						<span>·</span>
						<a href={entry.data.source} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-serif underline decoration-dotted underline-offset-4 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]">
							{entry.data.source_name}
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
						</a>
					</>
				)}

				{entry.data.tags.length > 0 && (
					<>
						<span>·</span>
						<div class="flex items-center gap-3">
							{entry.data.tags.map((tag: string) => (
								<span class="capitalize before:content-['#']">{tag}</span>
							))}
						</div>
					</>
				)}
			</div>

			<hr class="my-8 border-dashed border-gray-200 dark:border-gray-700" />

			<div class="prose prose-lg prose-serif dark:prose-invert max-w-none font-serif">
				<Content />
			</div>
		</article>
	</div>
</PageLayout>
