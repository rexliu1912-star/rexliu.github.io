---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";
import TelegramCTA from "@/components/TelegramCTA.astro";
import RelatedEssays from "@/components/RelatedEssays.astro";

export const getStaticPaths = (async () => {
	const digests = await getCollection("digest");
	return digests.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const formatCustomDate = (date: Date) => {
	const day = date.getDate();
	const month = date.toLocaleDateString("en-US", { month: "short" });
	const year = date.getFullYear();
	const getOrdinal = (n: number) => {
		const s = ["th", "st", "nd", "rd"];
		const v = n % 100;
		return s[(v - 20) % 10] || s[v] || s[0];
	};
	return `${month} ${day}${getOrdinal(day)} ${year}`;
};

// OG meta: Chinese-first for share cards
const ogTitle = entry.data.title_zh || entry.data.title;
const ogDesc = entry.data.summary_zh || entry.data.summary || entry.data.title;

const meta = {
	title: `${ogTitle} — Digest`,
	description: ogDesc,
};
---

<PageLayout meta={meta}>
	<div class="mb-16 sm:mt-8">
		<div class="mb-8">
			<button
				onclick="history.back()"
				class="group flex items-center gap-1 font-serif text-sm text-gray-500 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><polyline points="15 18 9 12 15 6"></polyline></svg>
				<span class="lang-en">Back</span><span class="lang-zh">返回</span>
			</button>
		</div>

		<article class="flex flex-col gap-4">
			<h1 class="font-serif text-3xl leading-tight font-bold text-black sm:text-4xl dark:text-white">
				<span class="lang-en">{entry.data.title}</span><span class="lang-zh">{entry.data.title_zh || entry.data.title}</span>
			</h1>

			{entry.data.summary && (
				<p class="font-serif text-lg leading-relaxed text-gray-500 dark:text-gray-400">
					<span class="lang-en">{entry.data.summary}</span><span class="lang-zh">{entry.data.summary_zh || entry.data.summary}</span>
				</p>
			)}

			<div class="mt-2 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
				<time datetime={entry.data.date.toISOString()}>
					{formatCustomDate(entry.data.date)}
				</time>

				{entry.data.source && entry.data.source_name && (
					<>
						<span>·</span>
						<a href={entry.data.source} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-serif underline decoration-dotted underline-offset-4 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]">
							{entry.data.source_name}
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
						</a>
					</>
				)}

				{entry.data.tags.length > 0 && (
					<>
						<span>·</span>
						<div class="flex items-center gap-3">
							{entry.data.tags.map((tag: string) => (
								<span class="capitalize before:content-['#']">{tag}</span>
							))}
						</div>
					</>
				)}

				<span>·</span>
				<button
					id="share-btn"
					class="inline-flex items-center text-gray-400 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
					title="Copy link"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
				</button>
				<span id="share-toast" class="font-serif text-xs text-[#8953d1] opacity-0 transition-opacity duration-300">✓</span>
			</div>

			<hr class="my-8 border-dashed border-gray-200 dark:border-gray-700" />

			<div class="prose prose-lg prose-serif dark:prose-invert max-w-none font-serif">
				<Content />
			</div>

			<RelatedEssays tags={entry.data.tags} />

			<TelegramCTA />
		</article>
	</div>
<script is:inline>
	document.getElementById('share-btn')?.addEventListener('click', async () => {
		try {
			await navigator.clipboard.writeText(window.location.href);
		} catch {
			const input = document.createElement('input');
			input.value = window.location.href;
			document.body.appendChild(input);
			input.select();
			document.execCommand('copy');
			document.body.removeChild(input);
		}
		const toast = document.getElementById('share-toast');
		if (toast) {
			toast.style.opacity = '1';
			setTimeout(() => { toast.style.opacity = '0'; }, 1500);
		}
	});
</script>
</PageLayout>
t>
</PageLayout>
