  <style>
    /* Hide cover in inline detail panels (only show in modal) */
    .library-details .detail-cover { display: none; }
    #library-modal-body .detail-cover { display: block; }
    .library-card { perspective: 800px; }
    .library-card-inner { transition: transform 0.3s ease, box-shadow 0.3s ease; transform-style: preserve-3d; }
    .library-card.scroll-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .library-card.scroll-reveal.revealed { opacity: 1; transform: translateY(0); }
    .library-panel { transition: opacity 0.2s ease; }
    .library-panel.fading { opacity: 0; }
    .books-view-stage { position: relative; }
    .library-books-view { transition: opacity 0.28s ease, transform 0.28s ease; }
    .library-books-view.is-transitioning { opacity: 0; transform: translateY(8px); }
    #library-modal.modal-open { display: flex; }
    #library-modal.modal-open #library-modal-content { transform: scale(1); opacity: 1; }
    #library-modal.modal-closing { display: flex; }
    #library-modal.modal-closing #library-modal-content { transform: scale(0.95); opacity: 0; }
    .library-modal-handle { display: none; }

    .library-shelf-stage { display: flex; flex-direction: column; gap: 1.25rem; }
    .shelf-row {
      position: relative;
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: flex-end;
      justify-content: flex-start;
      gap: 0.35rem;
      padding: 1.25rem 1rem 1.1rem;
      border-bottom: 10px solid rgba(120, 76, 42, 0.42);
      border-image: linear-gradient(90deg, rgba(82, 49, 24, 0.62), rgba(168, 121, 77, 0.85), rgba(82, 49, 24, 0.62)) 1;
      background: linear-gradient(180deg, rgba(137,83,209,0.03), rgba(137,83,209,0));
      overflow-x: auto;
      scrollbar-width: none;
    }
    .shelf-row::-webkit-scrollbar { display: none; }
    .shelf-book {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      width: clamp(32px, 3vw, 40px);
      min-height: 240px;
      flex: 0 0 clamp(32px, 3vw, 40px);
      background: transparent;
      border: 0;
      padding: 0;
      cursor: pointer;
