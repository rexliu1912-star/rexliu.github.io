              {hasNotes(item) && <p class="mt-2 font-serif text-xs text-[#8953d1] dark:text-[#a175e8]">💬</p>}
            </article>
            <div class="lib-detail hidden" data-detail={item.id}>
              <div class="flex flex-col sm:flex-row gap-5">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="w-28 sm:w-36 aspect-[2/3] rounded-md object-cover shrink-0 shadow-lg" />
                ) : (
                  <div class={`w-28 sm:w-36 aspect-[2/3] flex items-center justify-center rounded-md shrink-0 shadow-lg ${item.coverClass}`}><span class="font-serif text-sm text-white">{item.title}</span></div>
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  <p class="mt-1 font-serif text-sm text-gray-400">{item.year || "—"}</p>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[#8953d1] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300 dark:border-[#a175e8]">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                  {!hasNotes(item) && <p class="mt-4 font-serif text-sm text-gray-500"><span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span></p>}
                </div>
              </div>
            </div>
          </Fragment>
        ))}
      </div>
    ) : (
      <p class="font-serif text-sm text-gray-400"><span class="lang-en">Coming soon.</span><span class="lang-zh">敬请期待。</span></p>
    )}
  </section>

  <!-- ── Frosted-glass Modal (must be above <script> so getElementById works) ── -->
  <div id="lib-modal" role="dialog" aria-modal="true">
    <div id="lib-modal-backdrop"></div>
    <div id="lib-modal-card">
      <button id="lib-modal-close" aria-label="Close">✕</button>
      <div id="lib-modal-content" class="font-serif"></div>
    </div>
  </div>

  <style>
    /* ── Cursor spotlight on panels ── */
    .lib-panel {
      position: relative;
      --mx: 50%; --my: 50%; --spotlight: 0;
    }
    .lib-panel::before {
      content: '';
      position: absolute;
      inset: -40px;
      pointer-events: none;
      background: radial-gradient(
        600px circle at var(--mx) var(--my),
        rgba(137,83,209,0.07),
        transparent 50%
      );
      opacity: var(--spotlight);
      transition: opacity 0.4s ease;
      z-index: 0;
    }
    /* ── Card entry animation + 3D tilt via CSS vars ── */
    .lib-card {
      --rx: 0deg; --ry: 0deg; --rs: 1;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .lib-card.revealed {
      opacity: 1;
      /* CSS vars drive the tilt; JS only sets --rx/--ry/--rs */
      transform: perspective(700px) rotateX(var(--rx)) rotateY(var(--ry)) scale(var(--rs)) translateY(0px);
    }
    .lib-card.is-active {
      border-color: rgba(137,83,209,0.6) !important;
      box-shadow: 0 0 28px rgba(137,83,209,0.18);
    }

    /* ── Inline detail (kept as data container, always hidden) ── */
    .lib-detail { display: none !important; }

    /* ── Tab panel fade-in ── */
    .lib-panel:not(.hidden) {
      animation: panelFadeIn 0.3s ease both;
    }
    @keyframes panelFadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Tab / tag button ── */
    .lib-tab { transition: all 0.15s ease; }
    :global(.tag-btn) { transition: all 0.15s ease; }
    :global(.tag-btn.active) {
      background: #8953d1 !important; color: white !important; border-color: #8953d1 !important;
    }
    :global(.dark .tag-btn.active) {
      background: #a175e8 !important; color: black !important; border-color: #a175e8 !important;
    }

    /* ── Frosted-glass Modal ── */
    #lib-modal {
      position: fixed; inset: 0; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      padding: 1rem;
      opacity: 0; pointer-events: none;
      transition: opacity 0.25s ease;
    }
    #lib-modal.open { opacity: 1; pointer-events: auto; }
    #lib-modal-backdrop {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.55);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    #lib-modal-card {
      position: relative; z-index: 10;
      background: #ffffff;
      color: #1a1a1a;
      border-radius: 1rem;
      max-width: 640px; width: 100%;
      max-height: 88vh; overflow-y: auto;
      padding: 2rem;
      box-shadow: 0 24px 80px rgba(0,0,0,0.22), 0 0 0 1px rgba(137,83,209,0.15);
      transform: scale(0.96) translateY(12px);
      transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1);
    }
    :global(.dark) #lib-modal-card {
      background: #16162a;
      color: #e5e7eb;
      box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(137,83,209,0.25);
    }
    #lib-modal.open #lib-modal-card { transform: scale(1) translateY(0); }
    /* Modal content text colors — explicit, not relying on inherit */
    #lib-modal-content h3 { color: #111827; }
    :global(.dark) #lib-modal-content h3 { color: #f9fafb; }
    #lib-modal-content p, #lib-modal-content li span:last-child { color: #4b5563; }
    :global(.dark) #lib-modal-content p,
    :global(.dark) #lib-modal-content li span:last-child { color: #d1d5db; }
    #lib-modal-content blockquote { color: #4b5563; border-color: #8953d1; }
    :global(.dark) #lib-modal-content blockquote { color: #d1d5db; border-color: #a175e8; }
    #lib-modal-close {
      position: absolute; top: 1rem; right: 1rem;
      width: 2rem; height: 2rem;
      display: flex; align-items: center; justify-content: center;
      border-radius: 9999px;
      background: rgba(137,83,209,0.1);
      color: #8953d1;
      font-size: 1.1rem; line-height: 1;
      cursor: pointer;
      transition: background 0.15s ease;
      border: none;
    }
    #lib-modal-close:hover { background: rgba(137,83,209,0.2); }

    /* ── Shelf view ── */
    :global(.lib-view-toggle) { transition: all 0.18s ease; }
    .books-shelf-view { display: none; }
    .books-shelf-view.active { display: block; }
    .books-grid-view.hidden-view { display: none; }
    :global(.lib-shelf-stage) { display: flex; flex-direction: column; gap: 1.5rem; }
    /* shelf-row is JS-created — must use :global to bypass Astro scoping */
    :global(.shelf-row) {
      position: relative;
      display: flex; flex-direction: row; flex-wrap: nowrap;
      align-items: flex-end; justify-content: flex-start;
      gap: 0.35rem;
      padding: 1rem 1rem 0;
      border-bottom: 10px solid rgba(120,76,42,0.45);
      border-image: linear-gradient(90deg, rgba(82,49,24,0.6), rgba(168,121,77,0.9), rgba(82,49,24,0.6)) 1;
      background: linear-gradient(180deg, rgba(137,83,209,0.03), rgba(137,83,209,0));
      overflow-x: auto; scrollbar-width: none;
    }
    :global(.shelf-row::-webkit-scrollbar) { display: none; }
    .shelf-book {
      position: relative;
      display: flex; justify-content: center; align-items: flex-end;
      width: clamp(32px, 3vw, 42px);
      min-height: 220px;
      flex: 0 0 clamp(32px, 3vw, 42px);
      background: transparent; border: 0; padding: 0; cursor: pointer;
      transition: transform 0.28s ease, filter 0.28s ease;
    }
    .shelf-book:hover { transform: translateY(-22px) !important; filter: drop-shadow(0 16px 28px rgba(17,24,39,0.28)); }
    .shelf-spine {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      width: clamp(32px, 3vw, 42px);
      height: var(--shelf-height, 180px);
      border-radius: 10px 10px 4px 4px;
      overflow: hidden;
      box-shadow: 0 8px 22px rgba(17,24,39,0.18),
                  inset 1px 0 0 rgba(255,255,255,0.22),
                  inset -2px 0 0 rgba(0,0,0,0.14);
      transition: transform 0.28s ease;
    }
    .shelf-spine-sheen {
      position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(255,255,255,0.22), transparent 30%, transparent 72%, rgba(0,0,0,0.14));
    }
    .shelf-spine-title {
      position: relative; z-index: 1;
      padding: 0.6rem 0.2rem;
      font-family: Georgia, serif; font-size: 0.72rem;
      line-height: 1.15; letter-spacing: 0.04em;
      color: white;
      writing-mode: vertical-rl; text-orientation: mixed;
      white-space: normal;
      max-height: calc(var(--shelf-height, 180px) - 16px); overflow: hidden;
    }
    .shelf-spine-dot {
      position: absolute; left: 50%; bottom: 8px; z-index: 1;
      width: 6px; height: 6px; margin-left: -3px;
      border-radius: 999px;
      background: rgba(255,255,255,0.75);
      box-shadow: 0 0 10px rgba(255,255,255,0.4);
    }
    .shelf-book-preview {
      position: absolute; left: 50%; bottom: 12px;
      width: 100px; aspect-ratio: 2/3;
      transform: translateX(-50%) translateY(8px) scale(0.92);
      opacity: 0; pointer-events: none;
      transition: opacity 0.28s ease, transform 0.28s ease;
      z-index: 10; border-radius: 4px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.3);
      overflow: hidden;
    }
    .shelf-book:hover .shelf-book-preview { opacity: 1; transform: translateX(-50%) translateY(-42px) scale(1); }
    .shelf-book:hover .shelf-spine { transform: translateY(-2px) scale(1.02); }
  </style>

  <script is:inline>
    let activeTab = 'books';
    let activeTag = '全部';

    // ── Count-up ──────────────────────────────────────────────
    document.querySelectorAll('[data-countup]').forEach(el => {
      const target = parseInt(el.dataset.countup, 10);
      const start = performance.now();
      const step = (now) => {
        const p = Math.min((now - start) / 1000, 1);
        el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });

    // ── Scroll stagger entry ──────────────────────────────────
    function initStagger() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.lib-card').forEach((card, i) => {
        card.style.transitionDelay = `${(i % 16) * 45}ms`;
        observer.observe(card);
      });
    }
    initStagger();

    // ── 3D hover tilt (via CSS vars — no conflict with .revealed transform) ──
    function attachTilt(card) {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top)  / r.height - 0.5;
        card.style.setProperty('--rx', `${-y * 9}deg`);
        card.style.setProperty('--ry', `${x * 9}deg`);
        card.style.setProperty('--rs', '1.045');
        card.style.transition = 'transform 0.1s ease, box-shadow 0.1s ease, opacity 0.5s ease, border-color 0.2s ease';
        card.style.boxShadow = `${-x*14}px ${y*14}px 32px rgba(137,83,209,0.18)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--rx', '0deg');
        card.style.setProperty('--ry', '0deg');
        card.style.setProperty('--rs', '1');
        card.style.transition = 'transform 0.4s ease, box-shadow 0.4s ease, opacity 0.5s ease, border-color 0.2s ease';
        card.style.boxShadow = '';
      });
    }
    document.querySelectorAll('.lib-card').forEach(attachTilt);

    // ── Tab switching ─────────────────────────────────────────
    const tabs   = document.querySelectorAll('.lib-tab');
    const panels = document.querySelectorAll('.lib-panel');

    function switchTab(tab) {
      activeTab = tab;
      activeTag = '全部';
      tabs.forEach(t => {
        const on = t.dataset.tab === tab;
        t.setAttribute('aria-pressed', on);
        t.classList.toggle('border-[#8953d1]', on);
        t.classList.toggle('text-[#8953d1]', on);
        t.classList.toggle('dark:text-[#a175e8]', on);
        t.classList.toggle('border-transparent', !on);
        t.classList.toggle('text-gray-400', !on);
      });
      panels.forEach(p => {
        const show = p.dataset.panel === tab;
        p.classList.toggle('hidden', !show);
        if (show) {
          // re-trigger animation
          p.style.animation = 'none';
          requestAnimationFrame(() => { p.style.animation = ''; });
          // re-stagger newly visible cards
          p.querySelectorAll('.lib-card:not(.revealed)').forEach((c, i) => {
            c.style.transitionDelay = `${(i % 16) * 45}ms`;
          });
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); } });
          }, { threshold: 0.08 });
          p.querySelectorAll('.lib-card:not(.revealed)').forEach(c => obs.observe(c));
        }
      });
      renderTags();
      applyTagFilter();
    }
    tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

    // ── Tag filters ───────────────────────────────────────────
    const tagRoot = document.getElementById('tag-filters');

    function getTagsForTab() {
      const tags = new Set();
      document.querySelectorAll(`.lib-card[data-group="${activeTab}"]`).forEach(card => {
        try { JSON.parse(card.dataset.tags || '[]').forEach(t => tags.add(t)); } catch {}
      });
      return ['全部', ...Array.from(tags).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN'))];
    }

    function getLang() {
      return document.documentElement.lang === 'en' || document.body.classList.contains('lang-en') ? 'en' : 'zh';
    }

    // Tag translations (zh → en)
    const TAG_EN = {
      '成长':'Growth','古琴':'Guqin','历史':'History','投资':'Investing',
      '文化':'Culture','文学':'Literature','写作':'Writing','哲学':'Philosophy',
      '心理':'Psychology','商业':'Business','传记':'Biography','科技':'Tech',
      '社会':'Society','经济':'Economics','艺术':'Art','音乐':'Music',
      '爱情':'Romance','家庭':'Family','剧情':'Drama','喜剧':'Comedy',
      '悬疑':'Thriller','动画':'Animation','科幻':'Sci-Fi','战争':'War',
      '日剧':'J-Drama','韩剧':'K-Drama','美剧':'US Drama','港剧':'HK Drama',
      '励志':'Inspire','认知':'Cognition','财富':'Wealth','时间':'Time',
      '人生':'Life','情感':'Emotion','亲情':'Kinship',
    };
    function tagLabel(tag) {
      if (tag === '全部') return '<span class="lang-zh">全部</span><span class="lang-en">All</span>';
      const en = TAG_EN[tag];
      return en
        ? `<span class="lang-zh">${tag}</span><span class="lang-en">${en}</span>`
        : tag;
    }

    function renderTags() {
      tagRoot.innerHTML = '';
      getTagsForTab().forEach(tag => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tag-btn rounded-full border border-purple-500/20 px-4 py-2 font-serif text-sm text-gray-500 dark:border-purple-500/15 dark:text-gray-400';
        btn.innerHTML = tagLabel(tag);
        if (tag === activeTag) btn.classList.add('active');
        btn.addEventListener('click', () => {
          activeTag = tag === activeTag ? '全部' : tag;
          renderTags();
          applyTagFilter();
        });
        tagRoot.appendChild(btn);
      });
    }

    function applyTagFilter() {
      document.querySelectorAll(`.lib-card[data-group="${activeTab}"]`).forEach(card => {
        const show = activeTag === '全部' || (() => { try { return JSON.parse(card.dataset.tags||'[]').includes(activeTag); } catch { return false; } })();
        card.style.display = show ? '' : 'none';
      });
      // Re-layout shelf if active
      if (activeTab === 'books' && activeView === 'shelf') organizeShelf();
    }

    // ── Frosted-glass Modal ───────────────────────────────────
    // Modal elements exist above in DOM, safe to query now
    function getModal()        { return document.getElementById('lib-modal'); }
    function getModalContent() { return document.getElementById('lib-modal-content'); }

    function openModal(cardEl) {
      const id = cardEl.dataset.id;
      const detail = document.querySelector(`.lib-detail[data-detail="${id}"]`);
      const modal = getModal();
      const modalContent = getModalContent();
      if (!detail || !modal || !modalContent) return;

      modalContent.innerHTML = detail.innerHTML;
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';

      document.querySelectorAll('.lib-card.is-active').forEach(c => c.classList.remove('is-active'));
      cardEl.classList.add('is-active');
    }

    function closeModal() {
      const modal = getModal();
      if (!modal) return;
      modal.classList.remove('open');
      document.body.style.overflow = '';
      document.querySelectorAll('.lib-card.is-active').forEach(c => c.classList.remove('is-active'));
    }

    document.addEventListener('click', (e) => {
      // Close button
      if (e.target.closest('#lib-modal-close')) { closeModal(); return; }
      // Backdrop
      if (e.target.id === 'lib-modal-backdrop') { closeModal(); return; }
      // Card
      const card = e.target.closest('.lib-card');
      if (card) { e.preventDefault(); openModal(card); }
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // ── Shelf view ───────────────────────────────────────────
    let activeView = 'grid';
    const gridView  = document.getElementById('books-grid-view');
    const shelfView = document.getElementById('books-shelf-view');
    const shelfStage = document.getElementById('lib-shelf-stage');
    const btnGrid  = document.getElementById('view-btn-grid');
    const btnShelf = document.getElementById('view-btn-shelf');

    function organizeShelf() {
      if (!shelfStage) return;
      // Collect ALL shelf books from anywhere in the DOM (they may be in rows or loose)
      const allBooks = Array.from(document.querySelectorAll('[data-shelf-book]'));
      if (!allBooks.length) return;

      const visibleBooks = allBooks.filter(b => {
        if (activeTag === '全部') return true;
        try { return JSON.parse(b.dataset.tags || '[]').includes(activeTag); } catch { return false; }
      });
      const hiddenBooks = allBooks.filter(b => !visibleBooks.includes(b));

      const w = window.innerWidth;
      const cols = w >= 1280 ? 14 : w >= 1024 ? 12 : w >= 768 ? 10 : w >= 640 ? 8 : 7;

      // Detach all books first, then clear stage
      allBooks.forEach(b => b.parentNode && b.parentNode.removeChild(b));
      shelfStage.innerHTML = '';

      // Build rows in order and append
      for (let i = 0; i < visibleBooks.length; i += cols) {
        const row = document.createElement('div');
        row.className = 'shelf-row';
        visibleBooks.slice(i, i + cols).forEach(b => { b.style.display = ''; row.appendChild(b); });
        shelfStage.appendChild(row);
      }

      // Hidden books: keep in DOM (needed for modal data) in a hidden container
      if (hiddenBooks.length) {
        const hiddenWrap = document.createElement('div');
        hiddenWrap.style.display = 'none';
        hiddenBooks.forEach(b => { b.style.display = 'none'; hiddenWrap.appendChild(b); });
        shelfStage.appendChild(hiddenWrap);
      }
    }

    function switchView(view) {
      activeView = view;
      if (view === 'shelf') {
        gridView.classList.add('hidden-view');
        shelfView.classList.add('active');
        btnGrid.classList.remove('bg-[#8953d1]', 'text-white', 'dark:bg-[#a175e8]', 'dark:text-black');
        btnGrid.classList.add('text-gray-500');
        btnShelf.classList.add('bg-[#8953d1]', 'text-white', 'dark:bg-[#a175e8]', 'dark:text-black');
        btnShelf.classList.remove('text-gray-500');
        organizeShelf();
      } else {
        shelfView.classList.remove('active');
        gridView.classList.remove('hidden-view');
        btnShelf.classList.remove('bg-[#8953d1]', 'text-white', 'dark:bg-[#a175e8]', 'dark:text-black');
        btnShelf.classList.add('text-gray-500');
        btnGrid.classList.add('bg-[#8953d1]', 'text-white', 'dark:bg-[#a175e8]', 'dark:text-black');
        btnGrid.classList.remove('text-gray-500');
      }
    }

    if (btnGrid)  btnGrid.addEventListener('click',  () => switchView('grid'));
    if (btnShelf) btnShelf.addEventListener('click', () => switchView('shelf'));

    // Shelf book click → open modal
    document.addEventListener('click', (e) => {
      const sb = e.target.closest('[data-shelf-book]');
      if (sb) {
        e.preventDefault();
        const id = sb.dataset.id;
        const card = document.querySelector(`.lib-card[data-id="${id}"]`);
        if (card) openModal(card);
      }
    });

    // ── Cursor spotlight on card grids ────────────────────────
    document.querySelectorAll('.lib-panel').forEach(panel => {
      panel.addEventListener('mousemove', (e) => {
        const r = panel.getBoundingClientRect();
        panel.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        panel.style.setProperty('--my', (e.clientY - r.top)  + 'px');
        panel.style.setProperty('--spotlight', '1');
      });
      panel.addEventListener('mouseleave', () => {
        panel.style.setProperty('--spotlight', '0');
      });
    });

    // ── Init ──────────────────────────────────────────────────
    renderTags();
  </script>

</PageLayout>
