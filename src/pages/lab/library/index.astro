---
import PageLayout from "@/layouts/Base.astro";
import booksData from "@/data/books.json";
import mediaData from "@/data/media.json";

type Notes = {
  quotes?: string[];
  core_ideas?: string[];
  impact?: string;
};

type BookEntry = {
  title: string;
  titleEn?: string;
  author?: string;
  status: string;
  type?: string;
  rating?: string | null;
  tags?: string[];
  endDate?: string;
  notes?: Notes;
  cover?: string;
};

type MediaEntry = {
  title: string;
  titleEn?: string;
  year?: number;
  status: string;
  type: "movie" | "series" | "variety" | "documentary";
  tags?: string[];
  notes?: Notes;
  cover?: string;
};

type LibraryItem = {
  id: string;
  title: string;
  titleEn: string | undefined;
  subtitle: string;
  format: "book" | "movie" | "series" | "variety" | "documentary";
  rating: string | null | undefined;
  tags: string[];
  notes: Notes | undefined;
  meta: string | undefined;
  coverClass: string;
  aspectClass: string;
  sortDate: string | undefined;
  year: number | undefined;
  cover: string | undefined;
};

// Tag-based gradient colors for books without covers
const bookTagColors: Record<string, string> = {
  "投资": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "成长": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "文化": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "文学": "bg-gradient-to-br from-[#ec4899] to-[#be185d]",
  "古琴": "bg-gradient-to-br from-[#10b981] to-[#047857]",
  "写作": "bg-gradient-to-br from-[#6366f1] to-[#4338ca]",
};
const defaultBookColor = "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]";

// Type-based gradient colors for media without covers
const mediaTypeColors: Record<string, string> = {
  "movie": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "series": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "variety": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "documentary": "bg-gradient-to-br from-[#6b7280] to-[#374151]",
};

const books = (booksData as BookEntry[])
  .map((book, index) => ({
    id: `book-${index}`,
    title: book.title,
    titleEn: book.titleEn,
    subtitle: book.author || "Unknown author",
    format: "book" as const,
    rating: book.rating,
    tags: book.tags || [],
    notes: book.notes,
    meta: book.type,
    coverClass: (book.tags && book.tags[0] ? bookTagColors[book.tags[0]] : undefined) || defaultBookColor,
    aspectClass: "aspect-[2/3]",
    sortDate: book.endDate && book.endDate !== "-" ? book.endDate : undefined,
    year: undefined,
    cover: book.cover,
  }))
  .sort((a, b) => {
    if (!a.sortDate && !b.sortDate) return 0;
    if (!a.sortDate) return 1;
    if (!b.sortDate) return -1;
    return new Date(b.sortDate).valueOf() - new Date(a.sortDate).valueOf();
  });

const media = (mediaData as MediaEntry[])
  .map((item, index) => ({
    id: `media-${index}`,
    title: item.title,
    titleEn: item.titleEn,
    subtitle: item.type === "movie" ? "Film" : item.type === "series" ? "Series" : item.type === "documentary" ? "Documentary" : "Variety",
    format: item.type,
    rating: undefined,
    tags: item.tags || [],
    notes: item.notes,
    meta: undefined,
    coverClass: mediaTypeColors[item.type] || defaultBookColor,
    aspectClass: "aspect-[2/3]",
    sortDate: undefined,
    year: item.year,
    cover: item.cover,
  }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));

const films = media.filter((item) => item.format === "movie");
const series = media.filter((item) => item.format === "series");
const variety = media.filter((item) => item.format === "variety");
const documentary = media.filter((item) => item.format === "documentary");

const meta = {
  title: "Rex's Library — Lab",
  description: "Books, films, and shows that shaped how Rex thinks.",
};

// Stats for count-up
const statsBookNotes = books.filter(b => hasNotes(b)).length;
const statsMediaNotes = media.filter(m => hasNotes(m)).length;

function formatType(format: LibraryItem["format"]) {
  return format === "book"
    ? "Book"
    : format === "movie"
      ? "Film"
      : format === "series"
        ? "Series"
        : format === "documentary"
          ? "Documentary"
          : "Variety";
}

function formatTypeZh(format: LibraryItem["format"]) {
  return format === "book"
    ? "书籍"
    : format === "movie"
      ? "电影"
      : format === "series"
        ? "剧集"
        : format === "documentary"
          ? "纪录片"
          : "综艺";
}

function hasNotes(item: LibraryItem) {
  return !!(
    item.notes &&
    ((item.notes.quotes && item.notes.quotes.length > 0) ||
      (item.notes.core_ideas && item.notes.core_ideas.length > 0) ||
      (item.notes.impact && item.notes.impact.trim().length > 0))
  );
}


function shelfHeightFor(index: number) {
  return 180 + (index * 17) % 41;
}


---

<PageLayout meta={meta}>
  <section class="mb-12">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
      ← Lab
    </a>
    <h1 class="hero-reveal-text mt-4 mb-4 font-serif text-4xl font-bold dark:text-white">
      Rex's Library
    </h1>
    <p class="hero-reveal-subtitle lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      Books, films, and shows that shaped how I think.
    </p>
    <p class="hero-reveal-subtitle lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      读过的书、看过的片，塑造了现在的我。
    </p>
    <p class="mt-4 font-serif text-sm text-gray-400 dark:text-gray-500">
      <span data-countup={books.length}>0</span>
      <span class="lang-en"> books</span>
      <span class="lang-zh"> 本书</span>
      ·
      <span data-countup={statsBookNotes + statsMediaNotes}>0</span>
      <span class="lang-en"> with notes</span>
      <span class="lang-zh"> 有笔记</span>
      ·
      <span data-countup={media.length}>0</span>
      <span class="lang-en"> films & shows</span>
      <span class="lang-zh"> 部影视</span>
    </p>
  </section>

  <section class="mb-4 fade-in-up" style="--delay: 120ms">
    <div class="flex flex-wrap gap-6 border-b border-gray-200 font-serif text-sm dark:border-gray-800">
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-[#8953d1] pb-3 font-medium text-[#8953d1] transition-colors dark:text-[#a175e8]" data-tab-button data-tab-target="books" aria-pressed="true">
        <span class="lang-en">📚 Books ({books.length})</span>
        <span class="lang-zh">📚 书籍 ({books.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="film-tv" aria-pressed="false">
        <span class="lang-en">🎬 Film & TV ({media.length})</span>
        <span class="lang-zh">🎬 影视 ({media.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="variety" aria-pressed="false">
        <span class="lang-en">🎭 Variety ({variety.length})</span>
        <span class="lang-zh">🎭 综艺 ({variety.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="documentary" aria-pressed="false">
        <span class="lang-en">🎬 Documentary ({documentary.length})</span>
        <span class="lang-zh">🎬 纪录片 ({documentary.length})</span>
      </button>
    </div>
  </section>

  <section class="mb-10 fade-in-up" style="--delay: 140ms">
    <div id="library-tag-filters" class="flex flex-wrap gap-3"></div>
  </section>

  <section data-tab-panel="books" class="library-panel space-y-4">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="font-serif text-sm text-gray-400 dark:text-gray-500">
        <p class="lang-en">Browse by tag, then switch between the classic grid and a shelf-style view.</p>
        <p class="lang-zh">按标签浏览，可切换网格和书架两种视图。</p>
      </div>
      <div class="inline-flex w-fit items-center rounded-full border border-purple-500/20 bg-white/70 p-1 font-serif text-sm shadow-[0_0_20px_#8953d10f] backdrop-blur dark:border-purple-500/15 dark:bg-gray-900/60">
        <button type="button" class="library-view-toggle rounded-full bg-[#8953d1] px-4 py-2 text-white transition-all dark:bg-[#a175e8] dark:text-black" data-books-view-button data-view-target="grid" aria-pressed="true">📚 Grid</button>
        <button type="button" class="library-view-toggle rounded-full px-4 py-2 text-gray-500 transition-all hover:text-[#8953d1] dark:text-gray-400 dark:hover:text-[#a175e8]" data-books-view-button data-view-target="shelf" aria-pressed="false">📖 Shelf</button>
      </div>
    </div>

    <div class="books-view-stage relative">
      <div data-books-view="grid" class="library-books-view grid-view">
        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {books.map((item, index) => {
            return (
              <Fragment>
                <article
                  class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15"
                  style={`--delay: ${180 + index * 30}ms`}
                  data-library-item
                  data-tab-group="books"
                  data-view="grid"
                  data-tags={JSON.stringify(item.tags || [])}
                >
                  <button
                    type="button"
                    class="block w-full text-left"
                    data-library-toggle
                    data-target={item.id}
                    aria-expanded="false"
                  >
                      {item.cover ? (
                        <img
                          src={item.cover}
                          alt={`${item.title} cover`}
                          loading="lazy"
                          referrerpolicy="no-referrer"
                          class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`}
                        />
                      ) : (
                        <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}>
                          <span class="font-serif text-base font-medium text-white">{item.title}</span>
                        </div>
                      )}
                      <h2 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h2>
                      {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                      <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">{item.subtitle}</p>
                      <div class="mt-3 flex flex-wrap items-center gap-3 font-serif text-xs text-gray-400 dark:text-gray-500">
                        {item.rating && <span>⭐ {item.rating}</span>}
                        {hasNotes(item) ? (
                          <>
                            <span class="lang-en">💬 Notes</span>
                            <span class="lang-zh">💬 笔记</span>
                          </>
                        ) : (
                          <>
                            <span class="lang-en">↗ Details</span>
                            <span class="lang-zh">↗ 详情</span>
                          </>
                        )}
                      </div>
                    </button>
                </article>
                <div
                    id={item.id}
                    class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15"
                    style={`--delay: ${210 + index * 30}ms`}
                    data-library-detail
                    data-detail-for={item.id}
                    data-tab-group="books"
                    data-cover={item.cover || ''}
                    data-cover-class={item.coverClass}
                  >
                    {item.cover ? (
                      <img
                        src={item.cover}
                        alt={`${item.title} cover`}
                        loading="lazy"
                        referrerpolicy="no-referrer"
                        class="detail-cover mx-auto mb-4 block max-h-48 rounded-md object-cover object-center shadow-lg"
                      />
                    ) : (
                      <div class={`detail-cover mx-auto mb-4 flex h-48 w-32 items-center justify-center rounded-md px-4 text-center shadow-lg ${item.coverClass}`}>
                        <span class="font-serif text-sm font-medium text-white">{item.title}</span>
                      </div>
                    )}
                    <div class="mb-3 flex flex-wrap items-baseline gap-x-3 gap-y-2">
                      <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                      <p class="font-serif text-sm text-gray-400 dark:text-gray-500">{item.subtitle}</p>
                    </div>
                    <p class="font-serif text-sm text-gray-400 dark:text-gray-500">
                      {item.rating && <span>{item.rating} · </span>}
                      <span class="lang-en">{formatType(item.format)}</span>
                      <span class="lang-zh">{formatTypeZh(item.format)}</span>
                      {item.meta && <span> · {item.meta}</span>}
                      {item.year && <span> · {item.year}</span>}
                      {item.tags.length > 0 && <span> · {item.tags.join(" · ")}</span>}
                    </p>
                    {item.notes?.quotes && item.notes.quotes.length > 0 && (
                      <div class="mt-4 space-y-3">
                        {item.notes.quotes.map((quote) => (
                          <blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                            {quote}
                          </blockquote>
                        ))}
                      </div>
                    )}
                    {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (
                      <ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                        {item.notes.core_ideas.map((idea) => (
                          <li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>
                        ))}
                      </ul>
                    )}
                    {item.notes?.impact && item.notes.impact.trim() && (
                      <p class="mt-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                        {item.notes.impact}
                      </p>
                    )}
                    {!hasNotes(item) && (
                      <div class="mt-4 font-serif text-sm leading-relaxed text-gray-500 dark:text-gray-400">
                        <p class="lang-en">No notes yet.</p>
                        <p class="lang-zh">暂无笔记。</p>
                      </div>
                    )}
                  </div>
              </Fragment>
            );
          })}
        </div>
      </div>

      <div data-books-view="shelf" class="library-books-view shelf-view hidden">
        <div data-shelf-stage class="library-shelf-stage">
          {books.map((item, index) => {
            const expandable = hasNotes(item);
            return (
              <button
                type="button"
                class="shelf-book group"
                style={`--shelf-height: ${shelfHeightFor(index)}px`}
                data-library-item
                data-shelf-book
                data-tab-group="books"
                data-view="shelf"
                data-tags={JSON.stringify(item.tags || [])}
                data-library-toggle
                data-target={item.id}
                aria-expanded="false"
              >
                <span class="shelf-book-preview">
                  {item.cover ? (
                    <img
                      src={item.cover}
                      alt={`${item.title} cover`}
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      class="h-full w-full rounded-lg object-cover object-center shadow-2xl"
                    />
                  ) : (
                    <span class={`flex h-full w-full items-center justify-center rounded-lg px-3 text-center ${item.coverClass}`}>
                      <span class="font-serif text-xs font-medium leading-snug text-white">{item.title}</span>
                    </span>
                  )}
                </span>
                <span class={`shelf-spine ${item.coverClass}`}>
                  <span class="shelf-spine-sheen"></span>
                  <span class="shelf-spine-title">{item.title}</span>
                  {expandable && <span class="shelf-spine-dot"></span>}
                </span>
              </button>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <section data-tab-panel="film-tv" class="library-panel hidden space-y-10">
    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-serif text-lg font-medium text-black dark:text-white">
          <span class="lang-en">🎬 Films</span>
          <span class="lang-zh">🎬 电影</span>
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {films.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${180 + index * 30}ms`} data-library-item data-tab-group="film-tv" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    {item.cover ? (
                      <img src={item.cover} alt={`${item.title} poster`} loading="lazy" referrerpolicy="no-referrer" class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`} />
                    ) : (
                      <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    )}
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Film</span><span class="lang-zh">电影</span> · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">💬 Notes</span><span class="lang-zh">💬 笔记</span></div>
                  </button>
                ) : (
                  <div>
                    {item.cover ? (
                      <img src={item.cover} alt={`${item.title} poster`} loading="lazy" referrerpolicy="no-referrer" class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`} />
                    ) : (
                      <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    )}
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Film</span><span class="lang-zh">电影</span> · {item.year || "—"}</p>
                  </div>
                )}
              </article>
              {expandable && (
                <div id={item.id} class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15" data-library-detail data-detail-for={item.id} data-tab-group="film-tv">
                  <h3 class="mb-3 font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                </div>
              )}
            </Fragment>
          );
        })}
      </div>
    </div>

    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-serif text-lg font-medium text-black dark:text-white">
          <span class="lang-en">📺 Series</span>
          <span class="lang-zh">📺 剧集</span>
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {series.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${220 + index * 30}ms`} data-library-item data-tab-group="film-tv" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    {item.cover ? (
                      <img src={item.cover} alt={`${item.title} poster`} loading="lazy" referrerpolicy="no-referrer" class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`} />
                    ) : (
                      <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    )}
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Series</span><span class="lang-zh">剧集</span> · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">💬 Notes</span><span class="lang-zh">💬 笔记</span></div>
                  </button>
                ) : (
                  <div>
                    {item.cover ? (
                      <img src={item.cover} alt={`${item.title} poster`} loading="lazy" referrerpolicy="no-referrer" class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`} />
                    ) : (
