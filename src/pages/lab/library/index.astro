        transition: transform 0.3s ease-out, opacity 0.3s ease-out;
      }
      #library-modal.modal-open #library-modal-content { transform: translateY(0); opacity: 1; }
      #library-modal.modal-closing #library-modal-content { transform: translateY(100%); opacity: 1; }
      .library-modal-handle { display: block; }
      #library-modal-close { top: 0.85rem; }
      #library-modal-body { padding-bottom: max(1rem, env(safe-area-inset-bottom)); }
    }

  </style>

  <script is:inline>
    const tabButtons = Array.from(document.querySelectorAll('[data-tab-button]'));
    const tabPanels = Array.from(document.querySelectorAll('[data-tab-panel]'));
    const detailPanels = Array.from(document.querySelectorAll('[data-library-detail]'));
    const tagFilterRoot = document.getElementById('library-tag-filters');
    const libraryItems = Array.from(document.querySelectorAll('[data-library-item]'));
    const cards = Array.from(document.querySelectorAll('.library-card'));
    const modal = document.getElementById('library-modal');
    const modalBody = document.getElementById('library-modal-body');
    const modalClose = document.getElementById('library-modal-close');
    const booksViewButtons = Array.from(document.querySelectorAll('[data-books-view-button]'));
    const booksViews = Array.from(document.querySelectorAll('[data-books-view]'));
    const shelfStage = document.querySelector('[data-shelf-stage]');
    let activeTab = 'books';
    let activeTag = '全部';
    let activeBooksView = 'grid';
    let modalCloseTimer;

    // === COUNT-UP ANIMATION ===
    document.querySelectorAll('[data-countup]').forEach(el => {
      const target = parseInt(el.dataset.countup, 10);
      const duration = 1000;
      const start = performance.now();
      const step = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });

    // === 3D TILT EFFECT ===
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(800px) rotateY(${x * 12}deg) rotateX(${-y * 12}deg)`;
        card.style.boxShadow = `${-x * 15}px ${y * 15}px 30px rgba(137,83,209,0.12)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
        card.style.boxShadow = '';
      });
    });

    // === SCROLL REVEAL ===
    cards.forEach(card => card.classList.add('scroll-reveal'));
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target;
          const siblings = Array.from(card.parentElement?.querySelectorAll('.scroll-reveal:not(.revealed)') || []);
          const idx = siblings.indexOf(card);
          setTimeout(() => card.classList.add('revealed'), Math.max(0, idx) * 50);
          revealObserver.unobserve(card);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px 50px 0px' });
    cards.forEach(card => revealObserver.observe(card));

    // === MODAL ===
    const openModal = (detailEl) => {
      if (!modal || !modalBody || !detailEl) return;
      if (modalCloseTimer) { clearTimeout(modalCloseTimer); modalCloseTimer = undefined; }
      modalBody.innerHTML = detailEl.innerHTML;
      modal.style.display = 'flex';
      modal.classList.remove('modal-closing');
      void modal.offsetWidth;
      modal.classList.add('modal-open');
      document.body.style.overflow = 'hidden';
    };
    const closeModal = () => {
      if (!modal || modal.style.display === 'none') return;
      modal.classList.remove('modal-open');
      modal.classList.add('modal-closing');
      document.body.style.overflow = '';
      if (modalCloseTimer) clearTimeout(modalCloseTimer);
      modalCloseTimer = window.setTimeout(() => {
        modal.style.display = 'none';
        modal.classList.remove('modal-closing');
      }, window.innerWidth < 640 ? 300 : 200);
    };
    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // === TAB SWITCHING WITH FADE ===
    const closeAllDetails = () => {
      detailPanels.forEach((panel) => panel.classList.add('hidden'));
      document.querySelectorAll('[data-library-toggle]').forEach((b) => b.setAttribute('aria-expanded', 'false'));
    };

    const createTagButton = (label, selected) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.dataset.tagFilter = label;
      button.textContent = label;
      button.className = 'glow-card inline-flex items-center rounded-full border px-4 py-2 font-serif text-sm transition-all';
      if (selected) {
        button.classList.add('border-[#8953d1]', 'bg-[#8953d1]', 'text-white', 'dark:border-[#a175e8]', 'dark:bg-[#a175e8]', 'dark:text-black');
      } else {
        button.classList.add('border-purple-500/20', 'text-gray-500', 'hover:border-[#8953d1]', 'hover:text-[#8953d1]', 'dark:border-purple-500/15', 'dark:text-gray-400', 'dark:hover:border-[#a175e8]', 'dark:hover:text-[#a175e8]');
      }
      button.addEventListener('click', () => {
        activeTag = label === '全部' ? '全部' : activeTag === label ? '全部' : label;
        closeAllDetails();
        renderTagFilters();
        applyFilters();
      });
      return button;
    };

    const tagsForTab = (tab) => {
      const tags = new Set();
      libraryItems.filter((item) => item.dataset.tabGroup === tab).forEach((item) => {
        try { JSON.parse(item.dataset.tags || '[]').forEach((tag) => tags.add(tag)); } catch {}
      });
      return ['全部', ...Array.from(tags).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN'))];
    };

    const renderTagFilters = () => {
      if (!tagFilterRoot) return;
      const tags = tagsForTab(activeTab);
      if (!tags.includes(activeTag)) activeTag = '全部';
      tagFilterRoot.replaceChildren(...tags.map((tag) => createTagButton(tag, tag === activeTag)));
    };

    // === SHELF ROW LAYOUT (respects current filter) ===
    const layoutShelfRows = () => {
      if (!shelfStage) return;
      const allBooks = Array.from(shelfStage.querySelectorAll('[data-shelf-book]'));
      if (!allBooks.length) return;

      // Determine which books are visible based on current tag filter
      const visibleBooks = allBooks.filter((book) => {
        if (activeTag === '全部') return true;
        try { return JSON.parse(book.dataset.tags || '[]').includes(activeTag); } catch { return false; }
      });
      const hiddenBooks = allBooks.filter((book) => !visibleBooks.includes(book));

      const width = window.innerWidth;
      const columns = width >= 1536 ? 16 : width >= 1280 ? 14 : width >= 1024 ? 12 : width >= 768 ? 10 : width >= 640 ? 8 : 7;
      const frag = document.createDocumentFragment();

      // Layout visible books into rows
      for (let i = 0; i < visibleBooks.length; i += columns) {
        const row = document.createElement('div');
        row.className = 'shelf-row';
        visibleBooks.slice(i, i + columns).forEach((book) => {
          book.classList.remove('hidden');
          book.style.display = '';
          row.appendChild(book);
        });
        frag.appendChild(row);
      }

      // Put hidden books in a hidden container so they stay in DOM
      if (hiddenBooks.length) {
        const hiddenRow = document.createElement('div');
        hiddenRow.className = 'shelf-row hidden';
        hiddenRow.style.display = 'none';
        hiddenBooks.forEach((book) => {
          book.classList.add('hidden');
          book.style.display = 'none';
          hiddenRow.appendChild(book);
        });
        frag.appendChild(hiddenRow);
      }

      shelfStage.replaceChildren(frag);
    };

    const applyFilters = () => {
      // For grid view items and non-books
      libraryItems.forEach((item) => {
        const inActiveTab = item.dataset.tabGroup === activeTab;
        const matchesView = activeTab !== 'books' || (item.dataset.view || 'grid') === activeBooksView;
        let matchesTag = true;
        if (activeTag !== '全部') {
          try { matchesTag = JSON.parse(item.dataset.tags || '[]').includes(activeTag); } catch { matchesTag = false; }
        }
        const visible = inActiveTab && matchesView && matchesTag;
        item.classList.toggle('hidden', !visible);
        if (item instanceof HTMLElement) item.style.display = visible ? '' : 'none';
      });
      detailPanels.forEach((panel) => {
        if (panel.dataset.tabGroup !== activeTab) panel.classList.add('hidden');
      });
      // Re-layout shelf rows when in shelf view
      if (activeTab === 'books' && activeBooksView === 'shelf') {
        layoutShelfRows();
      }
    };

    const setBooksView = (view) => {
      activeBooksView = view === 'shelf' ? 'shelf' : 'grid';
      booksViewButtons.forEach((button) => {
        const active = button.dataset.viewTarget === activeBooksView;
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        button.classList.toggle('bg-[#8953d1]', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('dark:bg-[#a175e8]', active);
        button.classList.toggle('dark:text-black', active);
        button.classList.toggle('text-gray-500', !active);
        button.classList.toggle('dark:text-gray-400', !active);
      });
      booksViews.forEach((panel) => {
        const active = panel.dataset.booksView === activeBooksView;
        panel.classList.add('is-transitioning');
        if (active) panel.classList.remove('hidden');
        window.setTimeout(() => {
          panel.classList.toggle('hidden', !active);
          panel.classList.remove('is-transitioning');
        }, active ? 16 : 220);
      });
      applyFilters();
    };

    const setActiveTab = (target) => {
      const currentPanel = tabPanels.find(p => p.dataset.tabPanel === activeTab);
      const newPanel = tabPanels.find(p => p.dataset.tabPanel === target);

      if (currentPanel && newPanel && currentPanel !== newPanel) {
        currentPanel.classList.add('fading');
        setTimeout(() => {
          activeTab = target;
          tabButtons.forEach((button) => {
            const active = button.dataset.tabTarget === target;
            button.setAttribute('aria-pressed', active ? 'true' : 'false');
            button.classList.toggle('border-[#8953d1]', active);
            button.classList.toggle('text-[#8953d1]', active);
            button.classList.toggle('dark:text-[#a175e8]', active);
            button.classList.toggle('border-transparent', !active);
            button.classList.toggle('text-gray-400', !active);
            button.classList.toggle('dark:text-gray-500', !active);
          });
          tabPanels.forEach((panel) => {
            panel.classList.remove('fading');
            panel.classList.toggle('hidden', panel.dataset.tabPanel !== target);
          });
          renderTagFilters();
          applyFilters();
          newPanel.querySelectorAll('.library-card.scroll-reveal:not(.revealed)').forEach((card, i) => {
            setTimeout(() => card.classList.add('revealed'), i * 50);
          });
        }, 200);
      } else {
        activeTab = target;
        tabButtons.forEach((button) => {
          const active = button.dataset.tabTarget === target;
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
          button.classList.toggle('border-[#8953d1]', active);
          button.classList.toggle('text-[#8953d1]', active);
          button.classList.toggle('dark:text-[#a175e8]', active);
          button.classList.toggle('border-transparent', !active);
          button.classList.toggle('text-gray-400', !active);
          button.classList.toggle('dark:text-gray-500', !active);
        });
        tabPanels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.tabPanel !== target));
        renderTagFilters();
        applyFilters();
      }
    };

    booksViewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (activeBooksView === (button.dataset.viewTarget || 'grid')) return;
        closeAllDetails();
        closeModal();
        setBooksView(button.dataset.viewTarget || 'grid');
      });
    });

    // Initial shelf layout
    layoutShelfRows();

    window.addEventListener('resize', () => {
      if (activeTab === 'books' && activeBooksView === 'shelf') layoutShelfRows();
    });

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        closeAllDetails();
        closeModal();
        activeTag = '全部';
        setActiveTab(button.dataset.tabTarget || 'books');
      });
    });

    // === EVENT DELEGATION for book/media click → open modal ===
    // Using delegation so it works even after DOM re-arrangement (shelf rows)
    document.addEventListener('click', (e) => {
      const toggle = e.target.closest('[data-library-toggle]');
      if (!toggle) return;
      const targetId = toggle.dataset.target;
      if (!targetId) return;
      const panel = document.getElementById(targetId);
      if (panel) {
        e.preventDefault();
        e.stopPropagation();
        openModal(panel);
      }
    });

    setActiveTab(activeTab);
    setBooksView(activeBooksView);
  </script>
</PageLayout>
