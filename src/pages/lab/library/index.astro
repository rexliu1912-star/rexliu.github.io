    .shelf-spine-sheen { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(255,255,255,0.24), transparent 30%, transparent 72%, rgba(0,0,0,0.14)); }
    .shelf-spine-title {
      position: relative;
