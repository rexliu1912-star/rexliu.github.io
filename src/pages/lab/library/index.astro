---
import PageLayout from "@/layouts/Base.astro";
import booksData from "@/data/books.json";
import mediaData from "@/data/media.json";

type Notes = {
  quotes?: string[];
  core_ideas?: string[];
  impact?: string;
};

type BookEntry = {
  title: string;
  author?: string;
  status: string;
  type?: string;
  rating?: string | null;
  tags?: string[];
  endDate?: string;
  notes?: Notes;
  cover?: string;
};

type MediaEntry = {
  title: string;
  titleEn?: string;
  year?: number;
  status: string;
  type: "movie" | "series" | "variety" | "documentary";
  tags?: string[];
  notes?: Notes;
};

type LibraryItem = {
  id: string;
  title: string;
  subtitle: string;
  format: "book" | "movie" | "series" | "variety" | "documentary";
  rating: string | null | undefined;
  tags: string[];
  notes: Notes | undefined;
  meta: string | undefined;
  coverClass: string;
  aspectClass: string;
  sortDate: string | undefined;
  year: number | undefined;
  cover: string | undefined;
};

// Tag-based gradient colors for books without covers
const bookTagColors: Record<string, string> = {
  "投资": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "成长": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "文化": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "文学": "bg-gradient-to-br from-[#ec4899] to-[#be185d]",
  "古琴": "bg-gradient-to-br from-[#10b981] to-[#047857]",
  "写作": "bg-gradient-to-br from-[#6366f1] to-[#4338ca]",
};
const defaultBookColor = "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]";

// Type-based gradient colors for media without covers
const mediaTypeColors: Record<string, string> = {
  "movie": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "series": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "variety": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "documentary": "bg-gradient-to-br from-[#6b7280] to-[#374151]",
};

const books = (booksData as BookEntry[])
  .map((book, index) => ({
    id: `book-${index}`,
    title: book.title,
    subtitle: book.author || "Unknown author",
    format: "book" as const,
    rating: book.rating,
    tags: book.tags || [],
    notes: book.notes,
    meta: book.type,
    coverClass: (book.tags && book.tags[0] ? bookTagColors[book.tags[0]] : undefined) || defaultBookColor,
    aspectClass: "aspect-[2/3]",
    sortDate: book.endDate && book.endDate !== "-" ? book.endDate : undefined,
    year: undefined,
    cover: book.cover,
  }))
  .sort((a, b) => {
    if (!a.sortDate && !b.sortDate) return 0;
    if (!a.sortDate) return 1;
    if (!b.sortDate) return -1;
    return new Date(b.sortDate).valueOf() - new Date(a.sortDate).valueOf();
  });

const media = (mediaData as MediaEntry[])
  .map((item, index) => ({
    id: `media-${index}`,
    title: item.title,
    subtitle: item.type === "movie" ? "Film" : item.type === "series" ? "Series" : item.type === "documentary" ? "Documentary" : "Variety",
    format: item.type,
    rating: undefined,
    tags: item.tags || [],
    notes: item.notes,
    meta: undefined,
    coverClass: mediaTypeColors[item.type] || defaultBookColor,
    aspectClass: "aspect-video",
    sortDate: undefined,
    year: item.year,
    cover: undefined,
  }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));

const films = media.filter((item) => item.format === "movie");
const series = media.filter((item) => item.format === "series");
const variety = media.filter((item) => item.format === "variety");
const documentary = media.filter((item) => item.format === "documentary");

const meta = {
  title: "Rex's Library — Lab",
  description: "Books, films, and shows that shaped how Rex thinks.",
};

// Stats for count-up
const statsBookNotes = books.filter(b => hasNotes(b)).length;
const statsMediaNotes = media.filter(m => hasNotes(m)).length;

function formatType(format: LibraryItem["format"]) {
  return format === "book"
    ? "Book"
    : format === "movie"
      ? "Film"
      : format === "series"
        ? "Series"
        : "Variety";
}

function hasNotes(item: LibraryItem) {
  return !!(
    item.notes &&
    ((item.notes.quotes && item.notes.quotes.length > 0) ||
      (item.notes.core_ideas && item.notes.core_ideas.length > 0) ||
      (item.notes.impact && item.notes.impact.trim().length > 0))
  );
}

function badgeLine(item: LibraryItem) {
  const bits = [];
  if (item.rating) bits.push(item.rating);
  bits.push(formatType(item.format));
  if (item.meta) bits.push(item.meta);
  if (item.year) bits.push(String(item.year));
  if (item.tags.length) bits.push(item.tags.join(" · "));
  return bits.join(" · ");
}

---

<PageLayout meta={meta}>
  <section class="mb-12">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
      ← Lab
    </a>
    <h1 class="hero-reveal-text mt-4 mb-4 font-serif text-4xl font-bold dark:text-white">
      Rex's Library
    </h1>
    <p class="hero-reveal-subtitle lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      Books, films, and shows that shaped how I think.
    </p>
    <p class="hero-reveal-subtitle lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      读过的书、看过的片，塑造了现在的我。
    </p>
    <p class="mt-4 font-serif text-sm text-gray-400 dark:text-gray-500">
      <span data-countup={books.length}>0</span> books · <span data-countup={statsBookNotes + statsMediaNotes}>0</span> with notes · <span data-countup={media.length}>0</span> films & shows
    </p>
  </section>

  <section class="mb-4 fade-in-up" style="--delay: 120ms">
    <div class="flex flex-wrap gap-6 border-b border-gray-200 font-serif text-sm dark:border-gray-800">
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-[#8953d1] pb-3 font-medium text-[#8953d1] transition-colors dark:text-[#a175e8]" data-tab-button data-tab-target="books" aria-pressed="true">
        <span>📚 Books ({books.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="film-tv" aria-pressed="false">
        <span>🎬 Film & TV ({media.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="variety" aria-pressed="false">
        <span>🎭 Variety ({variety.length})</span>
      </button>
      <button type="button" class="library-tab inline-flex items-center gap-2 border-b-2 border-transparent pb-3 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]" data-tab-button data-tab-target="documentary" aria-pressed="false">
        <span>🎬 Documentary ({documentary.length})</span>
      </button>
    </div>
  </section>

  <section class="mb-10 fade-in-up" style="--delay: 140ms">
    <div id="library-tag-filters" class="flex flex-wrap gap-3"></div>
  </section>

  <section data-tab-panel="books" class="library-panel space-y-4">
    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
      {books.map((item, index) => {
        const expandable = hasNotes(item);
        return (
          <Fragment>
            <article
              class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15"
              style={`--delay: ${180 + index * 30}ms`}
              data-library-item
              data-tab-group="books"
              data-tags={JSON.stringify(item.tags || [])}
            >
              {expandable ? (
                <button
                  type="button"
                  class="block w-full text-left"
                  data-library-toggle
                  data-target={item.id}
                  aria-expanded="false"
                >
                  {item.cover ? (
                    <img
                      src={item.cover}
                      alt={`${item.title} cover`}
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`}
                    />
                  ) : (
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}>
                      <span class="font-serif text-base font-medium text-white">{item.title}</span>
                    </div>
                  )}
                  <h2 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h2>
                  <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">{item.subtitle}</p>
                  {(item.rating || expandable) && (
                    <div class="mt-3 flex flex-wrap items-center gap-3 font-serif text-xs text-gray-400 dark:text-gray-500">
                      {item.rating && <span>⭐ {item.rating}</span>}
                      {expandable && <span>💬 Notes</span>}
                    </div>
                  )}
                </button>
              ) : (
                <div>
                  {item.cover ? (
                    <img
                      src={item.cover}
                      alt={`${item.title} cover`}
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      class={`mb-4 block w-full ${item.aspectClass} rounded-md object-cover object-center`}
                    />
                  ) : (
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}>
                      <span class="font-serif text-base font-medium text-white">{item.title}</span>
                    </div>
                  )}
                  <h2 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h2>
                  <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">{item.subtitle}</p>
                  {item.rating && (
                    <div class="mt-3 flex flex-wrap items-center gap-3 font-serif text-xs text-gray-400 dark:text-gray-500">
                      <span>⭐ {item.rating}</span>
                    </div>
                  )}
                </div>
              )}
            </article>
            {expandable && (
              <div
                id={item.id}
                class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15"
                style={`--delay: ${210 + index * 30}ms`}
                data-library-detail
                data-detail-for={item.id}
                data-tab-group="books"
              >
                <div class="mb-3 flex flex-wrap items-baseline gap-x-3 gap-y-2">
                  <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  <p class="font-serif text-sm text-gray-400 dark:text-gray-500">{item.subtitle}</p>
                </div>
                <p class="font-serif text-sm text-gray-400 dark:text-gray-500">{badgeLine(item)}</p>
                {item.notes?.quotes && item.notes.quotes.length > 0 && (
                  <div class="mt-4 space-y-3">
                    {item.notes.quotes.map((quote) => (
                      <blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                        {quote}
                      </blockquote>
                    ))}
                  </div>
                )}
                {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (
                  <ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                    {item.notes.core_ideas.map((idea) => (
                      <li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>
                    ))}
                  </ul>
                )}
                {item.notes?.impact && item.notes.impact.trim() && (
                  <p class="mt-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                    {item.notes.impact}
                  </p>
                )}
              </div>
            )}
          </Fragment>
        );
      })}
    </div>
  </section>

  <section data-tab-panel="film-tv" class="library-panel hidden space-y-10">
    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-serif text-lg font-medium text-black dark:text-white">🎬 Films</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {films.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${180 + index * 30}ms`} data-library-item data-tab-group="film-tv" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Film · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500">💬 Notes</div>
                  </button>
                ) : (
                  <div>
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Film · {item.year || "—"}</p>
                  </div>
                )}
              </article>
              {expandable && (
                <div id={item.id} class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15" data-library-detail data-detail-for={item.id} data-tab-group="film-tv">
                  <h3 class="mb-3 font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                </div>
              )}
            </Fragment>
          );
        })}
      </div>
    </div>

    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-serif text-lg font-medium text-black dark:text-white">📺 Series</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {series.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${220 + index * 30}ms`} data-library-item data-tab-group="film-tv" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Series · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500">💬 Notes</div>
                  </button>
                ) : (
                  <div>
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Series · {item.year || "—"}</p>
                  </div>
                )}
              </article>
              {expandable && (
                <div id={item.id} class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15" data-library-detail data-detail-for={item.id} data-tab-group="film-tv">
                  <h3 class="mb-3 font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                </div>
              )}
            </Fragment>
          );
        })}
      </div>
    </div>
  </section>

  <section data-tab-panel="variety" class="library-panel hidden">
    {variety.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {variety.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${180 + index * 30}ms`} data-library-item data-tab-group="variety" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Variety · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500">💬 Notes</div>
                  </button>
                ) : (
                  <div>
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Variety · {item.year || "—"}</p>
                  </div>
                )}
              </article>
              {expandable && (
                <div id={item.id} class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15" data-library-detail data-detail-for={item.id} data-tab-group="variety">
                  <h3 class="mb-3 font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                </div>
              )}
            </Fragment>
          );
        })}
      </div>
    ) : (
      <div class="glow-card fade-in-up rounded-lg border border-dashed border-purple-500/20 px-5 py-8 font-serif text-sm text-gray-400 dark:border-purple-500/15 dark:text-gray-500" style="--delay: 180ms">
        Rex will add variety shows here later.
      </div>
    )}
  </section>

  <section data-tab-panel="documentary" class="library-panel hidden">
    {documentary.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {documentary.map((item, index) => {
          const expandable = hasNotes(item);
          return (
            <Fragment>
              <article class="library-card glow-card fade-in-up rounded-lg border border-purple-500/20 p-4 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15" style={`--delay: ${180 + index * 30}ms`} data-library-item data-tab-group="documentary" data-tags={JSON.stringify(item.tags || [])}>
                {expandable ? (
                  <button type="button" class="block w-full text-left" data-library-toggle data-target={item.id} aria-expanded="false">
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Documentary · {item.year || "—"}</p>
                    <div class="mt-3 font-serif text-xs text-gray-400 dark:text-gray-500">💬 Notes</div>
                  </button>
                ) : (
                  <div>
                    <div class={`mb-4 flex ${item.aspectClass} items-center justify-center rounded-md px-4 text-center ${item.coverClass}`}><span class="font-serif text-base font-medium text-white">{item.title}</span></div>
                    <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">Documentary · {item.year || "—"}</p>
                  </div>
                )}
              </article>
              {expandable && (
                <div id={item.id} class="library-details col-span-full hidden fade-in-up rounded-lg border border-purple-500/20 px-5 py-4 dark:border-purple-500/15" data-library-detail data-detail-for={item.id} data-tab-group="documentary">
                  <h3 class="mb-3 font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[var(--color-quote)] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                </div>
              )}
            </Fragment>
          );
        })}
      </div>
    ) : (
      <div class="glow-card fade-in-up rounded-lg border border-dashed border-purple-500/20 px-5 py-8 font-serif text-sm text-gray-400 dark:border-purple-500/15 dark:text-gray-500" style="--delay: 180ms">
        Rex will add documentaries here later.
      </div>
    )}
  </section>

  <!-- Notes Modal -->
  <div id="library-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background:rgba(0,0,0,0.6);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)">
    <div id="library-modal-content" class="relative max-h-[80vh] w-full max-w-xl overflow-y-auto rounded-xl border border-purple-500/30 bg-white/95 px-6 py-5 shadow-2xl dark:bg-gray-900/95 dark:border-purple-500/20" style="transform:scale(0.95);opacity:0;transition:transform 0.2s ease,opacity 0.2s ease">
      <button type="button" id="library-modal-close" class="absolute right-4 top-4 font-serif text-lg text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">✕</button>
      <div id="library-modal-body"></div>
    </div>
  </div>

  <style>
    .library-card { perspective: 800px; }
    .library-card-inner { transition: transform 0.3s ease, box-shadow 0.3s ease; transform-style: preserve-3d; }
    .library-card.scroll-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .library-card.scroll-reveal.revealed { opacity: 1; transform: translateY(0); }
    .library-panel { transition: opacity 0.2s ease; }
    .library-panel.fading { opacity: 0; }
    #library-modal.modal-open { display: flex; }
    #library-modal.modal-open #library-modal-content { transform: scale(1); opacity: 1; }
  </style>

  <script is:inline>
    const tabButtons = Array.from(document.querySelectorAll('[data-tab-button]'));
    const tabPanels = Array.from(document.querySelectorAll('[data-tab-panel]'));
    const detailPanels = Array.from(document.querySelectorAll('[data-library-detail]'));
    const detailButtons = Array.from(document.querySelectorAll('[data-library-toggle]'));
    const tagFilterRoot = document.getElementById('library-tag-filters');
    const libraryItems = Array.from(document.querySelectorAll('[data-library-item]'));
    const cards = Array.from(document.querySelectorAll('.library-card'));
    const modal = document.getElementById('library-modal');
    const modalBody = document.getElementById('library-modal-body');
    const modalClose = document.getElementById('library-modal-close');
    let activeTab = 'books';
    let activeTag = '全部';

    // === COUNT-UP ANIMATION ===
    document.querySelectorAll('[data-countup]').forEach(el => {
      const target = parseInt(el.dataset.countup, 10);
      const duration = 1000;
      const start = performance.now();
      const step = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });

    // === 3D TILT EFFECT ===
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(800px) rotateY(${x * 12}deg) rotateX(${-y * 12}deg)`;
        card.style.boxShadow = `${-x * 15}px ${y * 15}px 30px rgba(137,83,209,0.12)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
        card.style.boxShadow = '';
      });
    });

    // === SCROLL REVEAL ===
    cards.forEach(card => card.classList.add('scroll-reveal'));
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const card = entry.target;
          const siblings = Array.from(card.parentElement?.querySelectorAll('.scroll-reveal:not(.revealed)') || []);
          const idx = siblings.indexOf(card);
          setTimeout(() => card.classList.add('revealed'), Math.max(0, idx) * 50);
          revealObserver.unobserve(card);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px 50px 0px' });
    cards.forEach(card => revealObserver.observe(card));

    // === MODAL ===
    const openModal = (detailEl) => {
      if (!modal || !modalBody || !detailEl) return;
      modalBody.innerHTML = detailEl.innerHTML;
      modal.classList.add('modal-open');
      document.body.style.overflow = 'hidden';
    };
    const closeModal = () => {
      if (!modal) return;
      modal.classList.remove('modal-open');
      document.body.style.overflow = '';
    };
    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    // === TAB SWITCHING WITH FADE ===
    const closeAllDetails = () => {
      detailPanels.forEach((panel) => panel.classList.add('hidden'));
      detailButtons.forEach((button) => button.setAttribute('aria-expanded', 'false'));
    };

    const createTagButton = (label, selected) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.dataset.tagFilter = label;
      button.textContent = label;
      button.className = 'glow-card inline-flex items-center rounded-full border px-4 py-2 font-serif text-sm transition-all';
      if (selected) {
        button.classList.add('border-[#8953d1]', 'bg-[#8953d1]', 'text-white', 'dark:border-[#a175e8]', 'dark:bg-[#a175e8]', 'dark:text-black');
      } else {
        button.classList.add('border-purple-500/20', 'text-gray-500', 'hover:border-[#8953d1]', 'hover:text-[#8953d1]', 'dark:border-purple-500/15', 'dark:text-gray-400', 'dark:hover:border-[#a175e8]', 'dark:hover:text-[#a175e8]');
      }
      button.addEventListener('click', () => {
        activeTag = label === '全部' ? '全部' : activeTag === label ? '全部' : label;
        closeAllDetails();
        renderTagFilters();
        applyFilters();
      });
      return button;
    };

    const tagsForTab = (tab) => {
      const tags = new Set();
      libraryItems.filter((item) => item.dataset.tabGroup === tab).forEach((item) => {
        try { JSON.parse(item.dataset.tags || '[]').forEach((tag) => tags.add(tag)); } catch {}
      });
      return ['全部', ...Array.from(tags).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN'))];
    };

    const renderTagFilters = () => {
      if (!tagFilterRoot) return;
      const tags = tagsForTab(activeTab);
      if (!tags.includes(activeTag)) activeTag = '全部';
      tagFilterRoot.replaceChildren(...tags.map((tag) => createTagButton(tag, tag === activeTag)));
    };

    const applyFilters = () => {
      libraryItems.forEach((item) => {
        const inActiveTab = item.dataset.tabGroup === activeTab;
        let matchesTag = true;
        if (activeTag !== '全部') {
          try { matchesTag = JSON.parse(item.dataset.tags || '[]').includes(activeTag); } catch { matchesTag = false; }
        }
        item.classList.toggle('hidden', !(inActiveTab && matchesTag));
      });
      detailPanels.forEach((panel) => {
        const button = detailButtons.find((item) => item.dataset.target === panel.dataset.detailFor);
        const ownerCard = button?.closest('[data-library-item]');
        const shouldHide = !ownerCard || ownerCard.classList.contains('hidden') || panel.dataset.tabGroup !== activeTab;
        if (shouldHide) panel.classList.add('hidden');
      });
    };

    const setActiveTab = (target) => {
      // Fade out current panel
      const currentPanel = tabPanels.find(p => p.dataset.tabPanel === activeTab);
      const newPanel = tabPanels.find(p => p.dataset.tabPanel === target);

      if (currentPanel && newPanel && currentPanel !== newPanel) {
        currentPanel.classList.add('fading');
        setTimeout(() => {
          activeTab = target;
          tabButtons.forEach((button) => {
            const active = button.dataset.tabTarget === target;
            button.setAttribute('aria-pressed', active ? 'true' : 'false');
            button.classList.toggle('border-[#8953d1]', active);
            button.classList.toggle('text-[#8953d1]', active);
            button.classList.toggle('dark:text-[#a175e8]', active);
            button.classList.toggle('border-transparent', !active);
            button.classList.toggle('text-gray-400', !active);
            button.classList.toggle('dark:text-gray-500', !active);
          });
          tabPanels.forEach((panel) => {
            panel.classList.remove('fading');
            panel.classList.toggle('hidden', panel.dataset.tabPanel !== target);
          });
          renderTagFilters();
          applyFilters();
          // Re-reveal cards in new panel
          newPanel.querySelectorAll('.library-card.scroll-reveal:not(.revealed)').forEach((card, i) => {
            setTimeout(() => card.classList.add('revealed'), i * 50);
          });
        }, 200);
      } else {
        activeTab = target;
        tabButtons.forEach((button) => {
          const active = button.dataset.tabTarget === target;
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
          button.classList.toggle('border-[#8953d1]', active);
          button.classList.toggle('text-[#8953d1]', active);
          button.classList.toggle('dark:text-[#a175e8]', active);
          button.classList.toggle('border-transparent', !active);
          button.classList.toggle('text-gray-400', !active);
          button.classList.toggle('dark:text-gray-500', !active);
        });
        tabPanels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.tabPanel !== target));
        renderTagFilters();
        applyFilters();
      }
    };

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        closeAllDetails();
        closeModal();
        activeTag = '全部';
        setActiveTab(button.dataset.tabTarget || 'books');
      });
    });

    // Notes → open modal instead of inline
    detailButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.dataset.target;
        const panel = targetId ? document.getElementById(targetId) : null;
        if (panel) openModal(panel);
      });
    });

    setActiveTab(activeTab);
  </script>
</PageLayout>
