---
import PageLayout from "@/layouts/Base.astro";
import booksData from "@/data/books.json";
import mediaData from "@/data/media.json";

type Notes = {
  quotes?: string[];
  core_ideas?: string[];
  impact?: string;
};

type BookEntry = {
  title: string;
  titleEn?: string;
  author?: string;
  status: string;
  type?: string;
  rating?: string | null;
  tags?: string[];
  endDate?: string;
  notes?: Notes;
  cover?: string;
};

type MediaEntry = {
  title: string;
  titleEn?: string;
  year?: number;
  status: string;
  type: "movie" | "series" | "variety" | "documentary";
  tags?: string[];
  notes?: Notes;
  cover?: string;
};

type LibraryItem = {
  id: string;
  title: string;
  titleEn: string | undefined;
  subtitle: string;
  format: "book" | "movie" | "series" | "variety" | "documentary";
  rating: string | null | undefined;
  tags: string[];
  notes: Notes | undefined;
  meta: string | undefined;
  sortDate: string | undefined;
  year: number | undefined;
  cover: string | undefined;
  coverClass: string;
};

const bookTagColors: Record<string, string> = {
  "投资": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "成长": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "文化": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "文学": "bg-gradient-to-br from-[#ec4899] to-[#be185d]",
  "古琴": "bg-gradient-to-br from-[#10b981] to-[#047857]",
  "写作": "bg-gradient-to-br from-[#6366f1] to-[#4338ca]",
};
const defaultBookColor = "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]";
const mediaTypeColors: Record<string, string> = {
  "movie": "bg-gradient-to-br from-[#8953d1] to-[#6b3fa0]",
  "series": "bg-gradient-to-br from-[#3b82f6] to-[#1d4ed8]",
  "variety": "bg-gradient-to-br from-[#f59e0b] to-[#d97706]",
  "documentary": "bg-gradient-to-br from-[#6b7280] to-[#374151]",
};

function hasNotes(item: LibraryItem) {
  return !!(
    item.notes &&
    ((item.notes.quotes && item.notes.quotes.length > 0) ||
      (item.notes.core_ideas && item.notes.core_ideas.length > 0) ||
      (item.notes.impact && item.notes.impact.trim().length > 0))
  );
}

const books: LibraryItem[] = (booksData as BookEntry[])
  .map((book, index) => ({
    id: `book-${index}`,
    title: book.title,
    titleEn: book.titleEn,
    subtitle: book.author || "Unknown author",
    format: "book" as const,
    rating: book.rating,
    tags: book.tags || [],
    notes: book.notes,
    meta: book.type,
    sortDate: book.endDate && book.endDate !== "-" ? book.endDate : undefined,
    year: undefined,
    cover: book.cover,
    coverClass: (book.tags && book.tags[0] ? bookTagColors[book.tags[0]] : undefined) || defaultBookColor,
  }))
  .sort((a, b) => {
    if (!a.sortDate && !b.sortDate) return 0;
    if (!a.sortDate) return 1;
    if (!b.sortDate) return -1;
    return new Date(b.sortDate).valueOf() - new Date(a.sortDate).valueOf();
  });

const media: LibraryItem[] = (mediaData as MediaEntry[])
  .map((item, index) => ({
    id: `media-${index}`,
    title: item.title,
    titleEn: item.titleEn,
    subtitle: item.type === "movie" ? "Film" : item.type === "series" ? "Series" : item.type === "documentary" ? "Documentary" : "Variety",
    format: item.type,
    rating: undefined,
    tags: item.tags || [],
    notes: item.notes,
    meta: undefined,
    sortDate: undefined,
    year: item.year,
    cover: item.cover,
    coverClass: mediaTypeColors[item.type] || defaultBookColor,
  }))
  .sort((a, b) => (b.year || 0) - (a.year || 0));

const films = media.filter((item) => item.format === "movie");
const series = media.filter((item) => item.format === "series");
const variety = media.filter((item) => item.format === "variety");
const documentary = media.filter((item) => item.format === "documentary");

const meta = {
  title: "Library — Lab",
  description: "Books, films, and shows that shaped how Rex thinks.",
};

const statsWithNotes = books.filter(b => hasNotes(b)).length + media.filter(m => hasNotes(m)).length;


---

<PageLayout meta={meta}>
  <!-- Header -->
  <section class="mb-12">
    <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">← Lab</a>
    <h1 class="mt-4 mb-4 font-serif text-4xl font-bold dark:text-white"><span class="lang-en">Library</span><span class="lang-zh">书影音</span></h1>
    <p class="lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">Books, films, and shows that shaped how I think.</p>
    <p class="lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">读过的书、看过的片，塑造了现在的我。</p>
    <p class="mt-4 font-serif text-sm text-gray-400 dark:text-gray-500">
      <span data-countup={books.length}>0</span>
      <span class="lang-en"> books</span><span class="lang-zh"> 本书</span> ·
      <span data-countup={statsWithNotes}>0</span>
      <span class="lang-en"> with notes</span><span class="lang-zh"> 有笔记</span> ·
      <span data-countup={media.length}>0</span>
      <span class="lang-en"> films & shows</span><span class="lang-zh"> 部影视</span>
    </p>
  </section>

  <!-- Tabs -->
  <section class="mb-4">
    <div class="flex flex-wrap gap-6 border-b border-gray-200 font-serif text-sm dark:border-gray-800">
      <button type="button" class="lib-tab border-b-2 border-[#8953d1] pb-3 font-medium text-[#8953d1] dark:text-[#a175e8]" data-tab="books" aria-pressed="true">
        <span class="lang-en">📚 Books ({books.length})</span><span class="lang-zh">📚 书籍 ({books.length})</span>
      </button>
      <button type="button" class="lib-tab border-b-2 border-transparent pb-3 text-gray-400 hover:text-[#8953d1] dark:text-gray-500" data-tab="film-tv" aria-pressed="false">
        <span class="lang-en">🎬 Film & TV ({films.length + series.length})</span><span class="lang-zh">🎬 影视 ({films.length + series.length})</span>
      </button>
      <button type="button" class="lib-tab border-b-2 border-transparent pb-3 text-gray-400 hover:text-[#8953d1] dark:text-gray-500" data-tab="variety" aria-pressed="false">
        <span class="lang-en">🎭 Variety ({variety.length})</span><span class="lang-zh">🎭 综艺 ({variety.length})</span>
      </button>
      <button type="button" class="lib-tab border-b-2 border-transparent pb-3 text-gray-400 hover:text-[#8953d1] dark:text-gray-500" data-tab="documentary" aria-pressed="false">
        <span class="lang-en">🎬 Doc ({documentary.length})</span><span class="lang-zh">🎬 纪录片 ({documentary.length})</span>
      </button>
    </div>
  </section>

  <!-- Tag Filters -->
  <section class="mb-8">
    <div id="tag-filters" class="flex flex-wrap gap-3"></div>
  </section>

  <!-- ===== BOOKS PANEL ===== -->
  <section data-panel="books" class="lib-panel">
    <!-- View toggle -->
    <div class="mb-5 flex items-center justify-between">
      <div class="font-serif text-xs text-gray-400 dark:text-gray-500">
        <span class="lang-zh">按标签筛选，可切换网格和书架视图</span>
        <span class="lang-en">Filter by tag, toggle grid or shelf view</span>
      </div>
      <div class="inline-flex items-center rounded-full border border-purple-500/20 bg-white/70 p-1 text-sm shadow-sm backdrop-blur dark:border-purple-500/15 dark:bg-gray-900/60">
        <button type="button" id="view-btn-grid" class="lib-view-toggle rounded-full bg-[#8953d1] px-3 py-1.5 font-serif text-xs text-white dark:bg-[#a175e8] dark:text-black" aria-pressed="true">
          <span class="lang-en">📚 Grid</span><span class="lang-zh">📚 网格</span>
        </button>
        <button type="button" id="view-btn-shelf" class="lib-view-toggle rounded-full px-3 py-1.5 font-serif text-xs text-gray-500 hover:text-[#8953d1] dark:text-gray-400 dark:hover:text-[#a175e8]" aria-pressed="false">
          <span class="lang-en">📖 Shelf</span><span class="lang-zh">📖 书架</span>
        </button>
      </div>
    </div>

    <!-- Grid view -->
    <div id="books-grid-view" class="books-grid-view">
    <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4" id="books-grid">
      {books.map((item) => (
        <Fragment>
          <article
            class="lib-card group cursor-pointer rounded-lg border border-purple-500/20 p-3 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-purple-500/15"
            data-id={item.id}
            data-tags={JSON.stringify(item.tags)}
            data-group="books"
          >
            {item.cover ? (
              <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-3 block w-full aspect-[2/3] rounded-md object-cover object-center" />
            ) : (
              <div class={`mb-3 flex w-full aspect-[2/3] items-center justify-center rounded-md px-3 text-center ${item.coverClass}`}>
                <span class="font-serif text-sm font-medium text-white">{item.title}</span>
              </div>
            )}
            <h2 class="font-serif text-sm font-medium text-black dark:text-white leading-snug">{item.title}</h2>
            {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
            <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500">{item.subtitle}</p>
            <div class="mt-2 flex items-center gap-2 font-serif text-xs text-gray-400 dark:text-gray-500">
              {item.rating && <span>⭐ {item.rating}</span>}
              {hasNotes(item) && (
                <span class="text-[#8953d1] dark:text-[#a175e8]">
                  <span class="lang-en">💬 Notes</span><span class="lang-zh">💬 笔记</span>
                </span>
              )}
            </div>
          </article>
          <!-- Inline detail (inserted after row via JS) -->
          <div class="lib-detail hidden" data-detail={item.id}>
            <div class="flex flex-col sm:flex-row gap-5">
              {item.cover ? (
                <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="w-28 sm:w-36 aspect-[2/3] rounded-md object-cover object-center shrink-0 shadow-lg" />
              ) : (
                <div class={`w-28 sm:w-36 aspect-[2/3] flex items-center justify-center rounded-md px-3 text-center shrink-0 shadow-lg ${item.coverClass}`}>
                  <span class="font-serif text-sm font-medium text-white">{item.title}</span>
                </div>
              )}
              <div class="flex-1 min-w-0">
                <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                {item.titleEn && <p class="mt-0.5 font-serif text-sm text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                <p class="mt-1 font-serif text-sm text-gray-400 dark:text-gray-500">
                  {item.subtitle}
                  {item.rating && <span> · {item.rating}</span>}
                  {item.tags.length > 0 && <span> · {item.tags.join(" · ")}</span>}
                </p>
                {item.notes?.quotes && item.notes.quotes.length > 0 && (
                  <div class="mt-4 space-y-3">
                    {item.notes.quotes.map((q) => (
                      <blockquote class="border-l-2 border-[#8953d1] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300 dark:border-[#a175e8]">{q}</blockquote>
                    ))}
                  </div>
                )}
                {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (
                  <ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                    {item.notes.core_ideas.map((idea) => (
                      <li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>
                    ))}
                  </ul>
                )}
                {item.notes?.impact && item.notes.impact.trim() && (
                  <p class="mt-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.impact}</p>
                )}
                {!hasNotes(item) && (
                  <p class="mt-4 font-serif text-sm text-gray-500 dark:text-gray-400">
                    <span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span>
                  </p>
                )}
              </div>
            </div>
          </div>
        </Fragment>
      ))}
    </div>
    </div>{/* end books-grid-view */}

    <!-- Shelf view -->
    <div id="books-shelf-view" class="books-shelf-view">
      <div class="lib-shelf-stage" id="lib-shelf-stage">
        {/* Books are injected here by JS */}
        {books.map((item, index) => {
          const spineHeight = 180 + (index * 17) % 41;
          return (
            <button
              type="button"
              class="shelf-book"
              style={`--shelf-height: ${spineHeight}px; display:none`}
              data-shelf-book
              data-id={item.id}
              data-tags={JSON.stringify(item.tags)}
              data-group="books"
            >
              <span class="shelf-book-preview">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="h-full w-full object-cover object-center" />
                ) : (
                  <span class={`flex h-full w-full items-center justify-center px-2 text-center ${item.coverClass}`}>
                    <span class="font-serif text-xs font-medium leading-snug text-white">{item.title}</span>
                  </span>
                )}
              </span>
              <span class={`shelf-spine ${item.coverClass}`}>
                <span class="shelf-spine-sheen"></span>
                <span class="shelf-spine-title">{item.title}</span>
                {!!(item.notes && ((item.notes.quotes && item.notes.quotes.length > 0) || (item.notes.core_ideas && item.notes.core_ideas.length > 0))) && (
                  <span class="shelf-spine-dot"></span>
                )}
              </span>
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== FILM & TV PANEL ===== -->
  <section data-panel="film-tv" class="lib-panel hidden">
    {films.length > 0 && (
      <div class="mb-10">
        <h2 class="mb-4 font-serif text-lg font-medium text-black dark:text-white">
          <span class="lang-en">🎬 Films</span><span class="lang-zh">🎬 电影</span>
        </h2>
        <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
          {films.map((item) => (
            <Fragment>
              <article class="lib-card group cursor-pointer rounded-lg border border-purple-500/20 p-3 transition-all hover:border-purple-500/40 dark:border-purple-500/15" data-id={item.id} data-tags={JSON.stringify(item.tags)} data-group="film-tv">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-3 block w-full aspect-[2/3] rounded-md object-cover object-center" />
                ) : (
                  <div class={`mb-3 flex w-full aspect-[2/3] items-center justify-center rounded-md px-3 text-center ${item.coverClass}`}><span class="font-serif text-sm font-medium text-white">{item.title}</span></div>
                )}
                <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Film</span><span class="lang-zh">电影</span> · {item.year || "—"}</p>
                {hasNotes(item) && <p class="mt-2 font-serif text-xs text-[#8953d1] dark:text-[#a175e8]"><span class="lang-en">💬 Notes</span><span class="lang-zh">💬 笔记</span></p>}
              </article>
              <div class="lib-detail hidden" data-detail={item.id}>
                <div class="flex flex-col sm:flex-row gap-5">
                  {item.cover ? (
                    <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="w-28 sm:w-36 aspect-[2/3] rounded-md object-cover shrink-0 shadow-lg" />
                  ) : (
                    <div class={`w-28 sm:w-36 aspect-[2/3] flex items-center justify-center rounded-md shrink-0 shadow-lg ${item.coverClass}`}><span class="font-serif text-sm text-white">{item.title}</span></div>
                  )}
                  <div class="flex-1 min-w-0">
                    <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-sm text-gray-400">{item.year || "—"} · {item.tags.join(" · ")}</p>
                    {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[#8953d1] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300 dark:border-[#a175e8]">{q}</blockquote>))}</div>)}
                    {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                    {!hasNotes(item) && <p class="mt-4 font-serif text-sm text-gray-500"><span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span></p>}
                  </div>
                </div>
              </div>
            </Fragment>
          ))}
        </div>
      </div>
    )}
    {series.length > 0 && (
      <div>
        <h2 class="mb-4 font-serif text-lg font-medium text-black dark:text-white">
          <span class="lang-en">📺 Series</span><span class="lang-zh">📺 剧集</span>
        </h2>
        <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
          {series.map((item) => (
            <Fragment>
              <article class="lib-card group cursor-pointer rounded-lg border border-purple-500/20 p-3 transition-all hover:border-purple-500/40 dark:border-purple-500/15" data-id={item.id} data-tags={JSON.stringify(item.tags)} data-group="film-tv">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-3 block w-full aspect-[2/3] rounded-md object-cover object-center" />
                ) : (
                  <div class={`mb-3 flex w-full aspect-[2/3] items-center justify-center rounded-md px-3 text-center ${item.coverClass}`}><span class="font-serif text-sm font-medium text-white">{item.title}</span></div>
                )}
                <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
                {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
                <p class="mt-1 font-serif text-xs text-gray-400 dark:text-gray-500"><span class="lang-en">Series</span><span class="lang-zh">剧集</span> · {item.year || "—"}</p>
                {hasNotes(item) && <p class="mt-2 font-serif text-xs text-[#8953d1] dark:text-[#a175e8]"><span class="lang-en">💬 Notes</span><span class="lang-zh">💬 笔记</span></p>}
              </article>
              <div class="lib-detail hidden" data-detail={item.id}>
                <div class="flex flex-col sm:flex-row gap-5">
                  {item.cover ? (
                    <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="w-28 sm:w-36 aspect-[2/3] rounded-md object-cover shrink-0 shadow-lg" />
                  ) : (
                    <div class={`w-28 sm:w-36 aspect-[2/3] flex items-center justify-center rounded-md shrink-0 shadow-lg ${item.coverClass}`}><span class="font-serif text-sm text-white">{item.title}</span></div>
                  )}
                  <div class="flex-1 min-w-0">
                    <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                    <p class="mt-1 font-serif text-sm text-gray-400">{item.year || "—"} · {item.tags.join(" · ")}</p>
                    {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[#8953d1] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300 dark:border-[#a175e8]">{q}</blockquote>))}</div>)}
                    {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                    {!hasNotes(item) && <p class="mt-4 font-serif text-sm text-gray-500"><span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span></p>}
                  </div>
                </div>
              </div>
            </Fragment>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- ===== VARIETY PANEL ===== -->
  <section data-panel="variety" class="lib-panel hidden">
    {variety.length > 0 ? (
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {variety.map((item) => (
          <Fragment>
            <article class="lib-card group cursor-pointer rounded-lg border border-purple-500/20 p-3 transition-all hover:border-purple-500/40 dark:border-purple-500/15" data-id={item.id} data-tags={JSON.stringify(item.tags)} data-group="variety">
              {item.cover ? (
                <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-3 block w-full aspect-[2/3] rounded-md object-cover object-center" />
              ) : (
                <div class={`mb-3 flex w-full aspect-[2/3] items-center justify-center rounded-md px-3 text-center ${item.coverClass}`}><span class="font-serif text-sm font-medium text-white">{item.title}</span></div>
              )}
              <h3 class="font-serif text-sm font-medium text-black dark:text-white">{item.title}</h3>
              {item.titleEn && <p class="mt-0.5 font-serif text-xs text-gray-400 dark:text-gray-500">{item.titleEn}</p>}
              <p class="mt-1 font-serif text-xs text-gray-400"><span class="lang-en">Variety</span><span class="lang-zh">综艺</span> · {item.year || "—"}</p>
              {hasNotes(item) && <p class="mt-2 font-serif text-xs text-[#8953d1] dark:text-[#a175e8]">💬</p>}
            </article>
            <div class="lib-detail hidden" data-detail={item.id}>
              <div class="flex flex-col sm:flex-row gap-5">
                {item.cover ? (
                  <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="w-28 sm:w-36 aspect-[2/3] rounded-md object-cover shrink-0 shadow-lg" />
                ) : (
                  <div class={`w-28 sm:w-36 aspect-[2/3] flex items-center justify-center rounded-md shrink-0 shadow-lg ${item.coverClass}`}><span class="font-serif text-sm text-white">{item.title}</span></div>
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif text-lg font-medium text-black dark:text-white">{item.title}</h3>
                  <p class="mt-1 font-serif text-sm text-gray-400">{item.year || "—"}</p>
                  {item.notes?.quotes && item.notes.quotes.length > 0 && (<div class="mt-4 space-y-3">{item.notes.quotes.map((q) => (<blockquote class="border-l-2 border-[#8953d1] pl-4 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300 dark:border-[#a175e8]">{q}</blockquote>))}</div>)}
                  {item.notes?.core_ideas && item.notes.core_ideas.length > 0 && (<ul class="mt-4 space-y-2 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-300">{item.notes.core_ideas.map((idea) => (<li class="flex gap-2"><span class="text-[#8953d1] dark:text-[#a175e8]">•</span><span>{idea}</span></li>))}</ul>)}
                  {!hasNotes(item) && <p class="mt-4 font-serif text-sm text-gray-500"><span class="lang-en">No notes yet.</span><span class="lang-zh">暂无笔记。</span></p>}
                </div>
              </div>
            </div>
          </Fragment>
        ))}
      </div>
    ) : (
      <p class="font-serif text-sm text-gray-400"><span class="lang-en">Coming soon.</span><span class="lang-zh">敬请期待。</span></p>
    )}
  </section>

  <!-- ===== DOCUMENTARY PANEL ===== -->
  <section data-panel="documentary" class="lib-panel hidden">
    {documentary.length > 0 ? (
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {documentary.map((item) => (
          <Fragment>
            <article class="lib-card group cursor-pointer rounded-lg border border-purple-500/20 p-3 transition-all hover:border-purple-500/40 dark:border-purple-500/15" data-id={item.id} data-tags={JSON.stringify(item.tags)} data-group="documentary">
              {item.cover ? (
                <img src={item.cover} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-3 block w-full aspect-[2/3] rounded-md object-cover object-center" />
              ) : (
                <div class={`mb-3 flex w-full aspect-[2/3] items-center justify-center rounded-md px-3 text-center ${item.coverClass}`}><span class="font-serif text-sm font-medium text-white">{item.title}</span></div>
