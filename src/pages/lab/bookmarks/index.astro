---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

const allBookmarks = await getCollection("bookmarks");
const sortedBookmarks = allBookmarks.sort(
	(a, b) => new Date(b.data.created_at).valueOf() - new Date(a.data.created_at).valueOf(),
);

const categories = ["all", "ai", "crypto", "macro", "builder", "life"] as const;
const categoryLabels: Record<string, { en: string; zh: string }> = {
	all: { en: "All", zh: "全部" },
	ai: { en: "AI", zh: "AI" },
	crypto: { en: "Crypto", zh: "加密" },
	macro: { en: "Macro", zh: "宏观" },
	builder: { en: "Builder", zh: "Builder" },
	life: { en: "Life", zh: "生活" },
};

const meta = {
	title: "Bookmarks — Lab",
	description: "Curated tweets worth revisiting — AI, Crypto, Macro and more.",
};

function formatShortDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<PageLayout meta={meta}>
	<section class="mb-12">
		<a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
			← Lab
		</a>
		<h1 class="hero-reveal-text mt-4 mb-4 font-serif text-4xl font-bold dark:text-white">
			<span class="lang-en">Bookmarks</span><span class="lang-zh">收藏夹</span>
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
			<span class="lang-en">Curated tweets worth revisiting.</span>
			<span class="lang-zh">值得反复看的推文。</span>
		</p>
	</section>

	<!-- Category Filter Tabs -->
	<section class="mb-8">
		<div class="flex flex-wrap gap-2" id="bookmark-filters">
			{categories.map((cat) => (
				<button
					data-filter={cat}
					class:list={[
						"bookmark-filter-btn rounded-full border px-3 py-1 font-serif text-xs transition-all cursor-pointer",
						cat === "all"
							? "border-[#8953d1] bg-[#8953d1]/10 text-[#8953d1] dark:border-[#a175e8] dark:bg-[#a175e8]/10 dark:text-[#a175e8]"
							: "border-gray-200 text-gray-500 hover:border-[#8953d1] hover:text-[#8953d1] dark:border-gray-700 dark:text-gray-400 dark:hover:border-[#a175e8] dark:hover:text-[#a175e8]",
					]}
				>
					<span class="lang-en">{categoryLabels[cat]?.en || cat}</span><span class="lang-zh">{categoryLabels[cat]?.zh || cat}</span>
				</button>
			))}
		</div>
	</section>

	<!-- Bookmarks List -->
	<section>
		<div class="grid gap-4 sm:grid-cols-2" id="bookmarks-list">
			{sortedBookmarks.map((bm, i) => (
				<a
					href={bm.data.url}
					target="_blank"
					rel="noopener noreferrer"
					class="glow-card fade-in-up bookmark-card group block rounded-lg border border-gray-200 p-5 transition-all hover:border-purple-500/40 hover:shadow-[0_0_20px_#8953d122] dark:border-gray-800 dark:hover:border-purple-500/30"
					data-categories={JSON.stringify(bm.data.categories)}
					style={`--delay: ${100 + Math.min(i, 20) * 40}ms`}
				>
					{/* Author row: avatar + name + handle + date */}
					<div class="mb-3 flex items-center gap-3">
						{bm.data.avatar ? (
							<img
								src={bm.data.avatar}
								alt={bm.data.author_name || bm.data.author}
								class="h-10 w-10 shrink-0 rounded-full"
								loading="lazy"
							/>
						) : (
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gray-200 font-serif text-sm font-medium text-gray-500 dark:bg-gray-700 dark:text-gray-400">
								{(bm.data.author_name || bm.data.author).charAt(0).toUpperCase()}
							</div>
						)}
						<div class="min-w-0 flex-1">
							<div class="flex items-baseline gap-1.5">
								<span class="truncate font-serif text-sm font-medium text-black dark:text-white">
									{bm.data.author_name || bm.data.author}
								</span>
								<span class="shrink-0 font-serif text-xs text-gray-400 dark:text-gray-500">
									@{bm.data.author}
								</span>
							</div>
							<time class="font-serif text-xs text-gray-400 dark:text-gray-500" datetime={bm.data.created_at.toISOString()}>
								{formatShortDate(bm.data.created_at)}
							</time>
						</div>
					</div>

					{/* Card/article title if present */}
					{bm.data.card_title && (
						<p class="mb-2 font-serif text-base font-medium leading-snug text-black dark:text-white">
							{bm.data.card_title}
						</p>
					)}

					{/* Tweet text */}
					<p class="bookmark-text mb-3 font-serif text-sm leading-relaxed text-gray-600 dark:text-gray-400">
						{bm.data.text}
					</p>

					{/* Footer: categories + likes */}
					<div class="flex items-center justify-between">
						<div class="flex flex-wrap gap-1.5">
							{bm.data.categories.map((cat: string) => (
								<span class="rounded-sm bg-gray-100 px-1.5 py-0.5 font-serif text-[10px] font-medium uppercase text-gray-500 dark:bg-gray-800 dark:text-gray-400">
									<span class="lang-en">{categoryLabels[cat]?.en || cat}</span><span class="lang-zh">{categoryLabels[cat]?.zh || cat}</span>
								</span>
							))}
						</div>
						<span class="flex items-center gap-1 font-serif text-xs text-gray-400 dark:text-gray-500">
							❤️ {bm.data.likes.toLocaleString()}
						</span>
					</div>
				</a>
			))}
		</div>

		<!-- Empty state -->
		<div id="bookmarks-empty" class="hidden py-12 text-center">
			<p class="font-serif text-gray-400 dark:text-gray-500">
				<span class="lang-en">No bookmarks in this category yet.</span>
				<span class="lang-zh">该分类暂无收藏。</span>
			</p>
		</div>
	</section>
</PageLayout>

<style>
	.bookmark-text {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.bookmark-card {
		background: #fffaef;
		box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
	}
	.bookmark-card:hover {
		box-shadow: 0 4px 12px rgba(137, 83, 209, 0.15);
	}
	:global([data-theme="dark"]) .bookmark-card {
		background: #181818;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
	}
	:global([data-theme="dark"]) .bookmark-card:hover {
		box-shadow: 0 4px 16px rgba(161, 117, 232, 0.2);
	}
</style>

<script>
	document.addEventListener("astro:page-load", () => {
		const filters = document.querySelectorAll<HTMLButtonElement>(".bookmark-filter-btn");
		const cards = document.querySelectorAll<HTMLElement>(".bookmark-card");
		const emptyState = document.getElementById("bookmarks-empty");

		filters.forEach((btn) => {
			btn.addEventListener("click", () => {
				const filter = btn.dataset.filter || "all";

				// Update active state (match AI Timeline style)
				filters.forEach((b) => {
					b.classList.remove("border-[#8953d1]", "bg-[#8953d1]/10", "text-[#8953d1]", "dark:border-[#a175e8]", "dark:bg-[#a175e8]/10", "dark:text-[#a175e8]");
					b.classList.add("border-gray-200", "text-gray-500", "dark:border-gray-700", "dark:text-gray-400");
				});
				btn.classList.remove("border-gray-200", "text-gray-500", "dark:border-gray-700", "dark:text-gray-400");
				btn.classList.add("border-[#8953d1]", "bg-[#8953d1]/10", "text-[#8953d1]", "dark:border-[#a175e8]", "dark:bg-[#a175e8]/10", "dark:text-[#a175e8]");

				// Filter cards
				let visibleCount = 0;
				cards.forEach((card) => {
					const cats: string[] = JSON.parse(card.dataset.categories || "[]");
					const show = filter === "all" || cats.includes(filter);
					card.style.display = show ? "" : "none";
					if (show) visibleCount++;
				});

				if (emptyState) {
					emptyState.classList.toggle("hidden", visibleCount > 0);
				}
			});
		});
	});
</script>
