---
import PageLayout from "@/layouts/Base.astro";
import PlayerStats from "@/components/lab/PlayerStats";
import { getCollection } from "astro:content";
import travelData from "../../../public/data/travel.json";
import mediaData from "../../data/media.json";

// ─── Data Collections ──────────────────────────────────────────────────────
const posts = await getCollection("post");
const digests = await getCollection("digest");
const builderLogs = await getCollection("builder-log");
const projects = await getCollection("projects");

// ─── Travel ────────────────────────────────────────────────────────────────
const nomadCities = (travelData as any).cities as Array<{
  id: string; name: string; nameCN: string; lat: number; lng: number;
  arrival: string; departure?: string;
}>;
const priorCities = ((travelData as any).priorCities ?? []) as Array<{
  id: string; name: string; nameCN: string; lat: number; lng: number;
}>;
const cities = [...nomadCities, ...priorCities];
const travelStart = new Date((travelData as any).meta.startDate);
const travelDays = Math.floor((Date.now() - travelStart.getTime()) / (1000 * 60 * 60 * 24));
const currentCityId = (travelData as any).meta.currentCity as string;
const currentCityObj = cities.find(c => c.id === currentCityId) ?? cities[cities.length - 1]!;

// ─── Tag Counts ────────────────────────────────────────────────────────────
const tagCounts: Record<string, number> = {};
for (const post of posts) {
  for (const tag of (post.data.tags ?? [])) {
    const t = tag.toLowerCase();
    tagCounts[t] = (tagCounts[t] ?? 0) + 1;
  }
}

// ─── Counts ─────────────────────────────────────────────────────────────────
const postCount = posts.length;
const digestCount = digests.length;
const builderLogCount = builderLogs.length;
const projectCount = projects.length;
const libraryCount = (mediaData as any[]).length;
const cityCount = cities.length;
const agents = 6;
const followers = 6400; // hardcoded per spec

// ─── EXP Calculation (real data driven) ─────────────────────────────────────
// Each post: +10 EXP, each library item: +3 EXP, each city: +5 EXP,
// each builder-log: +8 EXP, each digest: +2 EXP
const totalExp = postCount * 10 + libraryCount * 3 + cityCount * 5 + builderLogCount * 8 + digestCount * 2;

// Level = floor(sqrt(totalEXP / 10)), cap 99
const level = Math.min(99, Math.floor(Math.sqrt(totalExp / 10)));

// EXP for current level and next level
const currentLevelExp = level * level * 10;
const nextLevelExp = (level + 1) * (level + 1) * 10;
const expInLevel = totalExp - currentLevelExp;
const expNeeded = nextLevelExp - currentLevelExp;
const expProgress = Math.min(100, Math.round((expInLevel / expNeeded) * 100));

// ─── Six Stats (per design spec) ────────────────────────────────────────────
// 体魄 Vitality: cities * 5, cap 100
const vitality = Math.min(100, Math.round(cityCount * 5));

// 悟性 Wisdom: posts + library * 0.3, cap 100
const wisdom = Math.min(100, Math.round(postCount + libraryCount * 0.3));

// 声望 Renown: log10(followers) * 25, cap 100
const renown = Math.min(100, Math.round(Math.log10(followers) * 25));

// 统御 Command: agents * 8 + projects * 2, cap 100
const command = Math.min(100, Math.round(agents * 8 + projectCount * 2));

// 技巧 Craft: builder-logs * 3, cap 100
const craft = Math.min(100, Math.round(builderLogCount * 3));

// 见闻 Insight: (library + digest * 0.2) * 0.8, cap 100
const insight = Math.min(100, Math.round((libraryCount + digestCount * 0.2) * 0.8));

const stats = { vitality, wisdom, renown, command, craft, insight };
const avgStat = Math.round((vitality + wisdom + renown + command + craft + insight) / 6);

// ─── Rank ──────────────────────────────────────────────────────────────────
function getRank(avg: number): { zh: string; en: string } {
  if (avg >= 81) return { zh: "天下无双", en: "Sovereign" };
  if (avg >= 61) return { zh: "一方宗师", en: "Master" };
  if (avg >= 41) return { zh: "当堂护法", en: "Guardian" };
  if (avg >= 21) return { zh: "内门弟子", en: "Disciple" };
  return { zh: "初入江湖", en: "Novice" };
}
const rank = getRank(avgStat);

// ─── Achievements ──────────────────────────────────────────────────────────
const achievements = [
  {
    id: "first-post",
    icon: "⚔️", nameZh: "初出茅庐", nameEn: "First Post",
    descZh: "发布第一篇文章", descEn: "Published the first article",
    unlocked: postCount > 0, unlockedDate: "2025-12",
  },
  {
    id: "century-club",
    icon: "👑", nameZh: "千人之师", nameEn: "Century Club",
    descZh: "X 1000+ 关注者", descEn: "X 1000+ followers",
    unlocked: followers >= 1000, unlockedDate: "2023",
  },
  {
    id: "nomad",
    icon: "🗺️", nameZh: "行万里路", nameEn: "Nomad",
    descZh: "游历 5 座城市", descEn: "Visited 5 cities",
    unlocked: cityCount >= 5, unlockedDate: "2025-11",
  },
  {
    id: "bookworm",
    icon: "📚", nameZh: "博览群书", nameEn: "Bookworm",
    descZh: "涉猎 50+ 本书/影视", descEn: "50+ books & shows",
    unlocked: libraryCount >= 50, unlockedDate: "2026-03",
  },
  {
    id: "agent-commander",
    icon: "🤖", nameZh: "六脉神剑", nameEn: "Agent Commander",
    descZh: "统御 6 位 AI 门客", descEn: "Command 6 AI agents",
    unlocked: agents >= 6, unlockedDate: "2026-02",
  },
  {
    id: "midnight-builder",
    icon: "🌙", nameZh: "夜行衣", nameEn: "Midnight Builder",
    descZh: "造物日志 20+", descEn: "20+ builder logs",
    unlocked: builderLogCount >= 20, unlockedDate: "2026-03",
  },
  ...(cityCount >= 20 ? [{
    id: "world-traveler",
    icon: "🌏", nameZh: "游遍天下", nameEn: "World Traveler",
    descZh: "游历 20 座城市", descEn: "Visit 20 cities",
    unlocked: true, unlockedDate: "2026",
  }] : [{
    id: "world-traveler",
    icon: "🌏", nameZh: "游遍天下", nameEn: "World Traveler",
    descZh: "游历 20 座城市", descEn: "Visit 20 cities",
    unlocked: false, progress: cityCount, max: 20,
  }]),
  {
    id: "10k-club",
    icon: "🚀", nameZh: "名震江湖", nameEn: "10K Club",
    descZh: "X 10,000 关注者", descEn: "X 10,000 followers",
    unlocked: false, progress: followers, max: 10000,
  },
  ...(postCount >= 100 ? [{
    id: "author",
    icon: "📖", nameZh: "著作等身", nameEn: "Author",
    descZh: "著文 100 篇", descEn: "Write 100 articles",
    unlocked: true, unlockedDate: "2026",
  }] : [{
    id: "author",
    icon: "📖", nameZh: "著作等身", nameEn: "Author",
    descZh: "著文 100 篇", descEn: "Write 100 articles",
    unlocked: false, progress: postCount, max: 100,
  }]),
];

// ─── Cultivation Log (ALL historical data) ──────────────────────────────────
type ActivityItem = {
  dateRaw: Date;
  dateEn: string;
  dateZh: string;
  icon: string;
  statZh: string;
  statEn: string;
  exp: number;
  descZh: string;
  descEn: string;
  type: string;
};

const allActivity: ActivityItem[] = [];
const months = ["一月","二月","三月","四月","五月","六月","七月","八月","九月","十月","十一月","十二月"];

function fmtDate(d: Date) {
  const dateZh = `${d.getFullYear()}年${months[d.getMonth()]}${d.getDate()}日`;
  const dateEn = d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
  return { dateZh, dateEn };
}

// Posts: +10 EXP each
for (const post of posts) {
  const d = new Date(post.data.publishDate);
  const { dateZh, dateEn } = fmtDate(d);
  allActivity.push({
    dateRaw: d, dateZh, dateEn,
    icon: "✍️", statZh: "悟性", statEn: "Wisdom", exp: 10,
    descZh: `著文《${post.data.title}》`, descEn: `Published "${post.data.title}"`,
    type: "post",
  });
}

// Builder Logs: +8 EXP each
for (const log of builderLogs) {
  const d = new Date(log.data.date);
  const { dateZh, dateEn } = fmtDate(d);
  allActivity.push({
    dateRaw: d, dateZh, dateEn,
    icon: "🛠️", statZh: "技巧", statEn: "Craft", exp: 8,
    descZh: log.data.title_zh ?? log.data.title, descEn: log.data.title,
    type: "builder-log",
  });
}

// Digests: +2 EXP each
for (const digest of digests) {
  const d = new Date(digest.data.date);
  const { dateZh, dateEn } = fmtDate(d);
  allActivity.push({
    dateRaw: d, dateZh, dateEn,
    icon: "📜", statZh: "见闻", statEn: "Insight", exp: 2,
    descZh: digest.data.title_zh ?? digest.data.title, descEn: digest.data.title,
    type: "digest",
  });
}

// Sort newest first
allActivity.sort((a, b) => b.dateRaw.getTime() - a.dateRaw.getTime());

// Serialize for client
const activityForClient = allActivity.map(({ dateRaw, ...rest }) => rest);

const meta = {
  title: "Player Stats — Lab",
  description: "Rex Liu's open-world cultivation dashboard. 江湖档案。",
};
---

<PageLayout meta={meta}>
  <!-- Back button -->
  <section class="mb-8">
    <div class="mb-4">
      <button
        onclick="history.back()"
        class="group flex items-center gap-1 font-serif text-sm text-gray-500 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back
      </button>
    </div>

    <h1 class="hero-reveal-text mb-3 font-serif text-4xl font-bold dark:text-white">
      <span class="lang-en">Player Stats</span>
      <span class="lang-zh">江湖档案</span>
    </h1>
    <p class="hero-reveal-subtitle lang-en max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      Your open-world cultivation dashboard. Every stat from real data, no manual input.
    </p>
    <p class="hero-reveal-subtitle lang-zh max-w-2xl font-serif text-lg leading-relaxed text-gray-600 dark:text-gray-300">
      开放世界修行面板。所有数值来自真实数据，无手动设置。
    </p>
  </section>

  <!-- React Island -->
  <PlayerStats
    client:only="react"
    stats={stats}
    level={level}
    totalExp={totalExp}
    expInLevel={expInLevel}
    expNeeded={expNeeded}
    expProgress={expProgress}
    rank={rank}
    avgStat={avgStat}
    currentCity={{ name: currentCityObj.name, nameCN: currentCityObj.nameCN }}
    travelDays={travelDays}
    tagCounts={tagCounts}
    postCount={postCount}
    builderLogCount={builderLogCount}
    digestCount={digestCount}
    libraryCount={libraryCount}
    cityCount={cityCount}
    projectCount={projectCount}
    cities={cities.map(c => ({ id: c.id, name: c.name, nameCN: c.nameCN, lat: c.lat, lng: c.lng }))}
    achievements={achievements}
    activityLog={activityForClient}
  />

  <!-- Footer -->
  <section class="mt-16 border-t border-gray-100 pt-8 dark:border-gray-800">
    <p class="font-serif text-sm text-gray-400 dark:text-gray-500">
      <span class="lang-en">All stats auto-calculated from content collections. No hardcoded values (except X followers). Updates on every build.</span>
      <span class="lang-zh">所有属性自动计算（X 粉丝数除外），每次构建更新。</span>
    </p>
    <div class="mt-3">
      <a href="/lab/" class="font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
        <span class="lang-en">← Back to Lab</span>
        <span class="lang-zh">← 返回 Lab</span>
      </a>
    </div>
  </section>
</PageLayout>
