---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/Base.astro";

const allEvents = await getCollection("ai-timeline");
const sorted = allEvents.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Build company counts for dropdown
const companyCounts: Record<string, number> = {};
for (const event of sorted) {
	const co = event.data.company;
	if (co) companyCounts[co] = (companyCounts[co] ?? 0) + 1;
}

// Companies with ≥2 events, sorted by count desc
const topCompanies = Object.entries(companyCounts)
	.filter(([, count]) => count >= 2)
	.sort((a, b) => b[1] - a[1]);

// Companies with <2 events → "Others"
const otherCompanies = new Set(
	Object.entries(companyCounts).filter(([, count]) => count < 2).map(([co]) => co)
);
const hasOthers = otherCompanies.size > 0;

// Simple markdown-to-HTML for event bodies (bold + links)
function mdToHtml(md: string): string {
	return md
		.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
		.replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
		.replace(/\n\n/g, '<br/><br/>')
		.replace(/\n/g, '<br/>');
}

// Group by year then month
type TimelineEvent = (typeof sorted)[number];
type MonthGroup = { month: string; events: TimelineEvent[] };
type YearGroup = { year: number; months: MonthGroup[] };

const grouped: YearGroup[] = [];
const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

for (const event of sorted) {
	const d = new Date(event.data.date);
	const year = d.getFullYear();
	const month = monthNames[d.getMonth()]!;

	let yg = grouped.find((g) => g.year === year);
	if (!yg) {
		yg = { year, months: [] };
		grouped.push(yg);
	}
	let mg = yg.months.find((m) => m.month === month);
	if (!mg) {
		mg = { month, events: [] };
		yg.months.push(mg);
	}
	mg.events.push(event);
}

const categories = [
	{ key: "all", label: "All" },
	{ key: "model", label: "Models" },
	{ key: "product", label: "Products" },
	{ key: "funding", label: "Funding" },
	{ key: "robotics", label: "Robotics" },
	{ key: "crypto-ai", label: "Crypto×AI" },
	{ key: "industry", label: "Industry" },
];

const categoryColors: Record<string, { bg: string; text: string }> = {
	model: { bg: "bg-purple-500/15 dark:bg-purple-400/15", text: "text-purple-600 dark:text-purple-400" },
	funding: { bg: "bg-green-500/15 dark:bg-green-400/15", text: "text-green-600 dark:text-green-400" },
	industry: { bg: "bg-blue-500/15 dark:bg-blue-400/15", text: "text-blue-600 dark:text-blue-400" },
	robotics: { bg: "bg-orange-500/15 dark:bg-orange-400/15", text: "text-orange-600 dark:text-orange-400" },
	"crypto-ai": { bg: "bg-yellow-500/15 dark:bg-yellow-400/15", text: "text-yellow-600 dark:text-yellow-400" },
	product: { bg: "bg-cyan-500/15 dark:bg-cyan-400/15", text: "text-cyan-600 dark:text-cyan-400" },
};

const meta = {
	title: "AI Timeline",
	description: "A curated timeline of major AI events, from Rex's perspective.",
};

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<PageLayout meta={meta}>
	<section class="mb-10">
		<a href="/lab/" class="fade-in-up mb-4 inline-block font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]">
			← Lab
		</a>
		<h1 class="hero-reveal-text mb-3 font-serif text-4xl font-bold dark:text-white">
			AI Timeline
		</h1>
		<p class="hero-reveal-subtitle max-w-2xl font-serif text-lg leading-relaxed text-gray-500 dark:text-gray-400">
			Major milestones in the AI revolution, annotated with a builder-investor lens.
		</p>
	</section>

	<!-- Filter buttons -->
	<section class="fade-in-up mb-4 flex flex-wrap gap-2" style="--delay: 200ms" id="timeline-filters">
		{categories.map((cat) => (
			<button
				data-filter={cat.key}
				class:list={[
					"rounded-full border px-3 py-1 font-serif text-xs transition-all",
					cat.key === "all"
						? "border-[#8953d1] bg-[#8953d1]/10 text-[#8953d1] dark:border-[#a175e8] dark:bg-[#a175e8]/10 dark:text-[#a175e8]"
						: "border-gray-200 text-gray-500 hover:border-[#8953d1] hover:text-[#8953d1] dark:border-gray-700 dark:text-gray-400 dark:hover:border-[#a175e8] dark:hover:text-[#a175e8]",
				]}
			>
				{cat.label}
			</button>
		))}
	</section>

	<!-- Company dropdown filter -->
	<section class="fade-in-up mb-8 flex items-center gap-3" style="--delay: 250ms">
		<span class="font-serif text-xs text-gray-400 dark:text-gray-500">Company:</span>
		<select
			id="company-filter"
			class="cursor-pointer rounded-full border border-gray-200 bg-transparent px-3 py-1 font-serif text-xs text-gray-500 transition-all hover:border-[#8953d1] hover:text-[#8953d1] focus:border-[#8953d1] focus:text-[#8953d1] focus:outline-none dark:border-gray-700 dark:text-gray-400 dark:hover:border-[#a175e8] dark:hover:text-[#a175e8] dark:focus:border-[#a175e8] dark:focus:text-[#a175e8]"
		>
			<option value="all">All Companies</option>
			{topCompanies.map(([co, count]) => (
				<option value={co}>{co} ({count})</option>
			))}
			{hasOthers && <option value="others">Others</option>}
		</select>
	</section>

	<!-- Timeline -->
	<section class="relative" id="timeline-container">
		{grouped.map((yg, yi) => (
			<div class="fade-in-up" data-year-group={yg.year} style={`--delay: ${300 + yi * 100}ms`}>
				{/* Year header */}
				<div class="mb-6 flex items-center gap-4">
					<span class="font-serif text-3xl font-bold text-[#8953d1] dark:text-[#a175e8]">{yg.year}</span>
					<div class="h-px flex-1 bg-gray-200 dark:bg-gray-800" />
				</div>

				{yg.months.map((mg) => (
					<div class="relative mb-8 pl-8 sm:pl-12" data-month-group={mg.month}>
						{/* Vertical line */}
						<div class="absolute top-0 bottom-0 left-3 sm:left-5 w-px bg-[#8953d1]/30 dark:bg-[#a175e8]/30" />

						{/* Month label */}
						<div class="relative mb-4">
							<div class="absolute -left-5 sm:-left-7 top-0.5 h-3 w-3 rounded-full border-2 border-[#8953d1] bg-[var(--color-global-bg)] dark:border-[#a175e8]" />
							<span class="font-serif text-sm font-semibold tracking-wide text-gray-400 uppercase dark:text-gray-500">
								{mg.month}
							</span>
						</div>

						{/* Events */}
						<div class="space-y-3">
							{mg.events.map((event) => {
								const colors = categoryColors[event.data.category] ?? { bg: "bg-gray-100 dark:bg-gray-800", text: "text-gray-600 dark:text-gray-400" };
								return (
									<article
										class="timeline-event glow-card group relative cursor-pointer"
										data-category={event.data.category}
										data-company={event.data.company ?? ""}
									>
										{/* Dot on timeline */}
										<div class="absolute -left-[25px] sm:-left-[33px] top-3 h-2 w-2 rounded-full bg-[#8953d1]/60 dark:bg-[#a175e8]/60" />

										<div class="flex flex-wrap items-start gap-2">
											{/* Category badge */}
											<span class:list={["inline-block rounded-full px-2 py-0.5 font-serif text-xs font-medium uppercase tracking-wider", colors.bg, colors.text]}>
												{event.data.category}
											</span>

											{/* Date */}
											<time class="font-serif text-sm text-gray-400 dark:text-gray-500" datetime={event.data.date.toISOString()}>
												{formatDate(event.data.date)}
											</time>

											{event.data.significance === "high" && (
												<span class="text-xs text-[#8953d1] dark:text-[#a175e8]" title="High significance">★</span>
											)}
										</div>

										{/* Title */}
										<h3 class:list={[
											"mt-1 font-serif text-base transition-colors group-hover:text-[#8953d1] dark:group-hover:text-[#a175e8]",
											event.data.significance === "high" ? "font-bold text-black dark:text-white" : "font-medium text-gray-800 dark:text-gray-200",
										]}>
											{event.data.title}
										</h3>

										{/* Expandable content */}
										<div class="timeline-detail mt-2 hidden">
											<div class="font-serif text-base leading-relaxed text-gray-600 dark:text-gray-400" set:html={mdToHtml(event.body || '')} />
											{event.data.source && (
												<a
													href={event.data.source}
													target="_blank" rel="noopener noreferrer"
													rel="noopener noreferrer"
													class="mt-2 inline-block font-serif text-xs text-[#8953d1] no-underline transition-colors hover:text-[#6b3fad] dark:text-[#a175e8] dark:hover:text-[#c4a8f0]"
												>
													Source: {event.data.source_name || "Link"} ↗
												</a>
											)}
										</div>
									</article>
								);
							})}
						</div>
					</div>
				))}
			</div>
		))}
	</section>
</PageLayout>

<script>
	// Other companies (single-event) passed from server
	const OTHER_COMPANIES = new Set<string>(
		Array.from(document.querySelectorAll(".timeline-event"))
			.map(el => (el as HTMLElement).dataset.company ?? "")
			.filter(co => co !== "")
			.filter(co => {
				// count occurrences
				return document.querySelectorAll(`.timeline-event[data-company="${co}"]`).length < 2;
			})
	);

	let currentCategory = "all";
	let currentCompany = "all";

	function applyFilters() {
		const activeClasses = ["border-[#8953d1]", "bg-[#8953d1]/10", "text-[#8953d1]", "dark:border-[#a175e8]", "dark:bg-[#a175e8]/10", "dark:text-[#a175e8]"];
		const inactiveClasses = ["border-gray-200", "text-gray-500", "dark:border-gray-700", "dark:text-gray-400"];

		// Update category button styles
		document.querySelectorAll("#timeline-filters button").forEach((b) => {
			const el = b as HTMLElement;
			activeClasses.forEach(c => el.classList.remove(c));
			inactiveClasses.forEach(c => el.classList.add(c));
		});
		const activeBtn = document.querySelector(`#timeline-filters button[data-filter="${currentCategory}"]`) as HTMLElement;
		if (activeBtn) {
			inactiveClasses.forEach(c => activeBtn.classList.remove(c));
			activeClasses.forEach(c => activeBtn.classList.add(c));
		}

		// When filtering, reveal all year groups first (override progressive reveal)
		if (currentCategory !== "all" || currentCompany !== "all") {
			yearGroups?.forEach((yg) => {
				const el = yg as HTMLElement;
				delete el.dataset.revealHidden;
				el.style.display = "";
			});
		}

		// Filter events: AND logic
		document.querySelectorAll(".timeline-event").forEach((el) => {
			const cat = (el as HTMLElement).dataset.category ?? "";
			const co = (el as HTMLElement).dataset.company ?? "";

			const catMatch = currentCategory === "all" || cat === currentCategory;
			let coMatch = false;
			if (currentCompany === "all") {
				coMatch = true;
			} else if (currentCompany === "others") {
				coMatch = co === "" || OTHER_COMPANIES.has(co);
			} else {
				coMatch = co === currentCompany;
			}

			(el as HTMLElement).style.display = (catMatch && coMatch) ? "" : "none";
		});

		// Hide empty month groups
		document.querySelectorAll("[data-month-group]").forEach((mg) => {
			const visible = mg.querySelectorAll(".timeline-event:not([style*='display: none'])");
			(mg as HTMLElement).style.display = visible.length === 0 ? "none" : "";
		});

		// Hide empty year groups (but respect the progressive reveal)
		document.querySelectorAll("[data-year-group]").forEach((yg) => {
			const el = yg as HTMLElement;
			// Only hide if it was previously visible (not hidden by progressive reveal)
			if (el.style.display === "none" && !el.dataset.revealHidden) return;
			const visibleMonths = el.querySelectorAll("[data-month-group]:not([style*='display: none'])");
			if (visibleMonths.length === 0) {
				el.dataset.filterHidden = "1";
				el.style.display = "none";
			} else {
				delete el.dataset.filterHidden;
				el.style.display = "";
			}
		});
	}

	// Category filter buttons
	document.querySelectorAll("#timeline-filters button").forEach((btn) => {
		btn.addEventListener("click", (e) => {
			e.preventDefault();
			e.stopPropagation();
			currentCategory = (btn as HTMLElement).dataset.filter || "all";
			applyFilters();
		});
	});

	// Company dropdown
	const companySelect = document.getElementById("company-filter") as HTMLSelectElement;
	if (companySelect) {
		companySelect.addEventListener("change", () => {
			currentCompany = companySelect.value;
			applyFilters();
		});
	}

	// Expand/collapse
	document.querySelectorAll(".timeline-event").forEach((el) => {
		el.addEventListener("click", (e) => {
			if ((e.target as HTMLElement).closest("a")) return;
			const detail = el.querySelector(".timeline-detail");
			if (detail) detail.classList.toggle("hidden");
		});
	});

	// Progressive reveal: hide year groups beyond the first 2, show on scroll
	const yearGroups = document.querySelectorAll("[data-year-group]");
	const INITIAL_YEARS = 2;
	yearGroups.forEach((yg, i) => {
		if (i >= INITIAL_YEARS) {
			const el = yg as HTMLElement;
			el.style.display = "none";
			el.dataset.revealHidden = "1";
		}
	});

	let revealed = INITIAL_YEARS;
	const loadMore = () => {
		if (revealed >= yearGroups.length) return;
		const sentinel = yearGroups[revealed - 1] as HTMLElement;
		if (!sentinel) return;
		const rect = sentinel.getBoundingClientRect();
		if (rect.bottom < window.innerHeight + 600) {
			const el = yearGroups[revealed] as HTMLElement;
			delete el.dataset.revealHidden;
			// Only show if not filter-hidden
			if (!el.dataset.filterHidden) el.style.display = "";
			revealed++;
		}
	};

	window.addEventListener("scroll", loadMore, { passive: true });
	loadMore(); // in case page is short
</script>
