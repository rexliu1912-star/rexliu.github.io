---
import { ClientRouter, fade } from "astro:transitions";
import BackToTop from "@/components/BackToTop.astro";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;

const GA_ID = "G-1EC76EZ517";
---

<html class="scroll-smooth" lang={siteConfig.lang} style="color-scheme: light dark">
	<head>
		<script is:inline>
			(function(){try{var l=localStorage.getItem("rex-lang")||"en";document.documentElement.setAttribute("data-lang",l)}catch(e){document.documentElement.setAttribute("data-lang","en")}})();
		</script>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<link rel="icon" href="/avatar.png" type="image/png" />
		<link rel="apple-touch-icon" href="/avatar.png" />
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
		<ClientRouter />

		<!-- Defer GA to after page load -->
		<script is:inline define:vars={{ GA_ID }}>
			window.addEventListener('load', function() {
				var s = document.createElement('script');
				s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
				s.async = true;
				document.head.appendChild(s);
				s.onload = function() {
					window.dataLayer = window.dataLayer || [];
					function gtag() { dataLayer.push(arguments); }
					gtag('js', new Date());
					gtag('config', GA_ID);
				};
			});
		</script>
		
		<!-- Prevent transition flash on initial load -->
		<script is:inline>
			(function() {
				document.documentElement.classList.add('theme-loaded');
				setTimeout(() => {
					document.documentElement.classList.remove('theme-loaded');
				}, 100);
			})();
		</script>
		<script is:inline>
			(function() {
				function generateDappledLight() {
					var W = 960, H = 540;
					var c = document.createElement('canvas');
					c.width = W; c.height = H;
					var ctx = c.getContext('2d');

					// 1) Warm base gradient (top-left to bottom-right)
					var g1 = ctx.createLinearGradient(0, 0, W, H);
					g1.addColorStop(0, 'rgba(255,248,235,1)');
					g1.addColorStop(0.5, 'rgba(255,252,245,1)');
					g1.addColorStop(1, 'rgba(250,245,235,1)');
					ctx.fillStyle = g1;
					ctx.fillRect(0, 0, W, H);

					// 2) Build noise-based light patches using layered circles
					var seed = 42;
					function rng() { seed = (seed * 16807 + 0) % 2147483647; return seed / 2147483647; }

					// Large warm glow spots (sunlight breaking through)
					for (var i = 0; i < 18; i++) {
						var x = rng() * W;
						var y = rng() * H * 0.7;
						var r = 100 + rng() * 280;
						var a = 0.04 + rng() * 0.10;
						var golden = rng() > 0.3;
						var grad = ctx.createRadialGradient(x, y, 0, x, y, r);
						if (golden) {
							grad.addColorStop(0, 'rgba(245,188,71,' + a + ')');
							grad.addColorStop(0.6, 'rgba(255,230,150,' + (a * 0.5) + ')');
						} else {
							grad.addColorStop(0, 'rgba(255,255,240,' + a + ')');
							grad.addColorStop(0.6, 'rgba(255,248,220,' + (a * 0.4) + ')');
						}
						grad.addColorStop(1, 'rgba(255,255,255,0)');
						ctx.fillStyle = grad;
						ctx.fillRect(0, 0, W, H);
					}

					// 3) Medium dappled spots (leaf-filtered patches)
					for (var j = 0; j < 40; j++) {
						var px = rng() * W;
						var py = rng() * H * 0.8;
						var pr = 30 + rng() * 120;
						var pa = 0.03 + rng() * 0.07;
						var pGrad = ctx.createRadialGradient(px, py, 0, px, py, pr);
						pGrad.addColorStop(0, 'rgba(255,240,200,' + pa + ')');
						pGrad.addColorStop(0.7, 'rgba(255,245,220,' + (pa * 0.3) + ')');
						pGrad.addColorStop(1, 'rgba(255,255,255,0)');
						ctx.fillStyle = pGrad;
						ctx.fillRect(0, 0, W, H);
					}

					// 4) Small bright highlights (direct sun spots)
					for (var k = 0; k < 12; k++) {
						var sx = rng() * W;
						var sy = rng() * H * 0.5;
						var sr = 20 + rng() * 60;
						var sa = 0.06 + rng() * 0.08;
						var sGrad = ctx.createRadialGradient(sx, sy, 0, sx, sy, sr);
						sGrad.addColorStop(0, 'rgba(255,250,230,' + sa + ')');
						sGrad.addColorStop(1, 'rgba(255,255,255,0)');
						ctx.fillStyle = sGrad;
						ctx.fillRect(0, 0, W, H);
					}

					// 5) Very subtle green-tinged patches (leaf shadow edges)
					for (var m = 0; m < 8; m++) {
						var gx = rng() * W;
						var gy = 0.2 * H + rng() * H * 0.5;
						var gr = 60 + rng() * 150;
						var ga = 0.02 + rng() * 0.03;
						var gGrad = ctx.createRadialGradient(gx, gy, 0, gx, gy, gr);
						gGrad.addColorStop(0, 'rgba(180,210,160,' + ga + ')');
						gGrad.addColorStop(1, 'rgba(255,255,255,0)');
						ctx.fillStyle = gGrad;
						ctx.fillRect(0, 0, W, H);
					}

					return c.toDataURL('image/png');
				}

				function applyDappled() {
					var url = generateDappledLight();
					document.documentElement.style.setProperty('--dappled-light', 'url(' + url + ')');
				}

				applyDappled();
				document.addEventListener('astro:after-swap', applyDappled);
			})();
		</script>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-4xl flex-col px-4 pt-8 font-mono text-sm font-normal antialiased sm:px-8"
	>
		{/* Bamboo shadow overlay — sunny mood only */}
		<div class="mood-overlay bamboo-shadow-overlay" aria-hidden="true">
			<div class="bamboo-shadow-layer bamboo-shadow-layer-1"></div>
			<div class="bamboo-shadow-layer bamboo-shadow-layer-2"></div>
			<div class="bamboo-shadow-layer bamboo-shadow-layer-3"></div>
		</div>
		{/* Rain canvas + fog — rainy mood only */}
		<canvas id="rain-canvas" class="mood-overlay" aria-hidden="true"></canvas>
		<div class="mood-overlay rain-fog-overlay" aria-hidden="true"></div>
		<ThemeProvider />
		<SkipLink />
		<Header />
		<main id="main" data-pagefind-body transition:animate={fade({ duration: "0.2s" })}>
			<slot />
		</main>
		<Footer />
		<BackToTop />

		{/* 播放器组件：已优化加载策略与审美视觉 */}
		<div
			id="minimal-player"
			transition:persist
			role="region"
			aria-label="Music player"
			class="fixed bottom-12 left-6 z-50 flex items-center sm:bottom-8 sm:left-8"
		>
			<div
				id="player-container"
				class="custom-glow flex h-10 w-10 items-center justify-start overflow-hidden rounded-full border border-[#8953d1]/40 bg-white/70 backdrop-blur-md transition-[width,box-shadow,border-color] duration-500 ease-in-out dark:border-[#8953d1]/30 dark:bg-[#1a1a1a]/70"
			>
				<button
					id="play-button"
					type="button"
					aria-label="Play music"
					class="relative ml-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-transparent transition-transform active:scale-95"
				>
					<svg
						id="music-icon"
						aria-hidden="true"
						class="text-[#8953d1] transition-opacity duration-300"
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle
							cx="18"
							cy="16"
							r="3"></circle>
					</svg>
					<div
						id="visualizer"
						aria-hidden="true"
						class="absolute inset-0 flex items-center justify-center gap-[2px] opacity-0 transition-opacity duration-300"
					>
						<div class="bar h-1 w-[2px] rounded-full bg-[#8953d1]"></div>
						<div class="bar h-3 w-[2px] rounded-full bg-[#8953d1]"></div>
						<div class="bar h-2 w-[2px] rounded-full bg-[#8953d1]"></div>
					</div>
				</button>
				<div
					id="expanded-controls"
					class="pointer-events-none flex items-center pl-2 opacity-0 transition-opacity duration-300"
				>
					<div class="flex w-28 flex-col overflow-hidden whitespace-nowrap"
					>
						<span class="font-serif text-[8px] font-bold tracking-wider text-[#8953d1]/80 italic"
							>Now Playing</span
						>
						<div id="current-song-container"
							>
							<span
								id="current-song-name"
								class="inline-block font-serif text-[12px] leading-tight font-medium text-gray-600 dark:text-gray-300"
								style="white-space: nowrap;"
							>
								Ready
							</span>
						</div>
					</div>
					<button
						id="next-button"
						type="button"
						aria-label="Next track"
						class="ml-1 p-1 text-gray-400 transition-colors hover:text-[#8953d1]"
						title="Next"
					>
						<svg
							aria-hidden="true"
							xmlns="http://www.w3.org/2000/svg"
							width="14"
							height="14"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><polygon points="5 4 15 12 5 20 5 4"></polygon><line x1="19" y1="5" x2="19" y2="19"
							></line></svg
						>
					</button>
					<button
						id="collapse-button"
						type="button"
						aria-label="Collapse player"
						class="ml-1 p-1 text-gray-400 transition-colors hover:text-red-400"
						title="Collapse"
					>
						<svg
							aria-hidden="true"
							xmlns="http://www.w3.org/2000/svg"
							width="14"
							height="14"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
003e<path d="M18 6L6 18M6 6l12 12"></path></svg
						>
					</button>
				</div>
			</div>
			{/* 🟢 关键修改：添加 preload="none"，彻底防止自动下载音频流量 */}
			<audio id="main-audio" preload="none"></audio>
		</div>

		<style is:global>
			.custom-glow {
				box-shadow:
					0 4px 15px -3px rgba(137, 83, 209, 0.2),
					0 4px 6px -2px rgba(137, 83, 209, 0.1);
			}

			.is-playing #player-container {
				box-shadow:
					0 0 20px -5px rgba(137, 83, 209, 0.4),
					0 4px 6px -2px rgba(137, 83, 209, 0.1);
				border-color: rgba(137, 83, 209, 0.6) !important;
			}

			.player-expanded #player-container {
				width: 230px !important;
				padding-right: 12px !important;
			}
			.player-expanded #expanded-controls {
				opacity: 1 !important;
				pointer-events: auto !important;
			}
			.is-playing #music-icon {
				opacity: 0 !important;
			}
			.is-playing #visualizer {
				opacity: 1 !important;
			}

			@keyframes quiet {
				25% {
					height: 4px;
				}
				50% {
					height: 10px;
				}
				75% {
					height: 4px;
				}
				100% {
					height: 10px;
				}
			}
			@keyframes loud {
				25% {
					height: 10px;
				}
				50% {
					height: 16px;
				}
				75% {
					height: 12px;
				}
				100% {
					height: 16px;
				}
			}
			.is-playing .bar:nth-child(1) {
				animation: quiet 0.8s infinite;
			}
			.is-playing .bar:nth-child(2) {
				animation: loud 1.2s infinite;
			}
			.is-playing .bar:nth-child(3) {
				animation: quiet 1s infinite;
			}

			.cactus-tag,
			.flex.flex-wrap.gap-2 a,
			aside ul.flex.flex-wrap a {
				display: inline-flex !important;
				align-items: center !important;
				border-radius: 0.375rem !important;
				padding: 0.25rem 0.5rem !important;
				font-size: 0.75rem !important;
				font-family: font-serif !important;
				color: inherit !important;
				background-color: transparent !important;
				border: none !important;
				text-decoration: none !important;
				transition: all 0.2s ease !important;
				margin-bottom: 0.25rem;
				opacity: 0.8;
			}

			.cactus-tag:hover,
			.flex.flex-wrap.gap-2 a:hover,
			aside ul.flex.flex-wrap a:hover {
				color: #8953d1 !important;
				background-color: rgba(137, 83, 209, 0.05) !important;
				transform: translateY(-1px) !important;
				opacity: 1;
			}

			@keyframes marquee {
				0% {
					transform: translateX(0);
				}
				100% {
					transform: translateX(-50%);
				}
			}
			#current-song-container {
				width: 110px;
				overflow: hidden;
				position: relative;
				mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
			}

			/* Reduced motion: silence player marquee + visualizer bars */
			@media (prefers-reduced-motion: reduce) {
				.is-playing .bar:nth-child(1),
				.is-playing .bar:nth-child(2),
				.is-playing .bar:nth-child(3) {
					animation: none !important;
				}
				#current-song-name {
					animation: none !important;
				}
		}
	</style>

	{/* ── Mood Overlay Styles ── */}
	<style is:global>
		/* Base overlay — hidden by default, mood-controlled */
		.mood-overlay {
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 0;
			opacity: 0;
			transition: opacity 0.8s ease;
		}

		/* Bamboo Shadow — sunny only */
		html[data-mood="sunny"] .bamboo-shadow-overlay {
			opacity: 1;
			transition: opacity 1s ease;
		}
		.bamboo-shadow-layer {
			position: absolute;
			inset: 0;
		}
		.bamboo-shadow-layer-1 {
			background:
				radial-gradient(ellipse 120px 90px at 15% 12%, rgba(139, 115, 85, 0.10) 0%, transparent 70%),
				radial-gradient(ellipse 80px 140px at 72% 8%, rgba(160, 130, 90, 0.08) 0%, transparent 65%),
				radial-gradient(ellipse 100px 70px at 45% 25%, rgba(139, 115, 85, 0.06) 0%, transparent 60%),
				radial-gradient(ellipse 60px 100px at 88% 30%, rgba(150, 120, 80, 0.07) 0%, transparent 55%),
				radial-gradient(ellipse 90px 60px at 25% 55%, rgba(139, 115, 85, 0.05) 0%, transparent 65%),
				radial-gradient(ellipse 70px 110px at 60% 70%, rgba(160, 130, 90, 0.06) 0%, transparent 60%);
			animation: bambooDrift1 20s ease-in-out infinite alternate;
		}
		.bamboo-shadow-layer-2 {
			background:
				radial-gradient(ellipse 40px 25px at 8% 35%, rgba(100, 80, 50, 0.12) 0%, transparent 70%),
				radial-gradient(ellipse 30px 50px at 32% 18%, rgba(90, 70, 40, 0.09) 0%, transparent 65%),
				radial-gradient(ellipse 50px 30px at 55% 42%, rgba(100, 80, 50, 0.08) 0%, transparent 60%),
				radial-gradient(ellipse 25px 40px at 78% 55%, rgba(90, 70, 40, 0.10) 0%, transparent 55%),
				radial-gradient(ellipse 35px 20px at 92% 20%, rgba(100, 80, 50, 0.07) 0%, transparent 70%),
				radial-gradient(ellipse 45px 35px at 18% 80%, rgba(90, 70, 40, 0.08) 0%, transparent 60%),
				radial-gradient(ellipse 20px 30px at 65% 88%, rgba(100, 80, 50, 0.06) 0%, transparent 65%),
				radial-gradient(ellipse 55px 25px at 40% 60%, rgba(90, 70, 40, 0.05) 0%, transparent 70%);
			animation: bambooDrift2 25s ease-in-out infinite alternate-reverse;
		}
		.bamboo-shadow-layer-3 {
			background:
				radial-gradient(ellipse at 20% 0%, rgba(255, 220, 150, 0.06) 0%, transparent 50%),
				radial-gradient(ellipse at 80% 10%, rgba(255, 210, 140, 0.04) 0%, transparent 45%),
				radial-gradient(ellipse at 50% 100%, rgba(255, 200, 120, 0.03) 0%, transparent 40%);
			animation: bambooDrift3 30s ease-in-out infinite alternate;
		}
		@keyframes bambooDrift1 {
			0%   { transform: translate(0, 0) scale(1); }
			100% { transform: translate(8px, 5px) scale(1.02); }
		}
		@keyframes bambooDrift2 {
			0%   { transform: translate(0, 0) scale(1); }
			100% { transform: translate(-6px, 4px) scale(1.01); }
		}
		@keyframes bambooDrift3 {
			0%   { transform: translate(0, 0); opacity: 1; }
			100% { transform: translate(3px, -3px); opacity: 0.8; }
		}

		/* Rain Canvas — rainy only */
		html[data-mood="rainy"] #rain-canvas {
			opacity: 1;
		}

		/* Rain Fog — rainy only */
		html[data-mood="rainy"] .rain-fog-overlay {
			opacity: 1;
			transition: opacity 1s ease;
			background:
				radial-gradient(ellipse at 15% 75%, rgba(130, 150, 180, 0.14) 0%, transparent 55%),
				radial-gradient(ellipse at 85% 65%, rgba(120, 140, 175, 0.11) 0%, transparent 50%),
				radial-gradient(ellipse at 50% 95%, rgba(140, 160, 190, 0.18) 0%, transparent 40%),
				linear-gradient(to bottom, transparent 50%, rgba(150, 170, 195, 0.08) 100%);
			animation: rainFogDrift 28s ease-in-out infinite alternate;
		}
		@keyframes rainFogDrift {
			0%   { transform: translate(0, 0); }
			100% { transform: translate(5px, -3px); }
		}
	</style>

	{/* ── Rain Canvas Script ── */}
	<script is:inline>
		(function __initRainEffect() {
			const canvas = document.getElementById('rain-canvas');
			if (!canvas) return;
			const ctx = canvas.getContext('2d');
			let drops = [];
			let splashes = [];
			let animId = null;
			let active = false;

			function resize() {
				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;
			}

			function createDrops() {
				drops = [];
				const W = canvas.width, H = canvas.height;
				for (let i = 0; i < 120; i++) {
					drops.push({ x: Math.random() * W, y: Math.random() * H, len: Math.random() * 10 + 5, speed: Math.random() * 2 + 1.5, opacity: Math.random() * 0.08 + 0.04, wind: 0.4 + Math.random() * 0.3, width: 0.5 });
				}
				for (let i = 0; i < 100; i++) {
					drops.push({ x: Math.random() * W, y: Math.random() * H, len: Math.random() * 15 + 10, speed: Math.random() * 4 + 3, opacity: Math.random() * 0.12 + 0.08, wind: 0.8 + Math.random() * 0.4, width: 0.8 });
				}
				for (let i = 0; i < 60; i++) {
					drops.push({ x: Math.random() * W, y: Math.random() * H, len: Math.random() * 22 + 14, speed: Math.random() * 6 + 5, opacity: Math.random() * 0.18 + 0.12, wind: 1.2 + Math.random() * 0.5, width: 1.2 });
				}
			}

			function addSplash(x, y) {
				if (splashes.length > 15) return;
				splashes.push({ x, y, radius: 0, maxRadius: 3 + Math.random() * 4, opacity: 0.3, speed: 0.3 + Math.random() * 0.2 });
			}

			function animate() {
				if (!active) return;
				ctx.clearRect(0, 0, canvas.width, canvas.height);
				for (const d of drops) {
					ctx.beginPath();
					ctx.moveTo(d.x, d.y);
					ctx.lineTo(d.x + d.wind * 2, d.y + d.len);
					ctx.strokeStyle = 'rgba(160, 180, 210, ' + d.opacity + ')';
					ctx.lineWidth = d.width;
					ctx.stroke();
					d.y += d.speed;
					d.x += d.wind * 0.3;
					if (d.y > canvas.height) {
						if (d.width > 0.8 && Math.random() < 0.15) addSplash(d.x + d.wind * 2, canvas.height - 2);
						d.y = -d.len - Math.random() * 40;
						d.x = Math.random() * canvas.width;
					}
				}
				for (let i = splashes.length - 1; i >= 0; i--) {
					const s = splashes[i];
					ctx.beginPath();
					ctx.ellipse(s.x, s.y, s.radius, s.radius * 0.3, 0, 0, Math.PI * 2);
					ctx.strokeStyle = 'rgba(160, 180, 210, ' + s.opacity + ')';
					ctx.lineWidth = 0.5;
					ctx.stroke();
					s.radius += s.speed;
					s.opacity -= 0.015;
					if (s.opacity <= 0 || s.radius >= s.maxRadius) splashes.splice(i, 1);
				}
				animId = requestAnimationFrame(animate);
			}

			function start() {
				if (active) return;
				active = true;
				resize();
				createDrops();
				animate();
			}

			function stop() {
				active = false;
				if (animId) { cancelAnimationFrame(animId); animId = null; }
				drops = [];
				splashes = [];
				ctx.clearRect(0, 0, canvas.width, canvas.height);
			}

			function checkMood() {
				const mood = document.documentElement.getAttribute('data-mood');
				if (mood === 'rainy') start();
				else stop();
			}

			new MutationObserver(checkMood).observe(document.documentElement, { attributes: true, attributeFilter: ['data-mood'] });
			window.addEventListener('resize', function() { if (active) { resize(); createDrops(); } });
			document.addEventListener('astro:after-swap', function() {
				const c2 = document.getElementById('rain-canvas');
				if (c2) { ctx && ctx.clearRect(0, 0, c2.width, c2.height); }
				checkMood();
			});
			checkMood();
		})();
	</script>

		<script is:inline>
			(function () {
				const CDN = "https://cdn.rexliu.io";
				const playlist = [
					{ name: "I Will Fight For You - Voyageur", url: CDN + "/music/i-will-fight-for-you.mp3" },
					{ name: "Still Moving On - Luminar", url: CDN + "/music/still-moving-on.mp3" },
					{ name: "一舞倾城 - 魏小涵", url: CDN + "/music/yiwuqingcheng.mp3" },
					{ name: "捣衣 - 古琴龚一", url: CDN + "/music/daoyi.mp3" },
					{ name: "穿越时空的思念 - 古琴梅旸", url: CDN + "/music/chuanyueshikong.mp3" },
					{ name: "美人兮 - 古琴赵晓霞", url: CDN + "/music/meirenxi.mp3" },
					{ name: "Angel - Cathartic Fall", url: CDN + "/music/angel.mp3" },
					{ name: "Head In The Clouds - Hayd", url: CDN + "/music/head-in-the-clouds.mp3" },
					{ name: "夢灯籠 - RADWIMPS", url: CDN + "/music/mengdenglong.mp3" },
					{ name: "三葉のテーマ - RADWIMPS", url: CDN + "/music/sanye.mp3" },
					{ name: "The Story Never Ends (Piano) - Lauv", url: CDN + "/music/lauv---the-story-never-ends-(piano-version).mp3" },
					{ name: "One Day - Matisyahu", url: CDN + "/music/matisyahu---one-day.mp3" },
					{ name: "Missin' You Like Crazy - Michael Alvarado & Carissa Rae", url: CDN + "/music/michael-alvarado,carissa-rae---missin'-you-like-crazy-(feat.-carissa-rae).mp3" },
					{ name: "落ちるパズルゲーム - 神前暁", url: CDN + "/music/神前暁---落ちるパズルゲーム.mp3" },
					{ name: "你愿意吗 - 何立", url: CDN + "/music/ni-yuan-yi-ma.mp3" },
					{ name: "Last Dance - 伍佰 & China Blue", url: CDN + "/music/last-dance.mp3" },
					{ name: "Viva La Vida - Coldplay", url: CDN + "/music/viva-la-vida.mp3" },
					{ name: "Don't Waste My Time - Dayon", url: CDN + "/music/dont-waste-my-time.mp3" },
					{ name: "Coming Home - Diddy & Skylar Grey", url: CDN + "/music/coming-home.mp3" },
				];
				let currentIndex = Math.floor(Math.random() * playlist.length);
				const state = { isPlaying: false, isExpanded: false };
				function updateUI() {
					const player = document.getElementById("minimal-player");
					const songName = document.getElementById("current-song-name");
					const container = document.getElementById("current-song-container");
					if (!player) return;

					state.isPlaying
						? player.classList.add("is-playing")
						: player.classList.remove("is-playing");
					state.isExpanded
						? player.classList.add("player-expanded")
						: player.classList.remove("player-expanded");

					if (songName && playlist[currentIndex]) {
						const name = playlist[currentIndex].name;
						songName.innerText = name;
						setTimeout(() => {
							if (songName.offsetWidth > container.offsetWidth) {
								songName.innerHTML = `${name} &nbsp;&nbsp;&nbsp;&nbsp; ${name} &nbsp;&nbsp;&nbsp;&nbsp;`;
								songName.style.animation = "marquee 8s linear infinite";
							} else {
								songName.style.animation = "none";
							}
						}, 50);
					}
				}
				function initPlayer() {
					const playBtn = document.getElementById("play-button");
					const nextBtn = document.getElementById("next-button");
					const collapseBtn = document.getElementById("collapse-button");
					const audio = document.getElementById("main-audio");
					if (!playBtn || !audio) return;

					const playNext = () => {
						currentIndex = (currentIndex + 1) % playlist.length;
						audio.src = playlist[currentIndex].url;
						audio.play().catch(() => {});
						state.isPlaying = true;
						updateUI();
					};

					playBtn.onclick = () => {
						if (!state.isExpanded) state.isExpanded = true;
						if (state.isPlaying) {
							audio.pause();
							state.isPlaying = false;
						} else {
							if (!audio.src) audio.src = playlist[currentIndex].url;
							audio.play().catch((e) => {
								console.error("Playback failed", e);
							});
							state.isPlaying = true;
						}
						updateUI();
					};

					nextBtn.onclick = (e) => {
						e.stopPropagation();
						playNext();
					};
					collapseBtn.onclick = (e) => {
						e.stopPropagation();
						state.isExpanded = false;
						updateUI();
					};

					// 自动播放下一首
					audio.onended = playNext;

					// 🟢 容错处理：如果当前歌曲加载失败（如 404），自动跳到下一首
					audio.onerror = () => {
						console.warn("Audio file failed to load, skipping...");
						playNext();
					};

					updateUI();
				}

				// Expose player API for page-specific auto-play
				window.__player = {
					play() { if (!state.isPlaying) document.getElementById("play-button")?.click(); },
					setTrack(idx) { if (idx >= 0 && idx < playlist.length) { currentIndex = idx; updateUI(); } },
					isPlaying() { return state.isPlaying; },
					playlist,
				};

				initPlayer();
				document.addEventListener("astro:after-swap", initPlayer);
				document.addEventListener("astro:page-load", updateUI);
			})();
		</script>

		<script>
			import { initAllAnimations } from "@/utils/animations";

			// Initialize all animations on page load
			initAllAnimations();

			// Re-initialize after Astro view transitions
			document.addEventListener("astro:page-load", () => {
				initAllAnimations();
			});
		</script>
	</body>
</html>
