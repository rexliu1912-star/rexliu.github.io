---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import ReadingProgress from "@/components/blog/ReadingProgress.astro";
import Comments from "@/components/blog/Comments.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import MagazineView from "@/components/blog/MagazineView";
import TagAnimation from "@/components/blog/TagAnimation.astro";
import { getRelatedPosts } from "@/utils/post";
import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

const allPosts = await getCollection("post");
const relatedPosts = getRelatedPosts(post, allPosts, 3);
const {
	data: { title, description, publishDate, originalUrl, tags, coverImage },
} = post;

const articleDate = publishDate.toISOString();

const formatCustomDate = (date: Date) => {
	const day = date.getDate();
	const month = date.toLocaleDateString("en-US", { month: "short" });
	const year = date.getFullYear();

	const getOrdinal = (n: number) => {
		const s = ["th", "st", "nd", "rd"];
		const v = n % 100;
		return s[(v - 20) % 10] || s[v] || s[0];
	};

	return `${month} ${day}${getOrdinal(day)} ${year}`;
};

const displayDate = formatCustomDate(publishDate);
---

<BaseLayout meta={{ title, description, articleDate }}>
	<ReadingProgress />
	<div class="mb-16 sm:mt-8">
		<div class="mb-8">
			<button
				onclick="history.back()"
				class="group flex items-center gap-1 font-serif text-sm text-gray-500 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="transition-transform group-hover:-translate-x-1"
				>
					<polyline points="15 18 9 12 15 6"></polyline>
				</svg>
				Back
			</button>
		</div>

		<article class="flex flex-col gap-4" data-view-root data-view="prose">
			<TagAnimation tags={tags} />

			<div class="flex items-start justify-between gap-4">
				<h1 class="font-serif text-3xl leading-tight font-bold text-black sm:text-4xl dark:text-white">
					{title}
				</h1>
			</div>

			{
				description && (
					<p class="font-serif text-lg leading-relaxed text-gray-500 dark:text-gray-400">
						{description}
					</p>
				)
			}

			<div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-2 font-serif text-sm text-gray-400">
				<time datetime={articleDate}>{displayDate}</time>

				{
					originalUrl && (
						<>
							<span>·</span>
							<a
								href={originalUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-1 font-serif underline decoration-dotted underline-offset-4 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
							>
								Original Link
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
									<polyline points="15 3 21 3 21 9" />
									<line x1="10" y1="14" x2="21" y2="3" />
								</svg>
							</a>
						</>
					)
				}

				{
					tags && tags.length > 0 && (
						<>
							<span>·</span>
							<div class="flex items-center gap-3">
								{tags.map((tag: string) => (
									<a
										href={`/tags/${tag}/`}
										class="capitalize transition-colors before:content-['#'] hover:text-[#8953d1] hover:underline hover:decoration-dotted hover:underline-offset-4 dark:hover:text-[#a175e8]"
									>
										{tag}
									</a>
								))}
							</div>
						</>
					)
				}
				{/* Copy link — after tags, matching digest style */}
				<span>·</span>
				<button
					id="share-btn"
					class="inline-flex items-center text-gray-400 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
					title="Copy link"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
				</button>
				<span id="share-toast" class="font-serif text-xs text-[#8953d1] opacity-0 transition-opacity duration-300">✓</span>

				{/* Magazine toggle — right-aligned */}
				<button
					type="button"
					data-view-option="toggle"
					class="ml-auto flex items-center gap-1 text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]"
					title="Switch to magazine view"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="3" width="7" height="18"></rect>
						<rect x="14" y="3" width="7" height="18"></rect>
					</svg>
					<span class="js-toggle-label text-xs">Magazine</span>
				</button>
			</div>

			<hr class="my-8 border-dashed border-gray-200 dark:border-gray-700" />

			{
				coverImage && (
					<div class="mb-8 overflow-hidden rounded-lg">
						<img
							src={coverImage.src}
							alt={coverImage.alt}
							class="w-full object-cover"
							loading="eager"
						/>
					</div>
				)
			}

			<div class="relative view-shell">
				<div id="blog-post-source" class="js-prose-view view-panel transition-all duration-300 ease-out">
					<div class="prose prose-lg prose-serif dark:prose-invert max-w-none font-serif">
						<slot />
					</div>
				</div>

				<div class="js-magazine-view view-panel hidden opacity-0 transition-all duration-300 ease-out">
					<MagazineView client:only="react" sourceId="blog-post-source" />
				</div>
			</div>

			<Comments slug={post.id} />
			<RelatedPosts posts={relatedPosts} />
		</article>
	</div>
</BaseLayout>

<script>
	document.addEventListener("astro:page-load", () => {
		// Copy link button (matching digest style)
		document.getElementById('share-btn')?.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(window.location.href);
			} catch {
				const input = document.createElement('input');
				input.value = window.location.href;
				document.body.appendChild(input);
				input.select();
				document.execCommand('copy');
				document.body.removeChild(input);
			}
			const toast = document.getElementById('share-toast');
			if (toast) {
				toast.style.opacity = '1';
				setTimeout(() => { toast.style.opacity = '0'; }, 2000);
			}
		});

		const article = document.querySelector<HTMLElement>("[data-view-root]");
		const options = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-view-option]"));
		const proseView = document.querySelector<HTMLElement>(".js-prose-view");
		const magazineView = document.querySelector<HTMLElement>(".js-magazine-view");
		if (!article || options.length === 0 || !proseView || !magazineView) return;

		const updateOptionState = (view: "prose" | "magazine") => {
			options.forEach((option) => {
				const isActive = option.dataset.viewOption === view;
				option.setAttribute("aria-pressed", String(isActive));
				option.classList.toggle("is-active", isActive);
			});
		};

		const syncReadingProgress = () => {
			window.dispatchEvent(new CustomEvent("reading-progress:refresh"));
		};

		const syncMagazineLayout = () => {
			window.dispatchEvent(new CustomEvent("magazine-view:refresh"));
			window.dispatchEvent(new Event("resize"));
		};

		const applyView = (view: "prose" | "magazine") => {
			const isMagazine = view === "magazine";
			article.dataset.view = view;
			updateOptionState(view);
			article.classList.toggle("is-magazine-view", isMagazine);

			proseView.classList.toggle("hidden", isMagazine);
			proseView.classList.toggle("pointer-events-none", isMagazine);
			proseView.classList.toggle("opacity-0", isMagazine);
			proseView.classList.toggle("translate-y-2", isMagazine);

			magazineView.classList.toggle("hidden", !isMagazine);
			magazineView.classList.toggle("pointer-events-none", !isMagazine);

			requestAnimationFrame(() => {
				magazineView.classList.toggle("opacity-0", !isMagazine);
				magazineView.classList.toggle("translate-y-2", !isMagazine);
				if (isMagazine) {
					requestAnimationFrame(syncMagazineLayout);
				}
				syncReadingProgress();
			});
		};

		applyView("prose");

		options.forEach((option) => {
			option.addEventListener("click", () => {
				if (option.dataset.viewOption === "toggle") {
					// Toggle between views
					const currentView = article.dataset.view || "prose";
					const nextView = currentView === "prose" ? "magazine" : "prose";
					applyView(nextView);
					// Update toggle label
					const label = option.querySelector(".js-toggle-label");
					if (label) label.textContent = nextView === "magazine" ? "Standard" : "Magazine";
					option.title = nextView === "magazine" ? "Switch to standard view" : "Switch to magazine view";
				} else {
					const nextView = option.dataset.viewOption === "magazine" ? "magazine" : "prose";
					applyView(nextView);
				}
			});
		});
	});
</script>

<style>
	.view-shell {
		position: relative;
	}

	.view-panel {
		transform-origin: top center;
	}

	.view-toggle-link.is-active {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		font-weight: 600;
	}

	[data-view-root].is-magazine-view .js-magazine-view {
		animation: view-expand 300ms ease;
	}

	[data-view-root]:not(.is-magazine-view) .js-prose-view {
		animation: view-expand 300ms ease;
	}

	@keyframes view-expand {
		from {
			opacity: 0;
			transform: translateY(8px) scaleY(0.985);
		}
		to {
			opacity: 1;
			transform: translateY(0) scaleY(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		[data-view-root].is-magazine-view .js-magazine-view,
		[data-view-root]:not(.is-magazine-view) .js-prose-view,
		.view-panel {
			animation: none;
			transition: none;
		}
	}
</style>
