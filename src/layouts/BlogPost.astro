---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import ReadingProgress from "@/components/blog/ReadingProgress.astro";
import Comments from "@/components/blog/Comments.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import MagazineView from "@/components/blog/MagazineView";
import { getRelatedPosts } from "@/utils/post";
import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

// Get all posts for related posts feature
const allPosts = await getCollection("post");
const relatedPosts = getRelatedPosts(post, allPosts, 3);
const {
	data: { title, description, publishDate, originalUrl, tags },
} = post;

const articleDate = publishDate.toISOString();

// 自定义日期格式化逻辑：生成类似 "Mar 3rd 2025" 的格式
const formatCustomDate = (date: Date) => {
	const day = date.getDate();
	const month = date.toLocaleDateString("en-US", { month: "short" });
	const year = date.getFullYear();

	// 计算序数词后缀 (st, nd, rd, th)
	const getOrdinal = (n: number) => {
		const s = ["th", "st", "nd", "rd"];
		const v = n % 100;
		return s[(v - 20) % 10] || s[v] || s[0];
	};

	return `${month} ${day}${getOrdinal(day)} ${year}`;
};

const displayDate = formatCustomDate(publishDate);
---

<BaseLayout meta={{ title, description, articleDate }}>
	<ReadingProgress />
	<div class="mb-16 sm:mt-8">
		{/* 1. Back 按钮 */}
		<div class="mb-8">
			<button
				onclick="history.back()"
				class="group flex items-center gap-1 font-serif text-sm text-gray-500 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="transition-transform group-hover:-translate-x-1"
				>
					<polyline points="15 18 9 12 15 6"></polyline>
				</svg>
				Back
			</button>
		</div>

		{/* 2. 文章头部区域 */}
		<article class="flex flex-col gap-4" data-view-root data-view="prose">
			<div class="flex items-start justify-between gap-4">
				<h1
					class="font-serif text-3xl leading-tight font-bold text-black sm:text-4xl dark:text-white"
				>
					{title}
				</h1>
				<button
					type="button"
					class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#8953d1]/20 bg-[#8953d1]/5 text-lg transition-all duration-300 hover:border-[#8953d1]/40 hover:bg-[#8953d1]/10 focus:outline-none focus:ring-2 focus:ring-[#8953d1]/40 dark:border-[#a175e8]/20 dark:bg-[#a175e8]/10"
					data-view-toggle
					aria-pressed="false"
					aria-label="Switch to magazine view"
					title="Toggle magazine view"
				>
					<span data-view-icon>📄</span>
				</button>
			</div>

			{
				description && (
					<p class="font-serif text-lg leading-relaxed text-gray-500 dark:text-gray-400">
						{description}
					</p>
				)
			}

			{/* Meta 信息：日期 & 原文链接 & Tags */}
			<div class="mt-2 flex flex-wrap items-center gap-3 font-serif text-sm text-gray-400">
				<time datetime={articleDate}>
					{displayDate}
				</time>

				{/* 只有当 originalUrl 存在时才渲染 */}
				{
					originalUrl && (
						<>
							<span>·</span>
							<a
								href={originalUrl}
								target="_blank" rel="noopener noreferrer"
								rel="noopener noreferrer"
								class="inline-flex items-center gap-1 font-serif underline decoration-dotted underline-offset-4 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
							>
								Original Link
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
									<polyline points="15 3 21 3 21 9" />
									<line x1="10" y1="14" x2="21" y2="3" />
								</svg>
							</a>
						</>
					)
				}

				{/* Tags */}
				{
					tags && tags.length > 0 && (
						<>
							<span>·</span>
							<div class="flex items-center gap-3">
								{tags.map((tag: string) => (
									<a
										href={`/tags/${tag}/`}
										class="capitalize transition-colors before:content-['#'] hover:text-[#8953d1] hover:underline hover:decoration-dotted hover:underline-offset-4 dark:hover:text-[#a175e8]"
									>
										{tag}
									</a>
								))}
							</div>
						</>
					)
				}
			</div>

			<hr class="my-8 border-dashed border-gray-200 dark:border-gray-700" />

			<div class="relative">
				<div id="blog-post-source" class="js-prose-view transition-opacity duration-300">
					<div class="prose prose-lg prose-serif dark:prose-invert max-w-none font-serif">
						<slot />
					</div>
				</div>

				<div class="js-magazine-view pointer-events-none hidden opacity-0 transition-opacity duration-300">
					<MagazineView client:only="react" sourceId="blog-post-source" />
				</div>
			</div>

			<Comments slug={post.id} />

			{/* Related Posts */}
			<RelatedPosts posts={relatedPosts} />
		</article>
	</div>
</BaseLayout>

<script>
	document.addEventListener("astro:page-load", () => {
		const article = document.querySelector<HTMLElement>("[data-view-root]");
		const toggle = document.querySelector<HTMLButtonElement>("[data-view-toggle]");
		const icon = document.querySelector<HTMLElement>("[data-view-icon]");
		const proseView = document.querySelector<HTMLElement>(".js-prose-view");
		const magazineView = document.querySelector<HTMLElement>(".js-magazine-view");
		if (!article || !toggle || !icon || !proseView || !magazineView) return;

		const applyView = (view: "prose" | "magazine") => {
			const isMagazine = view === "magazine";
			article.dataset.view = view;
			toggle.setAttribute("aria-pressed", String(isMagazine));
			toggle.setAttribute("aria-label", isMagazine ? "Switch to standard article view" : "Switch to magazine view");
			icon.textContent = isMagazine ? "📰" : "📄";
			proseView.classList.toggle("hidden", isMagazine);
			proseView.classList.toggle("opacity-0", isMagazine);
			magazineView.classList.toggle("hidden", !isMagazine);
			magazineView.classList.toggle("pointer-events-none", !isMagazine);
			requestAnimationFrame(() => {
				magazineView.classList.toggle("opacity-0", !isMagazine);
			});
		};

		applyView("prose");
		toggle.addEventListener("click", () => {
			applyView(article.dataset.view === "magazine" ? "prose" : "magazine");
		});
	});
</script>

<style>
	.magazine-dropcap::first-letter {
		float: left;
		margin: 0.1em 0.12em 0 0;
		font-size: 3.8em;
		line-height: 0.8;
		font-weight: 700;
		color: #8953d1;
	}
	.magazine-dropcap > div:first-child::first-letter {
		float: left;
		margin: 0.1em 0.12em 0 0;
		font-size: 3.8em;
		line-height: 0.8;
		font-weight: 700;
		color: #8953d1;
	}
</style>
