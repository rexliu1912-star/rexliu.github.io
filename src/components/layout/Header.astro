---
import ThemeToggle from "../ThemeToggle.astro";
import LanguageToggle from "../LanguageToggle.astro";
import Search from "../Search.astro";

const { pathname } = Astro.url;
const isHome = pathname === "/" || pathname === "/index.html";
const TWITTER_URL = "https://twitter.com/rexliu";
const GITHUB_URL = "https://github.com/rexliu1912-star";
const TELEGRAM_URL = "https://t.me/rexlab2026";
---

<header class="sticky top-0 z-50 mb-16 flex items-center justify-between pt-2 pb-2 transition-all duration-200" id="main-header" style="background: var(--color-global-bg);">
	<nav class="flex items-center gap-6 font-serif text-sm text-black dark:text-white">
		{
			isHome ? (
				<a
					href="/posts/"
					class="transition-colors hover:text-[#8953d1] hover:underline hover:decoration-[#8953d1] hover:decoration-1 hover:underline-offset-4 dark:hover:text-[#a175e8] dark:hover:decoration-[#a175e8]"
				>
					Archive
				</a>
			) : (
				<a
					href="/"
					class="transition-colors hover:text-[#8953d1] hover:underline hover:decoration-[#8953d1] hover:decoration-1 hover:underline-offset-4 dark:hover:text-[#a175e8] dark:hover:decoration-[#a175e8]"
				>
					Home
				</a>
			)
		}

		<a
			href="/lab/"
			class="transition-colors hover:text-[#8953d1] hover:underline hover:decoration-[#8953d1] hover:decoration-1 hover:underline-offset-4 dark:hover:text-[#a175e8] dark:hover:decoration-[#a175e8]"
		>
			Lab
		</a>

		<a
			href="/os/"
			class="transition-colors hover:text-[#8953d1] hover:underline hover:decoration-[#8953d1] hover:decoration-1 hover:underline-offset-4 dark:hover:text-[#a175e8] dark:hover:decoration-[#a175e8]"
		>
			OS
		</a>

	</nav>

	<div class="flex items-center gap-1">
		<!-- Twitter/X icon -->
		<a
			href={TWITTER_URL}
			target="_blank"
			rel="noopener noreferrer"
			class="relative h-9 w-9 cursor-pointer rounded-md p-2 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			title="Twitter / X"
			aria-label="Twitter / X"
		>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2"
				fill="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
			</svg>
		</a>

		<!-- GitHub icon -->
		<a
			href={GITHUB_URL}
			target="_blank"
			rel="noopener noreferrer"
			class="relative h-9 w-9 cursor-pointer rounded-md p-2 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			title="GitHub"
			aria-label="GitHub"
		>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2"
				fill="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
			</svg>
		</a>

		<!-- Telegram -->
		<a
			href={TELEGRAM_URL}
			target="_blank"
			rel="noopener noreferrer"
			class="relative h-9 w-9 cursor-pointer rounded-md p-2 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			title="Telegram"
			aria-label="Telegram"
		>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215l-16.5 7.5a.75.75 0 0 0 .044 1.389l4.78 1.593 1.5 5.25a.75.75 0 0 0 1.26.333l2.197-2.197 4.032 3.024a1.5 1.5 0 0 0 2.34-.795l3.75-15a1.5 1.5 0 0 0-2.381-1.312z" />
				<path d="M10.5 13.5l8.25-7.5" />
			</svg>
		</a>

		<!-- RSS -->
		<a
			href="/rss.xml"
			class="relative h-9 w-9 cursor-pointer rounded-md p-2 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
			title="Subscribe to RSS Feed"
			aria-label="Subscribe to RSS Feed"
		>
			<svg
				aria-hidden="true"
				class="absolute start-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M4 11a9 9 0 0 1 9 9" stroke-linecap="round" stroke-linejoin="round"></path>
				<path d="M4 4a16 16 0 0 1 16 16" stroke-linecap="round" stroke-linejoin="round"></path>
				<circle cx="5" cy="19" r="1"></circle>
			</svg>
		</a>

		<Search />
		<LanguageToggle />
		<ThemeToggle />
	</div>
</header>

<script>
	function initHeader() {
		const header = document.getElementById("main-header") as HTMLElement | null;
		if (!header) return;
		const gradDark = "radial-gradient(circle at top left, rgba(137,83,209,0.14), transparent 26%), radial-gradient(circle at 80% 10%, rgba(59,130,246,0.09), transparent 24%)";
		const gradLight = "radial-gradient(circle at top left, rgba(137,83,209,0.08), transparent 26%), radial-gradient(circle at 80% 10%, rgba(245,158,11,0.07), transparent 24%)";
		const onScroll = () => {
			const isDark = document.documentElement.getAttribute("data-theme") !== "light";
			const grad = isDark ? gradDark : gradLight;
			if (window.scrollY > 8) {
				header.style.backdropFilter = "blur(12px)";
				(header.style as CSSStyleDeclaration & { webkitBackdropFilter: string }).webkitBackdropFilter = "blur(12px)";
				header.style.background = `color-mix(in srgb, var(--color-global-bg) 85%, transparent), ${grad}`;
				header.style.borderBottom = "1px solid color-mix(in srgb, currentColor 8%, transparent)";
				header.style.boxShadow = "0 1px 12px rgba(0,0,0,0.06)";
			} else {
				header.style.backdropFilter = "";
				(header.style as CSSStyleDeclaration & { webkitBackdropFilter: string }).webkitBackdropFilter = "";
				header.style.background = `var(--color-global-bg), ${grad}`;
				header.style.borderBottom = "none";
				header.style.boxShadow = "none";
			}
		};
		window.addEventListener("scroll", onScroll, { passive: true });
		onScroll();
	}
	document.addEventListener("astro:page-load", initHeader);
</script>
