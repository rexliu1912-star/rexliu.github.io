---
import { getCollection } from "astro:content";
import { env } from "@/env";

// 获取 GitHub 用户名
const GITHUB_USERNAME = "rexliu1912-star";

// 获取所有文章的发布日期
const allPosts = await getCollection("post");
const postDates = allPosts.map((post) => {
	const date = new Date(post.data.publishDate);
	return date.toISOString().split("T")[0]; // YYYY-MM-DD
});

// 统计每天的文章数量
const postCountByDate: Record<string, number> = {};
postDates.forEach((date) => {
	if (date) {
		postCountByDate[date] = (postCountByDate[date] || 0) + 1;
	}
});



// 生成过去一年的日期数组
function generateYearDates(): string[] {
	const dates: string[] = [];
	const today = new Date();
	const oneYearAgo = new Date(today);
	oneYearAgo.setFullYear(today.getFullYear() - 1);

	// 调整到周日开始
	const startDate = new Date(oneYearAgo);
	startDate.setDate(startDate.getDate() - startDate.getDay());

	const current = new Date(startDate);
	while (current <= today) {
		const dateStr = current.toISOString().split("T")[0];
		if (dateStr) dates.push(dateStr);
		current.setDate(current.getDate() + 1);
	}
	return dates;
}

// GitHub Contributions 数据接口
interface ContributionData {
	date: string;
	count: number;
	level: number;
}

// 使用 GitHub GraphQL API 获取贡献数据
async function fetchGitHubContributions(): Promise<Record<string, number>> {
	const token = env.GITHUB_TOKEN;

	if (!token) {
		console.warn("GITHUB_TOKEN not found, using fallback");
		return {};
	}

	const query = `
		query($username: String!) {
			user(login: $username) {
				contributionsCollection {
					contributionCalendar {
						weeks {
							contributionDays {
								date
								contributionCount
							}
						}
					}
				}
			}
		}
	`;

	try {
		const response = await fetch("https://api.github.com/graphql", {
			method: "POST",
			headers: {
				Authorization: `Bearer ${token}`,
				"Content-Type": "application/json",
			},
			body: JSON.stringify({
				query,
				variables: { username: GITHUB_USERNAME },
			}),
		});

		if (response.ok) {
			const data = await response.json();
			const contributions: Record<string, number> = {};
			const weeks = data?.data?.user?.contributionsCollection?.contributionCalendar?.weeks;

			if (weeks) {
				for (const week of weeks) {
					for (const day of week.contributionDays) {
						contributions[day.date] = day.contributionCount;
					}
				}
			}
			return contributions;
		}
	} catch (e) {
		console.error("GitHub GraphQL API error:", e);
	}
	return {};
}

const githubContributions = await fetchGitHubContributions();
const yearDates = generateYearDates();

// 计算活动级别 (0-4) - 根据实际数据分布调整阈值
function getLevel(count: number): number {
	if (count === 0) return 0;
	if (count === 1) return 1;
	if (count <= 3) return 2;
	if (count <= 6) return 3;
	return 4;
}

// 组合数据
const contributionData: ContributionData[] = yearDates.map((date) => {
	const postCount = postCountByDate[date] || 0;
	const githubCount = githubContributions[date] || 0;
	const totalCount = postCount + githubCount;
	return {
		date,
		count: totalCount,
		level: getLevel(totalCount),
	};
});

// 按周分组
const weeks: ContributionData[][] = [];
for (let i = 0; i < contributionData.length; i += 7) {
	weeks.push(contributionData.slice(i, i + 7));
}

// 统计总数
const totalPosts = Object.values(postCountByDate).reduce((sum, count) => sum + count, 0);
const totalGithubCommits = Object.values(githubContributions).reduce((sum, c) => sum + c, 0);

---

<div class="fade-in activity-wrapper" style="--delay: 200ms">
	<div class="activity-graph">
		<div class="graph-scroll">
			<div class="contribution-grid">
				{
					weeks.map((week) => (
						<div class="week">
							{week.map((day) => (
								<div
									class={`day level-${day.level}`}
									data-date={day.date}
									data-count={day.count}
									title={`${day.count} contribution${day.count !== 1 ? "s" : ""} on ${day.date}`}
								/>
							))}
						</div>
					))
				}
			</div>
		</div>

		<div class="activity-footer">
			<div class="stats">
				<span>Last 365 Days</span>
				<span><span class="count">{totalGithubCommits}</span> commits</span>
				<span><span class="count">{totalPosts}</span> posts</span>
				<span class="nudge-stat" data-nudge-stat role="button" tabindex="0" title="Click to nudge Rex!">
					<span class="nudge-snek-icon">🐍</span>
					<span class="count" data-nudge-count>0</span> nudges
				</span>
			</div>

			<div class="nudge-quote-bubble font-serif" data-nudge-quote></div>
			<div class="legend">
				<span class="legend-label">Less</span>
				<div class="day level-0"></div>
				<div class="day level-1"></div>
				<div class="day level-2"></div>
				<div class="day level-3"></div>
				<div class="day level-4"></div>
				<span class="legend-label">More</span>
			</div>
		</div>
	</div>
</div>

<style>
	@reference "../styles/global.css";

	.activity-wrapper {
		@apply mb-8 flex justify-start;
	}

	.activity-graph {
		@apply rounded-lg p-5;
		width: fit-content;
		max-width: 100%;
		background: #181818;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
	}

	:global([data-theme="light"]) .activity-graph {
		background: #fffaef;
		box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
	}

	.graph-scroll {
		@apply overflow-x-auto pb-2;
	}

	.contribution-grid {
		display: flex;
		flex-direction: row;
		gap: 3px;
		width: max-content;
		min-width: 100%;
	}

	.week {
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex-shrink: 0;
	}

	.day {
		width: 10px;
		height: 10px;
		/* 使用像素值确保在不同屏幕下对齐更精准 */
		border-radius: 2px;
		transition: transform 0.1s ease;
	}

	.day:hover {
		transform: scale(1.2);
		cursor: pointer;
	}

	/* 暗色主题颜色 - 紫色系 */
	.level-0 {
		background: #1a1a1a;
	}
	.level-1 {
		background: #3d2a5c;
	}
	.level-2 {
		background: #5c3d8a;
	}
	.level-3 {
		background: #8953d1;
	}
	.level-4 {
		background: #a175e8;
	}

	/* 亮色主题颜色 */
	:global([data-theme="light"]) .level-0 {
		background: #ebedf0;
	}
	:global([data-theme="light"]) .level-1 {
		background: #d8c7f0;
	}
	:global([data-theme="light"]) .level-2 {
		background: #b794e8;
	}
	:global([data-theme="light"]) .level-3 {
		background: #8953d1;
	}
	:global([data-theme="light"]) .level-4 {
		background: #6b3fa0;
	}

	.activity-footer {
		@apply relative mt-4 flex flex-col gap-3 font-serif text-xs text-gray-500 sm:flex-row sm:items-center sm:justify-between sm:gap-2;
	}

	.stats {
		@apply flex flex-wrap items-center gap-x-4 gap-y-1;
	}

	.stats .count {
		color: #8953d1;
		font-weight: 600;
	}

	:global([data-theme="dark"]) .stats .count {
		color: #a175e8;
	}

	.legend {
		@apply flex items-center gap-1 self-end sm:self-auto;
	}

	.legend-label {
		@apply mx-1;
	}

	.legend .day {
		width: 10px;
		height: 10px;
	}

	.legend .day:hover {
		transform: none;
		cursor: default;
	}

	.nudge-stat {
		cursor: pointer;
		transition: color 0.2s;
		position: relative;
		user-select: none;
	}

	.nudge-stat:hover {
		color: #8953d1 !important;
	}

	:global([data-theme="dark"]) .nudge-stat:hover {
		color: #a175e8 !important;
	}

	.nudge-snek-icon {
		display: inline-block;
		transition: transform 0.2s;
	}

	.nudge-stat:hover .nudge-snek-icon {
		transform: scale(1.3);
	}

	.nudge-stat.is-clicked .nudge-snek-icon {
		animation: nudge-wiggle 0.4s ease-in-out;
	}

	.nudge-quote-bubble {
		position: absolute;
		bottom: calc(100% + 8px);
		right: 0;
		max-width: 260px;
		padding: 4px 12px;
		border-radius: 999px;
		font-size: 11px;
		font-family: var(--font-serif);
		color: #8953d1;
		background: rgba(255,255,255,0.95);
		box-shadow: 0 1px 4px rgba(0,0,0,0.08);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s, transform 0.2s;
		transform: translateY(4px);
		white-space: nowrap;
		z-index: 10;
	}

	:global([data-theme="dark"]) .nudge-quote-bubble {
		background: rgba(24,24,27,0.95);
		color: #d5b8ff;
	}

	.nudge-quote-bubble.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	@keyframes nudge-wiggle {
		0%, 100% { transform: scale(1.3) rotate(0deg); }
		25% { transform: scale(1.3) rotate(-12deg); }
		50% { transform: scale(1.3) rotate(10deg); }
		75% { transform: scale(1.3) rotate(-8deg); }
	}
</style>

<script is:inline>
(() => {
  const stat = document.querySelector('[data-nudge-stat]');
  if (!stat || stat.dataset.bound === 'true') return;
  stat.dataset.bound = 'true';

  const countEl = stat.querySelector('[data-nudge-count]');
  const quoteEl = document.querySelector('[data-nudge-quote]');
  const quotes = [
    'Stay Invested in the Game 🐍',
    '又被催了，那就继续干 👨‍💻',
    '复杂问题简单化，简单事情重复做',
    '信心就是黄金，你的催促是利息',
    '买预期，卖事实——你催我，我执行',
    '耐心是关键，但被催了就快一点',
    'Be the sovereign individual',
    '2017 年就入圈了，还差这一行代码？',
    '催催催，蛇蛇蛇 🐍',
    '每一次点击都是对抗熵增的努力',
    '福福问我为什么总在用电脑，因为有人在催',
    'Build in public，催在 rexliu.io',
    '一催一个准，谢谢老铁',
    'Shipped > Perfect',
    '数字在涨，代码在烧 🔥',
  ];
  let currentCount = 0;
  let clicking = false;
  let quoteTimer;

  function fmt(n) { return new Intl.NumberFormat('en-US').format(n); }

  function animateCount(next) {
    const start = currentCount, end = Number(next) || 0, diff = end - start;
    if (!countEl || diff === 0) { if (countEl) countEl.textContent = fmt(end); currentCount = end; return; }
    const steps = Math.min(15, Math.max(6, Math.abs(diff)));
    let step = 0;
    const tick = () => {
      step++;
      countEl.textContent = fmt(Math.round(start + diff * (step / steps)));
      if (step < steps) setTimeout(tick, 25); else { currentCount = end; countEl.textContent = fmt(end); }
    };
    tick();
  }

  function showQuote() {
    if (!quoteEl) return;
    quoteEl.textContent = quotes[Math.floor(Math.random() * quotes.length)];
    quoteEl.classList.add('is-visible');
    clearTimeout(quoteTimer);
    quoteTimer = setTimeout(() => quoteEl.classList.remove('is-visible'), 3000);
  }

  function wiggle() {
    stat.classList.remove('is-clicked');
    void stat.offsetWidth;
    stat.classList.add('is-clicked');
    setTimeout(() => stat.classList.remove('is-clicked'), 400);
  }

  async function loadCount() {
    try {
      const r = await fetch('https://shiny-butterfly-744.convex.cloud/api/query', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({path: 'nudge:getNudgeCount', args: {}, format: 'json'}),
      });
      const d = await r.json();
      currentCount = Number(d.value) || 0;
      if (countEl) countEl.textContent = fmt(currentCount);
    } catch {}
  }

  async function handleClick() {
    if (clicking) return;
    clicking = true;
    wiggle();
    try {
      const r = await fetch('https://shiny-butterfly-744.convex.cloud/api/mutation', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({path: 'nudge:incrementNudge', args: {}, format: 'json'}),
      });
      const d = await r.json();
      animateCount(Number(d.value) || currentCount + 1);
      showQuote();
    } catch {}
    setTimeout(() => { clicking = false; }, 500);
  }

  stat.addEventListener('click', handleClick);
  stat.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handleClick(); } });
  loadCount();
})();
</script>
