---
import { getCollection } from "astro:content";
import { env } from "@/env";

// 获取 GitHub 用户名（合并两个账号的贡献）
const GITHUB_USERNAMES = ["rexliu1912-star", "samantha-ai-agent"];

// 获取所有文章的发布日期
const allPosts = await getCollection("post");
const postDates = allPosts.map((post) => {
	const date = new Date(post.data.publishDate);
	return date.toISOString().split("T")[0]; // YYYY-MM-DD
});

// 统计每天的文章数量
const postCountByDate: Record<string, number> = {};
postDates.forEach((date) => {
	if (date) {
		postCountByDate[date] = (postCountByDate[date] || 0) + 1;
	}
});



// 生成过去一年的日期数组
function generateYearDates(): string[] {
	const dates: string[] = [];
	const today = new Date();
	const oneYearAgo = new Date(today);
	oneYearAgo.setFullYear(today.getFullYear() - 1);

	// 调整到周日开始
	const startDate = new Date(oneYearAgo);
	startDate.setDate(startDate.getDate() - startDate.getDay());

	const current = new Date(startDate);
	while (current <= today) {
		const dateStr = current.toISOString().split("T")[0];
		if (dateStr) dates.push(dateStr);
		current.setDate(current.getDate() + 1);
	}
	return dates;
}

// GitHub Contributions 数据接口
interface ContributionData {
	date: string;
	count: number;
	level: number;
}

// 使用 GitHub GraphQL API 获取贡献数据（支持合并多个账号）
async function fetchGitHubContributions(usernames: string[]): Promise<Record<string, number>> {
	const token = env.GITHUB_TOKEN;

	if (!token) {
		console.warn("GITHUB_TOKEN not found, using fallback");
		return {};
	}

	const merged: Record<string, number> = {};

	for (const username of usernames) {
		const query = `
			query($username: String!) {
				user(login: $username) {
					contributionsCollection {
						contributionCalendar {
							weeks {
								contributionDays {
									date
									contributionCount
								}
							}
						}
					}
				}
			}
		`;

		try {
			const response = await fetch("https://api.github.com/graphql", {
				method: "POST",
				headers: {
					Authorization: `Bearer ${token}`,
					"Content-Type": "application/json",
				},
				body: JSON.stringify({
					query,
					variables: { username },
				}),
			});

			if (response.ok) {
				const data = await response.json();
				const weeks = data?.data?.user?.contributionsCollection?.contributionCalendar?.weeks;

				if (weeks) {
					for (const week of weeks) {
						for (const day of week.contributionDays) {
							merged[day.date] = (merged[day.date] || 0) + day.contributionCount;
						}
					}
				}
			}
		} catch (e) {
			console.error(`GitHub GraphQL API error for ${username}:`, e);
		}
	}

	return merged;
}

const githubContributions = await fetchGitHubContributions(GITHUB_USERNAMES);
const yearDates = generateYearDates();

// 计算活动级别 (0-4) - 根据实际数据分布调整阈值
function getLevel(count: number): number {
	if (count === 0) return 0;
	if (count === 1) return 1;
	if (count <= 3) return 2;
	if (count <= 6) return 3;
	return 4;
}

// 组合数据
const contributionData: ContributionData[] = yearDates.map((date) => {
	const postCount = postCountByDate[date] || 0;
	const githubCount = githubContributions[date] || 0;
	const totalCount = postCount + githubCount;
	return {
		date,
		count: totalCount,
		level: getLevel(totalCount),
	};
});

// 按周分组
const weeks: ContributionData[][] = [];
for (let i = 0; i < contributionData.length; i += 7) {
	weeks.push(contributionData.slice(i, i + 7));
}

// 统计总数
const totalPosts = Object.values(postCountByDate).reduce((sum, count) => sum + count, 0);
const totalGithubCommits = Object.values(githubContributions).reduce((sum, c) => sum + c, 0);

---

<div class="fade-in activity-wrapper" style="--delay: 200ms">
	<div class="activity-graph">
		<div class="graph-scroll">
			<div class="contribution-grid">
				{
					weeks.map((week) => (
						<div class="week">
							{week.map((day) => (
								<div
									class={`day level-${day.level}`}
									data-date={day.date}
									data-count={day.count}
									data-tip={`${day.count} contribution${day.count !== 1 ? "s" : ""} on ${day.date}`}
								/>
							))}
						</div>
					))
				}
			</div>
		</div>

		<div class="activity-footer">
			<div class="stats">
				<span><span class="lang-en">Last 365 Days</span><span class="lang-zh">过去 365 天</span></span>
				<span><span class="count">{totalGithubCommits}</span> <span class="lang-en">commits</span><span class="lang-zh">次提交</span></span>
				<span><span class="count">{totalPosts}</span> <span class="lang-en">posts</span><span class="lang-zh">篇文章</span></span>
				<span class="nudge-stat nudge-loading" data-nudge-stat role="button" tabindex="0" title="点一下催 Rex 干活">
					<span class="count" data-nudge-count>0</span> <span class="lang-en">nudges</span><span class="lang-zh">次催更</span>
				</span>
			</div>

			<div class="nudge-quote-bubble font-serif" data-nudge-quote></div>
			<div class="legend">
				<span class="legend-label"><span class="lang-en">Less</span><span class="lang-zh">少</span></span>
				<div class="day level-0"></div>
				<div class="day level-1"></div>
				<div class="day level-2"></div>
				<div class="day level-3"></div>
				<div class="day level-4"></div>
				<span class="legend-label"><span class="lang-en">More</span><span class="lang-zh">多</span></span>
			</div>
		</div>
	</div>
</div>

<style>
	@reference "../styles/global.css";

	.activity-wrapper {
		@apply mb-8 flex justify-start;
	}

	.activity-graph {
		@apply rounded-lg p-5;
		width: fit-content;
		max-width: 100%;
		background: #181818;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
	}

	:global([data-theme="light"]) .activity-graph {
		background: #fffaef;
		box-shadow: 0 1px 6px rgba(0, 0, 0, 0.04);
	}

	.graph-scroll {
		@apply overflow-x-auto pb-2;
	}

	.contribution-grid {
		display: flex;
		flex-direction: row;
		gap: 3px;
		width: max-content;
		min-width: 100%;
	}

	.week {
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex-shrink: 0;
	}

	.day {
		width: 10px;
		height: 10px;
		/* 使用像素值确保在不同屏幕下对齐更精准 */
		border-radius: 2px;
		transition: transform 0.1s ease;
	}

	.day:hover {
		transform: scale(1.2);
		cursor: pointer;
	}

	/* 暗色主题颜色 - 紫色系 */
	.level-0 {
		background: #1a1a1a;
	}
	.level-1 {
		background: #3d2a5c;
	}
	.level-2 {
		background: #5c3d8a;
	}
	.level-3 {
		background: #8953d1;
	}
	.level-4 {
		background: #a175e8;
	}

	/* 亮色主题颜色 */
	:global([data-theme="light"]) .level-0 {
		background: #ebedf0;
	}
	:global([data-theme="light"]) .level-1 {
		background: #d8c7f0;
	}
	:global([data-theme="light"]) .level-2 {
		background: #b794e8;
	}
	:global([data-theme="light"]) .level-3 {
		background: #8953d1;
	}
	:global([data-theme="light"]) .level-4 {
		background: #6b3fa0;
	}

	.activity-footer {
		@apply relative mt-4 flex flex-col gap-3 font-serif text-xs text-gray-500 sm:flex-row sm:items-center sm:justify-between sm:gap-2;
	}

	.stats {
		@apply flex flex-wrap items-center gap-x-4 gap-y-1;
	}

	.stats .count {
		color: #8953d1;
		font-weight: 600;
	}

	:global([data-theme="dark"]) .stats .count {
		color: #a175e8;
	}

	.legend {
		@apply flex items-center gap-1 self-end sm:self-auto;
	}

	.legend-label {
		@apply mx-1;
	}

	.legend .day {
		width: 10px;
		height: 10px;
	}

	.legend .day:hover {
		transform: none;
		cursor: default;
	}

	.nudge-stat.nudge-loading {
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.nudge-stat.nudge-loaded {
		opacity: 1;
		transition: opacity 0.4s ease;
	}
	.nudge-stat {
		cursor: pointer;
		transition: color 0.2s;
		position: relative;
		user-select: none;
	}

	.nudge-stat:hover {
		color: #8953d1 !important;
	}

	:global([data-theme="dark"]) .nudge-stat:hover {
		color: #a175e8 !important;
	}

	.nudge-stat.is-clicked {
		animation: nudge-wiggle 0.3s ease-in-out;
	}

	.nudge-quote-bubble {
		position: absolute;
		bottom: calc(100% + 8px);
		right: 0;
		max-width: 260px;
		padding: 4px 12px;
		border-radius: 999px;
		font-size: 11px;
		font-family: var(--font-serif);
		color: #8953d1;
		background: rgba(255,255,255,0.95);
		box-shadow: 0 1px 4px rgba(0,0,0,0.08);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s, transform 0.2s;
		transform: translateY(4px);
		white-space: nowrap;
		z-index: 10;
	}

	:global([data-theme="dark"]) .nudge-quote-bubble {
		background: rgba(24,24,27,0.95);
		color: #d5b8ff;
	}

	.nudge-quote-bubble.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.nudge-quote-bubble.is-milestone {
		font-size: 12px;
		font-weight: 600;
		background: #8953d1;
		color: #fff;
		max-width: 300px;
		white-space: normal;
		text-align: center;
	}

	:global([data-theme="dark"]) .nudge-quote-bubble.is-milestone {
		background: #a175e8;
		color: #fff;
	}

	@keyframes nudge-wiggle {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-2px); }
		75% { transform: translateX(2px); }
	}
</style>

<script is:inline>
function initNudge() {
  const stat = document.querySelector('[data-nudge-stat]');
  if (!stat) return;
  // 重新绑定（View Transitions 后 DOM 刷新，需重置）
  stat.dataset.bound = 'true';

  const countEl = stat.querySelector('[data-nudge-count]');
  const quoteEl = document.querySelector('[data-nudge-quote]');
  const quotes = [
    'Stay Invested in the Game 🐍',
    '又被催了，继续干 👨‍💻',
    '信心就是黄金，催促是利息',
    '买预期，卖事实。你催，我执行',
    '蛇不催，蛇不动 🐍',
    '2017 入圈，还差这一行代码？',
    '催催催，蛇蛇蛇',
    '福福问我为啥总用电脑，因为有人催',
    'Shipped > Perfect',
    '数字在涨，代码在烧 🔥',
    'One more nudge. Come on.',
    '你点一下，我少摸一分钟鱼',
    '谢谢催我，真的，不是客气',
    "ok ok I'm coding 👀",
    "复杂问题简单化，简单事情重复做",
    'Be the sovereign individual',
    '蛇感受到了你的诚意',
    'Every click counts 🫡',
    '催完记得去书架点「我也看过」',
    '你催，我 build，大家赢',
    '牛市催代码，熊市催代码，永远催代码',
    'Rex noticed your nudge 👁',
    '数字到 100 有彩蛋，继续点',
    '不催白不催，催了也许有用',
    'gm gm gm 🐍',
    '一个 sovereign individual 正在被催',
    'brb shipping something',
    '耐心是关键，但被催就快一点',
    '你是第几个催我的？看数字',
    'Stay frosty. Stay building.',
  ];
  let currentCount = 0;
  let clicking = false;
  let quoteTimer;

  function fmt(n) { return new Intl.NumberFormat('en-US').format(n); }

  function animateCount(next) {
    const start = currentCount, end = Number(next) || 0, diff = end - start;
    if (!countEl || diff === 0) { if (countEl) countEl.textContent = fmt(end); currentCount = end; return; }
    const steps = Math.min(15, Math.max(6, Math.abs(diff)));
    let step = 0;
    const tick = () => {
      step++;
      countEl.textContent = fmt(Math.round(start + diff * (step / steps)));
      if (step < steps) setTimeout(tick, 25); else { currentCount = end; countEl.textContent = fmt(end); }
    };
    tick();
  }

  function showQuote() {
    if (!quoteEl) return;
    quoteEl.textContent = quotes[Math.floor(Math.random() * quotes.length)];
    quoteEl.classList.add('is-visible');
    clearTimeout(quoteTimer);
    quoteTimer = setTimeout(() => quoteEl.classList.remove('is-visible'), 3000);
  }

  function wiggle() {
    stat.classList.remove('is-clicked');
    void stat.offsetWidth;
    stat.classList.add('is-clicked');
    setTimeout(() => stat.classList.remove('is-clicked'), 400);
  }

  async function convexRetry(path, args, retries = 3) {
    for (let i = 0; i < retries; i++) {
      try {
        const r = await fetch('https://shiny-butterfly-744.convex.cloud/api/' + (args ? 'mutation' : 'query'), {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({path, args: args || {}, format: 'json'}),
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const d = await r.json();
        if (d.status === 'success') return d.value;
        throw new Error(d.errorMessage || 'failed');
      } catch (e) {
        if (i < retries - 1) await new Promise(r => setTimeout(r, 1000 * Math.pow(2, i)));
        else throw e;
      }
    }
  }

  async function loadCount() {
    try {
      const val = await convexRetry('nudge:getNudgeCount');
      currentCount = Number(val) || 0;
      if (countEl) countEl.textContent = fmt(currentCount);
    } catch (e) {
      console.warn('nudge loadCount failed', e);
    }
    // Fade in after data loaded (or failed)
    stat.classList.remove('nudge-loading');
    stat.classList.add('nudge-loaded');
  }

  async function handleClick() {
    if (clicking) return;
    clicking = true;
    wiggle();
    // Optimistic update
    animateCount(currentCount + 1);
    showQuote();
    try {
      const val = await convexRetry('nudge:incrementNudge', {});
      const newCount = Number(val) || currentCount;
      animateCount(newCount);
      checkMilestone(newCount);
    } catch (e) {
      // Rollback optimistic update
      console.warn('nudge increment failed', e);
      animateCount(currentCount);
    }
    setTimeout(() => { clicking = false; }, 500);
  }

  stat.addEventListener('click', handleClick);
  stat.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handleClick(); } });
  loadCount();
}

// --- Activity cell tooltip ---
function initActivityTooltip() {
  // Create or reuse tooltip element (inline styles to avoid Astro scoping issues)
  let tip = document.getElementById('activity-tooltip');
  if (!tip) {
    tip = document.createElement('div');
    tip.id = 'activity-tooltip';
    Object.assign(tip.style, {
      position: 'fixed',
      zIndex: '100',
      padding: '4px 8px',
      borderRadius: '4px',
      fontSize: '11px',
      lineHeight: '1.4',
      whiteSpace: 'nowrap',
      pointerEvents: 'none',
      opacity: '0',
      transition: 'opacity 0.15s ease',
      background: '#2d2d2d',
      color: '#e0e0e0',
      boxShadow: '0 2px 6px rgba(0,0,0,0.25)',
    });
    document.body.appendChild(tip);
    // Light theme support
    const updateTheme = () => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';
      tip.style.background = isLight ? '#fff' : '#2d2d2d';
      tip.style.color = isLight ? '#333' : '#e0e0e0';
      tip.style.boxShadow = isLight ? '0 2px 8px rgba(0,0,0,0.12)' : '0 2px 6px rgba(0,0,0,0.25)';
    };
    updateTheme();
    new MutationObserver(updateTheme).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  }

  let hideTimer;

  function showTip(el, e) {
    const text = el.dataset.tip;
    if (!text) return;
    tip.textContent = text;
    tip.style.opacity = '1';
    positionTip(e);
  }

  function positionTip(e) {
    const x = e.clientX;
    const y = e.clientY;
    const tw = tip.offsetWidth;
    const th = tip.offsetHeight;
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    let left = x + 12;
    let top = y - th - 8;
    if (left + tw > vw - 8) left = x - tw - 12;
    if (top < 8) top = y + 16;
    tip.style.left = left + 'px';
    tip.style.top = top + 'px';
  }

  function hideTip() {
    tip.style.opacity = '0';
  }

  // Delegate events on the contribution grid
  const grid = document.querySelector('.contribution-grid');
  if (!grid) return;

  grid.addEventListener('mouseover', (e) => {
    const cell = e.target.closest('[data-tip]');
    clearTimeout(hideTimer);
    if (cell) showTip(cell, e);
    else hideTip();
  });

  grid.addEventListener('mousemove', (e) => {
    if (tip.style.opacity === '1') positionTip(e);
  });

  grid.addEventListener('mouseleave', () => {
    hideTimer = setTimeout(hideTip, 100);
  });
}

// 多种方式确保初始化
function initAll() {
  initNudge();
  initActivityTooltip();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initAll);
} else {
  initAll();
}
document.addEventListener('astro:page-load', initAll);
</script>
