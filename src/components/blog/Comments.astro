---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div class="giscus-wrapper mt-8 mb-4" id={`giscus-container-${slug}`} data-giscus-container>
</div>

<script is:inline>
function getGiscusTheme() {
  return document.documentElement.dataset.theme === 'dark' ? 'dark_dimmed' : 'light';
}

function getGiscusLang() {
  return document.documentElement.classList.contains('lang-en') ? 'en' : 'zh-CN';
}

function syncGiscusTheme(container) {
  const iframe = container?.querySelector('iframe.giscus-frame');
  if (!iframe?.contentWindow) return;

  iframe.contentWindow.postMessage(
    {
      giscus: {
        setConfig: {
          theme: getGiscusTheme(),
          lang: getGiscusLang(),
        },
      },
    },
    'https://giscus.app'
  );
}

function initGiscus() {
  const containers = document.querySelectorAll('[data-giscus-container]');
  if (!containers.length) return;

  containers.forEach((container) => {
    if (container.dataset.loaded === 'true') {
      syncGiscusTheme(container);
      return;
    }

    container.innerHTML = '';
    container.dataset.loaded = 'true';

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.dataset.repo = 'rexliu1912-star/rexliu.github.io';
    script.dataset.repoId = 'R_kgDOQo6tCA';
    script.dataset.category = 'Announcements';
    script.dataset.categoryId = 'DIC_kwDOQo6tCM4C4c1z';
    script.dataset.mapping = 'pathname';
    script.dataset.strict = '0';
    script.dataset.reactionsEnabled = '1';
    script.dataset.emitMetadata = '0';
    script.dataset.inputPosition = 'top';
    script.dataset.theme = getGiscusTheme();
    script.dataset.lang = getGiscusLang();
    script.dataset.loading = 'lazy';
    script.crossOrigin = 'anonymous';
    script.async = true;

    container.appendChild(script);
  });
}

if (!window.__giscusThemeObserverBound) {
  window.__giscusThemeObserverBound = 'true';

  const observer = new MutationObserver((mutations) => {
    if (mutations.some((mutation) => mutation.attributeName === 'data-theme' || mutation.attributeName === 'class')) {
      document.querySelectorAll('[data-giscus-container]').forEach((container) => syncGiscusTheme(container));
    }
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme', 'class'],
  });

  document.addEventListener('theme-change', () => {
    document.querySelectorAll('[data-giscus-container]').forEach((container) => syncGiscusTheme(container));
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initGiscus);
} else {
  initGiscus();
}

document.addEventListener('astro:page-load', () => {
  document.querySelectorAll('[data-giscus-container]').forEach((container) => {
    container.dataset.loaded = 'false';
  });
  initGiscus();
});
</script>
