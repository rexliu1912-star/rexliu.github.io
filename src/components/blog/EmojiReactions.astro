---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div class="emoji-reactions" data-emoji-reactions data-slug={slug}>
  <button type="button" class="emoji-btn" data-emoji="fire" aria-label="React with fire">
    <span class="emoji-icon" aria-hidden="true">🔥</span>
    <span class="emoji-count font-serif" data-count>0</span>
  </button>
  <button type="button" class="emoji-btn" data-emoji="thinking" aria-label="React with thinking">
    <span class="emoji-icon" aria-hidden="true">🤔</span>
    <span class="emoji-count font-serif" data-count>0</span>
  </button>
  <button type="button" class="emoji-btn" data-emoji="idea" aria-label="React with idea">
    <span class="emoji-icon" aria-hidden="true">💡</span>
    <span class="emoji-count font-serif" data-count>0</span>
  </button>
  <button type="button" class="emoji-btn" data-emoji="clap" aria-label="React with clap">
    <span class="emoji-icon" aria-hidden="true">👏</span>
    <span class="emoji-count font-serif" data-count>0</span>
  </button>
</div>

<style>
  .emoji-reactions {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
  }

  .emoji-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
  }

  .emoji-icon {
    font-size: 1.5rem;
    line-height: 1;
    transition: transform 0.2s ease;
    transform-origin: center;
  }

  .emoji-btn:hover .emoji-icon,
  .emoji-btn:focus-visible .emoji-icon {
    transform: scale(1.3);
  }

  .emoji-btn:focus-visible {
    outline: none;
  }

  .emoji-count {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: rgb(156 163 175);
  }

  .emoji-btn.is-reacted .emoji-count {
    color: #8953d1;
  }

  .emoji-btn.is-clicked .emoji-icon {
    animation: emoji-bounce 0.3s ease;
  }

  @keyframes emoji-bounce {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  @media (max-width: 640px) {
    .emoji-reactions {
      gap: 1.5rem;
    }
  }
</style>

<script is:inline>
function initEmojiReactions() {
  const roots = document.querySelectorAll('[data-emoji-reactions]');
  if (!roots.length) return;

  const emojiKeys = ['fire', 'thinking', 'idea', 'clap'];
  const defaultCounts = { fire: 0, thinking: 0, idea: 0, clap: 0 };
  const queryUrl = 'https://shiny-butterfly-744.convex.cloud/api/query';
  const mutationUrl = 'https://shiny-butterfly-744.convex.cloud/api/mutation';

  roots.forEach((root) => {
    const slug = root.getAttribute('data-slug');
    if (!slug) return;

    const buttons = Array.from(root.querySelectorAll('[data-emoji]'));
    if (!buttons.length) return;

    buttons.forEach((button) => {
      const emoji = button.getAttribute('data-emoji');
      if (!emoji) return;

      const storageKey = `reaction_${slug}_${emoji}`;
      const reacted = localStorage.getItem(storageKey) === '1';
      button.classList.toggle('is-reacted', reacted);

      if (button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';

      button.addEventListener('click', async () => {
        if (button.dataset.loading === 'true') return;
        if (localStorage.getItem(storageKey) === '1') return;

        const countEl = button.querySelector('[data-count]');
        const currentCount = Number(countEl?.textContent || 0) || 0;

        button.dataset.loading = 'true';
        button.classList.remove('is-clicked');
        void button.offsetWidth;
        button.classList.add('is-clicked');
        setTimeout(() => button.classList.remove('is-clicked'), 350);

        if (countEl) countEl.textContent = String(currentCount + 1);
        button.classList.add('is-reacted');

        try {
          const response = await fetch(mutationUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path: 'reactions:incrementReaction', args: { slug, emoji }, format: 'json' }),
          });
          const data = await response.json();
          const nextCount = Number(data?.value?.[emoji] ?? data?.value ?? currentCount + 1) || currentCount + 1;
          if (countEl) countEl.textContent = String(nextCount);
          localStorage.setItem(storageKey, '1');
        } catch {
          if (countEl) countEl.textContent = String(currentCount);
          button.classList.remove('is-reacted');
        } finally {
          delete button.dataset.loading;
        }
      });
    });

    async function loadCounts() {
      try {
        const response = await fetch(queryUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: 'reactions:getReactions', args: { slug }, format: 'json' }),
        });
        const data = await response.json();
        const counts = { ...defaultCounts, ...(data?.value || {}) };

        buttons.forEach((button) => {
          const emoji = button.getAttribute('data-emoji');
          const countEl = button.querySelector('[data-count]');
          if (!emoji || !countEl) return;
          countEl.textContent = String(Number(counts[emoji] || 0));
          const reacted = localStorage.getItem(`reaction_${slug}_${emoji}`) === '1';
          button.classList.toggle('is-reacted', reacted);
        });
      } catch {
        buttons.forEach((button) => {
          const emoji = button.getAttribute('data-emoji');
          if (!emoji) return;
          const reacted = localStorage.getItem(`reaction_${slug}_${emoji}`) === '1';
          button.classList.toggle('is-reacted', reacted);
        });
      }
    }

    loadCounts();
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initEmojiReactions);
} else {
  initEmojiReactions();
}
document.addEventListener('astro:page-load', initEmojiReactions);
</script>
