---
/**
 * TagAnimation — article header animation strip
 * Maps article tags to a matching SVG animation.
 * Placed below the title, above meta info.
 */

interface Props {
  tags: string[];
}

const { tags } = Astro.props;

type AnimationType = "crypto" | "ai" | "investment" | "travel" | "none";

function detectType(tags: string[]): AnimationType {
  const t = tags.map((s) => s.toLowerCase()).join(" ");
  if (/crypto|bitcoin|btc|snek|cardano|ada|defi|web3|nft|trading/.test(t)) return "crypto";
  if (/ai|artificial|machine.learning|vibe.coding|vibe-coding|agent|llm|gpt|claude/.test(t)) return "ai";
  if (/invest|gold|etf|stock|wealth|finance|portfolio|market/.test(t)) return "investment";
  if (/travel|nomad|life|lifestyle|family|city/.test(t)) return "travel";
  return "none";
}

const type = detectType(tags);
---

{type !== "none" && (
  <div class="tag-anim-strip" aria-hidden="true">
    {type === "crypto" && (
      <svg class="tag-anim-svg" viewBox="0 0 600 60" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="g-crypto" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#8953d1" stop-opacity="0"/>
            <stop offset="40%" stop-color="#8953d1" stop-opacity="1"/>
            <stop offset="100%" stop-color="#a175e8" stop-opacity="0.3"/>
          </linearGradient>
        </defs>
        <path id="snakePath" d="" fill="none" stroke="url(#g-crypto)" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
        <circle r="4" fill="#8953d1">
          <animateMotion dur="4s" repeatCount="indefinite">
            <mpath href="#snakePath"/>
          </animateMotion>
        </circle>
        <circle r="2" fill="#fff" opacity="0.8">
          <animateMotion dur="4s" begin="0.4s" repeatCount="indefinite">
            <mpath href="#snakePath"/>
          </animateMotion>
        </circle>
        <text x="570" y="36" fill="#8953d1" font-size="24" font-weight="bold" opacity="0.7">₿</text>
        <script>
          {`(function(){
            var p = document.getElementById('snakePath');
            if(!p) return;
            var d = 'M 10 30';
            for(var x=10; x<=560; x+=4){
              var y = 30 + Math.sin((x/560)*Math.PI*3) * 13;
              d += ' L '+x+' '+y;
            }
            p.setAttribute('d', d);
          })()`}
        </script>
      </svg>
    )}

    {type === "ai" && (
      <svg class="tag-anim-svg" viewBox="0 0 600 60" preserveAspectRatio="xMidYMid meet">
        <defs>
          <style>{`
            .node { fill: #8953d1; }
            .edge { stroke: #8953d1; stroke-width: 1; opacity: 0.35; fill: none; }
          `}</style>
        </defs>
        {/* Nodes */}
        {[
          [30,30],[100,15],[100,45],[180,30],[260,15],[260,45],
          [340,30],[420,15],[420,45],[500,30],[565,30]
        ].map(([cx,cy], i) => (
          <circle class="node" cx={cx} cy={cy} r="3.5">
            <animate attributeName="opacity" values="1;0.3;1" dur="2s"
              begin={`${i * 0.18}s`} repeatCount="indefinite"/>
          </circle>
        ))}
        {/* Edges */}
        <polyline class="edge" points="30,30 100,15 180,30 260,15 340,30 420,15 500,30 565,30"/>
        <polyline class="edge" points="100,45 180,30 260,45 340,30 420,45 500,30"/>
        {/* Pulse */}
        <circle r="3" fill="#fff" opacity="0.9">
          <animateMotion dur="2.5s" repeatCount="indefinite"
            path="M30,30 L100,15 L180,30 L260,15 L340,30 L420,15 L500,30 L565,30"/>
        </circle>
        <circle r="2" fill="#a175e8" opacity="0.7">
          <animateMotion dur="2.5s" begin="1.2s" repeatCount="indefinite"
            path="M100,45 L180,30 L260,45 L340,30 L420,45 L500,30"/>
        </circle>
      </svg>
    )}

    {type === "investment" && (
      <svg class="tag-anim-svg" viewBox="0 0 600 60" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="g-inv" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#8953d1" stop-opacity="0.15"/>
            <stop offset="100%" stop-color="#8953d1" stop-opacity="0.5"/>
          </linearGradient>
          <clipPath id="chart-clip">
            <rect x="0" y="0" height="60" width="0">
              <animate attributeName="width" from="0" to="570" dur="2.5s"
                fill="freeze" calcMode="spline" keySplines="0.4 0 0.2 1"/>
            </rect>
          </clipPath>
        </defs>
        <polygon
          points="10,52 70,46 130,38 200,43 270,29 340,20 410,13 480,8 550,4 550,56 10,56"
          fill="url(#g-inv)" clip-path="url(#chart-clip)"/>
        <polyline
          points="10,52 70,46 130,38 200,43 270,29 340,20 410,13 480,8 550,4"
          fill="none" stroke="#8953d1" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round"
          clip-path="url(#chart-clip)"/>
        <circle cx="550" cy="4" r="5" fill="#8953d1">
          <animate attributeName="opacity" from="0" to="1" dur="0.3s" begin="2.4s" fill="freeze"/>
          <animate attributeName="r" values="5;7;5" dur="1.8s" begin="2.7s" repeatCount="indefinite"/>
        </circle>
        <text x="560" y="12" fill="#8953d1" font-size="18" opacity="0.8">↗</text>
      </svg>
    )}

    {type === "travel" && (
      <svg class="tag-anim-svg" viewBox="0 0 600 60" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="g-travel" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#8953d1" stop-opacity="0"/>
            <stop offset="30%" stop-color="#8953d1" stop-opacity="0.8"/>
            <stop offset="100%" stop-color="#a175e8" stop-opacity="0.3"/>
          </linearGradient>
        </defs>
        {/* Compass */}
        <circle cx="35" cy="30" r="22" fill="none" stroke="#8953d1" stroke-width="1.5" opacity="0.5"/>
        <circle cx="35" cy="30" r="2.5" fill="#8953d1"/>
        <g>
          <line x1="35" y1="30" x2="35" y2="12" stroke="#8953d1" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="35" y1="30" x2="35" y2="48" stroke="#555" stroke-width="2" stroke-linecap="round"/>
          <animateTransform attributeName="transform" type="rotate"
            values="0 35 30; 6 35 30; -2 35 30; 4 35 30; 0 35 30"
            dur="4s" repeatCount="indefinite"/>
        </g>
        <text x="31" y="10" fill="#8953d1" font-size="8">N</text>
        {/* Journey path */}
        <path d="M 65 30 Q 160 10 280 28 Q 380 44 480 18 Q 530 8 570 22"
          fill="none" stroke="url(#g-travel)" stroke-width="1.5" stroke-dasharray="5,5">
          <animate attributeName="stroke-dashoffset" from="200" to="0" dur="4s" repeatCount="indefinite"/>
        </path>
        {/* Stops */}
        {[130, 280, 420, 555].map((cx, i) => (
          <circle cx={cx} cy={i === 0 ? 18 : i === 1 ? 28 : i === 2 ? 22 : 20} r="3.5" fill="#8953d1">
            <animate attributeName="opacity" values="0.3;1;0.3" dur="2.5s"
              begin={`${i * 0.5}s`} repeatCount="indefinite"/>
          </circle>
        ))}
      </svg>
    )}
  </div>
)}

<style>
  .tag-anim-strip {
    width: 100%;
    margin: 12px 0 4px;
    overflow: hidden;
  }
  .tag-anim-svg {
    width: 100%;
    height: 60px;
    display: block;
  }
</style>
