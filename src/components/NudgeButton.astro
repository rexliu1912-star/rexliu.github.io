---
const snekPixels = [
  1, 2, 3,
  6, 11,
  12, 13, 14,
  21,
  26, 27, 28,
  33,
  36, 37, 38,
  43,
  48, 49, 50,
];

const quotes = [
  'Stay Invested in the Game 🐍',
  '复杂问题简单化，简单事情重复做',
  '信心就是黄金',
  '买预期，卖事实',
  '耐心是关键',
  'Be the sovereign individual',
];
---

<section class="nudge-shell fade-in-up" style="--delay: 260ms">
  <div class="nudge-row" data-nudge-root data-quotes={JSON.stringify(quotes)}>
    <div class="snek-mini" data-snek aria-hidden="true">
      {
        Array.from({ length: 54 }).map((_, index) => (
          <div class:list={["px", snekPixels.includes(index) && "filled"]} />
        ))
      }
    </div>

    <button type="button" class="nudge-btn font-serif" data-button>
      <span class="label-ready">
        <span class="lang-en">Nudge Rex to write</span>
        <span class="lang-zh">催 Rex 写</span>
      </span>
      <span class="label-done">
        <span class="lang-en">Nudged ✓</span>
        <span class="lang-zh">已催 ✓</span>
      </span>
    </button>

    <span class="nudge-count font-serif" data-count>0</span>

    <div class="snek-quote font-serif" data-quote></div>
  </div>
</section>

<script is:inline>
(() => {
  const root = document.querySelector('[data-nudge-root]');
  if (!root || root.dataset.bound === 'true') return;
  root.dataset.bound = 'true';

  const STORAGE_KEY = 'nudge_date';
  const countEl = root.querySelector('[data-count]');
  const button = root.querySelector('[data-button]');
  const snek = root.querySelector('[data-snek]');
  const quoteEl = root.querySelector('[data-quote]');
  const quotes = JSON.parse(root.dataset.quotes || '[]');
  let currentCount = 0;
  let quoteTimer;

  function todayLocal() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }

  function hasNudgedToday() {
    try { return localStorage.getItem(STORAGE_KEY) === todayLocal(); } catch { return false; }
  }

  function setNudgedToday() {
    try { localStorage.setItem(STORAGE_KEY, todayLocal()); } catch {}
  }

  function fmt(n) { return new Intl.NumberFormat('en-US').format(n); }

  function animateCount(next) {
    const start = currentCount, end = Number(next) || 0, diff = end - start;
    if (!countEl || diff === 0) { if (countEl) countEl.textContent = fmt(end); currentCount = end; return; }
    const steps = Math.min(20, Math.max(8, Math.abs(diff)));
    let step = 0;
    const tick = () => {
      step++;
      countEl.textContent = fmt(Math.round(start + diff * (step / steps)));
      if (step < steps) setTimeout(tick, 20); else { currentCount = end; countEl.textContent = fmt(end); }
    };
    tick();
  }

  function setState(s) {
    if (button) { button.dataset.state = s; button.disabled = s !== 'ready'; }
  }

  function showQuote() {
    if (!quoteEl || !quotes.length) return;
    quoteEl.textContent = quotes[Math.floor(Math.random() * quotes.length)];
    quoteEl.dataset.visible = 'true';
    clearTimeout(quoteTimer);
    quoteTimer = setTimeout(() => { quoteEl.dataset.visible = 'false'; }, 3000);
  }

  function shakeSnek() {
    if (!snek) return;
    snek.classList.remove('is-shaking');
    void snek.offsetWidth;
    snek.classList.add('is-shaking');
    setTimeout(() => snek.classList.remove('is-shaking'), 500);
  }

  async function loadCount() {
    try {
      const r = await fetch('/api/nudge');
      const d = await r.json();
      currentCount = Number(d.count) || 0;
      if (countEl) countEl.textContent = fmt(currentCount);
    } catch {}
  }

  async function handleClick() {
    if (hasNudgedToday()) { setState('done'); return; }
    setState('done');
    try {
      const r = await fetch('/api/nudge', { method: 'POST' });
      const d = await r.json();
      animateCount(Number(d.count) || currentCount + 1);
      setNudgedToday();
      shakeSnek();
      showQuote();
    } catch { setState('ready'); }
  }

  if (button) button.addEventListener('click', handleClick);
  loadCount();
  setState(hasNudgedToday() ? 'done' : 'ready');
})();
</script>

<style>
  @reference "../styles/global.css";

  .nudge-shell {
    @apply mb-6 flex w-full justify-center;
  }

  .nudge-row {
    @apply relative flex w-full max-w-4xl items-center justify-center gap-3;
  }

  .snek-mini {
    display: grid;
    grid-template-columns: repeat(6, 4px);
    gap: 1px;
    transform-origin: center;
    animation: snek-sway 2.5s ease-in-out infinite;
  }

  .px {
    width: 4px;
    height: 4px;
    border-radius: 1px;
    background: transparent;
  }

  .px.filled {
    background: #8953d1;
  }

  :global(html[data-theme="dark"]) .px.filled {
    background: #a175e8;
  }

  .snek-mini.is-shaking {
    animation: snek-shake 0.5s ease-in-out;
  }

  .nudge-btn {
    @apply inline-flex items-center rounded-full border border-gray-200 bg-white px-4 py-1.5 text-xs text-gray-600 transition-all hover:border-[#8953d1]/40 hover:text-[#8953d1] dark:border-zinc-700 dark:bg-zinc-800 dark:text-gray-400 dark:hover:border-[#a175e8]/40 dark:hover:text-[#a175e8];
    cursor: pointer;
  }

  .nudge-btn[data-state='done'] {
    @apply border-[#8953d1]/30 text-[#8953d1] dark:border-[#a175e8]/30 dark:text-[#a175e8];
    cursor: default;
  }

  .nudge-btn .label-done { display: none; }
  .nudge-btn[data-state='done'] .label-ready { display: none; }
  .nudge-btn[data-state='done'] .label-done { display: inline; }

  .nudge-count {
    @apply text-sm font-semibold text-[#8953d1] dark:text-[#a175e8];
    min-width: 3ch;
  }

  .snek-quote {
    @apply pointer-events-none absolute -top-8 left-1/2 w-max max-w-[200px] -translate-x-1/2 rounded-full bg-white/95 px-3 py-1 text-center text-xs text-[#8953d1] opacity-0 shadow-sm transition-all duration-200 dark:bg-zinc-900/95 dark:text-[#d5b8ff];
  }

  .snek-quote[data-visible='true'] {
    opacity: 1;
    transform: translate(-50%, -4px);
  }

  @keyframes snek-sway {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }

  @keyframes snek-shake {
    0%, 100% { transform: translateX(0) rotate(0deg); }
    20% { transform: translateX(-3px) rotate(-6deg); }
    40% { transform: translateX(2px) rotate(5deg); }
    60% { transform: translateX(-2px) rotate(-4deg); }
    80% { transform: translateX(2px) rotate(3deg); }
  }
</style>
