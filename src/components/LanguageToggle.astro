---
/**
 * Language toggle button — switches between EN and 中文.
 * Stores preference in localStorage, toggles [data-lang] on <html>.
 * All bilingual elements use CSS: html[data-lang="en"] .lang-zh { display:none }
 */
---

<button
	id="lang-toggle"
	class="inline-flex items-center gap-1 rounded-md px-2 py-1 font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]"
	aria-label="Switch language"
>
	<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
		<path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
	</svg>
	<span id="lang-label">中文</span>
</button>

<script is:inline>
(function () {
	const LANG_KEY = "rex-lang";
	const DEFAULT_LANG = "en";

	function getLang() {
		if (typeof localStorage !== "undefined") {
			return localStorage.getItem(LANG_KEY) || DEFAULT_LANG;
		}
		return DEFAULT_LANG;
	}

	function setLang(lang) {
		localStorage.setItem(LANG_KEY, lang);
		document.documentElement.setAttribute("data-lang", lang);
		// Update toggle label
		const label = document.getElementById("lang-label");
		if (label) label.textContent = lang === "en" ? "中文" : "EN";
	}

	// Initialize on load
	const lang = getLang();
	setLang(lang);

	// Toggle on click
	document.addEventListener("click", function (e) {
		const btn = e.target.closest("#lang-toggle");
		if (!btn) return;
		const current = getLang();
		setLang(current === "en" ? "zh" : "en");
	});

	// Re-apply on Astro page transitions (View Transitions)
	document.addEventListener("astro:after-swap", function () {
		setLang(getLang());
	});
})();
</script>
