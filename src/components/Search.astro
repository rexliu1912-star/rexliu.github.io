---
// Heavy inspiration taken from Astro Starlight -> https://github.com/withastro/starlight/blob/main/packages/starlight/components/Search.astro

import "@/styles/blocks/search.css";
---

<site-search class="ms-auto" id="search">
	<button
		class="relative h-9 w-9 cursor-pointer rounded-md p-2 transition-colors hover:text-[#8953d1] dark:hover:text-[#a175e8]"
		aria-keyshortcuts="Control+K Meta+K"
		data-open-modal
		disabled
		title="Search"
		aria-label="Search"
	>
		<svg
			aria-hidden="true"
			class="absolute start-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2"
			fill="none"
			height="16"
			stroke="currentColor"
			stroke-linecap="round"
			stroke-linejoin="round"
			stroke-width="1.5"
			viewBox="0 0 24 24"
			width="16"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M0 0h24v24H0z" stroke="none"></path>
			<path d="M3 10a7 7 0 1 0 14 0 7 7 0 1 0-14 0M21 21l-6-6"></path>
		</svg>
		<span class="sr-only">Open Search</span>
	</button>
	<dialog
		aria-label="search"
		class="bg-global-bg h-full max-h-full w-full max-w-full border border-gray-200 shadow-sm backdrop:backdrop-blur-sm open:flex dark:border-gray-700 sm:mx-auto sm:mt-16 sm:mb-auto sm:h-max sm:max-h-[calc(100%-8rem)] sm:min-h-[15rem] sm:w-5/6 sm:max-w-[48rem] sm:rounded-md"
	>
		<div class="dialog-frame flex grow flex-col gap-4 p-6 pt-12 sm:pt-6">
			<button
				class="ms-auto cursor-pointer rounded-md px-2 py-1 font-serif text-sm text-gray-400 transition-colors hover:text-[#8953d1] dark:text-gray-500 dark:hover:text-[#a175e8]"
				data-close-modal>Close</button
			>
			{
				import.meta.env.DEV ? (
					<div class="mx-auto text-center">
						<p>
							Search is only available in production builds. <br />
							Try building and previewing the site to test it out locally.
						</p>
					</div>
				) : (
					<div class="search-container">
						<div id="cactus__search" />
					</div>
				)
			}
		</div>
	</dialog>
</site-search>

<script>
	class SiteSearch extends HTMLElement {
		#closeBtn: HTMLButtonElement | null;
		#dialog: HTMLDialogElement | null;
		#dialogFrame: HTMLDivElement | null;
		#openBtn: HTMLButtonElement | null;
		#controller: AbortController;
		#pagefindUi: any = null;
		#pagefindCtor: any = null;
		#uiLang: string | null = null;

		constructor() {
			super();
			this.#openBtn = this.querySelector<HTMLButtonElement>("button[data-open-modal]");
			this.#closeBtn = this.querySelector<HTMLButtonElement>("button[data-close-modal]");
			this.#dialog = this.querySelector<HTMLDialogElement>("dialog");
			this.#dialogFrame = this.querySelector(".dialog-frame");
			this.#controller = new AbortController();

			if (this.#openBtn) {
				this.#openBtn.addEventListener("click", this.openModal);
				this.#openBtn.disabled = false;
			}

			if (this.#closeBtn) {
				this.#closeBtn.addEventListener("click", this.closeModal);
			}

			if (this.#dialog) {
				this.#dialog.addEventListener("close", () => {
					window.removeEventListener("click", this.onWindowClick);
				});
			}

			if (import.meta.env.DEV) return;
			const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
			onIdle(async () => {
				const mod = await import("@pagefind/default-ui");
				this.#pagefindCtor = mod.PagefindUI;
				await this.buildUi();
			});
		}

		getLang = () => {
			try {
				return localStorage.getItem("rex-lang") || document.documentElement.getAttribute("data-lang") || "en";
			} catch {
				return document.documentElement.getAttribute("data-lang") || "en";
			}
		};

		getTranslations = (lang: string) => lang === "zh"
			? {
				search_label: "搜索",
				placeholder: "搜索 Lab 内容",
				clear_search: "清除",
				load_more: "加载更多",
				zero_results: "没有找到结果",
				many_results: "[COUNT] 个结果",
				one_result: "[COUNT] 个结果",
				alt_search: "搜索",
			}
			: {
				search_label: "Search",
				placeholder: "Search the Lab",
				clear_search: "Clear",
				load_more: "Load more",
				zero_results: "No results found",
				many_results: "[COUNT] results",
				one_result: "[COUNT] result",
				alt_search: "Search",
			};

		getSectionInfo = (url: string, lang: string): { label: string; cls: string } | null => {
			if (url.includes("/lab/digest/"))       return { label: lang === "zh" ? "精读"        : "Digest",       cls: "badge-digest" };
			if (url.includes("/lab/builder-log/"))  return { label: lang === "zh" ? "Builder's Log" : "Builder's Log", cls: "badge-builder" };
		if (url.includes("/lab/snek-daily/"))   return { label: lang === "zh" ? "SNEK Daily"  : "SNEK Daily",   cls: "badge-snek" };
		if (url.includes("/lab/"))              return { label: "Lab",                                           cls: "badge-lab" };
			if (url.includes("/posts/"))            return { label: lang === "zh" ? "文章"         : "Posts",        cls: "badge-posts" };
			return null;
		};

		labelResults = () => {
			const lang = this.getLang();
			const results = this.querySelectorAll<HTMLElement>(".pagefind-ui__result:not([data-labeled])");
			results.forEach((result) => {
				result.dataset.labeled = "1";
				const link = result.querySelector<HTMLAnchorElement>(".pagefind-ui__result-link");
				const titleEl = result.querySelector(".pagefind-ui__result-title");
				if (!link || !titleEl) return;
				const info = this.getSectionInfo(link.getAttribute("href") || "", lang);
				if (!info) return;
				const badge = document.createElement("span");
				badge.className = `search-section-badge ${info.cls}`;
				badge.textContent = info.label;
				titleEl.insertBefore(badge, titleEl.firstChild);
			});
		};

		buildUi = async () => {
			if (!this.#pagefindCtor) return;
			const lang = this.getLang();
			const mount = this.querySelector("#cactus__search");
			if (!mount) return;
			if (this.#pagefindUi && this.#uiLang === lang) return;
			mount.innerHTML = "";
			this.#uiLang = lang;
			this.#pagefindUi = new this.#pagefindCtor({
				baseUrl: import.meta.env.BASE_URL,
				bundlePath: import.meta.env.BASE_URL.replace(/\/$/, "") + "/pagefind/",
				element: "#cactus__search",
				showImages: false,
				showSubResults: false,
				excerptLength: 18,
				translations: this.getTranslations(lang),
			});
			// Watch for results being injected by Pagefind
			const observer = new MutationObserver(() => this.labelResults());
			observer.observe(mount, { childList: true, subtree: true });
		};

		connectedCallback() {
			window.addEventListener("keydown", this.onWindowKeydown, { signal: this.#controller.signal });
			window.addEventListener("storage", this.onLangMaybeChanged, { signal: this.#controller.signal });
			document.addEventListener("astro:after-swap", this.onLangMaybeChanged, { signal: this.#controller.signal });
			document.addEventListener("click", this.onLangMaybeChanged, { signal: this.#controller.signal });
		}

		disconnectedCallback() {
			this.#controller.abort();
		}

		openModal = async (event?: MouseEvent) => {
			if (!this.#dialog) return;
			await this.buildUi();
			this.#dialog.showModal();
			setTimeout(() => this.querySelector("input")?.focus(), 30);
			event?.stopPropagation();
			window.addEventListener("click", this.onWindowClick, { signal: this.#controller.signal });
		};

		closeModal = () => this.#dialog?.close();

		onLangMaybeChanged = async () => {
			const nextLang = this.getLang();
			if (nextLang !== this.#uiLang) await this.buildUi();
		};

		onWindowClick = (event: MouseEvent) => {
			// check if it's a link
			const isLink = "href" in (event.target || {});
			// make sure the click is either a link or outside of the dialog
			if (
				isLink ||
				(document.body.contains(event.target as Node) &&
					!this.#dialogFrame?.contains(event.target as Node))
			) {
				this.closeModal();
			}
		};

		onWindowKeydown = (e: KeyboardEvent) => {
			if (!this.#dialog) {
				console.warn("Dialog not found");
				return;
			}
			// check if it's the Control+K or ⌘+K shortcut
			if ((e.metaKey === true || e.ctrlKey === true) && e.key === "k") {
				this.#dialog.open ? this.closeModal() : this.openModal();
				e.preventDefault();
			}
		};
	}

	customElements.define("site-search", SiteSearch);
</script>
