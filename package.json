{
	"name": "rexliu-insights",
	"type": "module",
	"version": "6.11.0",
	"packageManager": "pnpm@9.15.0",
	"scripts": {
		"postinstall": "npm rebuild sharp --force",
		"dev": "astro dev",
		"start": "astro dev",
		"sync:weread": "node scripts/sync-weread-library.mjs",
		"model:portfolio": "python3 scripts/portfolio-allocation-model.py",
		"backtest:portfolio": "python3 scripts/portfolio-allocation-backtest.py --output src/data/portfolio-allocation-backtest.json --report docs/research/portfolio-allocation-backtest.md",
		"prebuild": "pnpm model:portfolio && node scripts/build-portfolio-public.mjs && node scripts/preflight/portfolio-privacy-check.mjs",
		"build": "astro build",
		"postbuild": "node scripts/prepare-pagefind.mjs && pagefind --site dist && node scripts/postbuild-sync-custom-stocks.mjs",
		"preview": "astro preview",
		"check": "astro check && biome check",
		"lint": "biome check --write",
		"format": "prettier -w . --cache"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^7.1.2",
		"@astrojs/mdx": "5.0.6",
		"@astrojs/react": "^5.0.5",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@chenglou/pretext": "^0.0.7",
		"@tailwindcss/vite": "4.3.0",
		"@waline/client": "^3.13.0",
		"astro": "6.3.7",
		"astro-expressive-code": "^0.42.0",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"astro-webmanifest": "^1.0.0",
		"cssnano": "^8.0.1",
		"hastscript": "^9.0.1",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-directive": "^4.0.0",
		"satori": "0.26.0",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.5",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.15",
		"@iconify-json/mdi": "^1.2.3",
		"@pagefind/default-ui": "^1.5.2",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.5.0",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"reading-time": "^1.5.0",
		"tailwindcss": "4.3.0",
		"typescript": "^6.0.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@tailwindcss/oxide",
			"esbuild",
			"sharp"
		],
		"overrides": {
			"sharp": "^0.34.5",
			"yaml": "^2.8.3"
		}
	},
	"overrides": {
		"sharp": "^0.34.5"
	}
}
